---
const { title = "How it works" } = Astro.props;
---

<div class="tool-help-container">
  <button class="tool-help-toggle" type="button">
    ? {title}
  </button>

  <div class="tool-help-panel">
    <slot />
  </div>
</div>

<script>
  document.querySelectorAll(".tool-help-toggle").forEach((toggle) => {
    const panel = toggle.nextElementSibling;
    if (panel && panel.classList.contains("tool-help-panel")) {
      toggle.addEventListener("click", () => {
        panel.classList.toggle("open");
      });
    }
  });
</script>

<style>
  .tool-help-container {
    margin-bottom: 20px;
  }

  .tool-help-toggle {
    background: #f3f4f6;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    padding: 6px 12px;
    font-size: 14px;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .tool-help-toggle:hover {
    background: #e5e7eb;
  }

  .tool-help-panel {
    display: none;
    margin-top: 12px;
    padding: 16px;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    font-size: 14px;
    line-height: 1.5;
  }

  .tool-help-panel.open {
    display: block;
  }
</style>
