---
/**
 * Tool page header: title + optional icon from tools JSON.
 * Pass the tool object from the page (page looks up by pathname in tools JSON).
 */
interface Props {
  /** Tool entry from tools JSON (title, icon); when missing, fallbackTitle is used and no icon shown */
  tool?: { title?: string; icon?: string } | null;
  /** Title used when tool is not provided or has no title */
  fallbackTitle?: string;
}

const { tool = null, fallbackTitle = "Tool" } = Astro.props;

const title = tool?.title ?? fallbackTitle;
const iconUrl = tool?.icon ? `/icons/tools/${tool.icon}` : null;
---

<div class="tool-title">
  {iconUrl && (
    <img src={iconUrl} alt="" class="tool-title-icon" />
  )}
  <h1>{title}</h1>
</div>

<style>
  .tool-title {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 0.5rem;
  }

  .tool-title-icon {
    width: 44px;
    height: 44px;
    flex-shrink: 0;
  }

  .tool-title h1 {
    margin: 0;
    color: var(--kbm-green);
    font-size: 2rem;
    font-weight: 700;
  }
</style>
