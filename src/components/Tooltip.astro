---
interface Props {
  term: string;
  position?: "top" | "right" | "bottom" | "left";
}

const { term, position = "top" } = Astro.props;
const positionClass = `tooltip--${position}`;

// ✅ Adjust this import path if needed
import glossary from "../data/glossary.json";

const norm = (s: string) => (s || "").toLowerCase().trim();

// "english" can contain aliases like "Sponge Bar | Presser Bar"
const matchesTerm = (entryEnglish: string, t: string) => {
  const e = norm(entryEnglish);
  const target = norm(t);
  if (!e) return false;

  const parts = e.split("|").map(p => p.trim());
  return parts.includes(target) || e === target;
};

// Strip HTML to plain text (safe for tooltips)
const htmlToText = (html: string) => {
  if (!html) return "";

  let out = html
    .replace(/<script[\s\S]*?<\/script>/gi, "")
    .replace(/<style[\s\S]*?<\/style>/gi, "")
    .replace(/<\/(p|div|li|br|figure|figcaption|h\d)>/gi, " ")
    .replace(/<(br|hr)\s*\/?>/gi, " ")
    .replace(/<[^>]+>/g, " ");

  out = out
    .replace(/&nbsp;/g, " ")
    .replace(/&amp;/g, "&")
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&lt;/g, "<")
    .replace(/&gt;/g, ">")
    .replace(/\s+/g, " ")
    .trim();

  return out;
};

const firstSentence = (text: string) => {
  const t = (text || "").trim();
  if (!t) return "";
  const parts = t.split(/[.!?]/);
  const s = (parts[0] || "").trim();
  return s ? s + "." : t;
};

const truncate = (text: string, max = 180) => {
  const t = (text || "").trim();
  if (t.length <= max) return t;
  return t.slice(0, max).replace(/\s+\S*$/, "") + "…";
};

let tooltipText = "";

try {
  const entries: any[] = Array.isArray(glossary) ? glossary : ((glossary as { entries?: any[] })?.entries || []);
  const found = entries.find((e) => matchesTerm(e?.english || "", term));

  if (found?.example) {
    tooltipText = truncate(htmlToText(found.example));
  } else if (found?.metaDescription) {
    tooltipText = truncate(firstSentence(htmlToText(found.metaDescription)));
  } else if (found?.english) {
    tooltipText = found.english;
  } else {
    tooltipText = term;
  }
} catch (e) {
  tooltipText = term;
}
---

<span class={`tooltip tooltip-term ${positionClass}`} tabindex="0">
  <span class="tooltip-trigger">
    <slot />
  </span>

  {tooltipText && (
    <span class="tooltip-text" role="tooltip">
      {tooltipText}
    </span>
  )}
</span>

<style>
.tooltip-term .tooltip-trigger{
  text-decoration: underline dotted;
  text-underline-offset: 3px;
  cursor: help;
}

.tooltip-term .tooltip-trigger:hover{
  text-decoration-thickness: 2px;
}
</style>
