---
---
<!-- Contact Modal -->
<div
  id="contact-modal"
  class="contact-modal"
  aria-hidden="true"
  role="dialog"
  aria-labelledby="contact-modal-title"
>
  <div class="contact-modal-overlay" id="contact-modal-overlay"></div>
  <div class="contact-modal-container">
    <button
      class="contact-modal-close"
      id="contact-modal-close"
      aria-label="Close contact form"
    >
      <span aria-hidden="true">&times;</span>
    </button>

    <div class="contact-modal-header">
      <h2 id="contact-modal-title" class="contact-modal-title">
        Contact Sue
      </h2>
      <p class="contact-modal-subheader">
        Questions or feedback? Send a message below.
      </p>
    </div>

    <form
    id="contactFormModal"
    name="contact"
    method="POST"
    action="/contact/thanks/"
    data-netlify="true"
    netlify-honeypot="bot-field"
    class="contact-form"
  >
      <input type="hidden" name="form-name" value="contact" />
      <p style="display:none;">
        <label>Don't fill this out: <input name="bot-field" /></label>
      </p>
      <input type="hidden" name="submission-type" value="contact" />
      <input type="hidden" name="page_url" id="contactPageURLModal" />
      <input type="hidden" name="submitted_at" id="contactSubmittedAtModal" />

      <label class="contact-form__field">
        <span>Name *</span>
        <input type="text" name="name" required />
      </label>

      <label class="contact-form__field">
        <span>Email *</span>
        <input type="email" name="email" required />
      </label>

      <div class="contact-modal-tip">
        Tip: If you're troubleshooting, include your machine model, yarn type, and what the machine is doing.
      </div>

      <label class="contact-form__field">
       
        <textarea 
        name="message" 
        rows="6" 
        placeholder="Enter your message here. Example: I'm using a Brother KH260 and my carriage jams when knitting tuck stitch. I’ve already changed the sponge bar."
        required
      ></textarea>
      </label>

      <div class="contact-modal-leadmag">

        <div class="contact-modal-leadmag-intro">
          Before sending your message, you might also find this helpful:
        </div>
      
        <div class="contact-modal-leadmag-title">
          👉 It's Not You, It Might Be the Machine
        </div>
      
        <div class="contact-modal-leadmaghelp">
          A quick checklist for diagnosing common knitting machine problems.
        </div>
      
        <a href="/troubleshoot" class="contact-modal-leadmaglink">
          Use the checklist <i class="fa fa-external-link-alt"></i>
        </a>
      
      </div>

      <div class="contact-form__submit-wrap">
        <button type="submit" class="contact-form__submit">
          Send message
        </button>
        <span class="contact-form__submit-note">😊 I usually respond within 1–2 business days.</span>
      </div>
    </form>
    </div>

    <div class="contact-modal-success-wrapper">
    <div id="contactSuccessModal" class="contact-success hidden">
      <h2>Thank you - your message has been sent.</h2>
      <p>
        We'll read it soon and reply if needed. 
        While you wait:
👉 Get the checklist: It’s Not You, It Might Be the Machine
(Link to /troubleshoot)
      </p>
    </div>
    </div>
  </div>
</div>

<style is:global>
 .contact-modal-leadmag {
  background: #f5f7f2;
  border-left: 4px solid #6a8141;
  padding: 14px 16px;
  border-radius: 10px;
}

.contact-modal-leadmag-intro {
  font-size: 0.9rem;
  margin-bottom: 6px;
}

.contact-modal-leadmag-title {
  font-weight: 700;
  font-size: 1.05rem;
  color: #2e3c20;
  text-align: center;
  margin: 4px 0 6px 0;
}

.contact-modal-leadmaghelp {
  font-size: 0.9rem;
  color: #555;
  text-align: center;
  margin-bottom: 8px;
}

.contact-modal-leadmaglink {
  display: block;
  text-align: center;
  font-weight: 600;
  text-decoration: none;
}

.contact-modal-leadmaglink i {
  font-size: 0.85em;
  margin-left: 4px;
}
  .external-link-icon {
  font-size: 0.85em;
  margin-left: 4px;
  opacity: 0.7;
}
#contact-modal textarea {
  width: 100%;
  box-sizing: border-box;
  min-height: 140px;
  padding: 12px 14px;
  line-height: 1.5;
  resize: vertical;
  border-radius: 8px;
}

#contact-modal textarea:focus {
  outline: none;
  border-color: #6a8141;
  box-shadow: 0 0 0 2px rgba(106,129,65,0.15);
}
#contact-modal .contact-modal-container {
  position: relative;
  max-width: 520px;
  width: calc(100% - 32px);
  max-height: 90vh;
  overflow-y: auto;
  margin: 60px auto;
  padding: 26px 28px;
  border-radius: 14px;
  box-shadow: 0 18px 45px rgba(0,0,0,0.18);
  transform: translateY(8px);
  transition: transform 0.18s ease;
}

.contact-modal--open .contact-modal-container {
  transform: translateY(0);
}

#contact-modal-overlay {
  backdrop-filter: blur(2px);
  background: rgba(0,0,0,0.35);
}

  #contact-modal textarea::placeholder {
  font-style: italic;
  font-size: 0.9rem;
  color: #b5b5b5;
}


  #contact-modal .contact-modal-subheader {
    margin: 6px 0 14px 0;
    font-size: 0.95rem;
    line-height: 1.45;
    max-width: 42ch;
    opacity: 0.9;
  }

  #contact-modal .contact-modal-tip {
    background: #f5f7f2;
    border-left: 4px solid #6a8141;
    padding: 10px 12px;
    border-radius: 10px;
    font-size: 0.9rem;
    margin-bottom: 10px;
  }

  #contact-modal .contact-modal-leadmag {
    background: #f7f7f7;
    border-radius: 12px;
    padding: 10px 12px;
    margin-top: 6px;
  }

  #contact-modal .contact-modal-checkbox {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    cursor: pointer;
  }

  #contact-modal .contact-modal-checkbox input {
    margin-top: 3px;
  }

  #contact-modal .contact-modal-leadmaglink {
    margin-left: 6px;
    font-weight: 600;
    text-decoration: underline;
  }

  #contact-modal .contact-modal-leadmaghelp {
    font-size: 0.85rem;
    margin-top: 5px;
    opacity: 0.85;
  }

  #contact-modal .contact-modal-response {
    font-size: 0.85rem;
    margin-top: 6px;
    opacity: 0.8;
  }

  #contact-modal .contact-modal-header {
    margin-bottom: 12px;
  }

  #contact-modal .contact-modal-body {
    margin-top: 6px;
  }

  #contact-modal .contact-modal-success-wrapper {
    margin-top: 12px;
  }

  /* --- CONTACT MODAL LAYOUT SAFETY (center + visible) --- */
  #contact-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
  }

  #contact-modal.contact-modal--open {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #contact-modal-overlay,
  #contact-modal .contact-modal-overlay {
    position: absolute;
    inset: 0;
  }

  #contact-modal .contact-modal-container {
  position: relative;
  max-width: 520px;
  width: calc(100% - 32px);
  margin: auto;
  background: white;
}
#contact-modal.contact-modal--open {
  display: flex;
  align-items: center;
  justify-content: center;
}
  /* Make sure the form + submit are not accidentally hidden */
  #contact-modal #contactFormModal {
    display: block;
  }

  #contact-modal .contact-form__field {
    margin-bottom: 1.25rem;
  }

  #contact-modal .contact-form__submit-wrap {
    margin-top: 1.5rem;
    padding-top: 0.5rem;
  }

  #contact-modal .contact-form__submit {
    display: block;
    width: 100%;
    visibility: visible;
    opacity: 1;
    position: relative;
    padding: 0.85rem 1.5rem;
    cursor: pointer;
    background-color: #6a8141;
    color: #fff;
    font-weight: 600;
    font-size: 1rem;
    border: none;
    border-radius: 8px;
  }

  #contact-modal .contact-form__submit-note {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.9rem;
  }
</style>

<script is:inline>
  (function() {
    const modal = document.getElementById('contact-modal');
    const trigger = document.getElementById('contact-modal-trigger');
    const overlay = document.getElementById('contact-modal-overlay');
    const closeBtn = document.getElementById('contact-modal-close');
    const form = document.getElementById('contactFormModal');
    const successMsg = document.getElementById('contactSuccessModal');

    function openModal() {
      modal?.setAttribute('aria-hidden', 'false');
      modal?.classList.add('contact-modal--open');
      document.body.style.overflow = 'hidden';
      document.getElementById('contactPageURLModal').value = window.location.href;
      document.getElementById('contactSubmittedAtModal').value = new Date().toISOString();
    }

    function closeModal() {
      modal?.setAttribute('aria-hidden', 'true');
      modal?.classList.remove('contact-modal--open');
      document.body.style.overflow = '';
      form?.reset();
    }

    trigger?.addEventListener('click', function(e) {
      e.preventDefault();
      openModal();
    });

    overlay?.addEventListener('click', closeModal);
    closeBtn?.addEventListener('click', closeModal);

    form?.addEventListener('submit', function() {
      document.getElementById('contactSubmittedAtModal').value = new Date().toISOString();
    });
  })();
</script>
