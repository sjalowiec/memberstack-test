---
/**
 * GatedVimeoEmbed.astro
 * - If access_level === "open": render iframe for everyone.
 * - If access_level === "member": gate by paid plan IDs; iframe injected client-side only when allowed.
 */

const {
  videoId,
  title = "Video",
  access_level = "open", // "open" | "member"
  aspect = "16/9",
  thumbUrl = "", // optional: show a thumbnail for locked state
  ctaHref = "/membership",
  ctaText = "Join to watch",
} = Astro.props;

function paddingPercent(aspectStr: string) {
  // "16/9" -> 56.25
  const [w, h] = String(aspectStr).split("/").map(Number);
  if (!w || !h) return 56.25;
  return (h / w) * 100;
}

const pad = paddingPercent(aspect);
const iframeSrc = `https://player.vimeo.com/video/${videoId}`;
---

<div
  class="kbm-video"
  data-access-level={access_level}
  data-video-id={videoId}
  data-iframe-src={iframeSrc}
>
  <div class="kbm-video__frame" style={`padding-top:${pad}%;`}>
    <div
      id={`kbm-vimeo-slot-${videoId}`}
      data-access-level={access_level}
      data-state={access_level === "member" ? "loading" : "ready"}
    >
      {access_level === "open" ? (
        <iframe
          class="kbm-video__iframe"
          src={iframeSrc}
          title={title}
          loading="lazy"
          frameborder="0"
          allow="autoplay; fullscreen; picture-in-picture"
          allowfullscreen
        />
      ) : (
        <div class="kbm-video__loading" aria-hidden="true"></div>
      )}
    </div>
  </div>
</div>

<script is:inline define:vars={{ videoId, access_level, iframeSrc, title }}>
  document.addEventListener("DOMContentLoaded", async () => {
    if (access_level !== "member") return;

    const slot = document.getElementById(`kbm-vimeo-slot-${videoId}`);
    if (!slot) return;

    const lockedMarkup = `
  <div class="kbm-video__locked">
    <div class="kbm-video__overlay">
      <div class="kbm-video__lockline">
        🔒 <strong>Members only</strong>
      </div>
      <p>This video is available with membership.</p>
      <a href="/membership" class="kbm-video__cta">
        Join to watch
      </a>
    </div>
  </div>
`;

    if (!window.$memberstackDom) {
      slot.innerHTML = lockedMarkup;
      slot.setAttribute("data-state", "ready");
      return;
    }

    try {
      const res = await window.$memberstackDom.getCurrentMember();
      const member = res?.data;

      const allowedPlanIds = new Set([
        "pln_dev-kin-member-eim6011h",
        "pln_kin-membership-monthly-a59701wy",
        "pln_kin-membership-annual-qf9g01et"
      ]);

      const planConnections = member?.planConnections || [];
      const hasVideoAccess = planConnections.some(
        (pc) => pc.active && allowedPlanIds.has(pc.planId)
      );

      if (!hasVideoAccess) {
        slot.innerHTML = lockedMarkup;
        slot.setAttribute("data-state", "ready");
        return;
      }

      slot.innerHTML = `
        <iframe
          src="${iframeSrc}"
          title="${title}"
          loading="lazy"
          frameborder="0"
          allow="autoplay; fullscreen; picture-in-picture"
          allowfullscreen
          style="position:absolute; inset:0; width:100%; height:100%; border:0;"
        ></iframe>
      `;
      slot.setAttribute("data-state", "ready");
    } catch (e) {
      console.error("GatedVimeoEmbed paid check failed:", e);
      slot.innerHTML = lockedMarkup;
      slot.setAttribute("data-state", "ready");
    }
  });
</script>



<style>
  .kbm-video__frame [data-state="loading"] {
    position: absolute;
    inset: 0;
    background: #f3f4ef;
  }
  .kbm-video__loading {
    position: absolute;
    inset: 0;
    background: #f3f4ef;
  }
  .kbm-video__frame{
    position: relative;
    width: 100%;
    height: 0;
    overflow: hidden;
    border-radius: 14px;
    background: #fff;
  }
  .kbm-video__frame > [data-access-level] {
    position: absolute;
    inset: 0;
  }
  .kbm-video__iframe{
    position:absolute;
    top:0; left:0;
    width:100%;
    height:100%;
    border:0;
  }
  .kbm-video__locked{
    position:absolute;
    inset:0;
    display:block;
    background:#fff;
  }
  .kbm-video__thumb{
    width:100%;
    height:100%;
    object-fit:cover;
    display:block;
    filter: blur(0px);
  }
  .kbm-video__overlay{
    position:absolute;
    inset:0;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    padding:16px;
    text-align:center;
    background: rgba(255,255,255,0.86);
    gap:10px;
  }
  .kbm-video__lockline{
    display:flex;
    gap:8px;
    align-items:center;
    font-size: 1.05rem;
  }
  .kbm-video__msg{
    margin:0;
    max-width: 42ch;
  }
  .kbm-video__cta{
    display:inline-block;
    padding:10px 14px;
    border-radius: 999px;
    text-decoration:none;
    font-weight:700;
    background: var(--kbm-green, #52682d);
    color:#fff;
  }
</style>