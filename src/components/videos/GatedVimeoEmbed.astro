---
/**
 * GatedVimeoEmbed.astro
 * - If access_level === "open": render iframe for everyone.
 * - If access_level === "member": DOM gating via data-ms-content="member-videos" / "!member-videos".
 */

const {
  videoId,
  title = "Video",
  access_level = "open", // "open" | "member"
  aspect = "16/9",
  thumbUrl = "", // optional: show a thumbnail for locked state
  ctaHref = "/membership",
  ctaText = "Join to watch",
} = Astro.props;

function paddingPercent(aspectStr: string) {
  // "16/9" -> 56.25
  const [w, h] = String(aspectStr).split("/").map(Number);
  if (!w || !h) return 56.25;
  return (h / w) * 100;
}

const pad = paddingPercent(aspect);
const iframeSrc = `https://player.vimeo.com/video/${videoId}`;
---

<div
  class="kbm-video"
  data-access-level={access_level}
  data-video-id={videoId}
  data-iframe-src={iframeSrc}
>
  <div class="kbm-video__frame" style={`padding-top:${pad}%;`}>
    {access_level === "member" ? (
      <>
        <!-- Paid members see video -->
        <div data-ms-content="member-videos">
          <iframe
            class="kbm-video__iframe"
            src={iframeSrc}
            title={title}
            loading="lazy"
            frameborder="0"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
          />
        </div>

        <!-- Everyone else sees locked state -->
        <div data-ms-content="!member-videos">
          <div class="kbm-video__locked">
            <div class="kbm-video__overlay">
              <div class="kbm-video__lockline">
                🔒 <strong>Members only</strong>
              </div>
              <p>This video is available with membership.</p>
              <a href="/membership" class="kbm-video__cta">
                Join to watch
              </a>
            </div>
          </div>
        </div>
      </>
    ) : (
      <!-- Open video - iframe for everyone -->
      <iframe
        class="kbm-video__iframe"
        src={iframeSrc}
        title={title}
        loading="lazy"
        frameborder="0"
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen
      />
    )}
  </div>
</div>



<style>
  .kbm-video__frame{
    position: relative;
    width: 100%;
    height: 0;
    overflow: hidden;
    border-radius: 14px;
    background: #fff;
  }
  .kbm-video__frame [data-ms-content="member-videos"],
  .kbm-video__frame [data-ms-content="!member-videos"] {
    position: absolute;
    inset: 0;
  }
  .kbm-video__iframe{
    position:absolute;
    top:0; left:0;
    width:100%;
    height:100%;
    border:0;
  }
  .kbm-video__locked{
    position:absolute;
    inset:0;
    display:block;
    background:#fff;
  }
  .kbm-video__thumb{
    width:100%;
    height:100%;
    object-fit:cover;
    display:block;
    filter: blur(0px);
  }
  .kbm-video__overlay{
    position:absolute;
    inset:0;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    padding:16px;
    text-align:center;
    background: rgba(255,255,255,0.86);
    gap:10px;
  }
  .kbm-video__lockline{
    display:flex;
    gap:8px;
    align-items:center;
    font-size: 1.05rem;
  }
  .kbm-video__msg{
    margin:0;
    max-width: 42ch;
  }
  .kbm-video__cta{
    display:inline-block;
    padding:10px 14px;
    border-radius: 999px;
    text-decoration:none;
    font-weight:700;
    background: var(--kbm-green, #52682d);
    color:#fff;
  }
</style>