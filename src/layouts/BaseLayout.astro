---
import "../styles/global.css";
import "../styles/print.css";
import ContactModal from "../components/ContactModal.astro";

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
  skipGlobalHyvor?: boolean;
}

const {
  title = "Knit it Now",
  description = "Machine knitting tools and patterns",
  bodyClass = "",
  skipGlobalHyvor = false
} = Astro.props;

const hostname =
  typeof Astro.url !== "undefined" && Astro.url.hostname
    ? Astro.url.hostname.toLowerCase()
    : "";

const isProduction =
  (import.meta.env.PUBLIC_SITE_ENV || "").toLowerCase() === "production";
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- CRITICAL: Inline typography to prevent Astro CSS bundler reordering issues -->
    <style data-kbm-typography>
      html {
        font-size: 112.5% !important;
        -webkit-text-size-adjust: 100%;
        text-size-adjust: 100%;
      }
      @media (min-width: 1025px) {
        html {
          font-size: 112.5% !important;
        }
      }
    </style>

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Google Analytics -->
    {import.meta.env.PUBLIC_GA4_ID && (
      <>
        <script
          async
          src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA4_ID}`}
        ></script>
        <script
          is:inline
          define:vars={{ gaId: import.meta.env.PUBLIC_GA4_ID }}
        >
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}

    <!-- Fonts & icons -->
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Shadows+Into+Light+Two&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />

    <!-- Pinterest Embed Script -->
    <script async defer src="https://assets.pinterest.com/js/pinit.js"></script>
    <script is:inline>
      window.kbmPinterestBuild = function() {
        try {
          if (window.PinUtils && typeof window.PinUtils.build === "function") {
            window.PinUtils.build();
          }
        } catch (e) {}
      };
    </script>
    
    <slot name="head" />
   
    <!-- MemberStack -->
    <script
    is:inline
    src="https://static.memberstack.com/scripts/v2/memberstack.js"
    data-memberstack-app="app_cmfh3d1n802vb0wy706205810"
  ></script>

  

  <body class={bodyClass}>
    <div id="msTopError" class="ms-top-error" role="alert" aria-live="polite" hidden>
      <div class="ms-top-error__bar" aria-hidden="true"></div>
      <div class="ms-top-error__text"></div>
    </div>
    <slot /> <!-- Page content (or Layout wrapper) goes here -->

    <ContactModal />

    {!skipGlobalHyvor && (
      <script
        async
        src="https://talk.hyvor.com/embed/embed.js"
        type="module"
      ></script>
    )}

    <script is:inline>
(function () {
  function bannerEl() {
    return document.getElementById("msTopError");
  }

  function setBanner(message) {
    const banner = bannerEl();
    if (!banner) return;

    const textEl = banner.querySelector(".ms-top-error__text");
    if (!textEl) return;

    const msg = (message || "").trim();

    if (!msg) {
      banner.hidden = true;
      textEl.textContent = "";
      return;
    }

    textEl.textContent = msg;
    banner.hidden = false;

    // bring it into view so it's obvious
    try { banner.scrollIntoView({ behavior: "smooth", block: "start" }); } catch (e) {}
  }

  function readMemberstackError() {
    // Prefer the standard error message element if present
    const msError = document.querySelector(".ms-error-message");
    if (msError && msError.textContent.trim()) return msError.textContent.trim();

    // Fallback to data attribute containers
    const msContainers = document.querySelectorAll('[data-ms-message="error"]');
    for (const el of msContainers) {
      const txt = (el.textContent || "").trim();
      if (txt) return txt;
    }
    return "";
  }

  // clear on back/forward cache restore
  window.addEventListener("pageshow", () => setBanner(""));
})();
</script>
    <script is:inline>
  window.$memberstackDom?.onReady?.then(() => {
    window.$memberstackDom?.init?.();
  });
</script>
    <script is:inline>
  document.addEventListener("click", function (e) {
    const a = e.target?.closest?.("#kbmLoginLink");
    if (!a) return;
    e.preventDefault();
    if (window.$memberstackDom?.openModal) {
      window.$memberstackDom.openModal("LOGIN");
    }
  });
</script>

  </body>
</html>