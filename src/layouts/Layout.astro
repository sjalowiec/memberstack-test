---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
  skipGlobalHyvor?: boolean;
}

const { title, description, bodyClass = "", skipGlobalHyvor = false } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  bodyClass={bodyClass}
  skipGlobalHyvor={skipGlobalHyvor}
>
  <Header />

  <main class="site-content" style="padding-top: calc(var(--header-offset, 150px) + var(--header-buffer, 24px));">
    <slot />
  </main>

  <Footer />
</BaseLayout>

<style is:global>
  :root {
    --header-offset: 170px;   /* fallback if measurement fails */
    --header-buffer: 36px;   /* EXTRA breathing room */
  }

  body.page--tight-header {
    --header-buffer: 8px;
  }

  html {
    scroll-padding-top: calc(var(--header-offset, 170px) + var(--header-buffer, 24px));
  }

  .site-content > :first-child {
    margin-top: 0;
  }
</style>
<script is:inline>
(function () {

  function setHeaderOffset() {
    const fallback = 170;

    const headerEl =
      document.querySelector("header") ||
      document.querySelector(".kbm-header-wrap");

    if (!headerEl) {
      document.documentElement.style.setProperty("--header-offset", fallback + "px");
      return;
    }

    const headerHeight = Math.ceil(headerEl.getBoundingClientRect().height);

    // Subtract Memberstack debug pill height if present
    let debugHeight = 0;
    const debugPill = Array.from(headerEl.querySelectorAll("*")).find((el) => {
      const txt = (el.textContent || "").trim();
      return txt.startsWith("MS:ready") || txt.includes("MS:ready loggedIn");
    });

    if (debugPill) {
      debugHeight = Math.ceil(debugPill.getBoundingClientRect().height);
    }

    // Add a small safety margin so content never kisses the header
    const safety = 12;

    const corrected = Math.max(fallback, headerHeight - debugHeight + safety);

    document.documentElement.style.setProperty("--header-offset", corrected + "px");
  }

  window.addEventListener("load", setHeaderOffset);
  window.addEventListener("resize", setHeaderOffset);

  // Handle delayed layout shifts
  setTimeout(setHeaderOffset, 50);
  setTimeout(setHeaderOffset, 250);
  setTimeout(setHeaderOffset, 1000);

  // Recalculate after fonts load
  if (document.fonts && document.fonts.ready) {
    document.fonts.ready.then(setHeaderOffset).catch(function(){});
  }

  // Watch for header size changes
  window.addEventListener("load", function () {
    const wrap = document.querySelector(".kbm-header-wrap");
    if (!wrap || typeof ResizeObserver === "undefined") return;

    const observer = new ResizeObserver(setHeaderOffset);
    observer.observe(wrap);
  });

})();
</script>