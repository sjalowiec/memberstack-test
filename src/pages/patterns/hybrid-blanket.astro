const pinterestLink=document.querySelector('[data-pin-do="embedBoard"]');
if(!pinterestLink){console.log("Pinterest link not found");return}
console.log("Pinterest link found:",{href:pinterestLink.href,hasChildren:pinterestLink.children.length>0,innerHTML:pinterestLink.innerHTML.substring(0,100),rect:pinterestLink.getBoundingClientRect()});
