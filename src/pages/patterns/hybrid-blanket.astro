      const br = document.createElement('br');
      const comment = document.createComment('KBM insert: optional chain edge + popup');
      const textBefore = document.createTextNode('Optional: for a designer touch, work a ');
      const textAfter = document.createTextNode('.');

      // Create wrapper span
      const wrapper = document.createElement('span');
      wrapper.className = 'chain-edge-link-wrapper';
      wrapper.setAttribute('role', 'button');
      wrapper.setAttribute('tabindex', '0');

      // Create inner text span
      const linkSpan = document.createElement('span');
      linkSpan.className = 'chain-edge-link';
      linkSpan.textContent = 'chain (slipped) edge';

      // Create SVG icon using createElementNS for SVG namespace
      const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
