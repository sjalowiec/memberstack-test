const inspirationPanel=document.getElementById("panel-inspiration");
if(!inspirationTab||!inspirationPanel){setTimeout(init,100);return}
inspirationTab.addEventListener("click",function(){setTimeout(function(){if(inspirationPanel.getAttribute("data-active")==="true"){console.log("Inspiration tab activated, building Pinterest");setTimeout(buildPinterest,500);setTimeout(buildPinterest,1000);setTimeout(buildPinterest,2000)}},200)});
new MutationObserver(function(mutations){mutations.forEach(function(mutation){if(mutation.type==="attributes"&&mutation.attributeName==="data-active"&&inspirationPanel.getAttribute("data-active")==="true"){console.log("Inspiration panel became active, building Pinterest");setTimeout(buildPinterest,500);setTimeout(buildPinterest,1000);setTimeout(buildPinterest,2000)}})}).observe(inspirationPanel,{attributes:true,attributeFilter:["data-active"]})
