---
import Layout from "../../layouts/Layout.astro";
const isFullMode = Astro.url.searchParams.get('mode') === 'full';

/**
 * Hybrid Blanket Pattern Page
 * Uses PatternLayout and embeds HybridBlanketWizardV2 component
 */

export const prerender = true;

import PatternLayout from "../../layouts/PatternLayout.astro";
import HybridBlanketWizardV2 from "../../components/wizards/HybridBlanketWizardV2.astro";
import WizardBackLink from "../../components/wizards/WizardBackLink.astro";
import YarnRequirement from "../../components/tools/YarnRequirement.astro";
import "../../styles/wizard.css";

// Sample defaults (matches HybridBlanketWizardV2 SAMPLE_DEFAULTS)
const SAMPLE_DEFAULTS = {
  width: 36,
  length: 36,
  units: "in"
};

// Initial yarn dimensions: use sample defaults
// These will be updated client-side when pattern is built via custom event
const yarnWidth = SAMPLE_DEFAULTS.width;
const yarnLength = SAMPLE_DEFAULTS.length;
const yarnLengthUnit = SAMPLE_DEFAULTS.units === "in" ? "in" : "cm";
const yarnSource = "sample"; // Initial state is sample; updated to "custom" when pattern is built
---

<PatternLayout>
  title="The Hybrid Blanket Pattern | Knit by Machine" 
  description="Hand Knit + Machine Knit Blanket Pattern. Calculate stitch counts for blankets with hand-knit borders and machine-knit body."
  tabsEnabled={{ pattern: true, yarn: true, walkthrough: false, reference: false, askShare: true, inspiration: true }}
>
  <div slot="hero" class="no-print" style="max-width: 900px; margin: 0 auto; padding: 0 1rem;">
    <WizardBackLink category="pattern" />
  </div>

  <div slot="pattern" id="pattern">
    <!-- Top CTA for non-purchasers -->
    {!isFullMode && (
      <div class="top-cta">
        <a
          href="https://buy.stripe.com/28E14m25EcCL8TsgcO0oM05"
          class="btn-primary"
        >
          Purchase & Build Your Own
        </a>
      </div>
    )}

    <!-- Preview Section: Always visible to everyone -->
    <section class="pattern-preview">
      <h1>Hybrid Blanket Pattern</h1>
      <p class="preview-label">Preview</p>

      <HybridBlanketWizardV2 previewOnly={true} />
    </section>

    <!-- Interactive Pattern Builder: Visible when isFullMode is true -->
    {isFullMode && (
      <div>
        <HybridBlanketWizardV2 />
      </div>
    )}

    <!-- Locked Panel: Shown to non-purchasers -->
    {!isFullMode && (
      <div class="locked-panel">
        <h2>Unlock the Interactive Pattern</h2>

        <p>
          Generate this pattern for your size, your gauge, your yarn, and your machine.
        </p>

        <a
          href="https://buy.stripe.com/28E14m25EcCL8TsgcO0oM05"
          class="btn-primary"
        >
          Purchase & Access
        </a>

        <p class="small">
          Already purchased? Use the same button to log in.
        </p>
      </div>
    )}
  </div>

  <div slot="yarn">
    <!-- Yarn Needed tab: Visible when isFullMode is true -->
    {isFullMode && (
      <div>
        <!-- Yarn Needed tab: embeds YarnRequirement tool with pattern dimensions -->
        <!-- Initial values use sample defaults; updated client-side when pattern is built -->
        <YarnRequirement projectWidth={yarnWidth} projectLength={yarnLength} lengthUnit={yarnLengthUnit} source={yarnSource} />
      </div>
    )}

    <!-- Locked state for non-purchasers -->
    {!isFullMode && (
      <div class="locked-panel">
        <h2>Unlock this section</h2>
        <p>Purchase to access this tab.</p>

        <a
          href="https://buy.stripe.com/28E14m25EcCL8TsgcO0oM05"
          class="btn-primary"
        >
          Purchase & Access
        </a>

        <p class="small">Already purchased? Use the same button to log in.</p>
      </div>
    )}
  </div>

  <div slot="askShare" class="kbm-talk">
    <!-- Ask/Share tab: Visible when isFullMode is true -->
    {isFullMode && (
      <div>
        <h2>Talk</h2>
        <p>💡 Start the conversation: What are you making with this pattern?</p>
      
        <hyvor-talk-comments
          website-id="14706"
          page-id="hybrid-blanket"
        ></hyvor-talk-comments>
      </div>
    )}

    <!-- Locked state for non-purchasers -->
    {!isFullMode && (
      <div class="locked-panel">
        <h2>Unlock this section</h2>
        <p>Purchase to access this tab.</p>

        <a
          href="https://buy.stripe.com/28E14m25EcCL8TsgcO0oM05"
          class="btn-primary"
        >
          Purchase & Access
        </a>

        <p class="small">Already purchased? Use the same button to log in.</p>
      </div>
    )}
  </div>
  

  <div slot="inspiration">
    <!-- Inspiration tab: Visible when isFullMode is true -->
    {isFullMode && (
      <div>
        <h3>Inspiration</h3>
        <p>See examples and inspiration for hybrid blankets.</p>
        <div class="pinterest-board-embed" style="display: flex; justify-content: center;">
          <a 
            data-pin-do="embedBoard" 
            data-pin-board-width="400" 
            data-pin-scale-height="600" 
            data-pin-scale-width="80" 
            href="https://www.pinterest.com/1fsl6ow0d6rpwc1uh9vmw14qs5dww0/hybrid-blankets/">
          </a>
        </div>
      </div>
    )}

    <!-- Locked state for non-purchasers -->
    {!isFullMode && (
      <div class="locked-panel">
        <h2>Unlock this section</h2>
        <p>Purchase to access this tab.</p>

        <a
          href="https://buy.stripe.com/28E14m25EcCL8TsgcO0oM05"
          class="btn-primary"
        >
          Purchase & Access
        </a>

        <p class="small">Already purchased? Use the same button to log in.</p>
      </div>
    )}
  </div>
</PatternLayout>


<!-- Video Modal (also supports images) -->
<div id="transfer-video-modal" class="transfer-video-modal" role="dialog" aria-labelledby="transfer-video-modal-title" aria-modal="true" style="display: none;">
  <div class="transfer-video-modal-backdrop"></div>
  <div class="transfer-video-modal-content">
    <button type="button" class="transfer-video-modal-close" aria-label="Close modal">×</button>
    <div class="transfer-video-modal-video-container">
      <div id="transfer-video-iframe-container"></div>
    </div>
    <div class="transfer-video-modal-image-container" id="transfer-video-modal-image-container" style="display: none;">
      <img id="transfer-video-modal-image" src="" alt="" style="max-width: 100%; height: auto; display: block; border-radius: 8px;">
    </div>
  </div>
</div>

<!-- Success Modal -->
<div id="kbm-success-modal" class="kbm-success-modal" role="dialog" aria-labelledby="kbm-success-modal-title" aria-modal="true" style="display: none;">
  <div class="kbm-success-modal-backdrop"></div>
  <div class="kbm-success-modal-content">
    <h2 id="kbm-success-modal-title" class="kbm-success-modal-title">🎉 Ready to knit?</h2>
    <p class="kbm-success-modal-body">Your custom pattern is now on the page and ready to use.</p>
    <p class="kbm-success-modal-note">Your pattern is not saved automatically.<br>Print or save this page as a PDF to keep your numbers.</p>
    <div class="kbm-success-modal-actions">
      <button type="button" id="kbm-success-modal-print" class="kbm-success-modal-btn kbm-success-modal-btn--primary">
        Print / Save PDF
      </button>
      <button type="button" id="kbm-success-modal-continue" class="kbm-success-modal-btn kbm-success-modal-btn--secondary">
        Continue
      </button>
    </div>
  </div>
</div>

