  (function() {
    // Chain edge modal functionality
    function injectChainEdgeLine() {
      // Find all pattern steps
      const patternSteps = document.querySelectorAll('.pattern-step');
      
      if (!patternSteps.length) {
        return; // Don't retry here, let observers handle it
      }

      // Find the step containing "AT THE SAME TIME: Hand-manipulate..."
      let targetStep = null;
      for (let i = 0; i < patternSteps.length; i++) {
        const step = patternSteps[i];
        const text = step.textContent || '';
        if (text.includes('AT THE SAME TIME') && text.includes('Hand-manipulate') && text.includes('stitch border pattern along each edge')) {
          targetStep = step;
          break;
        }
      }

      if (!targetStep) {
        return; // Target step not found, observers will retry
      }

      // Check if already injected (look for the comment marker or the text)
      const stepHtml = targetStep.innerHTML;
      if (stepHtml.includes('KBM insert: optional chain edge') || stepHtml.includes('chain (slipped) edge')) {
        // Already injected, but check if we need to wire up click handlers
        const chainEdgeLink = targetStep.querySelector('.chain-edge-link-wrapper');
        if (chainEdgeLink && !chainEdgeLink.hasAttribute('data-wired')) {
          wireUpChainEdgeLink(chainEdgeLink);
        }
        return;
