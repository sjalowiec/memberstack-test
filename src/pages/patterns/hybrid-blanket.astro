<script src="https://talk.hyvor.com/web-api/embed.js" async></script>



<script>
  (function() {
    // Full mode check: skip access checks and delays when ?mode=full is present
    const urlParams = new URL(window.location.href).searchParams;
    const isFullMode = urlParams.get('mode') === 'full';
    
    if (isFullMode) {
      // Full mode: remove any "checking access" elements if present
      const accessCheckElements = document.querySelectorAll('[data-access-check], #access-check, .access-check, .checking-access');
      accessCheckElements.forEach(el => el.remove());
    }
    
    // Sample defaults in inches
    const SAMPLE_WIDTH_INCHES = 36;
    const SAMPLE_LENGTH_INCHES = 36;
    
    // Flag to prevent infinite loop - track if we're currently processing an event
    let isProcessingEvent = false;

    /**
     * Emit yarn dimension events for YarnRequirement component
     * @param {number} widthInches - Blanket width in inches
     * @param {number} lengthInches - Blanket length in inches
     * @param {'custom'|'sample'} source - Whether dimensions are from custom pattern or sample defaults
     */
    function emitYarnDimensions(widthInches, lengthInches, source) {
      // Guard: only dispatch if both values are > 0 and finite
      if (!Number.isFinite(widthInches) || !Number.isFinite(lengthInches) || 
          widthInches <= 0 || lengthInches <= 0) {
        return;
      }

      // Set flag to prevent re-processing
      isProcessingEvent = true;

      // Dispatch preferred event: kbm:yarnDimensions
      window.dispatchEvent(new CustomEvent('kbm:yarnDimensions', {
        detail: {
          projectWidth: widthInches,
          projectLength: lengthInches,
          lengthUnit: 'in',
          source: source
        }
      }));

      // Dispatch legacy event: kbm:hybridBlanket:dimensions
      window.dispatchEvent(new CustomEvent('kbm:hybridBlanket:dimensions', {
        detail: {
          widthInches: widthInches,
          lengthInches: lengthInches,
          source: source
        }
      }));
      
      // Reset flag after a short delay to allow event propagation
      setTimeout(function() {
        isProcessingEvent = false;
      }, 0);
    }

    // Listen for wizard dimension events and re-dispatch with correct format
    // The wizard dispatches kbm:hybridBlanket:dimensions with widthInches/lengthInches (always in inches)
    // We convert this to kbm:yarnDimensions format for YarnRequirement component
    window.addEventListener('kbm:hybridBlanket:dimensions', function(e) {
      // Skip if we're currently processing an event (prevent infinite loop)
      if (isProcessingEvent) {
        return;
      }
      
      // @ts-ignore - CustomEvent detail property exists at runtime
      const detail = e.detail;
      if (detail && detail.widthInches !== undefined && detail.lengthInches !== undefined) {
        const widthInches = detail.widthInches;
        const lengthInches = detail.lengthInches;
        
        // Determine source: check if it matches sample defaults (within tolerance)
        const tolerance = 0.1;
        const isSampleSize = Math.abs(widthInches - SAMPLE_WIDTH_INCHES) < tolerance && 
                            Math.abs(lengthInches - SAMPLE_LENGTH_INCHES) < tolerance;
        
        // Use source from event if provided, otherwise detect from dimensions
        const source = detail.source || (isSampleSize ? 'sample' : 'custom');
        
        // Re-dispatch with correct format for YarnRequirement
        emitYarnDimensions(widthInches, lengthInches, source);
      }
    });

    // Watch for changes to blanket width/length inputs and dispatch events
    // This ensures Yarn Needed tab updates when size preset is selected or inputs change
    function watchBlanketDimensions() {
      const inputWidth = document.getElementById('blanket-width');
      const inputLength = document.getElementById('blanket-length');
      
      if (!inputWidth || !inputLength) {
        // Retry after a short delay if elements aren't ready yet
        setTimeout(watchBlanketDimensions, 100);
        return;
      }
      
      // Helper to get current unit (check wizard's unit toggle)
      function getCurrentUnit() {
        const unitToggle = document.querySelector('#hybrid-blanket-v2 [data-unit].active');
        if (unitToggle && unitToggle.getAttribute('data-unit')) {
          return unitToggle.getAttribute('data-unit') === 'in' ? 'inches' : 'cm';
        }
        return 'inches'; // default
      }
      
      // Helper to dispatch dimension events based on current input values
      function dispatchDimensionsFromInputs() {
        if (!inputWidth || !inputLength) return;
        
        // @ts-ignore - HTMLInputElement value property exists at runtime
        const widthVal = parseFloat(inputWidth.value || '0');
        // @ts-ignore - HTMLInputElement value property exists at runtime
        const lengthVal = parseFloat(inputLength.value || '0');
        
        if (widthVal > 0 && lengthVal > 0) {
          const currentUnit = getCurrentUnit();
          let widthInches = widthVal;
          let lengthInches = lengthVal;
          
          // Convert to inches if needed
          if (currentUnit === 'cm') {
            widthInches = widthVal / 2.54;
            lengthInches = lengthVal / 2.54;
          }
          
          // Determine source: check if it matches sample defaults
          const tolerance = 0.1;
          const isSampleSize = Math.abs(widthInches - SAMPLE_WIDTH_INCHES) < tolerance && 
                              Math.abs(lengthInches - SAMPLE_LENGTH_INCHES) < tolerance;
          const source = isSampleSize ? 'sample' : 'custom';
          
          // Dispatch events
          emitYarnDimensions(widthInches, lengthInches, source);
        }
      }
      
      // Listen for input changes
      if (inputWidth) {
        inputWidth.addEventListener('input', dispatchDimensionsFromInputs);
        // Also listen for change event (when user finishes editing)
        inputWidth.addEventListener('change', dispatchDimensionsFromInputs);
      }
      if (inputLength) {
        inputLength.addEventListener('input', dispatchDimensionsFromInputs);
        // Also listen for change event (when user finishes editing)
        inputLength.addEventListener('change', dispatchDimensionsFromInputs);
      }
      
      // Dispatch initial event if inputs already have values
      setTimeout(dispatchDimensionsFromInputs, 100);
      
      // Also watch for size preset changes - read directly from the option's data attributes
      const sizePreset = document.getElementById('size-preset');
      if (sizePreset) {
        sizePreset.addEventListener('change', function(e) {
          const target = e.target;
          // @ts-ignore - HTMLSelectElement selectedOptions property exists at runtime
          if (target && 'selectedOptions' in target && target.selectedOptions && target.selectedOptions.length > 0) {
            const option = target.selectedOptions[0];
            if (option && option.value) {
              const widthAttr = option.getAttribute('data-width');
              const lengthAttr = option.getAttribute('data-length');
              
              if (widthAttr && lengthAttr) {
                const widthVal = parseFloat(widthAttr);
                const lengthVal = parseFloat(lengthAttr);
                
                if (widthVal > 0 && lengthVal > 0) {
                  const currentUnit = getCurrentUnit();
                  let widthInches = widthVal;
                  let lengthInches = lengthVal;
                  
                  // Convert to inches if needed
                  if (currentUnit === 'cm') {
                    widthInches = widthVal / 2.54;
                    lengthInches = lengthVal / 2.54;
                  }
                  
                  // Determine source
                  const tolerance = 0.1;
                  const isSampleSize = Math.abs(widthInches - SAMPLE_WIDTH_INCHES) < tolerance && 
                                      Math.abs(lengthInches - SAMPLE_LENGTH_INCHES) < tolerance;
                  const source = isSampleSize ? 'sample' : 'custom';
                  
                  // Dispatch events immediately
                  emitYarnDimensions(widthInches, lengthInches, source);
                }
              } else {
                // Fallback: read from inputs after a delay
                setTimeout(dispatchDimensionsFromInputs, 50);
              }
            }
          }
        });
      }
    }

    // Add bottom "Update my pattern" button to the form
    function addBottomUpdateButton() {
      // Find the wizard form card (the container for all form sections)
      const wizardFormCard = document.querySelector('#hybrid-blanket-wizard-v2 .wizard-form-card');
      if (!wizardFormCard) {
        // Retry if form isn't ready yet
        setTimeout(addBottomUpdateButton, 100);
        return;
      }
      
      // Check if button already exists (prevent duplicates)
      if (document.getElementById('btn-update-pattern-bottom')) {
        return;
      }
      
      // Find the last form section to insert after it
      const lastFormSection = wizardFormCard.querySelector('.form-section:last-child');
      if (!lastFormSection) {
        // Fallback: insert at end of form card
        const buttonWrapper = document.createElement('div');
        buttonWrapper.className = 'kbm-form-bottom-action';
        buttonWrapper.innerHTML = `
          <button 
            type="button" 
            id="btn-update-pattern-bottom" 
            class="kbm-bottom-update-btn"
            data-testid="button-update-my-pattern-bottom"
          >
            Update my pattern
          </button>
        `;
        wizardFormCard.appendChild(buttonWrapper);
      } else {
        // Insert after last form section
        const buttonWrapper = document.createElement('div');
        buttonWrapper.className = 'kbm-form-bottom-action';
        buttonWrapper.innerHTML = `
          <button 
            type="button" 
            id="btn-update-pattern-bottom" 
            class="kbm-bottom-update-btn"
            data-testid="button-update-my-pattern-bottom"
          >
            Update my pattern
          </button>
        `;
        lastFormSection.insertAdjacentElement('afterend', buttonWrapper);
      }
      
      // Wire up the button to trigger the existing top button
      const bottomBtn = document.getElementById('btn-update-pattern-bottom');
      const topBtn = document.getElementById('btn-show-pattern');
      
      if (bottomBtn && topBtn) {
        bottomBtn.addEventListener('click', () => {
          // Programmatically click the existing top button
          topBtn.click();
        });
      }
    }

    // Add bottom action buttons (Edit + Print) to pattern view
    function addBottomPatternActions() {
      // Find the result pattern card
      const resultCard = document.querySelector('#hybrid-blanket-wizard-v2 .result-pattern-card');
      if (!resultCard) {
        // Retry if pattern view isn't ready yet
        setTimeout(addBottomPatternActions, 100);
        return;
      }
      
      // Check if buttons already exist (prevent duplicates)
      if (document.getElementById('edit-btn-bottom')) {
        return;
      }
      
      // Find the pattern footer (last element in pattern output)
      const patternFooter = document.getElementById('pattern-footer');
      if (!patternFooter) {
        // Retry if footer isn't rendered yet
        setTimeout(addBottomPatternActions, 100);
        return;
      }
      
      // Create bottom action row
      const bottomActions = document.createElement('div');
      bottomActions.className = 'kbm-pattern-bottom-actions no-print';
      bottomActions.innerHTML = `
        <button 
          type="button" 
          id="edit-btn-bottom" 
          class="kbm-bottom-action-btn kbm-bottom-action-btn--edit"
          data-testid="button-edit-bottom"
        >
          Edit
        </button>
        <button 
          type="button" 
          id="print-btn-bottom" 
          class="kbm-bottom-action-btn kbm-bottom-action-btn--print"
          data-testid="button-print-bottom"
        >
          Print
        </button>
      `;
      
      // Insert after the footer
      patternFooter.insertAdjacentElement('afterend', bottomActions);
      
      // Wire up buttons to trigger existing top buttons
      const bottomEditBtn = document.getElementById('edit-btn-bottom');
      const bottomPrintBtn = document.getElementById('print-btn-bottom');
      const topEditBtn = document.getElementById('top-edit-btn');
      const topPrintBtn = document.getElementById('top-print-btn');
      
      if (bottomEditBtn && topEditBtn) {
        bottomEditBtn.addEventListener('click', () => {
          // Programmatically click the existing top Edit button
          topEditBtn.click();
        });
      }
      
      if (bottomPrintBtn && topPrintBtn) {
        bottomPrintBtn.addEventListener('click', () => {
          // Programmatically click the existing top Print button
          topPrintBtn.click();
        });
      }
    }

    // Watch for pattern view visibility changes and add/remove bottom actions
    function watchPatternViewVisibility() {
      const resultState = document.querySelector('#hybrid-blanket-wizard-v2 .wizard-state--result');
      if (!resultState) {
        setTimeout(watchPatternViewVisibility, 100);
        return;
      }
      
      // Check initial state
      updateBottomActionsVisibility();
      
      // Watch for class changes (when state changes)
      const observer = new MutationObserver(() => {
        updateBottomActionsVisibility();
      });
      
      observer.observe(resultState, {
        attributes: true,
        attributeFilter: ['class']
      });
      
    }

    // Success Modal functionality
    let modalHasBeenShown = false;
    let scrollPosition = 0;
    let escKeyHandler: ((e: KeyboardEvent) => void) | null = null;

    function lockScroll() {
      scrollPosition = window.pageYOffset || document.documentElement.scrollTop;
      document.body.classList.add('kbm-modal-open');
      document.body.style.top = `-${scrollPosition}px`;
    }

    function unlockScroll() {
      document.body.classList.remove('kbm-modal-open');
      document.body.style.top = '';
      window.scrollTo(0, scrollPosition);
    }

    function closeSuccessModal() {
      const modal = document.getElementById('kbm-success-modal');
      if (!modal) return;
      
      modal.style.display = 'none';
      unlockScroll();
      
      // Remove Esc key listener
      if (escKeyHandler) {
        document.removeEventListener('keydown', escKeyHandler);
        escKeyHandler = null;
      }
      
      // Return focus to pattern top element (don't scroll again)
      const patternTop = document.getElementById('patternTop') as HTMLElement | null;
      if (patternTop) {
        patternTop.focus({ preventScroll: true });
      } else {
        // Fallback to result-pattern-card
        const patternCard = document.querySelector('#hybrid-blanket-wizard-v2 .result-pattern-card') as HTMLElement | null;
        if (patternCard) {
          patternCard.focus({ preventScroll: true });
        }
      }
    }

    function openSuccessModal() {
      if (modalHasBeenShown) return; // Only show once per page load
      
      const modal = document.getElementById('kbm-success-modal');
      const printBtn = document.getElementById('kbm-success-modal-print');
      const continueBtn = document.getElementById('kbm-success-modal-continue');
      
      if (!modal || !printBtn || !continueBtn) return;
      
      modalHasBeenShown = true;
      modal.style.display = 'flex';
      lockScroll();
      
      // Move focus to modal
      setTimeout(() => {
        printBtn.focus();
      }, 100);
      
      // Handle Esc key
      escKeyHandler = (e: KeyboardEvent) => {
        if (e.key === 'Escape') {
          closeSuccessModal();
        }
      };
      document.addEventListener('keydown', escKeyHandler);
    }

    // Set up modal button handlers once
    function setupModalHandlers() {
      const printBtn = document.getElementById('kbm-success-modal-print');
      const continueBtn = document.getElementById('kbm-success-modal-continue');
      
      if (printBtn && continueBtn) {
        // Handle Print button
        printBtn.addEventListener('click', () => {
          window.print();
          // Don't close modal after print
        });
        
        // Handle Continue button
        continueBtn.addEventListener('click', () => {
          closeSuccessModal();
        });
      } else {
        // Retry if elements aren't ready yet
        setTimeout(setupModalHandlers, 100);
      }
    }

    // Expose helper function globally
    (window as any).kbmOpenSuccessModal = openSuccessModal;

    // Scroll to top of pattern results and set focus
    function scrollToPatternTop() {
      // Check if pattern content is actually rendered (wait for key elements)
      const patternTitle = document.getElementById('pattern-title');
      
      // Target the kbm-tabs div (tab navigation bar)
      let scrollTarget: HTMLElement | null = document.querySelector('.kbm-tabs') as HTMLElement | null;
      
      // Fallback to kbm-tabs-wrapper if kbm-tabs not found
      if (!scrollTarget) {
        scrollTarget = document.querySelector('.kbm-tabs-wrapper') as HTMLElement | null;
      }
      
      // Fallback to tabs-shell if neither found
      if (!scrollTarget) {
        scrollTarget = document.querySelector('.tabs-shell') as HTMLElement | null;
      }
      
      // Fallback to result-pattern-card if tabs not found
      if (!scrollTarget) {
        scrollTarget = document.querySelector('#hybrid-blanket-wizard-v2 .result-pattern-card') as HTMLElement | null;
      }
      
      // If pattern content isn't ready yet, retry
      if (!scrollTarget || !patternTitle) {
        setTimeout(scrollToPatternTop, 100);
        return;
      }
      
      // Use requestAnimationFrame to ensure DOM has updated and content is rendered
      requestAnimationFrame(() => {
        // Add ID and tabindex if they don't exist
        if (!scrollTarget!.id) {
          scrollTarget!.id = 'patternTop';
        }
        if (!scrollTarget!.hasAttribute('tabindex')) {
          scrollTarget!.setAttribute('tabindex', '-1');
        }
        
        // Wait one more frame to ensure layout is complete
        requestAnimationFrame(() => {
          // Get the element's position relative to the viewport
          const rect = scrollTarget!.getBoundingClientRect();
          const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
          const targetY = rect.top + scrollTop - 20; // Small offset for better visibility
          
          // Scroll window to the top of the kbm-tabs div
          window.scrollTo({
            top: Math.max(0, targetY), // Ensure we don't scroll to negative position
            behavior: 'smooth'
          });
          
          // Set keyboard focus for accessibility after scroll completes
          setTimeout(() => {
            if (scrollTarget) {
              scrollTarget.focus({ preventScroll: true });
            }
          }, 500);
        });
      });
    }

    // Watch for pattern results becoming visible
    function watchForPatternResults() {
      const resultState = document.querySelector('#hybrid-blanket-wizard-v2 .wizard-state--result');
      if (!resultState) {
        setTimeout(watchForPatternResults, 100);
        return;
      }
      
      // Check initial state
      if (!resultState.classList.contains('hidden')) {
        // Pattern is already visible
        setTimeout(() => {
          scrollToPatternTop();
          setTimeout(() => {
            openSuccessModal();
          }, 300);
        }, 500); // Delay to ensure pattern is fully rendered
      }
      
      // Watch for when pattern becomes visible
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
            const target = mutation.target as HTMLElement;
            if (!target.classList.contains('hidden')) {
              // Pattern just became visible - wait for content to render
              setTimeout(() => {
                scrollToPatternTop();
                // Delay modal slightly after scroll starts
                setTimeout(() => {
                  openSuccessModal();
                }, 300);
              }, 500);
              observer.disconnect(); // Only show once
            }
          }
        });
      });
      
      observer.observe(resultState, {
        attributes: true,
        attributeFilter: ['class']
      });
    }
    
    function updateBottomActionsVisibility() {
      const resultState = document.querySelector('#hybrid-blanket-wizard-v2 .wizard-state--result') as HTMLElement | null;
      const bottomActions = document.querySelector('.kbm-pattern-bottom-actions') as HTMLElement | null;
      
      if (!resultState) return;
      
      // Show bottom actions only when pattern view is visible (not hidden)
      const isVisible = !resultState.classList.contains('hidden');
      
      if (isVisible) {
        // Pattern is visible - ensure bottom actions exist
        if (!bottomActions) {
          addBottomPatternActions();
        } else {
          bottomActions.style.display = '';
        }
      } else {
        // Pattern is hidden - hide bottom actions
        if (bottomActions) {
          bottomActions.style.display = 'none';
        }
      }
    }

    // Initial dispatch with sample defaults on page load
    // Wait for DOM to be ready and give components time to initialize
    function initialize() {
      emitYarnDimensions(SAMPLE_WIDTH_INCHES, SAMPLE_LENGTH_INCHES, 'sample');
      // Set up modal handlers
      setupModalHandlers();
      
      if (isFullMode) {
        // Full mode: initialize immediately without delays
        watchBlanketDimensions();
        addBottomUpdateButton();
        watchPatternViewVisibility();
        watchForPatternResults();
      } else {
        // Normal mode: delay watcher setup to ensure wizard component is fully loaded
        setTimeout(watchBlanketDimensions, 200);
        // Add bottom update button after form is loaded
        setTimeout(addBottomUpdateButton, 300);
        // Watch for pattern view and add bottom actions when visible
        setTimeout(watchPatternViewVisibility, 400);
        // Watch for pattern results to show success modal
        setTimeout(watchForPatternResults, 500);
      }
    }
    
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initialize);
    } else {
      // DOM already ready
      if (isFullMode) {
        // Full mode: initialize immediately
        initialize();
      } else {
        // Normal mode: wait a bit for components to initialize
        setTimeout(initialize, 100);
      }
    }
  })();
</script>

<script is:inline>
  (function() {
    // Video modal functionality
    let videoModalScrollPosition = 0;
    let videoEscKeyHandler = null;

    function lockVideoModalScroll() {
      videoModalScrollPosition = window.pageYOffset || document.documentElement.scrollTop;
      document.body.classList.add('transfer-video-modal-open');
      document.body.style.top = `-${videoModalScrollPosition}px`;
    }

    function unlockVideoModalScroll() {
      document.body.classList.remove('transfer-video-modal-open');
      document.body.style.top = '';
      window.scrollTo(0, videoModalScrollPosition);
    }

    function openVideoModal() {
      const modal = document.getElementById('transfer-video-modal');
      const iframeContainer = document.getElementById('transfer-video-iframe-container');
      const videoContainer = iframeContainer ? iframeContainer.parentElement : null;
      const imageContainer = document.getElementById('transfer-video-modal-image-container');
      
      if (!modal || !iframeContainer || !videoContainer) return;

      // Hide image container, show video container
      if (imageContainer) imageContainer.style.display = 'none';
      videoContainer.style.display = 'block';

      // Create and insert iframe
      const iframe = document.createElement('iframe');
      iframe.src = 'https://player.vimeo.com/video/1161475161?autoplay=1&muted=1&loop=1&playlist=1161475161&background=1';
      iframe.setAttribute('frameborder', '0');
      iframe.setAttribute('allow', 'autoplay; fullscreen; picture-in-picture');
      iframe.setAttribute('loading', 'lazy');
      
      iframeContainer.innerHTML = '';
      iframeContainer.appendChild(iframe);

      modal.style.display = 'flex';
      lockVideoModalScroll();

      // Handle Esc key
      videoEscKeyHandler = function(e) {
        if (e.key === 'Escape') {
          closeVideoModal();
        }
      };
      document.addEventListener('keydown', videoEscKeyHandler);
    }

    function openImageModal(imageSrc, imageAlt) {
      const modal = document.getElementById('transfer-video-modal');
      const iframeContainer = document.getElementById('transfer-video-iframe-container');
      const videoContainer = iframeContainer ? iframeContainer.parentElement : null;
      const imageContainer = document.getElementById('transfer-video-modal-image-container');
      const imageElement = document.getElementById('transfer-video-modal-image');
      
      if (!modal || !imageContainer || !imageElement) return;

      // Hide video container, show image container
      if (videoContainer) videoContainer.style.display = 'none';
      imageContainer.style.display = 'block';

      // Set image source and alt
      imageElement.src = imageSrc;
      imageElement.alt = imageAlt || '';

      modal.style.display = 'flex';
      lockVideoModalScroll();

      // Handle Esc key
      videoEscKeyHandler = function(e) {
        if (e.key === 'Escape') {
          closeVideoModal();
        }
      };
      document.addEventListener('keydown', videoEscKeyHandler);
    }

    function closeVideoModal() {
      const modal = document.getElementById('transfer-video-modal');
      const iframeContainer = document.getElementById('transfer-video-iframe-container');
      const videoContainer = iframeContainer ? iframeContainer.parentElement : null;
      const imageContainer = document.getElementById('transfer-video-modal-image-container');
      
      if (!modal) return;

      modal.style.display = 'none';
      unlockVideoModalScroll();

      // Remove iframe to stop playback
      if (iframeContainer) {
        iframeContainer.innerHTML = '';
      }

      // Reset video container display
      if (videoContainer) {
        videoContainer.style.display = 'block';
      }

      // Clear image
      if (imageContainer) {
        imageContainer.style.display = 'none';
        const imageElement = document.getElementById('transfer-video-modal-image');
        if (imageElement) {
          imageElement.src = '';
          imageElement.alt = '';
        }
      }

      // Remove Esc key listener
      if (videoEscKeyHandler) {
        document.removeEventListener('keydown', videoEscKeyHandler);
        videoEscKeyHandler = null;
      }
    }

    // Set up modal handlers
    function setupVideoModalHandlers() {
      const modal = document.getElementById('transfer-video-modal');
      const closeBtn = modal?.querySelector('.transfer-video-modal-close');
      const backdrop = modal?.querySelector('.transfer-video-modal-backdrop');
      const imageElement = document.getElementById('transfer-video-modal-image');

      if (closeBtn) {
        closeBtn.addEventListener('click', closeVideoModal);
      }

      if (backdrop) {
        backdrop.addEventListener('click', closeVideoModal);
      }

      // Allow clicking image to close (nice-to-have)
      if (imageElement) {
        imageElement.addEventListener('click', closeVideoModal);
      }
    }

    // Find and wrap "transfer stitches to the machine" text in Section 2
    function wrapTransferText() {
      // Find all pattern steps in both sample and result states
      const patternSteps = document.querySelectorAll('.pattern-step');
      
      if (!patternSteps.length) {
        return; // Don't retry here, let observers handle it
      }

      // Find Section 2: The Transition
      let section2Index = -1;

      for (let i = 0; i < patternSteps.length; i++) {
        const step = patternSteps[i];
        const text = step.textContent || '';
        if (text.includes('Section 2: The Transition')) {
          section2Index = i;
          break;
        }
      }

      if (section2Index === -1) {
        return; // Section 2 not found, observers will retry
      }

      // Look for the step immediately after Section 2 that contains "transfer stitches to the machine"
      const nextStep = patternSteps[section2Index + 1];
      if (!nextStep) {
        return;
      }

      const stepText = nextStep.textContent || '';
      if (!stepText.toLowerCase().includes('transfer stitches to the machine')) {
        return;
      }

      // Check if already wrapped AND has icon
      const existingWrapper = nextStep.querySelector('.transfer-link-wrapper');
      if (existingWrapper) {
        const hasIcon = existingWrapper.querySelector('.transfer-play-icon');
        if (hasIcon) {
          // Check if icon has width/height attributes (newer version)
          const hasWidth = hasIcon.hasAttribute('width');
          const iconRect = hasIcon.getBoundingClientRect();
          const isVisible = iconRect.width > 0 && iconRect.height > 0;
          
          if (hasWidth && isVisible) {
            return;
          } else {
            // Remove wrapper to force rewrap with updated SVG
            const wrapperText = existingWrapper.textContent || '';
            existingWrapper.outerHTML = wrapperText;
          }
        } else {
          console.log('Wrapper exists but no icon found, unwrapping to rewrap');
          // Remove the wrapper so we can rewrap properly
          const wrapperText = existingWrapper.textContent || '';
          existingWrapper.outerHTML = wrapperText;
          // Get fresh HTML after unwrapping
          nextStep.innerHTML = nextStep.innerHTML;
        }
      }
      // Wrap the text "transfer stitches to the machine" and add play icon
      const html = nextStep.innerHTML;
      // Match case-insensitively - be flexible with whitespace
      // Try multiple patterns to catch variations
      const patterns = [
        /(Transfer\s+stitches\s+to\s+the\s+machine)/gi,
        /(transfer\s+stitches\s+to\s+the\s+machine)/gi,
        /(Transfer stitches to the machine)/gi,
        /(transfer stitches to the machine)/gi
      ];
      
      // SVG play icon: triangle centered inside a thin stroked circle
      const playIconSvg = '<svg class="transfer-play-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" role="button" tabindex="0" aria-label="Play video: transfer stitches to the machine" style="display: inline-block; vertical-align: middle; flex-shrink: 0;"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="1.5"/><polygon points="10,8 16,12 10,16" fill="currentColor"/></svg>';
      
      let wrappedHtml = html;
      let found = false;
      
      for (let i = 0; i < patterns.length; i++) {
        const regex = new RegExp(patterns[i].source, patterns[i].flags);
        wrappedHtml = html.replace(regex, function(match) {
          found = true;
          return '<span class="transfer-link-wrapper" role="button" tabindex="0"><span class="transfer-link">' + match + '</span>' + playIconSvg + '</span>';
        });
        if (found && wrappedHtml !== html) break;
      }
      
      if (wrappedHtml !== html) {
        nextStep.innerHTML = wrappedHtml;
        
        // Add click handler to the wrapper (both text and icon are clickable)
        const wrapper = nextStep.querySelector('.transfer-link-wrapper');
        const icon = nextStep.querySelector('.transfer-play-icon');
        
        if (wrapper) {
          wrapper.addEventListener('click', function(e) {
            e.preventDefault();
            openVideoModal();
          });
          
          // Handle Enter/Space key for accessibility
          wrapper.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              openVideoModal();
            }
          });
        }
        
        // Also make icon directly clickable and keyboard accessible
        if (icon) {
          icon.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            openVideoModal();
          });
          
          icon.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              e.stopPropagation();
              openVideoModal();
            }
          });
        }
      }
    }

    // Initialize video modal functionality
    function initVideoModal() {
      setupVideoModalHandlers();
      
      // Watch both pattern-steps containers for changes
      const samplePatternSteps = document.getElementById('sample-pattern-steps');
      const resultPatternSteps = document.getElementById('pattern-steps');
      
      // Function to watch a container
      function watchPatternContainer(container) {
        if (!container) return;
        
        // Try wrapping immediately
        wrapTransferText();
        
        // Watch for content changes
        const observer = new MutationObserver(function() {
          // Small delay to ensure DOM is updated
          setTimeout(wrapTransferText, 50);
        });
        
        observer.observe(container, {
          childList: true,
          subtree: true,
          characterData: true
        });
      }
      
      // Watch both containers
      watchPatternContainer(samplePatternSteps);
      watchPatternContainer(resultPatternSteps);
      
      // Also watch for when result state becomes visible
      const resultState = document.querySelector('#hybrid-blanket-wizard-v2 .wizard-state--result');
      if (resultState) {
        const stateObserver = new MutationObserver(function() {
          if (!resultState.classList.contains('hidden')) {
            // Result state is visible, check for pattern
            setTimeout(wrapTransferText, 200);
          }
        });
        
        stateObserver.observe(resultState, {
          attributes: true,
          attributeFilter: ['class']
        });
      }
      
      // Also watch for when sample state becomes visible (default state)
      const sampleState = document.querySelector('#hybrid-blanket-wizard-v2 .wizard-state--sample');
      if (sampleState) {
        // Check immediately if sample state is visible
        if (!sampleState.classList.contains('hidden')) {
          setTimeout(wrapTransferText, 100);
        }
        
        const sampleStateObserver = new MutationObserver(function() {
          if (!sampleState.classList.contains('hidden')) {
            // Sample state is visible, check for pattern
            setTimeout(wrapTransferText, 200);
          }
        });
        
        sampleStateObserver.observe(sampleState, {
          attributes: true,
          attributeFilter: ['class']
        });
      }
      
      // Listen for pattern generation button clicks
      const showPatternBtn = document.getElementById('btn-show-pattern');
      if (showPatternBtn) {
        showPatternBtn.addEventListener('click', function() {
          // Pattern will be generated, wait a bit then wrap
          setTimeout(function() {
            wrapTransferText();
            setTimeout(wrapTransferText, 500);
            setTimeout(wrapTransferText, 1000);
          }, 100);
        });
      }
      
      // Run immediately
      wrapTransferText();
      
      // Periodic check as fallback (every 300ms for first 6 seconds, then every 2 seconds)
      let checkCount = 0;
      const maxQuickChecks = 20; // 6 seconds at 300ms intervals
      const quickCheckInterval = setInterval(function() {
        wrapTransferText();
        checkCount++;
        if (checkCount >= maxQuickChecks) {
          clearInterval(quickCheckInterval);
          // Then check every 2 seconds
          setInterval(wrapTransferText, 2000);
        }
      }, 300);
      
      // Initial attempts with increasing delays
      setTimeout(wrapTransferText, 100);
      setTimeout(wrapTransferText, 300);
      setTimeout(wrapTransferText, 600);
      setTimeout(wrapTransferText, 1000);
      setTimeout(wrapTransferText, 2000);
      setTimeout(wrapTransferText, 3000);
    }

    // Wait for DOM to be ready and wizard component to load
    function startInit() {
      // Check if wizard component exists
      const wizard = document.getElementById('hybrid-blanket-wizard-v2');
      if (!wizard) {
        // Retry if wizard hasn't loaded yet
        setTimeout(startInit, 200);
        return;
      }
      
      initVideoModal();
      
      // Also listen for when pattern steps are generated by watching for .pattern-step elements
      const patternObserver = new MutationObserver(function(mutations) {
        let shouldWrap = false;
        mutations.forEach(function(mutation) {
          if (mutation.type === 'childList' && mutation.addedNodes.length > 0) {
            // Check if any added nodes are pattern-step elements or contain them
            for (let i = 0; i < mutation.addedNodes.length; i++) {
              const node = mutation.addedNodes[i];
              if (node.nodeType === 1) { // Element node
                if (node.classList && node.classList.contains('pattern-step')) {
                  shouldWrap = true;
                  break;
                }
                if (node.querySelector && node.querySelector('.pattern-step')) {
                  shouldWrap = true;
                  break;
                }
              }
            }
          }
        });
        if (shouldWrap) {
          setTimeout(wrapTransferText, 150);
        }
      });
      
      // Watch the entire wizard for pattern step additions
      if (wizard) {
        patternObserver.observe(wizard, {
          childList: true,
          subtree: true
        });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        setTimeout(startInit, 500);
      });
    } else {
      setTimeout(startInit, 500);
    }
    
    // Also expose function globally for manual testing/debugging
    if (typeof window !== 'undefined') {
      window.wrapTransferText = wrapTransferText;
    }

    // Expose openImageModal globally
    if (typeof window !== 'undefined') {
      window.openImageModal = openImageModal;
    }
  })();
</script>

