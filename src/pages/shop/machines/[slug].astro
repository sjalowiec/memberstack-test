---
/**
 * Dynamic machine detail page.
 * Data: src/data/machines.json (slug used for routing).
 * URL: /shop/machines/[slug] (e.g. /shop/machines/th160, /shop/machines/sk280).
 */
import Layout from "../../../layouts/Layout.astro";
import PageHead from "../../../components/PageHead.astro";
import machinesData from "../../../data/machines.json";

// Types matching your JSON (exact field names).
interface WhoItsForItem {
  title: string;
  text: string;
}

interface Bonus {
  title: string;
  description?: string;
  value?: string;
}

interface Warranty {
  us?: string;
  international?: string;
}

interface Machine {
  name: string;
  id?: number;
  slug: string;
  shortDescription?: string;
  intro?: string;
  whoItsFor?: WhoItsForItem[];
  features?: string[];
  quickSpecs?: string[];
  bonus?: Bonus;
  warranty?: Warranty;
  shipping?: string;
  image?: string;
  sku?: string;
}

const machines = machinesData as Machine[];

export function getStaticPaths() {
  return machines.map((machine) => ({
    params: { slug: machine.slug },
    props: { machine },
  }));
}

const { machine } = Astro.props;

// Defensive: should always exist when built from getStaticPaths; redirect if missing.
if (!machine) {
  return Astro.redirect("/shop/machines");
}

const title = `${machine.name} | Knit by Machine`;
const description =
  machine.shortDescription ||
  `${machine.name} – knitting machine details and specifications.`;
---

<Layout {title} {description}>
  <PageHead title={machine.name} />

  <div class="machine-detail-page">
    <!-- Breadcrumb / back navigation -->
    <nav class="machine-breadcrumb" aria-label="Breadcrumb">
      <a href="/shop/machines" class="back-link">← Back to Machines</a>
      <span class="breadcrumb-sep">/</span>
      <span class="breadcrumb-current">{machine.name}</span>
    </nav>

    <!-- Hero: name, short description, optional SKU/model -->
    <header class="machine-hero">
      <div class="machine-hero-text">
        <h1 class="machine-name">{machine.name}</h1>
        {(machine.sku || machine.id) && (
          <p class="machine-meta">
            {machine.sku && <span class="machine-sku">{machine.sku}</span>}
            {machine.sku && machine.id != null && " · "}
            {machine.id != null && <span>ID: {machine.id}</span>}
          </p>
        )}
        {machine.shortDescription && (
          <p class="machine-short">{machine.shortDescription}</p>
        )}
      </div>
      {machine.image && (
        <div class="machine-hero-image-wrap">
          <img
            src={machine.image.startsWith("/") ? machine.image : `/${machine.image}`}
            alt={machine.name}
            class="machine-hero-image"
            width="400"
            height="260"
          />
        </div>
      )}
    </header>

    <!-- Intro section -->
    {machine.intro && (
      <section class="machine-section machine-intro">
        <h2 class="section-title">Overview</h2>
        <p class="machine-intro-text">{machine.intro}</p>
      </section>
    )}

    <!-- Who It's For -->
    {machine.whoItsFor && machine.whoItsFor.length > 0 && (
      <section class="machine-section machine-who">
        <h2 class="section-title">Who It's For</h2>
        <div class="who-cards">
          {machine.whoItsFor.map((item) => (
            <div class="who-card">
              <h3 class="who-title">{item.title}</h3>
              <p class="who-text">{item.text}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Features list -->
    {machine.features && machine.features.length > 0 && (
      <section class="machine-section machine-features">
        <h2 class="section-title">Features</h2>
        <ul class="features-list">
          {machine.features.map((feature) => (
            <li>{feature}</li>
          ))}
        </ul>
      </section>
    )}

    <!-- Quick Specs -->
    {machine.quickSpecs && machine.quickSpecs.length > 0 && (
      <section class="machine-section machine-specs">
        <h2 class="section-title">Quick Specs</h2>
        <ul class="specs-list">
          {machine.quickSpecs.map((spec) => (
            <li class="spec-tag">{spec}</li>
          ))}
        </ul>
      </section>
    )}

    <!-- Bonus (visually distinct, not flashy) -->
    {machine.bonus && (machine.bonus.title || machine.bonus.description || machine.bonus.value) && (
      <section class="machine-section machine-bonus">
        <h2 class="section-title">{machine.bonus.title || "Bonus"}</h2>
        <div class="bonus-box">
          {machine.bonus.description && (
            <p class="bonus-description">{machine.bonus.description}</p>
          )}
          {machine.bonus.value && (
            <p class="bonus-value">{machine.bonus.value}</p>
          )}
        </div>
      </section>
    )}

    <!-- Warranty -->
    {machine.warranty && (machine.warranty.us || machine.warranty.international) && (
      <section class="machine-section machine-warranty">
        <h2 class="section-title">Warranty</h2>
        <div class="warranty-box">
          {machine.warranty.us && (
            <p><strong>US:</strong> {machine.warranty.us}</p>
          )}
          {machine.warranty.international && (
            <p><strong>International:</strong> {machine.warranty.international}</p>
          )}
        </div>
      </section>
    )}

    <!-- Shipping -->
    {machine.shipping && (
      <section class="machine-section machine-shipping">
        <h2 class="section-title">Shipping</h2>
        <p class="shipping-text">{machine.shipping}</p>
      </section>
    )}

    <!-- CTA: placeholder until buy link exists -->
    <section class="machine-section machine-cta">
      <a href="/shop/machines" class="cta-secondary">← Back to Machines</a>
      <span class="cta-placeholder" aria-hidden="true">
        Purchase Information Coming Soon
      </span>
    </section>
  </div>
</Layout>

<style>
  .machine-detail-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
  }

  .machine-breadcrumb {
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
  }

  .back-link {
    font-weight: 600;
    color: var(--kbm-green);
    text-decoration: underline;
  }

  .back-link:hover {
    color: var(--kbm-green-hover, #445626);
  }

  .breadcrumb-sep {
    color: #8a9a6e;
  }

  .breadcrumb-current {
    color: #5a6b47;
  }

  /* Hero */
  .machine-hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 640px) {
    .machine-hero {
      grid-template-columns: 1fr 320px;
      align-items: start;
    }
  }

  .machine-hero-text {
    min-width: 0;
  }

  .machine-name {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--kbm-green);
    margin: 0 0 0.5rem 0;
  }

  .machine-meta {
    font-size: 0.9rem;
    color: #6b7b55;
    margin: 0 0 0.75rem 0;
  }

  .machine-sku {
    font-weight: 600;
  }

  .machine-short {
    font-size: 1.05rem;
    color: #5a6b47;
    line-height: 1.6;
    margin: 0;
  }

  .machine-hero-image-wrap {
    width: 100%;
    max-width: 320px;
    aspect-ratio: 400 / 260;
    overflow: hidden;
    border-radius: 12px;
    background: #eef3e6;
  }

  .machine-hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Sections */
  .machine-section {
    margin-bottom: 2rem;
  }

  .section-title {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--kbm-green);
    margin: 0 0 0.75rem 0;
  }

  .machine-intro-text {
    font-size: 1rem;
    color: #5a6b47;
    line-height: 1.7;
    margin: 0;
  }

  /* Who It's For cards */
  .who-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .who-card {
    background: #fafbf9;
    border: 1px solid #e8ebe4;
    border-radius: 12px;
    padding: 1.25rem;
  }

  .who-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--kbm-green);
    margin: 0 0 0.5rem 0;
  }

  .who-text {
    font-size: 0.95rem;
    color: #5a6b47;
    line-height: 1.55;
    margin: 0;
  }

  /* Features list */
  .features-list {
    margin: 0;
    padding-left: 1.35rem;
    color: #5a6b47;
    line-height: 1.7;
  }

  .features-list li {
    margin-bottom: 0.35rem;
  }

  /* Quick Specs tags */
  .specs-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .spec-tag {
    display: inline-block;
    padding: 0.4rem 0.85rem;
    background: #eef3e6;
    border: 1px solid #d7e2c8;
    border-radius: 8px;
    font-size: 0.9rem;
    color: #52682d;
  }

  /* Bonus box */
  .machine-bonus .section-title {
    margin-bottom: 0.5rem;
  }

  .bonus-box {
    background: #f8faf5;
    border: 1px solid #e8ebe4;
    border-radius: 12px;
    padding: 1.25rem;
  }

  .bonus-description {
    font-size: 1rem;
    color: #5a6b47;
    line-height: 1.6;
    margin: 0 0 0.5rem 0;
  }

  .bonus-value {
    font-size: 1rem;
    font-weight: 600;
    color: var(--kbm-green);
    margin: 0;
  }

  /* Warranty */
  .warranty-box {
    font-size: 0.95rem;
    color: #5a6b47;
    line-height: 1.6;
  }

  .warranty-box p {
    margin: 0 0 0.5rem 0;
  }

  .warranty-box p:last-child {
    margin-bottom: 0;
  }

  /* Shipping */
  .shipping-text {
    font-size: 0.95rem;
    color: #5a6b47;
    line-height: 1.6;
    margin: 0;
  }

  /* CTA */
  .machine-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid #e8ebe4;
  }

  .cta-secondary {
    font-weight: 600;
    color: var(--kbm-green);
    text-decoration: underline;
  }

  .cta-secondary:hover {
    color: var(--kbm-green-hover, #445626);
  }

  .cta-placeholder {
    font-size: 0.9rem;
    color: #8a9a6e;
    font-style: italic;
  }
</style>
