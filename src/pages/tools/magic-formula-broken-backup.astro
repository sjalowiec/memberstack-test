        <text x="${centerX}" y="${centerY + 5}" text-anchor="middle" fill="#1f2937" stroke="white" stroke-width="4" paint-order="stroke" style="font-size: 20px; font-weight: 600; font-family: 'JetBrains Mono', monospace;">${steps[1].sts}–${steps[1].rows}–${steps[1].times}</text>
        <text x="${centerX}" y="${centerY + 28}" text-anchor="middle" fill="#6b7280" stroke="white" stroke-width="3" paint-order="stroke" style="font-size: 11px; font-family: system-ui, -apple-system, sans-serif; font-style: italic;">sts – rows – times</text>
      `;
    } else if (steps.length > 2) {
      let yPos = centerY - 30;
      steps.forEach(step => {
        shorthandSvg += `<text x="${centerX}" y="${yPos}" text-anchor="middle" fill="#1f2937" stroke="white" stroke-width="4" paint-order="stroke" style="font-size: 18px; font-weight: 600; font-family: 'JetBrains Mono', monospace;">${step.sts}–${step.rows}–${step.times}</text>`;
        yPos += 24;
      });
      shorthandSvg += `<text x="${centerX}" y="${yPos + 5}" text-anchor="middle" fill="#6b7280" stroke="white" stroke-width="3" paint-order="stroke" style="font-size: 11px; font-family: system-ui, -apple-system, sans-serif; font-style: italic;">sts – rows – times</text>`;
    }
    
    // Build the shaping distance display for the left side
    const distanceHtml = shapingDistance ? `
      <div style="display: flex; flex-direction: column; justify-content: center; align-items: flex-end; padding-right: 0.75rem; min-width: 80px;">
