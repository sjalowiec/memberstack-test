        yPos += 28;
      });
      shorthandSvg += `<text x="130" y="${yPos + 5}" text-anchor="middle" fill="#6b7280" stroke="white" stroke-width="3" paint-order="stroke" style="font-size: 13px; font-family: system-ui, -apple-system, sans-serif; font-style: italic;">sts – rows – times</text>`;
