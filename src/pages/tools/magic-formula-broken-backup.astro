          <svg viewBox="0 0 260 200" style="width: 100%; height: auto; display: block;" aria-label="Shaping diagram showing ${direction} from ${startSts} to ${endSts} stitches on ${mode === 'both' ? 'both sides' : 'one side'}">
            <polygon points="${polygonPoints}" fill="none" stroke="#52682D" stroke-width="3" stroke-linejoin="round"/>
            <!-- Labels positioned over the polygon lines with white knockout -->
            <text x="130" y="173" text-anchor="middle" fill="#6b7280" stroke="white" stroke-width="4" paint-order="stroke" style="font-size: 14px; font-family: system-ui, -apple-system, sans-serif;">${startLabel}</text>
            <text x="130" y="33" text-anchor="middle" fill="#6b7280" stroke="white" stroke-width="4" paint-order="stroke" style="font-size: 14px; font-family: system-ui, -apple-system, sans-serif;">${endLabel}</text>
