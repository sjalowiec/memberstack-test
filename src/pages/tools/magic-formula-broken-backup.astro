      shorthandSvg = `
        <text x="130" y="75" text-anchor="middle" fill="#1f2937" stroke="white" stroke-width="4" paint-order="stroke" style="font-size: 24px; font-weight: 600; font-family: 'JetBrains Mono', monospace;">${steps[0].sts}–${steps[0].rows}–${steps[0].times}</text>
        <text x="130" y="110" text-anchor="middle" fill="#1f2937" stroke="white" stroke-width="4" paint-order="stroke" style="font-size: 24px; font-weight: 600; font-family: 'JetBrains Mono', monospace;">${steps[1].sts}–${steps[1].rows}–${steps[1].times}</text>
        <text x="130" y="135" text-anchor="middle" fill="#6b7280" stroke="white" stroke-width="3" paint-order="stroke" style="font-size: 13px; font-family: system-ui, -apple-system, sans-serif; font-style: italic;">sts – rows – times</text>
