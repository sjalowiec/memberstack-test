  // ========== MODE DETECTION & AUTO-CALCULATION ==========
  
  // DOM references for mode detection
  const shapingOptionsSection = document.getElementById('shapingOptionsSection');
  const calculateBtn = document.getElementById('calculateBtn');
  const resultsEl = document.getElementById('results');
  const slopeIndicatorEl = document.getElementById('slopeIndicator');
  
  // State tracking
  let currentMode = null; // 'slope', 'regular', or null
  let isAutoCalculating = false;
  
  // Convert measurements to stitches/rows (measurement mode only)
  function measurementsToStitches() {
    const startingWidth = parseFloat(getInputValue('startingWidth'));
    const endingWidth = parseFloat(getInputValue('endingWidth'));
    const shapingLength = parseFloat(getInputValue('shapingLength'));
    const stsGaugeRaw = getInputValue('magicformula-stitch-gauge');
    const rowGaugeRaw = getInputValue('magicformula-row-gauge');
    const gaugeBase = useCm ? 10 : 4;
    const startingSts = Math.round((startingWidth / gaugeBase) * stsGaugeRaw);
    const endingSts = Math.round((endingWidth / gaugeBase) * stsGaugeRaw);
    const totalRows = Math.round((shapingLength / gaugeBase) * rowGaugeRaw);
    return { startingSts, endingSts, totalRows };
  }

  // Check if all required inputs have valid values for current mode
  function hasValidInputs() {
    if (inputMode === 'stitch') {
      const startSts = parseFloat(getInputValue('startingStitches'));
      const endSts = parseFloat(getInputValue('endingStitches'));
      const rows = parseFloat(getInputValue('totalRows'));
      if (isNaN(startSts) || startSts < 1) return false;
      if (isNaN(endSts) || endSts < 0) return false;
      if (isNaN(rows) || rows < 1) return false;
      return true;
    }
    // measurement mode
    const startWidth = parseFloat(getInputValue('startingWidth'));
    const endWidth = parseFloat(getInputValue('endingWidth'));
    const length = parseFloat(getInputValue('shapingLength'));
    const stsGaugeRaw = getInputValue('magicformula-stitch-gauge');
    const rowGaugeRaw = getInputValue('magicformula-row-gauge');
    if (isNaN(startWidth) || startWidth <= 0) return false;
    if (isNaN(endWidth) || endWidth < 0) return false;
    if (isNaN(length) || length <= 0) return false;
    const stsGauge = Number(stsGaugeRaw);
    const rowGauge = Number(rowGaugeRaw);
    if (stsGaugeRaw === '' || rowGaugeRaw === '' || isNaN(stsGauge) || stsGauge < 1 || isNaN(rowGauge) || rowGauge < 1) return false;
    return true;
  }
  
  // Detect which shaping mode (no-shaping / slope / regular) based on current input mode
  function detectMode() {
    if (!hasValidInputs()) return null;

    let startSts, endSts, rows;
    if (inputMode === 'stitch') {
      startSts = parseInt(document.getElementById('startingStitches').value);
      endSts = parseInt(document.getElementById('endingStitches').value);
      rows = parseInt(document.getElementById('totalRows').value);
    } else {
      const converted = measurementsToStitches();
      startSts = converted.startingSts;
      endSts = converted.endingSts;
      rows = converted.totalRows;
    }

    const deltaSts = Math.abs(startSts - endSts);
    if (deltaSts === 0) return 'no-shaping';
    if (deltaSts > rows) return 'slope';
    return 'regular';
  }
  
  // Update UI based on detected mode
  function updateModeUI() {
    const mode = detectMode();
    
    if (mode === null) {
      // Not enough valid inputs - hide everything
      shapingOptionsSection.style.display = 'none';
      calculateBtn.style.display = 'none';
      currentMode = null;
      return;
    }
    
    if (mode === 'no-shaping') {
      // No shaping needed - show calculate button but hide options
      shapingOptionsSection.style.display = 'none';
      calculateBtn.style.display = 'block';
      currentMode = 'no-shaping';
      return;
    }
    
    if (mode === 'slope') {
      // Slope mode: hide options, auto-calculate with one-side
      shapingOptionsSection.style.display = 'none';
      calculateBtn.style.display = 'none';
      currentMode = 'slope';
      
      // Auto-calculate immediately
      autoCalculateSlope();
      return;
    }
    
    if (mode === 'regular') {
      // Regular mode: show options and calculate button
      shapingOptionsSection.style.display = 'block';
      calculateBtn.style.display = 'block';
      currentMode = 'regular';
      
      // Hide results if we switched from slope to regular
      if (resultsEl.classList.contains('show') && isAutoCalculating) {
        resultsEl.classList.remove('show');
        isAutoCalculating = false;
      }
      return;
    }
  }
  
  // Auto-calculate for slope mode (one-side only, no user choice)
  function autoCalculateSlope() {
    isAutoCalculating = true;
    
    // Force one-side shaping for slope mode
    document.querySelectorAll('.icon-toggle[data-value]').forEach(btn => {
      if (btn.dataset.value === 'one') {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    });
    
    runCalculation();
  }

  // Input mode button handlers
  document.getElementById('inputModeStitch')?.addEventListener('click', () => setInputMode('stitch'));
  document.getElementById('inputModeMeasurement')?.addEventListener('click', () => setInputMode('measurement'));

  // Add input listeners to all form fields for real-time detection
  const allInputIds = [...stitchInputIds, ...measurementInputIds];
  allInputIds.forEach(fieldId => {
    const input = document.getElementById(fieldId);
    if (input) {
      input.addEventListener('input', () => {
        input.classList.remove('error');
        const errorEl = document.getElementById(fieldId + 'Error');
        if (errorEl) errorEl.classList.remove('show');
        clearTimeout(input._detectTimeout);
        input._detectTimeout = setTimeout(updateModeUI, 150);
      });
    }
  });
  gaugeInputIds.forEach(fieldId => {
    const input = document.getElementById(fieldId);
    if (input) {
      input.addEventListener('input', () => {
        const err = document.getElementById('magicformula-gauge-error');
        if (err) { err.classList.remove('show'); err.style.display = 'none'; }
        clearTimeout(input._detectTimeout);
        input._detectTimeout = setTimeout(updateModeUI, 150);
      });
    }
  });

  // Load saved unit preference
  const savedUnit = localStorage.getItem('kbm-unit-preference') || 'in';
  if (savedUnit === 'cm') {
    useCm = true;
    inchesBtn.classList.remove('active');
    cmBtn.classList.add('active');
  } else {
    useCm = false;
    inchesBtn.classList.add('active');
    cmBtn.classList.remove('active');
  }
  updateLabels();
  updateRequiredAndDisabled();

  inchesBtn.addEventListener('click', function() {
    if (!useCm) return;
    useCm = false;
    inchesBtn.classList.add('active');
    cmBtn.classList.remove('active');
    localStorage.setItem('kbm-unit-preference', 'in');
    updateLabels();
  });

  cmBtn.addEventListener('click', function() {
    if (useCm) return;
    useCm = true;
    cmBtn.classList.add('active');
    inchesBtn.classList.remove('active');
    localStorage.setItem('kbm-unit-preference', 'cm');
    updateLabels();
  });

  // Shaping side toggle
  document.querySelectorAll('.icon-toggle').forEach(btn => {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.icon-toggle').forEach(b => b.classList.remove('active'));
      this.classList.add('active');
    });
  });

  // Validation helper
  function validateField(input, errorEl, allowZero = false) {
    const value = parseFloat(input.value);
    const minValue = allowZero ? 0 : 1;
    if (!input.value || isNaN(value) || value < minValue) {
      input.classList.add('error');
      errorEl.classList.add('show');
      return false;
    }
    input.classList.remove('error');
    errorEl.classList.remove('show');
    return true;
  }

  // Single calculation path: runCalculation() does validation, math, and rendering.
  function runCalculation() {
    const gaugeErrorEl = document.getElementById('magicformula-gauge-error');
    if (gaugeErrorEl) { gaugeErrorEl.style.display = 'none'; gaugeErrorEl.classList.remove('show'); gaugeErrorEl.textContent = 'If you enter one gauge, enter both.'; }
    
    const shapingMode = document.querySelector('.icon-toggle.active').dataset.value === 'both' ? 'both-sides' : 'one-side';
    const units = useCm ? 'cm' : 'in';
    const gaugeDivisor = useCm ? 10 : 4;
    let startingSts, endingSts, totalRows, stsGauge, rowsGauge, showConversionSummary, hasLengthDisplay;
    let savedStartingWidth, savedEndingWidth, savedShapingLength;

    if (inputMode === 'stitch') {
      const startingStitchesInput = document.getElementById('startingStitches');
      const endingStitchesInput = document.getElementById('endingStitches');
      const totalRowsInput = document.getElementById('totalRows');
      const stitchGaugeRaw = getInputValue('magicformula-stitch-gauge');
      const rowGaugeRaw = getInputValue('magicformula-row-gauge');
      let valid = true;
      valid = validateField(startingStitchesInput, document.getElementById('startingStitchesError')) && valid;
      valid = validateField(endingStitchesInput, document.getElementById('endingStitchesError'), true) && valid;
      valid = validateField(totalRowsInput, document.getElementById('totalRowsError')) && valid;
      const hasStitchGauge = stitchGaugeRaw !== '' && !isNaN(Number(stitchGaugeRaw)) && Number(stitchGaugeRaw) >= 1;
      const hasRowGauge = rowGaugeRaw !== '' && !isNaN(Number(rowGaugeRaw)) && Number(rowGaugeRaw) >= 1;
      const gaugeErrorEl = document.getElementById('magicformula-gauge-error');
      if (hasStitchGauge !== hasRowGauge) {
        if (gaugeErrorEl) { gaugeErrorEl.classList.add('show'); gaugeErrorEl.style.display = ''; }
        if (!hasStitchGauge && !hasRowGauge) { if (gaugeErrorEl) gaugeErrorEl.style.display = 'none'; } else { valid = false; }
      } else {
        if (gaugeErrorEl) { gaugeErrorEl.classList.remove('show'); gaugeErrorEl.style.display = 'none'; }
      }
      if (!valid) return;
      startingSts = parseInt(getInputValue('startingStitches'), 10);
      endingSts = parseInt(getInputValue('endingStitches'), 10);
      totalRows = parseInt(getInputValue('totalRows'), 10);
      showConversionSummary = false;
      if (hasStitchGauge && hasRowGauge) {
        stsGauge = Number(stitchGaugeRaw) / gaugeDivisor;
        rowsGauge = Number(rowGaugeRaw) / gaugeDivisor;
        hasLengthDisplay = true;
      } else {
        stsGauge = 1;
        rowsGauge = 1;
        hasLengthDisplay = false;
      }
    } else {
      const startingWidthInput = document.getElementById('startingWidth');
      const endingWidthInput = document.getElementById('endingWidth');
      const shapingLengthInput = document.getElementById('shapingLength');
      const stitchGaugeRaw = getInputValue('magicformula-stitch-gauge');
      const rowGaugeRaw = getInputValue('magicformula-row-gauge');
      let valid = true;
      valid = validateField(startingWidthInput, document.getElementById('startingWidthError')) && valid;
      valid = validateField(endingWidthInput, document.getElementById('endingWidthError'), true) && valid;
      valid = validateField(shapingLengthInput, document.getElementById('shapingLengthError')) && valid;
      if (stitchGaugeRaw === '' || rowGaugeRaw === '') {
        const gaugeErrorEl = document.getElementById('magicformula-gauge-error');
        if (gaugeErrorEl) { gaugeErrorEl.classList.add('show'); gaugeErrorEl.style.display = ''; }
        valid = false;
      } else {
        const stsNum = Number(stitchGaugeRaw);
        const rowNum = Number(rowGaugeRaw);
        if (isNaN(stsNum) || stsNum < 1 || isNaN(rowNum) || rowNum < 1) {
          const gaugeErrorEl = document.getElementById('magicformula-gauge-error');
          if (gaugeErrorEl) { gaugeErrorEl.textContent = 'Please enter a valid gauge.'; gaugeErrorEl.classList.add('show'); gaugeErrorEl.style.display = ''; }
          valid = false;
        }
      }
      if (!valid) return;
      stsGauge = Number(stitchGaugeRaw) / gaugeDivisor;
      rowsGauge = Number(rowGaugeRaw) / gaugeDivisor;
      const converted = measurementsToStitches();
      startingSts = converted.startingSts;
      endingSts = converted.endingSts;
      totalRows = converted.totalRows;
      showConversionSummary = true;
      hasLengthDisplay = true;
      savedStartingWidth = parseFloat(getInputValue('startingWidth'));
      savedEndingWidth = parseFloat(getInputValue('endingWidth'));
      savedShapingLength = parseFloat(getInputValue('shapingLength'));
    }

    // Calculate shaping
    const result = calculateShaping({
      startingSts,
      endingSts,
      totalRows,
      stsGauge,
      rowsGauge,
      units,
      shapingMode
    });

    let instructions = '';
    
    // Handle errors
    if (result.error === 'not-enough-rows') {
      instructions += `<div class="note error">`;
      instructions += `<strong>Not enough rows!</strong><br>`;
      instructions += `You need ${result.shapingCount} ${result.direction}s but only have ${result.totalRows} rows.<br>`;
      instructions += `Please increase your total rows or reduce the stitch difference.`;
      instructions += `</div>`;
      
      document.getElementById('resultsContent').innerHTML = instructions;
      document.getElementById('results').classList.add('show');
      document.getElementById('breakdownToggle').style.display = 'none';
      window.currentInstructions = document.getElementById('resultsContent').innerText;
      document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      return;
    }
    
    // Handle no shaping needed
    if (result.noShaping) {
      const unitLabel = result.units === 'cm' ? 'cm' : 'inches';
      const lengthFormatted = result.units === 'cm' 
        ? Math.round(result.lengthInUnits) 
        : result.lengthInUnits.toFixed(1);
      
      instructions += `<p><strong>No shaping needed!</strong></p>`;
      instructions += `<p>Your starting and ending stitch counts are the same (${result.startingSts} stitches).</p>`;
      instructions += `<p>Simply knit ${result.totalRows} rows with no increases or decreases.</p>`;
      instructions += `<p style="margin-top: 1rem; color: #6b7280;"><em>This section spans about ${lengthFormatted} ${unitLabel}.</em></p>`;
      
      document.getElementById('resultsContent').innerHTML = instructions;
      document.getElementById('results').classList.add('show');
      document.getElementById('breakdownToggle').style.display = 'none';
      window.currentInstructions = document.getElementById('resultsContent').innerText;
      document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      return;
    }
    
    // Build success instructions
    const action = result.direction === 'increase' ? 'Increase' : 'Decrease';
    const actionLower = result.direction === 'increase' ? 'increasing' : 'decreasing';
    const location = result.shapingMode === 'both-sides' ? 'at EACH end' : 'at ONE end';
    const locationDisplay = result.shapingMode === 'both-sides' ? 'both sides' : 'one side';
    const unitLabel = result.units === 'cm' ? 'cm' : 'inches';
    const lengthFormatted = result.units === 'cm' 
      ? Math.round(result.lengthInUnits) 
      : result.lengthInUnits.toFixed(1);
    
    // Build shaping steps array for diagram
    const intervalStep = result.intervalStep || 1;
    let shapingSteps = [];
    
    if (result.mode === 'slope' && result.slopeData) {
      // SLOPE MODE: show stitch counts per action instead of 1
      const sd = result.slopeData;
      if (sd.timesAtMore > 0) {
        shapingSteps.push({ sts: sd.stsPerAction + 1, rows: 2, times: sd.timesAtMore });
      }
      if (sd.timesAtBase > 0) {
        shapingSteps.push({ sts: sd.stsPerAction, rows: 2, times: sd.timesAtBase });
      }
    } else if (result.extraRows === 0) {
      shapingSteps = [{ sts: 1, rows: result.baseInterval, times: result.changesPerSide }];
    } else {
      if (result.timesAtBase > 0) {
        shapingSteps.push({ sts: 1, rows: result.baseInterval, times: result.timesAtBase });
      }
      shapingSteps.push({ sts: 1, rows: result.baseInterval + intervalStep, times: result.timesAtLonger });
    }
    
    const diagramMode = result.shapingMode === 'both-sides' ? 'both' : 'one';
    const shapingDistanceDisplay = hasLengthDisplay ? `${lengthFormatted} ${unitLabel}` : null;

    // Render the SVG diagram - use slope diagram for slope mode, standard for others
    if (result.mode === 'slope') {
      instructions += renderSlopeDiagram(result.startingSts, result.endingSts, diagramMode, result.direction, shapingSteps, shapingDistanceDisplay);
      
      // Activate both slope indicator AND one-side toggle (slope uses one-side shaping)
      document.getElementById('slopeIndicator').classList.add('active');
      // Slope mode forces one-side shaping - update the toggle icons
      document.querySelectorAll('.icon-toggle[data-value]').forEach(btn => {
        if (btn.dataset.value === 'one') {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });
    } else {
      instructions += renderShapingDiagram(result.startingSts, result.endingSts, diagramMode, result.direction, shapingSteps, shapingDistanceDisplay);
      document.getElementById('slopeIndicator').classList.remove('active');
    }
    
    // Measurement conversion summary (measurement mode only)
    if (showConversionSummary && savedStartingWidth != null) {
      const measureLabel = useCm ? 'cm' : '"';
      instructions += `<div class="note info" style="margin-bottom: 1rem;">`;
      instructions += `<strong>Your measurements:</strong><br>`;
      instructions += `${savedStartingWidth}${measureLabel} wide → ${result.startingSts} sts &nbsp;|&nbsp; ${savedEndingWidth}${measureLabel} wide → ${result.endingSts} sts &nbsp;|&nbsp; ${savedShapingLength}${measureLabel} long → ${result.totalRows} rows`;
      instructions += `</div>`;
    }
    
    // Slope mode indicator text with icon
    if (result.mode === 'slope') {
      instructions += `<div style="display: flex; align-items: center; gap: 0.75rem; margin: 1rem 0; padding: 0.75rem 1rem; background: #fef9e7; border-left: 4px solid #f39c12; border-radius: 0 6px 6px 0;">`;
      instructions += `<div style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; background: var(--kbm-green); border-radius: 6px; flex-shrink: 0;">`;
      instructions += `<img src="/images/slope-choice.svg" alt="Slope" style="width: 20px; height: 20px; filter: brightness(0) invert(1);" />`;
      instructions += `</div>`;
      instructions += `<div>`;
      instructions += `<strong style="color: #b58900;">Shoulder-style slope</strong>`;
      instructions += `<span style="color: #6c5700; display: block; font-size: 0.85rem;">Bind off or short row multiple stitches every other row</span>`;
      instructions += `</div>`;
      instructions += `</div>`;
    }
    
    // Summary
    instructions += `<p><strong>Summary:</strong></p>`;
    instructions += `<p>You are ${actionLower} from <strong>${result.startingSts}</strong> to <strong>${result.endingSts}</strong> stitches over <strong>${result.totalRows}</strong> rows.</p>`;
    instructions += `<p>Shape <strong>${locationDisplay}</strong>.</p>`;
    
    // Show total changes clearly
    if (result.shapingMode === 'both-sides') {
      if (result.unevenWarning) {
        instructions += `<p>Total ${result.direction}s: <strong>${result.totalChange}</strong> (left side: ${result.leftSideChanges}, right side: ${result.rightSideChanges})</p>`;
      } else {
        instructions += `<p>Total ${result.direction}s: <strong>${result.totalChange}</strong> (${result.changesPerSide} per side)</p>`;
      }
    } else {
      instructions += `<p>Total ${result.direction}s: <strong>${result.totalChange}</strong></p>`;
    }
    
    // Uneven warning
    if (result.unevenWarning) {
      instructions += `<div class="note info">`;
      instructions += `<strong>Note:</strong> The total stitch change (${result.totalChange}) isn't even, so one side will have 1 more ${result.direction} than the other.<br>`;
      instructions += `Left side: ${result.leftSideChanges} ${result.direction}s. Right side: ${result.rightSideChanges} ${result.direction}s.`;
      instructions += `</div>`;
    }
    
    // Main instructions
    instructions += `<p style="margin-top: 1rem;"><strong>Instructions:</strong></p>`;
    
    // Helper to format inline shorthand
    const shorthand = (sts, rows, times) => `<span style="font-family: 'JetBrains Mono', monospace; color: #52682d;">(${sts}–${rows}–${times} sts/rows/times)</span>`;
    
    // SLOPE MODE: special instructions for binding off multiple stitches
    if (result.mode === 'slope' && result.slopeData) {
      const sd = result.slopeData;
      const actionVerb = result.direction === 'decrease' ? 'Bind off' : 'Cast on';
      const locationText = result.shapingMode === 'both-sides' ? 'on each side' : 'on one side';
      
      if (sd.timesAtMore > 0 && sd.timesAtBase > 0) {
        // Two different stitch counts
        instructions += `<p>• ${actionVerb} <strong>${sd.stsPerAction + 1}</strong> stitches ${locationText} every 2 rows, <strong>${sd.timesAtMore}</strong> times ${shorthand(sd.stsPerAction + 1, 2, sd.timesAtMore)}.</p>`;
        instructions += `<p>• ${actionVerb} <strong>${sd.stsPerAction}</strong> stitches ${locationText} every 2 rows, <strong>${sd.timesAtBase}</strong> times ${shorthand(sd.stsPerAction, 2, sd.timesAtBase)}.</p>`;
        
        instructions += `<div class="note">`;
        instructions += `<strong>Tip:</strong> Alternate between binding off ${sd.stsPerAction + 1} and ${sd.stsPerAction} stitches to distribute the shaping evenly.`;
        instructions += `</div>`;
      } else if (sd.timesAtBase > 0) {
        // Only one stitch count
        instructions += `<p>${actionVerb} <strong>${sd.stsPerAction}</strong> stitches ${locationText} every 2 rows, <strong>${sd.shapingRows}</strong> times ${shorthand(sd.stsPerAction, 2, sd.shapingRows)}.</p>`;
      } else {
        // Only larger stitch count (rare)
        instructions += `<p>${actionVerb} <strong>${sd.stsPerAction + 1}</strong> stitches ${locationText} every 2 rows, <strong>${sd.timesAtMore}</strong> times ${shorthand(sd.stsPerAction + 1, 2, sd.timesAtMore)}.</p>`;
      }
      
      // Handle asymmetric leftover: 1 extra stitch on right side (on the last shaping row)
      if (sd.hasAsymmetricLeftover && result.shapingMode === 'both-sides') {
        instructions += `<p style="margin-top: 0.5rem;">• On the <strong>last shaping row</strong>, ${actionVerb.toLowerCase()} 1 extra stitch on the right side only (to account for the odd total).</p>`;
      }
    } else {
      // STANDARD MODE: regular shaping instructions
      
      // Helper function to analyze intervals from breakdown
      function analyzeIntervals(breakdown) {
        if (breakdown.length === 0) return [];
        
        const intervals = [];
        let prevRow = 0;
        
        breakdown.forEach(step => {
          const interval = step.rowNumber - prevRow;
          prevRow = step.rowNumber;
          
          // Find or create interval entry
          const existing = intervals.find(i => i.interval === interval);
          if (existing) {
            existing.count++;
          } else {
            intervals.push({ interval, count: 1 });
          }
        });
        
        // Sort by interval (smaller first)
        intervals.sort((a, b) => a.interval - b.interval);
        return intervals;
      }
      
      if (result.shapingMode === 'both-sides') {
      if (result.unevenWarning) {
        // Asymmetric case - derive from breakdown
        const bothSidesSteps = result.breakdown.filter(s => s.location === 'each side');
        const rightOnlySteps = result.breakdown.filter(s => s.location.includes('right side'));
        
        const bothIntervals = analyzeIntervals(bothSidesSteps);
        
        if (bothIntervals.length === 1) {
          instructions += `<p>• On each side, ${action} 1 stitch every ${bothIntervals[0].interval} rows, ${bothIntervals[0].count} times ${shorthand(1, bothIntervals[0].interval, bothIntervals[0].count)}.</p>`;
        } else if (bothIntervals.length > 1) {
          bothIntervals.forEach(int => {
            instructions += `<p>• On each side, ${action} 1 stitch every ${int.interval} rows, ${int.count} times ${shorthand(1, int.interval, int.count)}.</p>`;
          });
        }
        
        if (rightOnlySteps.length > 0) {
          const extraRow = rightOnlySteps[0].rowNumber;
          instructions += `<p style="margin-top: 0.5rem;">• On right side only, ${action} 1 additional stitch at row ${extraRow}.</p>`;
        }
      } else {
        const longerInterval = result.baseInterval + intervalStep;
        if (result.extraRows === 0) {
          instructions += `<p>On each side, ${action} 1 stitch every ${result.baseInterval} rows, ${result.changesPerSide} times ${shorthand(1, result.baseInterval, result.changesPerSide)}.</p>`;
        } else {
          if (result.timesAtBase > 0) {
            instructions += `<p>• On each side, ${action} 1 stitch every ${result.baseInterval} rows, ${result.timesAtBase} times ${shorthand(1, result.baseInterval, result.timesAtBase)}.</p>`;
          }
          instructions += `<p>• On each side, ${action} 1 stitch every ${longerInterval} rows, ${result.timesAtLonger} times ${shorthand(1, longerInterval, result.timesAtLonger)}.</p>`;
          
          instructions += `<div class="note">`;
          instructions += `<strong>Tip:</strong> Your shaping doesn't divide evenly. Alternate between the two intervals to distribute the shaping evenly across your ${result.totalRows} rows.`;
          instructions += `</div>`;
        }
      }
    } else {
      const longerInterval = result.baseInterval + intervalStep;
      if (result.extraRows === 0) {
        instructions += `<p>On one side only, ${action} 1 stitch every ${result.baseInterval} rows, ${result.changesPerSide} times ${shorthand(1, result.baseInterval, result.changesPerSide)}.</p>`;
      } else {
        if (result.timesAtBase > 0) {
          instructions += `<p>• On one side only, ${action} 1 stitch every ${result.baseInterval} rows, ${result.timesAtBase} times ${shorthand(1, result.baseInterval, result.timesAtBase)}.</p>`;
        }
        instructions += `<p>• On one side only, ${action} 1 stitch every ${longerInterval} rows, ${result.timesAtLonger} times ${shorthand(1, longerInterval, result.timesAtLonger)}.</p>`;
        
        instructions += `<div class="note">`;
        instructions += `<strong>Tip:</strong> Your shaping doesn't divide evenly. Alternate between the two intervals to distribute the shaping evenly across your ${result.totalRows} rows.`;
        instructions += `</div>`;
      }
    }
    } // Close standard mode else block
    
    // Slope mode warnings
    if (result.warnings && result.warnings.length > 0) {
      instructions += `<div class="note info" style="margin-top: 1rem;">`;
      instructions += `<strong>Note:</strong> `;
      instructions += result.warnings.join(' ');
      instructions += `</div>`;
    }
    
    // Note: Shaping distance is now displayed on the left side of the SVG diagram

    document.getElementById('resultsContent').innerHTML = instructions;
    document.getElementById('results').classList.add('show');
    document.getElementById('breakdownToggle').style.display = 'flex';
    
    // Build breakdown table
    const breakdownBody = document.getElementById('breakdownBody');
    breakdownBody.innerHTML = '';
    
    result.breakdown.forEach(step => {
      const row = document.createElement('tr');
      row.innerHTML = `
        <td>Row ${step.rowNumber}</td>
        <td>${step.action}</td>
        <td>${step.location}</td>
        <td>${step.stitchesAfter}</td>
      `;
      breakdownBody.appendChild(row);
    });
    
    window.currentInstructions = document.getElementById('resultsContent').innerText;
    document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    
    // Show ActionBar
    const actionBar = document.getElementById('action-bar');
    const printBtn = document.getElementById('print-btn');
    if (actionBar) actionBar.style.display = 'flex';
    if (printBtn) printBtn.style.display = 'block';
  }

  document.getElementById('wizard-form').addEventListener('submit', function(e) {
    e.preventDefault();
    e.stopPropagation();
    runCalculation();
  });

  // Action Bar buttons
  const actionBarEl = document.getElementById('action-bar');
  const startOverBtn = document.getElementById('start-over-btn');
  const printBtnEl = document.getElementById('print-btn');

  // Start Over handler - full reset to initial state
  if (startOverBtn) {
    startOverBtn.addEventListener('click', () => {
      document.getElementById('results').classList.remove('show');
      if (actionBarEl) actionBarEl.style.display = 'none';
      setInputMode('stitch');
      [...stitchInputIds, ...measurementInputIds, ...gaugeInputIds].forEach(fieldId => {
        const input = document.getElementById(fieldId);
        if (input) {
          input.value = '';
          input.classList.remove('error');
        }
        const errorEl = document.getElementById(fieldId + 'Error');
        if (errorEl) errorEl.classList.remove('show');
      });
      const gaugeErrorEl = document.getElementById('magicformula-gauge-error');
      if (gaugeErrorEl) { gaugeErrorEl.classList.remove('show'); gaugeErrorEl.style.display = 'none'; gaugeErrorEl.textContent = 'If you enter one gauge, enter both.'; }
      document.querySelectorAll('.icon-toggle[data-value]').forEach(btn => {
        if (btn.dataset.value === 'both') {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });
      if (slopeIndicatorEl) slopeIndicatorEl.classList.remove('active');
      if (shapingOptionsSection) shapingOptionsSection.style.display = 'none';
      if (calculateBtn) calculateBtn.style.display = 'none';
      currentMode = null;
      isAutoCalculating = false;
      const breakdownToggle = document.getElementById('breakdownToggle');
      const breakdownContent = document.getElementById('breakdownContent');
      if (breakdownToggle) breakdownToggle.classList.remove('open');
      if (breakdownContent) breakdownContent.classList.remove('show');
      window.scrollTo({ top: 0, behavior: 'smooth' });
      setTimeout(() => {
        document.getElementById('startingStitches').focus();
      }, 300);
    });
  }

  // Print handler
  if (printBtnEl) {
    printBtnEl.addEventListener('click', () => {
      window.print();
    });
  }

  // Breakdown toggle
  document.getElementById('breakdownToggle').addEventListener('click', function() {
    this.classList.toggle('open');
    document.getElementById('breakdownContent').classList.toggle('show');
  });

  // Copy button
  document.getElementById('copyBtn').addEventListener('click', function() {
    if (window.currentInstructions) {
      // Also include breakdown if visible
      let textToCopy = window.currentInstructions;
      const breakdownContent = document.getElementById('breakdownContent');
      if (breakdownContent.classList.contains('show')) {
        const rows = document.querySelectorAll('#breakdownBody tr');
        textToCopy += '\n\nRow-by-row breakdown:\n';
        rows.forEach(row => {
          const cells = row.querySelectorAll('td');
          textToCopy += `${cells[0].textContent}: ${cells[1].textContent} (${cells[2].textContent}) → ${cells[3].textContent}\n`;
        });
      }
      
      navigator.clipboard.writeText(textToCopy).then(() => {
        const originalText = this.innerHTML;
        this.innerHTML = '<i class="fas fa-check"></i> Copied!';
        setTimeout(() => {
          this.innerHTML = originalText;
        }, 2000);
      });
    }
  });
</script>

</Layout>
