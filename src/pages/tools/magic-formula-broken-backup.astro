---
import Layout from "../../layouts/Layout.astro";
import Tooltip from "../../components/Tooltip.astro";
import WhyUseThisToolTooltip from "../../components/common/WhyUseThisToolTooltip.astro";
import PrintFooter from "../../components/common/PrintFooter.astro";
import ActionBar from "../../components/wizards/ActionBar.astro";
import WizardBackLink from "../../components/wizards/WizardBackLink.astro";
import UnitToggle from "../../components/wizards/components/UnitToggle.astro";
import GaugeInput from "../../components/wizards/components/GaugeInput.astro";
const pageTitle = "Magic Formula – Shaping Calculator | Knit it Now";
const pageDescription = "The \"Magic Formula\" is the industry standard for distributing increases or decreases evenly across a slope. Whether you’re shaping a sleeve, a neckline, or a waist, just plug in your starting and ending counts to get perfectly spaced instructions. No math, no \"rounding errors,\" just a smooth edge.";
const pageUrl = "tools/magic-formula";



---

<Layout title={pageTitle} description={pageDescription}>

<style>
.wizard-page {
  padding-top: 120px;
  padding-bottom: 2rem;
  min-height: 100vh;
  background: var(--page-bg);
}

.page-header {
  max-width: 800px;
  margin: 0 auto 1.25rem;
  padding: 0 1rem;
}

.page-header-title {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  margin-bottom: 0.75rem;
  flex-wrap: wrap;
}

@media (max-width: 640px) {
  .page-header-title {
    flex-direction: column;
    gap: 0.75rem;
  }
}

.page-header h1 {
  color: var(--kbm-green);
  font-size: 2rem;
  font-weight: 700;
  margin: 0;
}

.page-header p {
  color: #6b7280;
  font-size: 1.05rem;
  line-height: 1.6;
  text-align: center;
}

.wizard-description {
  color: #6b7280;
  font-size: 1.05rem;
  line-height: 1.6;
  text-align: center;
}

.wizard-description p {
  margin: 0 0 0.5rem 0;
}

.wizard-description p:last-child {
  margin-bottom: 0;
}

.video-button {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.5rem 1rem;
  background: #e5e7eb;
  color: #374151;
  text-decoration: none;
  font-weight: 600;
  border-radius: 6px;
  transition: all 0.2s;
  border: 1px solid #d1d5db;
  cursor: pointer;
  font-size: 0.9rem;
  white-space: nowrap;
}

.video-button:hover {
  background: #d1d5db;
  transform: translateY(-1px);
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
}

.wizard-container {
  max-width: 700px;
  margin: 0 auto;
  background: white;
  padding: 1.5rem;
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

@media (max-width: 640px) {
  .wizard-container {
    padding: 1.25rem 1rem;
    margin: 0 1rem;
  }
}

.toggle-group {
  display: flex;
  gap: 1rem;
  align-items: center;
  justify-content: center;
  margin-bottom: 1.25rem;
}

.input-mode-label {
  font-size: 0.95rem;
  font-weight: 600;
  color: #374151;
  margin: 1rem 0 0.5rem 0;
}

.input-mode-toggle {
  display: flex;
  gap: 0;
  margin-bottom: 1.25rem;
  border-radius: 8px;
  overflow: hidden;
  border: 2px solid #d0d5cc;
  background: #f9fafb;
}

.input-mode-btn {
  flex: 1;
  padding: 0.65rem 1rem;
  border: none;
  background: transparent;
  font-family: var(--font);
  font-size: 0.9rem;
  font-weight: 500;
  color: #6b7280;
  cursor: pointer;
  transition: background 0.2s, color 0.2s;
}

.input-mode-btn:hover {
  background: rgba(82, 104, 45, 0.08);
  color: #374151;
}

.input-mode-btn.active {
  background: var(--kbm-green);
  color: white;
}

.mode-fields {
  margin-top: 0;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 0.75rem 1rem;
}

.section-label {
  grid-column: 1 / -1;
}

.section-divider {
  grid-column: 1 / -1;
}

.form-row-2 {
  display: contents;
}

.form-row-2 > .floating-input {
  grid-column: span 3;
}

.form-row-3 {
  display: contents;
}

.form-row-3 > .floating-input {
  grid-column: span 2;
}

@media (max-width: 768px) {
  .form-row-3 > .floating-input {
    grid-column: span 3;
  }
}

@media (max-width: 480px) {
  .form-row-2 > .floating-input,
  .form-row-3 > .floating-input {
    grid-column: 1 / -1;
  }
}

.floating-input {
  position: relative;
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.floating-input input {
  width: 100%;
  padding: 1.25rem 0.875rem 0.5rem;
  border: 1px solid #d0d5cc;
  border-radius: 6px;
  font-family: var(--font);
  font-size: 1rem;
  color: var(--text-dark);
  background: white;
  transition: border-color 0.2s, box-shadow 0.2s;
  -moz-appearance: textfield;
  box-sizing: border-box;
}

.floating-input input::-webkit-outer-spin-button,
.floating-input input::-webkit-inner-spin-button {
  -webkit-appearance: none;
  margin: 0;
}

.floating-input input:focus {
  outline: none;
  border-color: var(--kbm-green);
  box-shadow: 0 0 0 3px rgba(82, 104, 45, 0.1);
}

.floating-input input.error {
  border-color: #dc3545;
}

.floating-input label {
  position: absolute;
  left: 0.875rem;
  top: 50%;
  transform: translateY(-50%);
  font-size: 0.95rem;
  color: #6b7280;
  pointer-events: none;
  transition: all 0.2s ease;
  background: transparent;
  padding: 0 2px;
}

.floating-input input:focus ~ label,
.floating-input input:not(:placeholder-shown) ~ label {
  top: 0.5rem;
  transform: translateY(0);
  font-size: 0.75rem;
  color: var(--kbm-green);
  font-weight: 500;
}

.floating-input input.error ~ label {
  color: #dc3545;
}

.floating-input input::placeholder {
  color: transparent;
}

.floating-input input:focus::placeholder {
  color: #9ca3af;
}

.error-text {
  color: #dc3545;
  font-size: 0.8rem;
  margin-top: 0.35rem;
  display: none;
}

.error-text.show {
  display: block;
}

.section-divider {
  border: none;
  border-top: 1px solid #e5e7eb;
  margin: 1rem 0;
}

.section-label {
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--kbm-green);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 0.75rem;
}

.icon-toggle-group {
  display: flex;
  justify-content: center;
  gap: 1.5rem;
}

.icon-toggle {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  cursor: pointer;
  background: none;
  border: none;
  padding: 0;
}

.icon-toggle-box {
  width: 56px;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid var(--kbm-green);
  border-radius: 8px;
  background: white;
  transition: all 0.2s ease;
}

.icon-toggle-box img {
  width: 32px;
  height: 32px;
  transition: filter 0.2s ease;
}

.icon-toggle.active .icon-toggle-box {
  background: var(--kbm-green);
  border-color: var(--kbm-green);
}

.icon-toggle.active .icon-toggle-box img {
  filter: brightness(0) invert(1);
}

.icon-toggle:hover:not(.active) .icon-toggle-box {
  background: rgba(82, 104, 45, 0.08);
}

.icon-toggle-label {
  font-size: 0.75rem;
  color: #6b7280;
  font-weight: 400;
  transition: color 0.2s ease;
}

.icon-toggle.active .icon-toggle-label {
  color: #4b5563;
  font-weight: 500;
}

/* Slope indicator - hidden by default, only visible when slope mode is active */
.slope-indicator {
  cursor: default;
  pointer-events: none;
  display: none;
}

.slope-indicator .icon-toggle-box {
  border-style: dashed;
}

.slope-indicator.active {
  display: flex;
}

.slope-indicator.active .icon-toggle-box {
  background: var(--kbm-green);
  border-color: var(--kbm-green);
  border-style: solid;
}

.slope-indicator.active .icon-toggle-box img {
  filter: brightness(0) invert(1);
}

.slope-indicator.active .icon-toggle-label {
  color: var(--kbm-green);
  font-weight: 500;
}

.calculate-btn {
  width: 100%;
  padding: 1rem;
  background: var(--kbm-green);
  color: white;
  border: none;
  border-radius: 6px;
  font-family: var(--font);
  font-size: 1.05rem;
  font-weight: 600;
  cursor: pointer;
  margin-top: 1rem;
  transition: background 0.2s, transform 0.1s;
}

.calculate-btn:hover {
  background: #445626;
}

.calculate-btn:active {
  transform: scale(0.99);
}

.results {
  display: none;
  margin-top: 1.5rem;
  padding: 1.25rem 1.5rem;
  background: #ffffff;
  border-radius: 12px;
  border: 2px solid var(--kbm-green);
  box-shadow: 0 2px 8px rgba(82, 104, 45, 0.08);
}

.results.show {
  display: block;
}

.results h2 {
  color: var(--kbm-green);
  font-size: 1.15rem;
  font-weight: 600;
  margin: 0 0 0.75rem 0;
}

.results p {
  margin: 0.5rem 0;
  line-height: 1.5;
}

.results-section-label {
  font-weight: 600;
  color: #374151;
  margin-top: 0.75rem;
  margin-bottom: 0.25rem;
}

.note {
  margin-top: 1rem;
  padding: 1rem;
  background: #fff3cd;
  border-left: 3px solid #ffc107;
  border-radius: 4px;
  font-size: 0.9rem;
}

.note.info {
  background: #e8f4fd;
  border-left-color: #0d6efd;
}

.note.error {
  background: #f8d7da;
  border-left-color: #dc3545;
}

.copy-btn {
  margin-top: 1rem;
  padding: 0.65rem 1.25rem;
  background: white;
  color: var(--kbm-green);
  border: 2px solid var(--kbm-green);
  border-radius: 6px;
  font-family: var(--font);
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
}

.copy-btn:hover {
  background: var(--kbm-green);
  color: white;
}

.back-link {
  display: inline-block;
  color: #52682D;
  text-decoration: none;
  font-weight: 500;
  margin-bottom: 1.5rem;
  padding: 0.5rem 0;
  transition: color 0.2s;
}

.back-link:hover {
  color: #3d4e21;
  text-decoration: underline;
}

.breakdown-toggle {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem 1rem;
  background: white;
  border: 1px solid #d0d5cc;
  border-radius: 6px;
  cursor: pointer;
  font-family: var(--font);
  font-size: 0.95rem;
  color: var(--text-dark);
  margin-top: 1rem;
  transition: all 0.2s;
  width: 100%;
  text-align: left;
}

.breakdown-toggle:hover {
  background: #f9fafb;
  border-color: var(--kbm-green);
}

.breakdown-toggle .icon {
  transition: transform 0.2s;
}

.breakdown-toggle.open .icon {
  transform: rotate(90deg);
}

.breakdown-content {
  display: none;
  margin-top: 0.5rem;
}

.breakdown-content.show {
  display: block;
}

.breakdown-explanation {
  font-size: 0.8rem;
  color: #6b7280;
  margin-bottom: 0.5rem;
  font-style: italic;
}

.breakdown-table-wrapper {
  overflow-x: auto;
  max-height: 300px;
  overflow-y: auto;
  border-radius: 6px;
  border: 1px solid #e5e7eb;
}

.breakdown-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.875rem;
}

.breakdown-table th,
.breakdown-table td {
  padding: 0.5rem 0.75rem;
  text-align: left;
}

.breakdown-table th {
  background: #ffffff;
  font-weight: 600;
  color: #374151;
  font-size: 0.8rem;
  border-bottom: 2px solid var(--kbm-green);
  position: sticky;
  top: 0;
}

.breakdown-table tbody tr:nth-child(odd) {
  background: #ffffff;
}

.breakdown-table tbody tr:nth-child(even) {
  background: #E8F0DC;
}

.breakdown-table .sts-col,
.breakdown-table td:last-child {
  text-align: center;
}

/* Print styles - hide input sections */
@media print {
  .wizard-page {
    padding-top: 0 !important;
    background: white !important;
  }
  
  .page-header,
  .video-button,
  .back-link,
  .toggle-group,
  .input-mode-label,
  .input-mode-toggle,
  .mode-fields,
  .form-grid,
  .section-label,
  .section-divider,
  .floating-input,
  .form-row-2,
  .form-row-3,
  .icon-toggle-group,
  .calculate-btn,
  .results-actions,
  .breakdown-toggle,
  .no-print {
    display: none !important;
  }
  
  .wizard-container {
    box-shadow: none !important;
    padding: 0 !important;
    background: white !important;
    border: none !important;
  }
  
  .results {
    border: none !important;
    box-shadow: none !important;
    padding: 0 !important;
    background: white !important;
  }
  
  .breakdown-content {
    display: block !important;
    max-height: none !important;
  }
  
  .breakdown-table-wrapper {
    max-height: none !important;
    overflow: visible !important;
  }
}

</style>

  <div class="wizard-page">
    <div style="max-width: 800px; margin: 0 auto; padding: 0 1rem;">
      <WizardBackLink category="tool" />
    </div>

  <div class="page-header">
    <div class="page-header-title">
      <h1>Magic Formula – Shaping Calculator</h1>
      
    </div>
  
      <p>
        Calculate shaping from either measurements or stitch counts. Get clear increase or decrease instructions for your knitting.
      </p>
  </div>
  <div class="wizard-container">
    <form id="wizard-form">
      <!-- Unit Toggle - left-aligned, above first input -->
      <UnitToggle id="mfmf" />

      <p class="input-mode-label">How do you want to calculate your shaping?</p>
      <div class="input-mode-toggle" role="group" aria-label="Input mode">
        <button type="button" class="input-mode-btn active" data-mode="stitch" id="inputModeStitch" data-testid="input-mode-stitch">
          I know my stitch counts and rows
        </button>
        <button type="button" class="input-mode-btn" data-mode="measurement" id="inputModeMeasurement" data-testid="input-mode-measurement">
          I know my measurements
        </button>
      </div>

      <div id="shapingOptionsSection" style="display: none;">
        <hr class="section-divider" />
        <div class="section-label">Shaping Options</div>

        <div class="icon-toggle-group">
          <button type="button" class="icon-toggle active" data-value="both" data-testid="button-shape-both">
            <div class="icon-toggle-box">
              <img src="/images/choice-both-sides.svg" alt="Both sides" />
            </div>
            <span class="icon-toggle-label">Both sides</span>
          </button>
          <button type="button" class="icon-toggle" data-value="one" data-testid="button-shape-one">
            <div class="icon-toggle-box">
              <img src="/images/tools/choice-one-side.svg" alt="One side" />
            </div>
            <span class="icon-toggle-label">One side</span>
          </button>
          <div class="icon-toggle slope-indicator" id="slopeIndicator" data-testid="indicator-slope" title="Auto-activates when steep shaping is needed">
            <div class="icon-toggle-box">
              <img src="/images/tools/choice-slope.svg" alt="Slope" />
            </div>
            <span class="icon-toggle-label">Slope</span>
          </div>
        </div>
      </div>

      <GaugeInput id="magicformula" showTitle={false} showToggle={false} />
      <span class="error-text" id="magicformula-gauge-error" style="display: none;">If you enter one gauge, enter both.</span>

      <div id="stitchModeFields" class="mode-fields">
      <div class="form-grid">
        <div class="section-label">Stitch Counts</div>
        
        <div class="form-row-2">
          <div class="floating-input">
            <input 
              type="number" 
              id="startingStitches" 
              min="1"
              step="1" 
              placeholder=" "
              data-testid="input-starting-stitches"
            />
            <label for="startingStitches" id="startingStitchesLabel">Starting stitches</label>
            <span class="error-text" id="startingStitchesError">Please enter a valid number.</span>
          </div>

          <div class="floating-input">
            <input 
              type="number" 
              id="endingStitches" 
              min="0"
              step="1" 
              placeholder=" "
              data-testid="input-ending-stitches"
            />
            <label for="endingStitches" id="endingStitchesLabel">Ending stitches</label>
            <span class="error-text" id="endingStitchesError">Please enter a valid number.</span>
          </div>
        </div>

        <hr class="section-divider" />
        <div class="section-label">Rows</div>

        <div class="form-row-2">
          <div class="floating-input">
            <input 
              type="number" 
              id="totalRows" 
              min="1"
              step="1" 
              placeholder=" "
              data-testid="input-total-rows"
            />
            <label for="totalRows" id="totalRowsLabel">Total rows</label>
            <span class="error-text" id="totalRowsError">Please enter a valid number.</span>
          </div>
        </div>
      </div>
      </div>

      <div id="measurementModeFields" class="mode-fields" style="display: none;">
      <div class="form-grid">
        <div class="section-label">Measurements</div>
        
        <div class="form-row-2">
          <div class="floating-input">
            <input 
              type="number" 
              id="startingWidth" 
              min="0.1"
              step="0.1" 
              placeholder=" "
              data-testid="input-starting-width"
            />
            <label for="startingWidth" id="startingWidthLabel">Starting width (inches)</label>
            <span class="error-text" id="startingWidthError">Please enter a valid width.</span>
          </div>

          <div class="floating-input">
            <input 
              type="number" 
              id="endingWidth" 
              min="0"
              step="0.1" 
              placeholder=" "
              data-testid="input-ending-width"
            />
            <label for="endingWidth" id="endingWidthLabel">Ending width (inches)</label>
            <span class="error-text" id="endingWidthError">Please enter a valid width.</span>
          </div>
        </div>

        <hr class="section-divider" />
        <div class="section-label">Shaping Length</div>

        <div class="form-row-2">
          <div class="floating-input">
            <input 
              type="number" 
              id="shapingLength" 
              min="0.1"
              step="0.1" 
              placeholder=" "
              data-testid="input-shaping-length"
            />
            <label for="shapingLength" id="shapingLengthLabel">Shaping length (inches)</label>
            <span class="error-text" id="shapingLengthError">Please enter a valid length.</span>
          </div>
        </div>
      </div>
      </div>

      <button type="submit" class="calculate-btn" id="calculateBtn" data-testid="button-calculate" style="display: none;">Calculate Shaping</button>
    </form>

    <div id="results" class="results" data-testid="results-section">
      <ActionBar />
      <h2>Your Shaping Instructions</h2>
      <div id="resultsContent" data-testid="results-content"></div>
      
      <button id="breakdownToggle" class="breakdown-toggle" data-testid="button-breakdown-toggle">
        <span class="icon">▶</span> Row-by-row breakdown
      </button>
      <div id="breakdownContent" class="breakdown-content" data-testid="breakdown-content">
        <p class="breakdown-explanation">Stitch counts shown are totals after each shaping action.</p>
        <div class="breakdown-table-wrapper">
          <table class="breakdown-table">
            <thead>
              <tr>
                <th>Row</th>
                <th>Action</th>
                <th>Location</th>
                <th class="sts-col">sts</th>
              </tr>
            </thead>
            <tbody id="breakdownBody"></tbody>
          </table>
        </div>
      </div>
      
      <div class="results-actions" style="display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 1rem;">
        <button id="copyBtn" class="copy-btn" data-testid="button-copy">
          <i class="fas fa-copy"></i> Copy Instructions
        </button>
      </div>
    </div>
  </div>
  <PrintFooter url={pageUrl} />
</div>

<script is:inline src="/js/generateRowByRow.js"></script>
<script is:inline>
  // ========== SHAPING FORMULA CALCULATION HELPER ==========
  
  function calculateShaping(params) {
    const {
      startingSts,
      endingSts,
      totalRows,
      stsGauge,
      rowsGauge,
      units,
      shapingMode
    } = params;
    
    const totalChange = Math.abs(startingSts - endingSts);
    const direction = startingSts > endingSts ? 'decrease' : 'increase';
    
    // No shaping needed
    if (totalChange === 0) {
      return {
        noShaping: true,
        startingSts,
        endingSts,
        totalRows,
        direction: null,
        lengthInUnits: totalRows / rowsGauge,
        units,
        mode: 'standard',
        warnings: []
      };
    }
    
    let changesPerSide;
    let leftSideChanges;
    let rightSideChanges;
    let unevenWarning = false;
    
    if (shapingMode === 'both-sides') {
      if (totalChange % 2 !== 0) {
        // Uneven - distribute as best as possible
        unevenWarning = true;
        leftSideChanges = Math.floor(totalChange / 2);
        rightSideChanges = Math.ceil(totalChange / 2);
        changesPerSide = leftSideChanges; // Use lower for calculation
      } else {
        leftSideChanges = totalChange / 2;
        rightSideChanges = totalChange / 2;
        changesPerSide = totalChange / 2;
      }
    } else {
      // One side only
      changesPerSide = totalChange;
      leftSideChanges = null;
      rightSideChanges = null;
    }
    
    // Determine if we need slope mode:
    // 1. Auto-trigger: when more shaping actions than rows available
    // 2. Manual-trigger: when user forces slope mode
    let mode = 'standard';
    let warnings = [];
    let slopeData = null;
    
    // For asymmetric both-sides, use the larger side count (rightSideChanges) for slope detection
    const primaryCount = shapingMode === 'both-sides' && unevenWarning ? rightSideChanges : changesPerSide;
    const needsAutoSlope = primaryCount > totalRows;
    
    if (needsAutoSlope) {
      // SLOPE MODE: bind off multiple stitches on every other row (shoulder-style)
      mode = 'slope';
      
      // Number of shaping rows (every other row)
      const shapingRows = Math.max(1, Math.floor(totalRows / 2));
      
      // For both-sides mode, use the common portion (min of left/right) for symmetric slope
      // The leftover stitch (if any) will be handled separately on one side
      let stsToDistribute;
      let hasAsymmetricLeftover = false;
      
      if (shapingMode === 'both-sides') {
        // Use the minimum to get symmetric bind-offs, leftover handled separately
        const minSide = Math.min(leftSideChanges, rightSideChanges);
        stsToDistribute = minSide;
        hasAsymmetricLeftover = unevenWarning; // Will have 1 extra stitch on right side
      } else {
        stsToDistribute = changesPerSide;
      }
      
      // Calculate how many stitches to bind off per shaping row
      // Use Shaping Formula: distribute stsToDistribute across shapingRows
      const stsPerAction = Math.floor(stsToDistribute / shapingRows);
      const extraSts = stsToDistribute % shapingRows;
      
      // Some rows will bind off (stsPerAction + 1), others just stsPerAction
      const timesAtMore = extraSts;
      const timesAtBase = shapingRows - extraSts;
      
      slopeData = {
        shapingRows,
        stsPerAction,
        extraSts,
        timesAtMore,
        timesAtBase,
        rowInterval: 2, // Every other row
        hasAsymmetricLeftover, // True if one side needs 1 extra stitch
        leftSideTotal: leftSideChanges,
        rightSideTotal: rightSideChanges
      };
      
      warnings.push(
        "This is a steep change over a short distance. This tool auto-converted to shoulder-style slope shaping: bind off or short row multiple stitches on every other row."
      );
      
      if (hasAsymmetricLeftover) {
        warnings.push(
          "One side requires 1 extra stitch. The right side will have an additional bind-off step."
        );
      }
    }
    
    // For standard mode, calculate spacing as before
    let baseInterval, extraRows, intervalMultiplier, timesAtBase, timesAtLonger;
    
    if (mode === 'standard') {
      // primaryCount already calculated above for slope detection
      baseInterval = Math.floor(totalRows / primaryCount);
      
      // Guard: if baseInterval is 0, we need slope mode (this shouldn't happen if slope detection worked correctly)
      if (baseInterval === 0) {
        // This is a safety fallback - should be caught by needsAutoSlope detection above
        console.warn('baseInterval=0 reached in standard mode - this should have been caught by slope detection');
        baseInterval = 1; // Minimum interval
      }
      
      extraRows = totalRows % primaryCount;
      intervalMultiplier = 1;
      timesAtBase = primaryCount - extraRows;
      timesAtLonger = extraRows;
    } else {
      // Slope mode uses different structure
      baseInterval = 2; // Every other row
      extraRows = 0;
      intervalMultiplier = 1;
      timesAtBase = slopeData.timesAtBase;
      timesAtLonger = slopeData.timesAtMore;
    }
    
    // Build row-by-row breakdown with running stitch totals
    let breakdown = [];
    
    // Generate breakdown steps
    if (mode === 'slope') {
      // SLOPE MODE: bind off multiple stitches every other row
      let currentRow = 0;
      let currentStitches = startingSts;
      const isDecrease = direction === 'decrease';
      const stsMultiplier = shapingMode === 'both-sides' ? 2 : 1; // Double for both sides
      
      // Distribute stitches: some rows bind off more, some less
      for (let i = 0; i < slopeData.shapingRows; i++) {
        currentRow += 2; // Every other row
        const useLarger = i < slopeData.timesAtMore;
        const stsThisRow = useLarger ? (slopeData.stsPerAction + 1) : slopeData.stsPerAction;
        const totalStsChanged = stsThisRow * stsMultiplier;
        
        currentStitches = isDecrease ? currentStitches - totalStsChanged : currentStitches + totalStsChanged;
        
        const actionVerb = isDecrease ? 'Bind off' : 'Cast on';
        const location = shapingMode === 'both-sides' ? `${stsThisRow} sts each side` : `${stsThisRow} sts one side`;
        
        breakdown.push({
          rowNumber: currentRow,
          action: `${actionVerb} ${stsThisRow} ${stsThisRow === 1 ? 'stitch' : 'stitches'}`,
          location: location,
          stitchesAfter: Math.max(0, currentStitches)
        });
      }
      
      // Handle asymmetric leftover: add 1 extra stitch on right side
      // Note: This is included in the last shaping action on the right side only
      // We don't add an extra row - it's handled on the same row as the last symmetric action
      if (slopeData.hasAsymmetricLeftover && shapingMode === 'both-sides') {
        // Update the last breakdown entry to note the asymmetry
        if (breakdown.length > 0) {
          const lastEntry = breakdown[breakdown.length - 1];
          const currentSts = parseInt(lastEntry.action.match(/\d+/)[0]);
          const isDecrease = direction === 'decrease';
          const actionVerb = isDecrease ? 'Bind off' : 'Cast on';
          
          // The right side binds off 1 more stitch on this row
          lastEntry.location = `${currentSts} sts left side, ${currentSts + 1} sts right side`;
          lastEntry.stitchesAfter = isDecrease ? lastEntry.stitchesAfter - 1 : lastEntry.stitchesAfter + 1;
          lastEntry.action = `${actionVerb} ${currentSts}/${currentSts + 1} stitches`;
        }
      }
    } else if (shapingMode === 'both-sides' && unevenWarning) {
      // STANDARD MODE - Asymmetric case: one side has more changes than the other
      // This requires custom logic because the last shaping is on one side only
      let currentRow = 0;
      let currentStitches = startingSts;
      const isDecrease = direction === 'decrease';
      
      for (let i = 0; i < rightSideChanges; i++) {
        const useLonger = i < timesAtLonger;
        const interval = useLonger ? (baseInterval + 1) : baseInterval;
        currentRow += interval;
        
        if (i < leftSideChanges) {
          // This row applies to both sides - 2 stitches changed
          currentStitches = isDecrease ? currentStitches - 2 : currentStitches + 2;
          breakdown.push({
            rowNumber: currentRow,
            action: `${direction === 'decrease' ? 'Decrease' : 'Increase'} 1 stitch`,
            location: 'Both sides',
            stitchesAfter: currentStitches
          });
        } else {
          // This extra row only applies to right side - 1 stitch changed
          currentStitches = isDecrease ? currentStitches - 1 : currentStitches + 1;
          breakdown.push({
            rowNumber: currentRow,
            action: `${direction === 'decrease' ? 'Decrease' : 'Increase'} 1 stitch`,
            location: 'Right side only (extra)',
            stitchesAfter: currentStitches
          });
        }
      }
    } else {
      // STANDARD MODE - Symmetric case or one-side mode: use the reusable utility
      const sideMode = shapingMode === 'both-sides' ? 'both' : 'one';
      
      // Build steps array for the utility (longer intervals first for proper row distribution)
      const breakdownSteps = [];
      if (timesAtLonger > 0) {
        breakdownSteps.push({ sts: 1, rows: baseInterval + 1, times: timesAtLonger });
      }
      if (timesAtBase > 0) {
        breakdownSteps.push({ sts: 1, rows: baseInterval, times: timesAtBase });
      }
      
      // Use the reusable generateRowByRow utility
      breakdown = window.generateRowByRow({
        startingStitches: startingSts,
        steps: breakdownSteps,
        shapingMode: sideMode,
        direction: direction
      });
    }
    
    // Calculate approximate length
    const lengthInUnits = totalRows / rowsGauge;
    
    return {
      noShaping: false,
      error: null,
      startingSts,
      endingSts,
      totalRows,
      totalChange,
      direction,
      shapingMode,
      changesPerSide,
      leftSideChanges,
      rightSideChanges,
      unevenWarning,
      baseInterval,
      extraRows,
      timesAtBase,
      timesAtLonger,
      intervalStep: intervalMultiplier,
      slopeData, // For slope mode: { shapingRows, stsPerAction, extraSts, timesAtMore, timesAtBase }
      breakdown,
      lengthInUnits,
      units,
      mode,
      warnings
    };
  }
  
  // ========== UI LOGIC ==========
  
  const inchesBtn = document.getElementById('mfmf-btn-inches');
  const cmBtn = document.getElementById('mfmf-btn-cm');
  let useCm = false;
