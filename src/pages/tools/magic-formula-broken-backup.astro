  // Render SVG slope diagram - right triangle shape matching slope-choice.svg icon
  // Triangle with hypotenuse from top-left to bottom-right
  // shapingDistance is optional - displayed on the left side of the diagram
  function renderSlopeDiagram(startSts, endSts, mode, direction, steps, shapingDistance = null) {
    // Right triangle matching the slope-choice.svg icon shape:
    // - Top-left corner (narrow end / ending stitches)
    // - Bottom-left corner 
    // - Bottom-right corner (wide end / starting stitches)
