<script is:inline>
// is:inline keeps script as-is without Astro bundling
// Hybrid Blanket Wizard - Pattern Calculator

  
  // ====================
  // DEV TOGGLE + PAID/UNPAID VIEW TOGGLE (ROBUST)
  // ====================

  // Ensure the hide class actually hides things (in case CSS is missing)
  (function ensureHiddenClass() {
    if (document.getElementById('kbm-hidden-class-style')) return;
    const style = document.createElement('style');
    style.id = 'kbm-hidden-class-style';
    style.textContent = `.is-hidden{display:none!important;}`;
    document.head.appendChild(style);
  })();

  // Check if we're in a dev/preview environment (not production)
  function isDevEnvironment() {
    const params = new URLSearchParams(window.location.search);
    const devParam = params.get('dev');
    
    // ?dev=1 ALWAYS forces toggle visible, regardless of environment
    if (devParam === '1') return true;
    
    const hostname = window.location.hostname;
    // Production domains - hide toggle unless ?dev=1
    if (hostname === 'knitbymachine.com' || hostname === 'www.knitbymachine.com') {
      return false;
    }
    // Dev environments: localhost, Netlify deploy previews, branch deploys
    if (hostname === 'localhost' || hostname === '127.0.0.1') return true;
    if (hostname.includes('netlify.app')) return true;  // deploy previews
    if (hostname.includes('.repl.co') || hostname.includes('.replit.dev')) return true;
    // Default to showing in dev
    return true;
  }

  function getIsPaidFromUrl() {
    const params = new URLSearchParams(window.location.search);
    const paidParam = params.get('paid');
    // If no param, default to paid=1 (paid view)
    if (paidParam === null) return true;
    return paidParam === '1';
  }

  function injectDevToggle(isPaid) {
    if (document.getElementById('devToggle')) return; // prevent duplicates
    const basePath = window.location.pathname;
    const toggleHtml = `
      <div class="dev-preview-toggle no-print" id="devToggle" data-testid="dev-preview-toggle">
        <span class="dev-label">DEV</span>
        <span class="mode-label">Preview:</span>
        <a href="${basePath}?dev=1&paid=0" class="${!isPaid ? 'active' : ''}" data-testid="toggle-not-paid">Not Paid</a>
        <a href="${basePath}?dev=1&paid=1" class="${isPaid ? 'active' : ''}" data-testid="toggle-paid">Paid</a>
        <span class="hint">Use ?dev=1 to force this bar.</span>
      </div>
    `;
    // Insert near the top of the page, after the back link if it exists
    const backLink = document.querySelector('.wizard-back-link');
    const patternSlot = document.querySelector('.pattern-slot-wrapper');
    
    if (backLink && backLink.parentNode) {
      backLink.insertAdjacentHTML('afterend', toggleHtml);
    } else if (patternSlot) {
      patternSlot.insertAdjacentHTML('afterbegin', toggleHtml);
    } else {
      // Fallback: prepend to body
      document.body.insertAdjacentHTML('afterbegin', toggleHtml);
    }
    console.log('Dev toggle injected, isPaid:', isPaid);
  }

  function showDevBanner(message) {
    // reuse if already exists
    let banner = document.getElementById('kbmDevBanner');
    if (!banner) {
      banner = document.createElement('div');
      banner.id = 'kbmDevBanner';
      banner.style.cssText =
        'position:fixed;top:0;left:0;right:0;background:#dc2626;color:#fff;padding:10px 12px;text-align:center;z-index:999999;font:700 14px/1.2 system-ui;';
      document.body.prepend(banner);
    }
    banner.textContent = 'DEV ERROR: ' + message;
  }

  function applyPaidView(isPaid) {
    const salesSectionEl = document.getElementById('salesSection');
    const patternWrapperEl = document.getElementById('patternWrapper');

    if (!salesSectionEl) showDevBanner('Missing #salesSection (sales block)');
    if (!patternWrapperEl) showDevBanner('Missing #patternWrapper (pattern block)');

    if (!salesSectionEl || !patternWrapperEl) {
      console.error('Paid view setup failed:', { salesSectionEl, patternWrapperEl });
      return;
    }

    // Paid => pattern visible, sales hidden
    salesSectionEl.classList.toggle('is-hidden', isPaid);
    patternWrapperEl.classList.toggle('is-hidden', !isPaid);
    console.log('View applied:', isPaid ? 'PAID (pattern visible)' : 'UNPAID (sales visible)');
  }

  function setupPaidToggle() {
    const isPaid = getIsPaidFromUrl();

    // Only inject toggle UI in dev environments
    if (isDevEnvironment()) {
      injectDevToggle(isPaid);
    }

    // Apply view on next frame so layout is settled
    requestAnimationFrame(() => applyPaidView(isPaid));
  }

  // Run after DOM is ready (prevents null elements)
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupPaidToggle);
  } else {
    setupPaidToggle();
  }
  
  // ====================
  // BLANKET WIZARD LOGIC
  // ====================
  
  // Blanket size presets
  const blanketSizes = {
    "adult-throw": { name: "Adult Throw", length: 78, width: 48 },
    "bassinet": { name: "Bassinet", length: 36, width: 16 },
    "child": { name: "Child", length: 48, width: 42 },
    "cradle": { name: "Cradle", length: 36, width: 20 },
    "crib": { name: "Crib", length: 54, width: 30 },
    "large-preemie": { name: "Large Preemie", length: 36, width: 36 },
    "small-preemie": { name: "Small Preemie", length: 24, width: 24 },
    "standard-throw": { name: "Standard Throw", length: 60, width: 48 },
    "toddler": { name: "Toddler or Lapghan", length: 48, width: 36 }
  };

  // Default sample values for "viewer mode"
  // Using Large Preemie: 36" x 36", 16 sts x 24 rows per 4"
  const sampleDefaults = {
    size: 'large-preemie',
    handGauge: 16,
    machineGauge: 16,
    borderRowGauge: 24,
    bodyRowGauge: 24,
    borderDepth: 3,
    edgeStitches: 6
  };

  // In-memory state object - source of truth for calculations
  // This allows calculations to work even if DOM inputs don't exist
  let currentInputs = {
    handGauge: sampleDefaults.handGauge,
    machineGauge: sampleDefaults.machineGauge,
    borderRowGauge: sampleDefaults.borderRowGauge,
    bodyRowGauge: sampleDefaults.bodyRowGauge,
    borderDepth: sampleDefaults.borderDepth,
    edgeStitches: sampleDefaults.edgeStitches
  };

  let units = 'inches';
  let selectedSize = 'large-preemie';
  let isViewerMode = true;
  
  // DOM Elements
  const glassOverlay = document.getElementById('glass-overlay');
  const customizeBtn = document.getElementById('customize-btn');
  const settingsDrawer = document.getElementById('settings-drawer');
  const drawerCloseBtn = document.getElementById('drawer-close-btn');
  const actionBarWrapper = document.getElementById('action-bar-wrapper');
  const actionBar = document.getElementById('action-bar');
  const actionBarTopbar = document.getElementById('action-bar-topbar');
  const editBtn = document.getElementById('edit-btn');
  const customizeBtn = document.getElementById('customize-btn');
  
  // Track if user has built a pattern (so we don't trap them in viewer mode)
  let hasBuiltPattern = false;
  
  const btnInches = document.getElementById('btn-inches');
  const btnCm = document.getElementById('btn-cm');
  const sizeTilesContainer = document.getElementById('size-tiles');
  const sizeSelectDropdown = document.getElementById('hb-size-select');
  const customSizeRow = document.getElementById('custom-size-row');
  const selectedSizeNameEl = document.getElementById('selected-size-name');
  const selectedSizeDimsEl = document.getElementById('selected-size-dims');
  
  const inputCustomWidth = document.getElementById('custom-width');
  const inputCustomLength = document.getElementById('custom-length');
  const inputHandGauge = document.getElementById('hand-gauge');
  const inputMachineGauge = document.getElementById('machine-gauge');
  const inputBorderRowGauge = document.getElementById('border-row-gauge');
  const inputBodyRowGauge = document.getElementById('body-row-gauge');
  const inputBorderDepth = document.getElementById('border-depth');
  const inputEdgeStitches = document.getElementById('edge-stitches');
  const inputNeedlesAvailable = document.getElementById('needles-available');
  
  const gaugeUnitLabel = document.getElementById('gauge-unit-label');
  const machineGaugeUnitLabel = document.getElementById('machine-gauge-unit-label');
  const rowGaugeWarning = document.getElementById('row-gauge-warning');
  
  const summaryHandSts = document.getElementById('summary-hand-sts');
  const summaryMachineSts = document.getElementById('summary-machine-sts');
  const summaryDelta = document.getElementById('summary-delta');
  const patternStepsContainer = document.getElementById('kbm-pattern-steps');
  const inputsSummary = document.getElementById('inputs-summary');
  
  const widthValidation = document.getElementById('width-validation');
  const lengthValidation = document.getElementById('length-validation');
  const handGaugeValidation = document.getElementById('hand-gauge-validation');
  const machineGaugeValidation = document.getElementById('machine-gauge-validation');
  const borderRowGaugeValidation = document.getElementById('border-row-gauge-validation');
  const bodyRowGaugeValidation = document.getElementById('body-row-gauge-validation');
  const borderDepthValidation = document.getElementById('border-depth-validation');
  const needlesValidation = document.getElementById('needles-validation');
  
  // Needle warning elements
  const needleWarning = document.getElementById('needle-warning');
  const needleWarningTitle = document.getElementById('needle-warning-title');
  const needleWarningBody = document.getElementById('needle-warning-body');
  const stitchCountsSection = document.querySelector('.stitch-counts-section');
  const instructionsWrapper = document.querySelector('.instructions-wrapper');
  const whyNote = document.querySelector('.why-note');
  
  // Blanket Size attention elements
  const blanketSizeSection = document.getElementById('hb-blanket-size');
  const customSizeTile = document.getElementById('hb-size-custom');
  const sizeFixHelper = document.getElementById('size-fix-helper');
  
  // Hidden needle count spans
  const needlesBorderSpan = document.getElementById('hb-needles-border');
  const needlesBodySpan = document.getElementById('hb-needles-body');
  const needlesRequiredSpan = document.getElementById('hb-needles-required');
  const needlesAvailableSpan = document.getElementById('hb-needles-available');
  
  // Needle persistence key
  const NEEDLES_STORAGE_KEY = 'kbm:hybridBlanket:needlesAvailable';
  
  // Submit-style validation: only check on "Build My Pattern" click
  // No warnings shown during editing/preview
  let buildAttempted = false;
  
  const printBtn = document.getElementById('print-btn');
  const startOverBtn = document.getElementById('start-over-btn');
  const applyBtn = document.getElementById('apply-btn');

  // Initialize with sample defaults
  // Uses in-memory state as source of truth, syncs to DOM inputs when they exist
  function loadSampleDefaults() {
    // 1. Set in-memory state (source of truth - always works)
    currentInputs = {
      handGauge: sampleDefaults.handGauge,
      machineGauge: sampleDefaults.machineGauge,
      borderRowGauge: sampleDefaults.borderRowGauge,
      bodyRowGauge: sampleDefaults.bodyRowGauge,
      borderDepth: sampleDefaults.borderDepth,
      edgeStitches: sampleDefaults.edgeStitches
    };
    
    // 2. Sync to DOM inputs if they exist (optional - for when drawer is open)
    if (inputHandGauge) inputHandGauge.value = currentInputs.handGauge;
    if (inputMachineGauge) inputMachineGauge.value = currentInputs.machineGauge;
    if (inputBorderRowGauge) inputBorderRowGauge.value = currentInputs.borderRowGauge;
    if (inputBodyRowGauge) inputBodyRowGauge.value = currentInputs.bodyRowGauge;
    if (inputBorderDepth) inputBorderDepth.value = currentInputs.borderDepth;
    if (inputEdgeStitches) inputEdgeStitches.value = currentInputs.edgeStitches;
    
    // 3. Set size and recalculate
    selectedSize = sampleDefaults.size;
    updateTileSelection();
    calculate();
  }
  
  // Sync DOM input values to in-memory state (called when user changes inputs)
  function syncInputsToState() {
    if (inputHandGauge) currentInputs.handGauge = parseFloat(inputHandGauge.value) || currentInputs.handGauge;
    if (inputMachineGauge) currentInputs.machineGauge = parseFloat(inputMachineGauge.value) || currentInputs.machineGauge;
    if (inputBorderRowGauge) currentInputs.borderRowGauge = parseFloat(inputBorderRowGauge.value) || currentInputs.borderRowGauge;
    if (inputBodyRowGauge) currentInputs.bodyRowGauge = parseFloat(inputBodyRowGauge.value) || currentInputs.bodyRowGauge;
    if (inputBorderDepth) currentInputs.borderDepth = parseFloat(inputBorderDepth.value) || currentInputs.borderDepth;
    if (inputEdgeStitches) currentInputs.edgeStitches = parseInt(inputEdgeStitches.value) || currentInputs.edgeStitches;
  }

  // Mode switching
  function enterDesignerMode() {
    if (!settingsDrawer) {
      console.error('DRAWER ERROR: settingsDrawer not found!');
      return;
    }
    isViewerMode = false;
    if (glassOverlay) glassOverlay.classList.add('hidden');
    if (actionBarWrapper) actionBarWrapper.classList.remove('viewer-mode');
    settingsDrawer.showModal();
  }

  function exitDesignerMode() {
    if (settingsDrawer) settingsDrawer.close();
    // Apply view state based on whether user has built a pattern
    applyViewState();
  }
  
  // Centralized function to apply view state based on hasBuiltPattern
  function applyViewState() {
    if (hasBuiltPattern) {
      // User has built a pattern - show action bar, hide overlay
      if (glassOverlay) glassOverlay.classList.add('hidden');
      if (actionBar) actionBar.classList.add('is-active');
      if (actionBarTopbar) actionBarTopbar.classList.add('is-active');
      if (printBtn) printBtn.classList.add('is-active');
      if (actionBarWrapper) actionBarWrapper.classList.remove('viewer-mode');
      isViewerMode = false;
    } else {
      // Preview mode - show overlay, hide action bar
      if (glassOverlay) glassOverlay.classList.remove('hidden');
      if (actionBar) actionBar.classList.remove('is-active');
      if (actionBarTopbar) actionBarTopbar.classList.remove('is-active');
      if (printBtn) printBtn.classList.remove('is-active');
      if (actionBarWrapper) actionBarWrapper.classList.add('viewer-mode');
      isViewerMode = true;
    }
  }

  // ====================
  // CRITICAL: CUSTOMIZE BUTTON + DRAWER - FAIL LOUDLY
  // ====================
  if (!customizeBtn) {
    console.error('CRITICAL: customizeBtn (#customize-btn) not found!');
    showDevBanner('customizeBtn (#customize-btn) not found!');
  } else if (!settingsDrawer) {
    console.error('CRITICAL: settingsDrawer (#settings-drawer) not found!');
    showDevBanner('settingsDrawer (#settings-drawer) not found!');
  } else {
    customizeBtn.addEventListener('click', function(e) {
      enterDesignerMode();
    });
  }
  
  if (drawerCloseBtn) {
    drawerCloseBtn.addEventListener('click', exitDesignerMode);
  }
  
  // Apply button - builds pattern with submit-style validation
  if (applyBtn) {
    applyBtn.addEventListener('click', () => {
      console.log('Build clicked - validating needle fit');
      buildAttempted = true;
      
      // Sync inputs and calculate to get current values
      syncInputsToState();
      
      // Get needle counts for validation
      const availableNeedles = parseInt(inputNeedlesAvailable?.value || '0', 10);
      const requiredBorderNeedles = parseInt(needlesBorderSpan?.getAttribute('data-value') || '0', 10);
      const requiredBodyNeedles = parseInt(needlesBodySpan?.getAttribute('data-value') || '0', 10);
      const requiredNeedles = Math.max(requiredBorderNeedles, requiredBodyNeedles);
      
      const needlesMissing = isNaN(availableNeedles) || availableNeedles <= 0;
      const needlesExceeded = !needlesMissing && requiredNeedles > availableNeedles;
      
      // Case A: Needles missing/invalid
      if (needlesMissing) {
        showBuildBlockedWarning('missing', 0, 0, 0);
        scrollToNeedleInput();
        return; // Block build
      }
      
      // Case B: Won't fit
      if (needlesExceeded) {
        showBuildBlockedWarning('exceeded', requiredBorderNeedles, requiredBodyNeedles, availableNeedles);
        scrollToSizeAndPulse();
        return; // Block build
      }
      
      // Case C: Fits - proceed with build
      hideBuildBlockedWarning();
      calculate();
      
      // Mark that user has built a pattern
      hasBuiltPattern = true;
      
      // Close drawer (which will call applyViewState)
      if (settingsDrawer) settingsDrawer.close();
      applyViewState();
    });
  }
  
  // Edit/Rebuild button - opens drawer to edit settings
  if (editBtn) {
    editBtn.addEventListener('click', () => {
      console.log('Edit/Rebuild clicked - opening drawer');
      isViewerMode = false;
      if (settingsDrawer) settingsDrawer.showModal();
    });
  }
  
  if (settingsDrawer) {
    // Prevent native Escape key close behavior - we handle it explicitly
    settingsDrawer.addEventListener('cancel', (e) => {
      console.log('Dialog cancel event fired - preventing default');
      e.preventDefault();
    });
    
    // Explicitly handle Escape key to close drawer
    settingsDrawer.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        e.preventDefault();
        exitDesignerMode();
      }
    });
    
    // Log close events to debug unexpected closes
    settingsDrawer.addEventListener('close', () => {
      console.log('Dialog close event fired - stack trace:', new Error().stack);
    });
    
    // Backdrop click detection: close if click is on dialog element itself (the backdrop)
    // but not on any child elements (the actual drawer content)
    settingsDrawer.addEventListener('click', (e) => {
      // Only close if clicking directly on the dialog backdrop, not on content
      if (e.target === settingsDrawer) {
        console.log('Backdrop click detected - closing drawer');
        exitDesignerMode();
      }
    });
  }

  // Size tile selection
  function updateTileSelection() {
    document.querySelectorAll('.size-tile').forEach(tile => {
      const tileSize = tile.dataset.size;
      tile.classList.toggle('is-active', tileSize === selectedSize);
    });
    
    // Sync mobile dropdown
    if (sizeSelectDropdown) {
      sizeSelectDropdown.value = selectedSize;
    }
    
    // Show/hide custom size inputs
    customSizeRow.classList.toggle('hidden', selectedSize !== 'custom');
    
    // Update selected size bar display
    updateSelectedSizeBar();
  }

  // Update the "Selected: Name — W × L" bar below the grid
  function updateSelectedSizeBar() {
    if (!selectedSizeNameEl || !selectedSizeDimsEl) return;
    
    const unitLabel = units === 'cm' ? 'cm' : '"';
    
    if (selectedSize === 'custom') {
      // Custom size
      selectedSizeNameEl.textContent = 'Custom';
      const customW = parseFloat(inputCustomWidth.value) || 0;
      const customL = parseFloat(inputCustomLength.value) || 0;
      
      if (customW > 0 && customL > 0) {
        selectedSizeDimsEl.textContent = `— ${customW} × ${customL}${unitLabel}`;
      } else {
        selectedSizeDimsEl.textContent = '— enter your size below';
      }
    } else {
      // Preset size
      const size = blanketSizes[selectedSize];
      if (size) {
        // Find display name from tile
        const tile = document.querySelector(`.size-tile[data-size="${selectedSize}"]`);
        const nameEl = tile?.querySelector('.size-name');
        const displayName = nameEl?.textContent || selectedSize;
        
        selectedSizeNameEl.textContent = displayName;
        
        if (units === 'cm') {
          const w = Math.round(size.width * 2.54);
          const l = Math.round(size.length * 2.54);
          selectedSizeDimsEl.textContent = `— ${w} × ${l} cm`;
        } else {
          selectedSizeDimsEl.textContent = `— ${size.width} × ${size.length}"`;
        }
      }
    }
  }

  // Update all tile dimensions display based on units
  function updateTileDimensions() {
    document.querySelectorAll('.size-tile').forEach(tile => {
      const sizeKey = tile.dataset.size;
      if (sizeKey === 'custom') {
        // Update custom tile dimensions if values are set
        const customDimsEl = tile.querySelector('.size-dims');
        if (customDimsEl) {
          const w = parseFloat(inputCustomWidth.value);
          const h = parseFloat(inputCustomLength.value);
          if (w && h) {
            const unitSymbol = units === 'cm' ? ' cm' : '"';
            customDimsEl.textContent = `${w} × ${h}${unitSymbol}`;
          } else {
            customDimsEl.textContent = 'Set below';
          }
        }
        return;
      }
      
      const size = blanketSizes[sizeKey];
      if (!size) return;
      
      const dimsEl = tile.querySelector('.size-dims');
      if (!dimsEl) return;
      
      if (units === 'cm') {
        const w = Math.round(size.width * 2.54);
        const l = Math.round(size.length * 2.54);
        dimsEl.textContent = `${w} × ${l} cm`;
      } else {
        dimsEl.textContent = `${size.width} × ${size.length}"`;
      }
    });
  }

  // Update mobile dropdown option labels when units change
  function updateSelectOptions() {
    if (!sizeSelectDropdown) return;
    
    const unitSymbol = units === 'cm' ? ' cm' : '"';
    
    Array.from(sizeSelectDropdown.options).forEach(option => {
      const key = option.value;
      if (key === 'custom') {
        option.textContent = 'Custom Measurements';
        return;
      }
      
      const size = blanketSizes[key];
      if (!size) return;
      
      let w, l;
      if (units === 'cm') {
        w = Math.round(size.width * 2.54);
        l = Math.round(size.length * 2.54);
      } else {
        w = size.width;
        l = size.length;
      }
      
      option.textContent = `${size.name} — ${w} × ${l}${unitSymbol}`;
    });
  }

  sizeTilesContainer.addEventListener('click', (e) => {
    const tile = e.target.closest('.size-tile');
    if (!tile) return;
    
    selectedSize = tile.dataset.size;
    updateTileSelection();
    
    // If selecting a preset, clear custom inputs
    if (selectedSize !== 'custom') {
      inputCustomWidth.value = '';
      inputCustomLength.value = '';
    }
    
    calculate();
  });

  // Mobile dropdown change handler - uses same selection logic as tile clicks
  sizeSelectDropdown?.addEventListener('change', (e) => {
    selectedSize = e.target.value;
    updateTileSelection();
    
    // If selecting a preset, clear custom inputs
    if (selectedSize !== 'custom') {
      inputCustomWidth.value = '';
      inputCustomLength.value = '';
    }
    
    calculate();
  });

  // Check if custom values match any preset
  function checkForPresetMatch() {
    if (selectedSize !== 'custom') return;
    
    const customW = parseFloat(inputCustomWidth.value) || 0;
    const customL = parseFloat(inputCustomLength.value) || 0;
    
    // Convert to inches if in cm mode
    let widthInches = customW;
    let lengthInches = customL;
    if (units === 'cm') {
      widthInches = customW / 2.54;
      lengthInches = customL / 2.54;
    }
    
    // Check against presets
    for (const [key, size] of Object.entries(blanketSizes)) {
      if (Math.abs(size.width - widthInches) < 0.5 && Math.abs(size.length - lengthInches) < 0.5) {
        selectedSize = key;
        updateTileSelection();
        return;
      }
    }
  }

  // Unit toggle
  btnInches.addEventListener('click', () => {
    units = 'inches';
    btnInches.classList.add('active');
    btnCm.classList.remove('active');
    updateGaugeLabels();
    updateTileDimensions();
    updateSelectOptions();
    updateSelectedSizeBar();
    updatePlaceholders();
    calculate();
  });

  btnCm.addEventListener('click', () => {
    units = 'cm';
    btnCm.classList.add('active');
    btnInches.classList.remove('active');
    updateGaugeLabels();
    updateTileDimensions();
    updateSelectOptions();
    updateSelectedSizeBar();
    updatePlaceholders();
    calculate();
  });

  function updateGaugeLabels() {
    if (units === 'cm') {
      gaugeUnitLabel.textContent = '(over 10 cm)';
      machineGaugeUnitLabel.textContent = '(over 10 cm)';
    } else {
      gaugeUnitLabel.textContent = '(over 4")';
      machineGaugeUnitLabel.textContent = '(over 4")';
    }
  }

  function updatePlaceholders() {
    const unitText = units === 'inches' ? 'in' : 'cm';
    inputCustomWidth.placeholder = `Width (${unitText})`;
    inputCustomLength.placeholder = `Length (${unitText})`;
    inputBorderDepth.placeholder = `Depth (${unitText})`;
  }

  function getCurrentDimensions() {
    if (selectedSize === 'custom') {
      let width = parseFloat(inputCustomWidth.value) || 0;
      let length = parseFloat(inputCustomLength.value) || 0;
      if (units === 'cm') {
        width = width / 2.54;
        length = length / 2.54;
      }
      return { width, length, name: 'Custom Size' };
    } else if (selectedSize && blanketSizes[selectedSize]) {
      const data = blanketSizes[selectedSize];
      return { width: data.width, length: data.length, name: data.name };
    }
    return null;
  }

  function validatePositive(input, validationEl) {
    if (!input || !validationEl) return { valid: false, hasValue: false };
    const value = parseFloat(input.value);
    if (input.value === '' || isNaN(value)) {
      validationEl.innerHTML = '';
      input.classList.remove('error');
      return { valid: false, hasValue: false };
    }
    if (value <= 0) {
      validationEl.innerHTML = '<span class="error">Must be > 0</span>';
      input.classList.add('error');
      return { valid: false, hasValue: true };
    }
    validationEl.innerHTML = '';
    input.classList.remove('error');
    return { valid: true, hasValue: true, value: value };
  }

  function calculate() {
    const dimensions = getCurrentDimensions();
    const widthVal = dimensions ? dimensions.width : 48;
    const lengthVal = dimensions ? dimensions.length : 60;
    const sizeName = dimensions ? dimensions.name : 'Standard Throw';
    
    // Use in-memory state as source of truth (synced from inputs when they exist)
    const edgeStitches = currentInputs.edgeStitches;
    
    let customWidthValid = true;
    let customLengthValid = true;
    
    if (selectedSize === 'custom') {
      if (inputCustomWidth && inputCustomLength) {
        const widthResult = validatePositive(inputCustomWidth, widthValidation);
        const lengthResult = validatePositive(inputCustomLength, lengthValidation);
        customWidthValid = widthResult.valid;
        customLengthValid = lengthResult.valid;
      }
    }
    
    // Validate inputs if they exist, otherwise use in-memory state
    let handGaugeVal = currentInputs.handGauge;
    let machineGaugeVal = currentInputs.machineGauge;
    let borderRowGaugeVal = currentInputs.borderRowGauge;
    let bodyRowGaugeVal = currentInputs.bodyRowGauge;
    let borderDepth = currentInputs.borderDepth;
    
    if (inputHandGauge) {
      const handResult = validatePositive(inputHandGauge, handGaugeValidation);
      handGaugeVal = handResult.valid ? handResult.value : currentInputs.handGauge;
    }
    if (inputMachineGauge) {
      const machineResult = validatePositive(inputMachineGauge, machineGaugeValidation);
      machineGaugeVal = machineResult.valid ? machineResult.value : currentInputs.machineGauge;
    }
    if (inputBorderRowGauge) {
      const borderRowResult = validatePositive(inputBorderRowGauge, borderRowGaugeValidation);
      borderRowGaugeVal = borderRowResult.valid ? borderRowResult.value : currentInputs.borderRowGauge;
    }
    if (inputBodyRowGauge) {
      const bodyRowResult = validatePositive(inputBodyRowGauge, bodyRowGaugeValidation);
      bodyRowGaugeVal = bodyRowResult.valid ? bodyRowResult.value : currentInputs.bodyRowGauge;
    }
    if (inputBorderDepth) {
      const borderDepthResult = validatePositive(inputBorderDepth, borderDepthValidation);
      borderDepth = borderDepthResult.valid ? borderDepthResult.value : currentInputs.borderDepth;
    }
    
    // Stitch gauge warning is computed later after handSts/machineSts are calculated
    
    // With in-memory state, these are always valid unless explicitly null
    const gaugesValid = handGaugeVal > 0 && machineGaugeVal > 0 && borderRowGaugeVal > 0 && bodyRowGaugeVal > 0;
    const hasSizeSelection = selectedSize && (selectedSize !== 'custom' || (customWidthValid && customLengthValid));
    
    const gaugeDisplayUnit = units === 'inches' ? 'over 4"' : 'over 10 cm';
    const dimensionUnit = units === 'inches' ? '"' : 'cm';
    const displayWidth = units === 'inches' ? widthVal : Math.round(widthVal * 2.54 * 10) / 10;
    const displayLength = units === 'inches' ? lengthVal : Math.round(lengthVal * 2.54 * 10) / 10;
    
    const borderGaugeDisplay = (handGaugeVal !== null && borderRowGaugeVal !== null) 
      ? `${handGaugeVal} sts / ${borderRowGaugeVal} rows ${gaugeDisplayUnit}` 
      : '—';
    const bodyGaugeDisplay = (machineGaugeVal !== null && bodyRowGaugeVal !== null)
      ? `${machineGaugeVal} sts / ${bodyRowGaugeVal} rows ${gaugeDisplayUnit}`
      : '—';
    
    inputsSummary.innerHTML = `
      <p><strong>Size:</strong> ${sizeName} (${displayWidth}${dimensionUnit} × ${displayLength}${dimensionUnit})</p>
      <p><strong>Border gauge:</strong> ${borderGaugeDisplay}</p>
      <p><strong>Body gauge:</strong> ${bodyGaugeDisplay}</p>
    `;
    
    const gaugeSampleInches = units === 'inches' ? 4 : (10 / 2.54);
    const borderRowsPerInch = borderRowGaugeVal ? borderRowGaugeVal / gaugeSampleInches : null;
    
    let borderDepthInches = borderDepth;
    if (units === 'cm' && borderDepthInches) {
      borderDepthInches = borderDepthInches / 2.54;
    }
    
    const borderRows = (borderRowsPerInch && borderDepthInches) ? Math.round((borderDepthInches * borderRowsPerInch) / 2) * 2 : null;
    
    const borderDisplay = borderRows !== null 
      ? `${borderDepth}${dimensionUnit} (${borderRows} rows)` 
      : (borderDepth !== null ? `${borderDepth}${dimensionUnit}` : 'your desired depth');
    
    const bodyRowsPerInch = bodyRowGaugeVal ? bodyRowGaugeVal / gaugeSampleInches : null;
    let bodyLengthInches = lengthVal;
    if (borderDepthInches) {
      bodyLengthInches = lengthVal - (2 * borderDepthInches);
    }
    const bodyRows = (bodyRowsPerInch && bodyLengthInches > 0) ? Math.round(bodyLengthInches * bodyRowsPerInch) : null;
    const bodyLengthDisplay = units === 'inches' ? Math.round(bodyLengthInches * 10) / 10 : Math.round(bodyLengthInches * 2.54 * 10) / 10;
    
    const hasAllInputs = gaugesValid && hasSizeSelection && borderDepth !== null;
    
    if (!hasAllInputs) {
      summaryHandSts.innerHTML = '&mdash;';
      summaryMachineSts.innerHTML = '&mdash;';
      summaryDelta.innerHTML = '&mdash;';
      renderInstructionsPlaceholder(displayWidth, dimensionUnit, displayLength, borderDisplay, edgeStitches);
      // Hide needle warning when pattern is incomplete (no stitch counts to validate)
      if (needleWarning) needleWarning.hidden = true;
      // Show all result sections (placeholder content)
      if (stitchCountsSection) stitchCountsSection.style.display = '';
      if (instructionsWrapper) instructionsWrapper.style.display = '';
      if (whyNote) whyNote.style.display = '';
      // Note: Print stays in its current state (managed by view mode, not needle validation)
      // Still update dimension outputs for Yarn tab even with incomplete pattern
      updateDimensionOutputs(widthVal, lengthVal);
      return;
    }
    
    const handStsPerInch = handGaugeVal / gaugeSampleInches;
    const machineStsPerInch = machineGaugeVal / gaugeSampleInches;

    const handSts = Math.round(widthVal * handStsPerInch);
    const machineSts = Math.round(widthVal * machineStsPerInch);
    const delta = machineSts - handSts;
    
    // DEV check: calculations should produce valid positive integers
    if (handSts <= 0 || machineSts <= 0 || !Number.isFinite(handSts) || !Number.isFinite(machineSts)) {
      showDevBanner(`Invalid calculation: handSts=${handSts}, machineSts=${machineSts}`);
    }
    const absDelta = Math.abs(delta);

    summaryHandSts.textContent = handSts + ' sts';
    summaryMachineSts.textContent = machineSts + ' sts';
    summaryDelta.textContent = (delta >= 0 ? '+' : '') + delta;
    
    // Stitch gauge warning (uses handSts & machineSts)
    if (rowGaugeWarning && Number.isFinite(handSts) && Number.isFinite(machineSts) && handSts > 0 && machineSts > 0) {
      const avgStitchGauge = (handSts + machineSts) / 2;
      const percentDiff = Math.abs(handSts - machineSts) / avgStitchGauge;
      rowGaugeWarning.style.display = percentDiff >= 0.20 ? 'flex' : 'none';
    } else if (rowGaugeWarning) {
      rowGaugeWarning.style.display = 'none';
    }
    
    // ===== NEEDLE COUNT VALIDATION =====
    // Border stitches = handSts (cast on for border)
    // Body stitches = machineSts (cast on for body section)
    const requiredBorderNeedles = handSts;
    const requiredBodyNeedles = machineSts;
    const requiredNeedles = Math.max(requiredBorderNeedles, requiredBodyNeedles);
    
    // Get available needles from input (try localStorage if input empty)
    let availableNeedles = 0;
    if (inputNeedlesAvailable) {
      const inputVal = parseInt(inputNeedlesAvailable.value, 10);
      if (!isNaN(inputVal) && inputVal > 0) {
        availableNeedles = inputVal;
      }
    }
    
    // Update hidden needle spans
    if (needlesBorderSpan) needlesBorderSpan.setAttribute('data-value', requiredBorderNeedles.toString());
    if (needlesBodySpan) needlesBodySpan.setAttribute('data-value', requiredBodyNeedles.toString());
    if (needlesRequiredSpan) needlesRequiredSpan.setAttribute('data-value', requiredNeedles.toString());
    if (needlesAvailableSpan) needlesAvailableSpan.setAttribute('data-value', availableNeedles.toString());
    
    // Submit-style validation: calculate() always shows results during editing
    // Blocking only happens on "Build My Pattern" click - handled in applyBtn listener
    // ===== END NEEDLE COUNT VALIDATION =====

    const edgeDisplay = edgeStitches === 6 ? '5–7' : edgeStitches.toString();
    
    let spacingToMachine = 0;
    let spacingToHand = 0;
    
    if (absDelta > 0) {
      spacingToMachine = Math.max(1, Math.floor(Math.min(handSts, machineSts) / absDelta));
      spacingToHand = Math.max(1, Math.floor(Math.min(handSts, machineSts) / absDelta));
    }

    const instructions = [];

    instructions.push({ type: 'phase', text: 'Section 1: Foundation & First Border' });
    instructions.push({ type: 'step', text: `Your blanket size: <span class="calculated-value">${displayWidth}${dimensionUnit}</span> wide × <span class="calculated-value">${displayLength}${dimensionUnit}</span> long.` });
    instructions.push({ type: 'step', text: `Cast on <span class="calculated-value">${handSts} sts</span> and knit in border pattern for <span class="calculated-value">${borderDisplay}</span>.` });

    instructions.push({ type: 'phase', text: 'Section 2: The Transition' });
    if (delta > 0) {
      instructions.push({ type: 'step', text: `Transfer stitches to the machine or change stitch pattern. Increase <span class="calculated-value">${absDelta} sts</span> evenly across the row (about every <span class="calculated-value">${spacingToMachine} sts</span>) to reach <span class="calculated-value">${machineSts} sts</span>.` });
    } else if (delta < 0) {
      instructions.push({ type: 'step', text: `Transfer stitches to the machine or change stitch pattern. Decrease <span class="calculated-value">${absDelta} sts</span> evenly across the row (about every <span class="calculated-value">${spacingToMachine} sts</span>) to reach <span class="calculated-value">${machineSts} sts</span>.` });
    } else {
      instructions.push({ type: 'step', text: `Transfer stitches to the machine or change stitch pattern. No stitch adjustment needed—gauges match.` });
    }

    instructions.push({ type: 'phase', text: 'Section 3: The Blanket Body' });
    const bodyLengthNote = bodyRows !== null 
      ? `<span class="calculated-value">${bodyLengthDisplay}${dimensionUnit}</span> (~<span class="calculated-value">${bodyRows} rows</span>)`
      : 'desired length';
    instructions.push({ type: 'step', text: `Knit the blanket body for ${bodyLengthNote}.<span class="step-aside"><span class="step-aside__label"><br>AT THE SAME TIME:</span> Hand-manipulate <span class="calculated-value">${edgeDisplay}</span> stitch border pattern along each edge as you knit.</span>` });

    instructions.push({ type: 'phase', text: 'Section 4: Finishing' });
    if (delta > 0) {
      instructions.push({ type: 'step', text: `Move stitches to a hand needle or change stitch pattern. Decrease <span class="calculated-value">${absDelta} sts</span> evenly across the row (about every <span class="calculated-value">${spacingToHand} sts</span>) to return to <span class="calculated-value">${handSts} sts</span>.` });
    } else if (delta < 0) {
      instructions.push({ type: 'step', text: `Move stitches to a hand needle or change stitch pattern. Increase <span class="calculated-value">${absDelta} sts</span> evenly across the row (about every <span class="calculated-value">${spacingToHand} sts</span>) to return to <span class="calculated-value">${handSts} sts</span>.` });
    } else {
      instructions.push({ type: 'step', text: `Move stitches to a hand needle or change stitch pattern.` });
    }
    instructions.push({ type: 'step', text: `Knit in border pattern for <span class="calculated-value">${borderDisplay}</span>. <br>Bind off.` });

    renderPatternStepsSections(instructions);
    
    // Update hidden spans for Yarn tab and dispatch event
    updateDimensionOutputs(widthVal, lengthVal);
  }
  
  // Update hidden dimension spans and dispatch event for Yarn calculator
  function updateDimensionOutputs(widthIn, lengthIn) {
    const widthSpan = document.getElementById('hb-finished-width-in');
    const lengthSpan = document.getElementById('hb-finished-length-in');
    
    if (widthSpan) widthSpan.setAttribute('data-value', widthIn.toString());
    if (lengthSpan) lengthSpan.setAttribute('data-value', lengthIn.toString());
    
    window.dispatchEvent(new CustomEvent('kbm:hybridBlanket:dimensions', {
      detail: { widthIn, lengthIn }
    }));
  }
  
  // Show build-blocked warning (submit-style validation)
  // type: 'missing' or 'exceeded'
  function showBuildBlockedWarning(type, borderNeedles, bodyNeedles, availableNeedles) {
    if (!needleWarning || !needleWarningBody) return;
    
    needleWarning.hidden = false;
    
    if (type === 'missing') {
      // Case A: Needle count not entered
      if (needleWarningTitle) needleWarningTitle.textContent = 'Before you build';
      needleWarningBody.innerHTML = `
        <p>Enter your machine's needle count to confirm this size will fit.</p>
        <a class="go-to-size-link" id="go-to-needles-link">Go to Needle Count</a>
      `;
      // Remove size attention styling (not relevant for missing needles)
      if (blanketSizeSection) blanketSizeSection.classList.remove('needs-attention');
      if (customSizeTile) customSizeTile.classList.remove('recommended');
      if (sizeFixHelper) sizeFixHelper.classList.remove('visible');
      
      // Attach scroll handler
      const goToNeedlesLink = document.getElementById('go-to-needles-link');
      if (goToNeedlesLink) {
        goToNeedlesLink.addEventListener('click', scrollToNeedleInput);
      }
    } else {
      // Case B: Won't fit
      if (needleWarningTitle) needleWarningTitle.textContent = "Stop — this size won't fit your machine";
      needleWarningBody.innerHTML = `
        <div class="needle-counts">
          <p>Border needs <strong>${borderNeedles}</strong> needles.</p>
          <p>Body needs <strong>${bodyNeedles}</strong> needles.</p>
          <p>Your machine: <strong>${availableNeedles}</strong> needles.</p>
        </div>
        <p>Adjust the blanket size or settings until BOTH border and body needle counts are at or under ${availableNeedles}.</p>
        <a class="go-to-size-link" id="go-to-size-link">Go to Blanket Size</a>
      `;
      
      // Add attention styling to blanket size section
      if (blanketSizeSection) blanketSizeSection.classList.add('needs-attention');
      
      // Recommend Custom tile only if not already on Custom
      if (customSizeTile) {
        customSizeTile.classList.toggle('recommended', selectedSize !== 'custom');
      }
      
      // Show helper text only if not on Custom
      if (sizeFixHelper) {
        sizeFixHelper.classList.toggle('visible', selectedSize !== 'custom');
      }
      
      // Attach scroll handler
      const goToSizeLink = document.getElementById('go-to-size-link');
      if (goToSizeLink) {
        goToSizeLink.addEventListener('click', scrollToSizeAndPulse);
      }
    }
  }
  
  // Hide build-blocked warning and remove all attention styling
  function hideBuildBlockedWarning() {
    if (needleWarning) needleWarning.hidden = true;
    if (blanketSizeSection) blanketSizeSection.classList.remove('needs-attention');
    if (customSizeTile) customSizeTile.classList.remove('recommended');
    if (sizeFixHelper) sizeFixHelper.classList.remove('visible');
  }
  
  // Scroll to needle input and focus it
  function scrollToNeedleInput() {
    const needleSection = document.getElementById('hb-needles-input');
    if (needleSection) {
      needleSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
    if (inputNeedlesAvailable) {
      setTimeout(() => inputNeedlesAvailable.focus(), 300);
    }
  }
  
  // Scroll to blanket size section, open drawer if needed, focus and highlight
  function scrollToSizeAndPulse() {
    // Open drawer if closed
    if (settingsDrawer && !settingsDrawer.open) {
      settingsDrawer.showModal();
    }
    
    // Small delay to let drawer open, then scroll and highlight
    setTimeout(() => {
      if (blanketSizeSection) {
        blanketSizeSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
        blanketSizeSection.focus({ preventScroll: true });
        
        // Add attention highlight
        blanketSizeSection.classList.add('kbm-attn');
        setTimeout(() => {
          blanketSizeSection.classList.remove('kbm-attn');
        }, 1200);
      }
      if (customSizeTile) {
        customSizeTile.classList.add('pulse-once');
        setTimeout(() => {
          customSizeTile.classList.remove('pulse-once');
        }, 1200);
      }
    }, 100);
  }
  
  // Disable/enable print button
  function disablePrint(disabled) {
    if (!printBtn) return;
    
    // Find or create the print hint element
    let printHint = document.getElementById('print-blocked-hint');
    
    if (disabled) {
      printBtn.disabled = true;
      printBtn.setAttribute('aria-disabled', 'true');
      
      // Add helper text if not exists
      if (!printHint) {
        printHint = document.createElement('div');
        printHint.id = 'print-blocked-hint';
        printHint.className = 'print-blocked-hint no-print';
        printHint.textContent = 'Resolve the needle count warning to enable printing.';
        printBtn.parentNode.insertBefore(printHint, printBtn.nextSibling);
      }
      printHint.style.display = '';
    } else {
      printBtn.disabled = false;
      printBtn.removeAttribute('aria-disabled');
      
      if (printHint) {
        printHint.style.display = 'none';
      }
    }
  }
  
  function renderInstructionsPlaceholder(width, dimensionUnit, length, borderDepthDisplay, edgeStitches) {
    const edgeDisplay = edgeStitches === 6 ? '5–7' : edgeStitches.toString();
    const placeholder = '—';
    
    const instructions = [];
    
    instructions.push({ type: 'phase', text: 'Section 1: Foundation & First Border' });
    instructions.push({ type: 'step', text: `Your dimensions: <span class="calculated-value">${width}${dimensionUnit}</span> wide × <span class="calculated-value">${length}${dimensionUnit}</span> long.` });
    instructions.push({ type: 'step', text: `Cast on <span class="calculated-value">${placeholder}</span> and knit in border stitch pattern for <span class="calculated-value">${borderDepthDisplay}</span>.` });

    instructions.push({ type: 'phase', text: 'Section 2: The Transition' });
    instructions.push({ type: 'step', text: `Transfer stitches to the machine or change to body stitch pattern. <span class="calculated-value">${placeholder}</span>` });

    instructions.push({ type: 'phase', text: 'Section 3: The Blanket Body' });
    instructions.push({ type: 'step', text: `Knit the blanket body to desired length.<span class="step-aside"><span class="step-aside__label">AT THE SAME TIME:</span> Hand-manipulate <span class="calculated-value">${edgeDisplay}</span> stitches along each edge as you knit.</span>` });

    instructions.push({ type: 'phase', text: 'Section 4: Finishing' });
    instructions.push({ type: 'step', text: `Transfer stitches to a hand needle or change to border stitch pattern. <span class="calculated-value">${placeholder}</span>` });
    instructions.push({ type: 'step', text: `Knit in border stitch pattern for <span class="calculated-value">${borderDepthDisplay}</span>. Bind off.` });

    renderPatternStepsSections(instructions);
  }
  
  // Render instructions grouped by phase into focusable sections
  function renderPatternStepsSections(instructions) {
    if (!patternStepsContainer) return;
    
    // Group instructions by phase - each phase starts a new section
    const sections = [];
    let currentSection = null;
    let sectionCounter = 0;
    
    instructions.forEach(item => {
      if (item.type === 'phase') {
        if (currentSection) sections.push(currentSection);
        sectionCounter++;
        // Generate stable slug from phase text
        const slug = slugify(item.text) || `section-${sectionCounter}`;
        currentSection = { header: item.text, steps: [], slug: slug };
      } else if (currentSection) {
        currentSection.steps.push(item.text);
      }
    });
    if (currentSection) sections.push(currentSection);
    
    // Helper to create slug from text
    function slugify(text) {
      if (!text) return '';
      return text
        .toLowerCase()
        .replace(/[^a-z0-9\s-]/g, '')
        .replace(/\s+/g, '-')
        .replace(/-+/g, '-')
        .replace(/^-|-$/g, '')
        .substring(0, 50);
    }
    
    // Build HTML using new class names: kbm-step-ol, kbm-section-header, kbm-step-section, kbm-step-header, kbm-step
    // Wrap step content in a span to keep all text in the second grid column (prevents spans from becoming separate grid cells)
    const sectionsHtml = sections.map(sec => {
      const stepsHtml = sec.steps.map(stepContent => 
        `<li class="kbm-step"><span class="kbm-step-content">${stepContent}</span></li>`
      ).join('');
      
      return `
        <li class="kbm-section-header">
          <div class="kbm-step-section">
            <div class="kbm-step-header">${sec.header}</div>
          </div>
        </li>
        ${stepsHtml}
      `;
    }).join('');
    
    const html = `<ol class="kbm-step-ol">${sectionsHtml}</ol>`;
    
    patternStepsContainer.innerHTML = html;
  }

  // Input event listeners
  [inputCustomWidth, inputCustomLength].forEach(input => {
    if (input) {
      input.addEventListener('input', () => {
        checkForPresetMatch();
        updateTileDimensions();
        updateSelectedSizeBar();
        calculate();
      });
    }
  });

  [inputHandGauge, inputMachineGauge, inputBorderRowGauge, inputBodyRowGauge, inputBorderDepth, inputEdgeStitches].forEach(input => {
    if (input) input.addEventListener('input', () => {
      syncInputsToState();
      calculate();
    });
  });
  
  // Needle input listener with localStorage persistence
  if (inputNeedlesAvailable) {
    // Load persisted value on init (prefill only)
    const savedNeedles = localStorage.getItem(NEEDLES_STORAGE_KEY);
    if (savedNeedles) {
      inputNeedlesAvailable.value = savedNeedles;
    }
    
    // Persist on input and recalculate preview
    inputNeedlesAvailable.addEventListener('input', () => {
      const val = inputNeedlesAvailable.value;
      if (val && parseInt(val, 10) > 0) {
        localStorage.setItem(NEEDLES_STORAGE_KEY, val);
      } else {
        localStorage.removeItem(NEEDLES_STORAGE_KEY);
      }
      calculate();
    });
  }
  
  // Initial calculate called after all listeners are set up ensures localStorage values are applied

  // Print event handlers - add class for CSS targeting
  window.addEventListener('beforeprint', () => {
    document.documentElement.classList.add('is-printing');
  });
  window.addEventListener('afterprint', () => {
    document.documentElement.classList.remove('is-printing');
  });

  // Print button handling
  if (printBtn) {
    printBtn.addEventListener('click', () => {
      // Close drawer before printing
      if (settingsDrawer.open) {
        settingsDrawer.close();
      }
      
      // Disable print in viewer mode
      if (isViewerMode) {
        enterDesignerMode();
        return;
      }
      
      const originalTitle = document.title;
      document.title = 'Hybrid Blanket Pattern';
      window.print();
      document.title = originalTitle;
    });
  }

 // Start over - reset to preview mode
if (startOverBtn) {
  startOverBtn.addEventListener('click', () => {
    console.log('Start over - returning to preview defaults');

    loadSampleDefaults();
    hasBuiltPattern = false;

    if (settingsDrawer && settingsDrawer.open) {
      settingsDrawer.close();
    }

    applyViewState();
  });
}

// Build My Pattern (customize button)
if (customizeBtn) {
  customizeBtn.addEventListener('click', () => {
    hasBuiltPattern = true;
    syncInputsToState?.();
    calculate();

    if (settingsDrawer) settingsDrawer.close();

    applyViewState();
  });
}




  // Set up viewer mode styling
  if (actionBarWrapper) {
    actionBarWrapper.classList.add('viewer-mode');
  }
  
  // Ensure drawer is closed on page load
  if (settingsDrawer && settingsDrawer.open) {
    settingsDrawer.close();
  }

  // Mobile topbar action buttons - wire to same handlers via event delegation
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('[data-action]');
    if (!btn) return;
    const action = btn.getAttribute('data-action');
    
    if (action === 'edit') {
      console.log('Topbar Edit clicked - opening drawer');
      isViewerMode = false;
      if (settingsDrawer) settingsDrawer.showModal();
    }
    
    if (action === 'reset') {
      console.log('Topbar Start over clicked');
      loadSampleDefaults();
      hasBuiltPattern = false;
      applyViewState();
      if (settingsDrawer && settingsDrawer.open) {
        settingsDrawer.close();
      }
    }
    
    if (action === 'print') {
      if (settingsDrawer && settingsDrawer.open) {
        settingsDrawer.close();
      }
      if (isViewerMode) {
        enterDesignerMode();
        return;
      }
      window.print();
    }
  });

// Always initialize - load sample defaults so pattern shows real values
loadSampleDefaults();
updatePlaceholders();
updateGaugeLabels();
// Wizard initialization complete

// Yarn Calculator
(function initYarnCalculator() {
  const swatchWidth = document.getElementById('yarn-swatch-width');
  const swatchLength = document.getElementById('yarn-swatch-length');
  const swatchWeight = document.getElementById('yarn-swatch-weight');
  const outputBox = document.getElementById('yarn-output-box');
  const errorBox = document.getElementById('yarn-error');
  const blanketHint = document.getElementById('yarn-blanket-hint');
  const blanketSizeEl = document.getElementById('yarn-blanket-size');
  const blanketWidthDisplay = document.getElementById('yarn-blanket-width-display');
  const blanketLengthDisplay = document.getElementById('yarn-blanket-length-display');
  const unitLabels = document.querySelectorAll('.yarn-unit-label');
  const unitBtns = document.querySelectorAll('.yarn-unit-btn');
  
  if (!swatchWidth || !swatchLength || !swatchWeight) {
    return; // Yarn tab not present
  }
  
  const swatchAreaEl = document.getElementById('yarn-swatch-area');
  const gramsPerSqinEl = document.getElementById('yarn-grams-per-sqin');
  const blanketAreaEl = document.getElementById('yarn-blanket-area');
  const estimatedGramsEl = document.getElementById('yarn-estimated-grams');
  const estimatedOzEl = document.getElementById('yarn-estimated-oz');
  
  // State
  const STORAGE_KEY = 'kbm:hybridBlanket:units';
  let currentUnit = localStorage.getItem(STORAGE_KEY) || 'in';
  let blanketWidthIn = 0;
  let blanketLengthIn = 0;
  
  // Initialize units UI
  function updateUnitsUI() {
    unitBtns.forEach(btn => {
      btn.classList.toggle('active', btn.dataset.unit === currentUnit);
    });
    unitLabels.forEach(label => {
      label.textContent = currentUnit;
    });
    updateBlanketDisplay();
  }
  
  // Update blanket size display
  function updateBlanketDisplay() {
    if (blanketWidthIn <= 0 || blanketLengthIn <= 0) {
      blanketWidthDisplay.textContent = '—';
      blanketLengthDisplay.textContent = '—';
      blanketHint.style.display = 'block';
      blanketSizeEl.style.display = 'none';
      return;
    }
    
    blanketHint.style.display = 'none';
    blanketSizeEl.style.display = 'block';
    
    const unitSuffix = currentUnit === 'in' ? '"' : ' cm';
    if (currentUnit === 'in') {
      blanketWidthDisplay.textContent = blanketWidthIn.toFixed(1) + unitSuffix;
      blanketLengthDisplay.textContent = blanketLengthIn.toFixed(1) + unitSuffix;
    } else {
      blanketWidthDisplay.textContent = (blanketWidthIn * 2.54).toFixed(1) + unitSuffix;
      blanketLengthDisplay.textContent = (blanketLengthIn * 2.54).toFixed(1) + unitSuffix;
    }
  }
  
  function calculateYarn() {
    // Get swatch values - convert to inches if user entered cm
    let sw = parseFloat(swatchWidth.value);
    let sl = parseFloat(swatchLength.value);
    const swt = parseFloat(swatchWeight.value);
    
    // Convert cm to inches for calculation
    if (currentUnit === 'cm') {
      sw = sw / 2.54;
      sl = sl / 2.54;
    }
    
    // Validate swatch inputs
    const swatchValid = !isNaN(sw) && !isNaN(sl) && !isNaN(swt) && sw > 0 && sl > 0 && swt > 0;
    const blanketValid = blanketWidthIn > 0 && blanketLengthIn > 0;
    
    if (!swatchValid) {
      outputBox.style.display = 'none';
      // Only show error if at least one swatch field has a value
      const hasAnyValue = [swatchWidth, swatchLength, swatchWeight]
        .some(el => el.value.trim() !== '');
      errorBox.style.display = hasAnyValue ? 'block' : 'none';
      return;
    }
    
    if (!blanketValid) {
      outputBox.style.display = 'none';
      errorBox.style.display = 'none';
      return;
    }
    
    errorBox.style.display = 'none';
    outputBox.style.display = 'block';
    
    const swatchArea = sw * sl;
    const gramsPerSqIn = swt / swatchArea;
    const blanketArea = blanketWidthIn * blanketLengthIn;
    const baseGrams = blanketArea * gramsPerSqIn;
    const estimatedGrams = baseGrams * 1.10; // 10% buffer
    const estimatedOz = estimatedGrams / 28.3495;
    
    swatchAreaEl.textContent = swatchArea.toFixed(1) + ' sq in';
    gramsPerSqinEl.textContent = gramsPerSqIn.toFixed(3) + ' g/sq in';
    blanketAreaEl.textContent = blanketArea.toFixed(0) + ' sq in';
    estimatedGramsEl.textContent = Math.ceil(estimatedGrams) + ' g';
    estimatedOzEl.textContent = estimatedOz.toFixed(1) + ' oz';
  }
  
  // Listen for dimension events from pattern engine
  window.addEventListener('kbm:hybridBlanket:dimensions', function(e) {
    blanketWidthIn = e.detail.widthIn || 0;
    blanketLengthIn = e.detail.lengthIn || 0;
    updateBlanketDisplay();
    calculateYarn();
  });
  
  // Fallback: read from hidden spans on init
  function readDimensionsFromDOM() {
    const widthSpan = document.getElementById('hb-finished-width-in');
    const lengthSpan = document.getElementById('hb-finished-length-in');
    if (widthSpan && lengthSpan) {
      blanketWidthIn = parseFloat(widthSpan.getAttribute('data-value')) || 0;
      blanketLengthIn = parseFloat(lengthSpan.getAttribute('data-value')) || 0;
      updateBlanketDisplay();
      calculateYarn();
    }
  }
  
  // Unit toggle handlers
  unitBtns.forEach(btn => {
    btn.addEventListener('click', function() {
      currentUnit = this.dataset.unit;
      localStorage.setItem(STORAGE_KEY, currentUnit);
      updateUnitsUI();
      calculateYarn();
    });
  });
  
  // Add input listeners
  [swatchWidth, swatchLength, swatchWeight].forEach(input => {
    input.addEventListener('input', calculateYarn);
  });
  
  // Initialize
  updateUnitsUI();
  // Delay reading DOM dimensions to ensure pattern engine has initialized
  setTimeout(readDimensionsFromDOM, 100);
})();
</script>

<script define:vars={{ hyvorPageId }}>
// Hyvor Talk loader for Discussion tab
(function() {
  let hyvorLoaded = false;
  
  function loadHyvor() {
    if (hyvorLoaded) return;
    
    const pageId = hyvorPageId;
    
    window.HYVOR_TALK_WEBSITE = 14706;
    window.HYVOR_TALK_CONFIG = {
      url: false,
      id: pageId
    };

    if (window.hyvorTalkReload) {
      window.hyvorTalkReload();
      hyvorLoaded = true;
      return;
    }

    const existingScript = document.querySelector('script[src*="talk.hyvor.com/web-api/embed"]');
    if (!existingScript) {
      const script = document.createElement("script");
      script.src = "https://talk.hyvor.com/web-api/embed.js";
      script.async = true;
      script.type = "text/javascript";
      document.body.appendChild(script);
    }
    hyvorLoaded = true;
  }

  // Load Hyvor when Discussion tab is clicked
  document.addEventListener('DOMContentLoaded', function() {
    const discussionTab = document.getElementById('tab-discussion');
    if (discussionTab) {
      discussionTab.addEventListener('click', loadHyvor);
    }
  });
})();
</script>
