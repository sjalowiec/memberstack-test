---
/**
 * Hand + Machine Blanket Planner Wizard - REDESIGNED
 * Location: src/pages/wizards/hand-machine-blanket.astro
 * 
 * "Gated Complexity" design:
 * - Full-width pattern preview with sample data loaded by default
 * - Glass overlay for viewer mode
 * - Right-side drawer for customization inputs
 * - Size preset chips instead of large cards
 */

export const prerender = true;

import PatternLayout from "../../layouts/PatternLayout.astro";
import ActionBar from "../../components/wizards/ActionBar.astro";
import PrintFooter from "../../components/common/PrintFooter.astro";
import WizardBackLink from "../../components/wizards/WizardBackLink.astro";
import PinterestEmbed from "../../components/PinterestEmbed.astro";
import VimeoEmbed from "../../components/media/VimeoEmbed.astro";
import wizardData from "../../content/wizards/hand-machine-blanket.json";
import "../../styles/wizard.css";

const pageUrl = "https://knitbymachine.com/wizards/hand-machine-blanket";
const hyvorPageId = wizardData.hyvorPageId || "wizards-hand-machine-blanket";

// Access level from JSON - "free" or "paid"
const accessLevel = wizardData.accessLevel || "free";
const price = wizardData.price || "$9.99";
---

<PatternLayout 
  title="The Hybrid Blanket Pattern | Knit by Machine" 
  description="Hand Knit + Machine Knit Blanket Pattern. Calculate stitch counts for blankets with hand-knit garter borders and machine-knit body."
  tabsEnabled={{ pattern: true, yarn: true, resources: true, discussion: true, inspiration: true }}
>

<style is:global>
.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

.pattern-slot-wrapper {
  padding-top: 20px;
  padding-bottom: 3rem;
}

.inspiration-content,
.resources-content,
.discussion-content {
  max-width: 900px;
  margin: 0 auto;
  padding: 0 1rem;
}

.inspiration-content h3,
.resources-content h3,
.discussion-content h3 {
  color: var(--kbm-green);
  font-size: 1.2rem;
  margin-bottom: 0.5rem;
}

.inspiration-intro,
.resources-intro,
.discussion-intro {
  color: #6b7280;
  font-size: 0.95rem;
  margin-bottom: 1rem;
}

.video-placeholder {
  background: #f9fafb;
  border: 1px dashed #e5e7eb;
  border-radius: 12px;
  padding: 2rem;
  text-align: center;
}

.video-note {
  color: #6b7280;
  font-style: italic;
}

/* Yarn Calculator Styles */
.yarn-content {
  max-width: 600px;
  margin: 0 auto;
  padding: 1.5rem;
}

.yarn-content h3 {
  color: var(--kbm-green);
  font-size: 1.2rem;
  margin-bottom: 0.5rem;
}

.yarn-intro {
  color: #6b7280;
  font-size: 0.95rem;
  margin-bottom: 1.5rem;
}

.yarn-calculator {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.yarn-section {
  background: #f9fafb;
  border: 1px solid var(--kbm-border, #e5e7eb);
  border-radius: 12px;
  padding: 1rem;
}

.yarn-section-label {
  font-weight: 600;
  color: var(--kbm-green);
  font-size: 0.9rem;
  margin-bottom: 0.75rem;
  display: block;
}

.yarn-input-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0.75rem;
}

@media (max-width: 480px) {
  .yarn-input-grid {
    grid-template-columns: 1fr;
  }
}

.yarn-input-group {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.yarn-input-group label {
  font-size: 0.8rem;
  color: #6b7280;
  font-weight: 500;
}

.yarn-input-group input {
  padding: 0.5rem 0.75rem;
  border: 1px solid var(--kbm-border, #e5e7eb);
  border-radius: 8px;
  font-size: 1rem;
  width: 100%;
  transition: border-color 0.2s ease;
}

.yarn-input-group input:focus {
  outline: none;
  border-color: var(--kbm-green);
}

.yarn-output-box {
  background: var(--surface, #ffffff);
  border: 1px solid var(--kbm-green);
  border-radius: var(--radius, 18px);
  padding: 1.25rem;
  margin-top: 0.5rem;
}

.yarn-output-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0.75rem 1.5rem;
}

@media (max-width: 480px) {
  .yarn-output-grid {
    grid-template-columns: 1fr;
  }
}

.yarn-output-item {
  display: flex;
  flex-direction: column;
  gap: 0.125rem;
}

.yarn-output-label {
  font-size: 0.8rem;
  color: #6b7280;
}

.yarn-output-value {
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--kbm-green);
}

.yarn-output-value.highlight {
  font-size: 1.4rem;
  color: var(--kbm-green);
}

.yarn-error {
  color: #dc2626;
  font-size: 0.9rem;
  text-align: center;
  padding: 1rem;
  margin: 0;
}

.yarn-units-toggle {
  display: flex;
  gap: 0.5rem;
  margin-bottom: 0.5rem;
}

.yarn-unit-btn {
  flex: 1;
  padding: 0.5rem 1rem;
  border: 1px solid var(--kbm-border, #e5e7eb);
  border-radius: 8px;
  background: var(--surface, #ffffff);
  color: #6b7280;
  font-size: 0.9rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
}

.yarn-unit-btn:hover {
  border-color: var(--kbm-green);
}

.yarn-unit-btn.active {
  background: var(--kbm-green);
  color: #ffffff;
  border-color: var(--kbm-green);
}

.yarn-blanket-display {
  text-align: center;
}

.yarn-blanket-size {
  font-size: 1.3rem;
  font-weight: 600;
  color: var(--kbm-green);
  margin: 0.5rem 0 0;
}

.yarn-blanket-hint {
  color: #dc2626;
  font-size: 0.85rem;
  margin: 0.5rem 0 0;
}

#hyvor-talk-view {
  min-height: 200px;
}

/* Universal hide class */
.is-hidden {
  display: none !important;
}

/* Dev Preview Toggle - injected near top of page via JS */
.dev-preview-toggle {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  align-items: center;
  padding: 10px 12px;
  border: 1px solid var(--kbm-border, #e5e7eb);
  border-radius: var(--radius, 18px);
  background: var(--surface, #fff);
  margin: 12px 1rem;
  font-size: 14px;
  max-width: 900px;
  margin-left: auto;
  margin-right: auto;
}

.dev-preview-toggle .hint {
  opacity: 0.6;
  font-size: 12px;
}

.dev-preview-toggle .dev-label {
  background: #f59e0b;
  color: #1f2937;
  padding: 2px 6px;
  border-radius: 4px;
  font-weight: 700;
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.dev-preview-toggle span.mode-label {
  color: #374151;
  font-weight: 500;
}

.dev-preview-toggle a {
  display: inline-block;
  padding: 6px 10px;
  border-radius: 999px;
  border: 1px solid var(--kbm-border, #e5e7eb);
  text-decoration: none;
  color: #374151;
  font-size: 13px;
  transition: all 0.15s ease;
}

.dev-preview-toggle a:hover {
  background: #f3f4f6;
}

.dev-preview-toggle a.active {
  background: var(--kbm-green, #52682D);
  color: #fff;
  border-color: var(--kbm-green, #52682D);
}

/* Sales Section (for unpaid view) */
.sales-section {
  max-width: 700px;
  margin: 2rem auto;
  padding: 2rem;
  text-align: center;
}

/* Sales section visibility handled by .is-hidden class */

.sales-title {
  color: var(--kbm-green);
  font-size: 1.8rem;
  font-weight: 700;
  margin-bottom: 1rem;
}

.sales-description {
  color: #4b5563;
  font-size: 1.1rem;
  line-height: 1.6;
  margin-bottom: 1.5rem;
}

.sales-how-it-works {
  text-align: left;
  max-width: 420px;
  margin: 0 auto 1.5rem;
}

.sales-how-it-works h3 {
  font-size: 1rem;
  font-weight: 600;
  color: var(--kbm-green);
  margin: 0 0 0.75rem 0;
}

.sales-how-it-works ul,
.sales-how-it-works ol {
  list-style: none;
  padding: 0;
  margin: 0;
}

.sales-how-it-works li {
  padding: 0.35rem 0;
  color: #374151;
  font-size: 0.95rem;
}

.sales-features {
  text-align: left;
  max-width: 500px;
  margin: 0 auto 1.5rem;
}

.sales-features ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.sales-features li {
  padding: 0.4rem 0;
  padding-left: 1.5rem;
  position: relative;
  color: #374151;
  font-size: 0.95rem;
}

.sales-features li strong {
  color: #1f2937;
}

.sales-features li::before {
  content: "✓";
  position: absolute;
  left: 0;
  color: var(--kbm-green);
  font-weight: bold;
}

.sales-microcopy {
  font-size: 0.85rem;
  color: #6b7280;
  margin-top: 0.5rem;
}

.sales-price {
  font-size: 2rem;
  font-weight: 700;
  color: var(--kbm-green);
  margin-bottom: 1rem;
}

.sales-cta {
  display: inline-block;
  background: var(--kbm-green);
  color: white;
  padding: 1rem 2rem;
  border-radius: 8px;
  font-size: 1.1rem;
  font-weight: 600;
  text-decoration: none;
  transition: background 0.2s;
}

.sales-cta:hover {
  background: #3d4e22;
}

/* Pattern content visibility */
.pattern-content-wrapper {
  transition: opacity 0.3s;
}

/* Pattern content visibility handled by .is-hidden class */

.page-header {
  max-width: 900px;
  margin: 0 auto 1.5rem;
  padding: 0 1rem;
}

.page-header-title {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  margin-bottom: 0.5rem;
  flex-wrap: wrap;
}

.page-header h1 {
  color: var(--kbm-green);
  font-size: 2rem;
  font-weight: 700;
  margin: 0;
}

.page-header p {
  color: #6b7280;
  font-size: 1rem;
  line-height: 1.5;
  text-align: center;
  max-width: 700px;
  margin: 0 auto;
}

/* Pattern Preview Container */
.pattern-preview-wrapper {
  position: relative;
  max-width: 900px;
  margin: 0 auto;
  padding: 0 1rem 120px 1rem;
}

/* Glass Overlay - Semi-transparent overlay (no blur on background) */
.glass-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.15);
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

.glass-overlay.hidden {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}

/* Glass message card - centered preview info block with glass effect */
.glass-message {
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.4);
  border-radius: 18px;
  padding: 1.5rem 2rem;
  text-align: center;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
  max-width: 340px;
  width: 90%;
}

.glass-message-title {
  font-size: 1.25rem;
  font-weight: 600;
  color: #374151;
  margin: 0 0 1rem 0;
}

.glass-message-prompt {
  font-size: 0.95rem;
  color: #374151;
  margin: 0 0 0.5rem 0;
}

.glass-message-subprompt {
  font-size: 0.85rem;
  color: #6b7280;
  margin: 0 0 1rem 0;
}

.customize-btn {
  background: var(--kbm-green);
  color: white;
  border: none;
  padding: 0.75rem 1.5rem;
  border-radius: 12px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s ease;
}

.customize-btn:hover {
  background: #3d4e22;
  transform: translateY(-1px);
}

/* Pattern Card */
.pattern-card {
  background: white;
  padding: 2rem;
  border-radius: 18px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  border: 1px solid rgba(0,0,0,0.05);
}

.pattern-output-header {
  margin-bottom: 1.5rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid #eef0ea;
}

.pattern-output-header h2 {
  color: var(--kbm-green);
  font-size: 1.5rem;
  font-weight: 700;
  margin: 0 0 0.25rem 0;
}

.pattern-output-header .subtitle {
  color: #6b7280;
  font-size: 1rem;
  margin: 0 0 0.75rem 0;
}

.pattern-output-header .what-youll-do {
  color: #374151;
  font-size: 0.95rem;
  margin: 0;
  line-height: 1.5;
}

.inputs-summary {
  background: #f9fafb;
  padding: 1rem;
  border-radius: 12px;
  margin-bottom: 1.5rem;
  font-size: 0.95rem;
  border: 1px solid #eef0ea;
}

.inputs-summary p {
  margin: 0 0 0.25rem 0;
}

.stitch-counts-section {
  background: rgba(82, 104, 45, 0.08);
  padding: 1.25rem;
  border-radius: 12px;
  margin-bottom: 1.5rem;
}

.stitch-counts-section h4 {
  color: var(--kbm-green);
  font-size: 1rem;
  font-weight: 600;
  margin: 0 0 1rem 0;
  text-align: center;
}

.stitch-counts-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.75rem;
  margin: 0;
  padding: 0;
}

.stitch-count-card {
  background: white;
  border-radius: 10px;
  padding: 1rem;
  text-align: center;
  border: 1px solid rgba(82, 104, 45, 0.15);
}

.stitch-count-card dt {
  font-size: 0.85rem;
  color: #6b7280;
  margin-bottom: 0.25rem;
  font-weight: 500;
}

.stitch-count-card dd {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--kbm-green);
  margin: 0;
  line-height: 1.2;
}

.instructions-wrapper {
  background: #f9fafb;
  padding: 1.5rem;
  border-radius: 12px;
  margin-bottom: 1rem;
}

.instructions-wrapper h3 {
  color: var(--kbm-green);
  font-size: 1.1rem;
  margin: 0 0 1rem 0;
}

.instructions-list {
  margin-left: 0;
  padding-left: 0;
  line-height: 1.9;
  list-style: none;
  counter-reset: step-counter;
}

:global(.instructions-list li) {
  margin-bottom: 0.75rem;
  position: relative;
  padding-left: 1.75rem;
}

:global(.instructions-list li:not(.phase-heading)) {
  counter-increment: step-counter;
}

:global(.instructions-list li:not(.phase-heading)::before) {
  content: counter(step-counter) ".";
  position: absolute;
  left: 0;
  font-weight: 400;
  color: inherit;
}

:global(.instructions-list .calculated-value) {
  font-weight: 700;
  white-space: nowrap;
}

:global(.instructions-list .phase-heading) {
  font-weight: 600;
  font-size: 0.9rem;
  color: var(--kbm-green);
  text-transform: uppercase;
  letter-spacing: 0.025em;
  margin-top: 1.25rem;
  margin-bottom: 0.5rem;
  padding-left: 0;
  padding-bottom: 0.25rem;
  border-bottom: 1px solid rgba(82, 104, 45, 0.2);
}

:global(.instructions-list .phase-heading:first-child) {
  margin-top: 0;
}

:global(.instructions-list .step-aside) {
  display: block;
  margin: 0.5rem 0 0 1.25rem;
  padding-left: 0.75rem;
  border-left: 2px solid rgba(82, 104, 45, 0.35);
  color: #6b7280;
  font-size: 0.95em;
}

:global(.instructions-list .step-aside__label) {
  font-weight: 600;
  letter-spacing: 0.02em;
}

.why-note {
  font-style: italic;
  color: #6b7280;
  padding: 1rem;
  background: #f0f4eb;
  border-radius: 10px;
  font-size: 0.9rem;
  line-height: 1.5;
}

.why-note-text {
  font-style: italic;
  color: #6b7280;
  font-size: 0.9rem;
  line-height: 1.5;
  margin: 0;
}

/* =========================
   MAIN SECTIONS (no focus)
   ========================= */
.kbm-sections {
  display: block;
}

.kbm-section {
  border: 1px solid var(--kbm-border, #e5e7eb);
  border-radius: var(--radius, 18px);
  padding: 14px 18px;
  margin: 14px 0;
  background: var(--surface, #fff);
}

.kbm-section__title {
  margin: 0 0 12px 0;
  color: var(--kbm-green);
  font-size: 18px;
  font-weight: 700;
}

/* =========================
   PATTERN STEPS
   ========================= */

/* --- Pattern Steps: hard-scoped styling --- */
#kbm-pattern-steps { width: 100%; }

#kbm-pattern-steps .kbm-step-ol {
  list-style: none;
  margin: 0;
  padding: 0;
  counter-reset: kbmstep;
}

/* Section header rows should NOT be centered by any global list styles */
#kbm-pattern-steps .kbm-section-header {
  list-style: none;
  margin: 14px 0 6px;
  padding: 0;
  text-align: left !important;
}
#kbm-pattern-steps .kbm-section-header::marker { content: ""; }

/* The visible section "box" */
#kbm-pattern-steps .kbm-section-header .kbm-step-section {
  display: block;
  text-align: left !important;
  border: 1px solid var(--border, #e5e7eb) !important;
  border-radius: var(--radius, 18px) !important;
  background: var(--surface, #fff) !important;
  padding: 14px !important;
  margin: 0 !important;
}

/* Title */
#kbm-pattern-steps .kbm-section-header .kbm-step-header {
  margin: 0 !important;
  font-weight: 800;
  color: var(--kbm-green, #52682D);
  font-size: 16px;
}

/* Instruction steps: continuous numbering */
#kbm-pattern-steps .kbm-step {
  counter-increment: kbmstep;
  display: grid;
  grid-template-columns: 2.2em 1fr;
  column-gap: 10px;
  padding: 8px 0;
  text-align: left !important;
}
#kbm-pattern-steps .kbm-step::before {
  content: counter(kbmstep) ".";
  font-weight: 700;
  color: var(--kbm-green, #52682D);
  text-align: right;
}

/* Step content wrapper - keeps all inline content together in grid cell */
#kbm-pattern-steps .kbm-step-content {
  display: block;
}

#kbm-pattern-steps .kbm-step-content .calculated-value {
  display: inline;
  font-weight: 700;
  white-space: nowrap;
}

/* Notes: unnumbered */
#kbm-pattern-steps .kbm-step-note {
  counter-increment: none;
  display: block;
  margin-left: 2.2em;
  padding: 6px 0 10px;
}
#kbm-pattern-steps .kbm-step-note::before { content: ""; }

@media print {
  /* Prevent forced page breaks */
  #kbm-pattern-steps, 
  .kbm-section { 
    break-inside: avoid-page; 
    page-break-inside: avoid; 
    break-after: auto; 
    page-break-after: auto; 
  }
  
  /* Kill sticky/fixed positioning that can cause blank pages */
  [style*="position:sticky"], 
  [style*="position: sticky"],
  [style*="position:fixed"],
  [style*="position: fixed"] { 
    position: static !important; 
  }
}

.pattern-illustration {
  margin-top: 1.5rem;
  text-align: center;
}

.pattern-illustration img {
  max-width: 100%;
  height: auto;
}

/* Action Bar in Designer Mode */
.action-bar-wrapper {
  margin-bottom: 1.5rem;
}

.action-bar-wrapper.viewer-mode .print-action {
  opacity: 0.5;
  pointer-events: none;
}

/* Settings Drawer - Native dialog with slide-in animation from right */
.settings-drawer {
  position: fixed;
  top: 0;
  left: auto;  /* Override browser default left:0 for dialogs */
  right: 0;
  width: min(400px, 90vw);
  height: 100vh;
  max-height: 100vh;
  max-width: none;  /* Override browser default max-width for dialogs */
  background: white;
  box-shadow: -4px 0 24px rgba(0, 0, 0, 0.15);
  z-index: 100;
  border-radius: 18px 0 0 18px;
  overflow-x: hidden;
  flex-direction: column;
  margin: 0;
  padding: 0;
  border: none;
  transform: translateX(100%);
  transition: transform 0.3s ease;
}

.settings-drawer[open] {
  display: flex;
  transform: translateX(0);
}

.drawer-footer {
  padding: 1rem 1.5rem;
  border-top: 1px solid #eef0ea;
  flex-shrink: 0;
}

.apply-btn {
  width: 100%;
  background: var(--kbm-green);
  color: white;
  border: none;
  padding: 0.875rem 1.5rem;
  border-radius: 12px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s ease;
}

.apply-btn:hover {
  background: #3d4e22;
  transform: translateY(-1px);
}

.settings-drawer::backdrop {
  background: rgba(0, 0, 0, 0.3);
}

.drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1rem 1.5rem;
  border-bottom: 1px solid #eef0ea;
  flex-shrink: 0;
}

.drawer-header h2 {
  margin: 0;
  font-size: 1.25rem;
  color: var(--kbm-green);
  font-weight: 600;
}

.drawer-close-btn {
  background: none;
  border: none;
  font-size: 1.5rem;
  color: #6b7280;
  cursor: pointer;
  padding: 0.25rem;
  line-height: 1;
  border-radius: 8px;
  transition: background 0.2s;
}

.drawer-close-btn:hover {
  background: #f3f4f6;
}

.drawer-content {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  padding: 1.25rem;
}

/* Screen-reader only */
.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

/* Mobile/Desktop size picker switching */
.size-picker--mobile { display: none; }
.size-picker--desktop { display: block; }

@media (max-width: 640px) {
  .size-picker--mobile { display: block; margin-bottom: 10px; }
  .size-picker--desktop { display: none; }

  .size-select {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--kbm-green, #52682D);
    border-radius: var(--radius, 18px);
    background: var(--surface, #fff);
    font-size: 16px; /* prevent iOS zoom */
    line-height: 1.2;
    color: inherit;
  }
}

/* Size Preset Tile Grid */
.size-tiles {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8px;
}

.size-tile {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  border: 1px solid var(--kbm-green, #52682D);
  background: transparent;
  color: inherit;
  border-radius: 14px;
  padding: 8px 8px;
  min-height: 44px;
  line-height: 1.05;
  cursor: pointer;
  transition: all 0.2s ease;
}

.size-name {
  font-weight: 600;
  font-size: 14px;
  color: inherit;
}

.size-dims {
  font-size: 12px;
  opacity: 0.75;
  margin-top: 3px;
  display: block;
}

/* Hide the Selected size bar (replaced by dimensions in pills) */
.selected-size-bar {
  display: none;
}

.selected-size-label {
  color: #6b7280;
}

.selected-size-name {
  font-weight: 600;
  color: #374151;
}

.selected-size-dims {
  color: #374151;
}

.size-tile:hover {
  background: rgba(82, 104, 45, 0.1);
}

.size-tile.is-active {
  background: var(--kbm-green, #52682D);
  border-color: var(--kbm-green, #52682D);
  color: #fff;
}

.size-tile.is-active .size-name {
  color: white;
}

.size-tile.is-active .size-dims {
  opacity: 0.95;
}

/* Custom tile - full width */
.size-tile--custom {
  grid-column: 1 / -1;
  align-items: flex-start;
  text-align: left;
  padding: 10px 10px;
}

.size-tile--custom .size-name {
  font-size: 14px;
}

.size-tile--custom .size-dims {
  font-size: 12px;
}

/* Custom Size Inputs */
.custom-size-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
  margin-top: 0.75rem;
}

.custom-size-row.hidden {
  display: none;
}

/* Unit Toggle */
.unit-toggle {
  display: inline-flex;
  background: #f3f4f6;
  border-radius: 8px;
  padding: 3px;
  margin-bottom: 1.5rem;
}

.unit-toggle button {
  padding: 0.5rem 1rem;
  border: none;
  background: transparent;
  cursor: pointer;
  font-weight: 600;
  color: #6b7280;
  border-radius: 6px;
  transition: all 0.2s;
  font-size: 0.875rem;
}

.unit-toggle button.active {
  background: var(--kbm-green);
  color: white;
}

/* Section Dividers */
.drawer-section {
  margin-bottom: 1.5rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid #eef0ea;
}

.drawer-section:last-child {
  border-bottom: none;
  margin-bottom: 0;
}

.section-label {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--kbm-green);
  margin-bottom: 1rem;
  display: block;
}

/* Input Groups */
.input-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
  margin-bottom: 0.75rem;
}

.input-group {
  display: flex;
  flex-direction: column;
}

.input-group label {
  font-weight: 500;
  color: #374151;
  margin-bottom: 0.375rem;
  font-size: 0.8rem;
}

.input-group input {
  padding: 0.5rem 0.625rem;
  border: 1px solid #d1d5db;
  border-radius: 10px;
  font-size: 0.9rem;
  transition: all 0.2s;
  width: 100%;
  box-sizing: border-box;
}

.input-group input:focus {
  outline: none;
  border-color: var(--kbm-green);
  box-shadow: 0 0 0 3px rgba(82, 104, 45, 0.1);
}

.input-group input.error {
  border-color: #dc3545;
}

.input-hint {
  font-size: 0.75rem;
  color: #6b7280;
  margin-top: 0.25rem;
}

.validation-message {
  margin-top: 0.25rem;
  font-size: 0.8rem;
}

.validation-message.error {
  color: #dc3545;
}

/* Gauge Warning */
.gauge-warning {
  display: flex;
  gap: 0.5rem;
  padding: 0.75rem;
  margin-top: 0.75rem;
  background-color: #fef3c7;
  border: 1px solid #f59e0b;
  border-radius: 10px;
  color: #92400e;
  font-size: 0.85rem;
}

.gauge-warning-icon {
  flex-shrink: 0;
}

/* Required field marker */
.required-marker {
  color: #dc2626;
  font-weight: 600;
}

/* Full-width input group in drawer */
.input-group--full {
  grid-column: 1 / -1;
}

/* Needle Warning Panel */
.needle-warning-wrapper {
  margin-bottom: 1.5rem;
}

.needle-warning-wrapper[hidden] {
  display: none;
}

.needle-warning-panel {
  background: #fef2f2;
  border: 2px solid #dc2626;
  border-radius: 12px 12px 0 0;
  padding: 1rem 1.25rem;
  display: flex;
  gap: 1rem;
  align-items: flex-start;
}

.needle-warning-fix {
  background: #fff5f5;
  border: 1px solid #fca5a5;
  border-top: none;
  border-radius: 0 0 12px 12px;
  padding: 0.75rem 1rem 0.75rem 3.5rem;
  font-size: 0.95rem;
  color: #7f1d1d;
  line-height: 1.5;
}

.needle-warning-fix-icon {
  margin-right: 0.5rem;
}

.needle-warning-fix strong {
  font-weight: 700;
  color: #991b1b;
}

.needle-warning-icon {
  flex-shrink: 0;
  color: #dc2626;
  font-size: 1.5rem;
  line-height: 1;
}

.needle-warning-content {
  flex: 1;
}

.needle-warning-title {
  margin: 0 0 0.5rem 0;
  font-size: 1.1rem;
  font-weight: 700;
  color: #991b1b;
}

.needle-warning-body {
  font-size: 0.95rem;
  color: #7f1d1d;
  line-height: 1.5;
}

.needle-warning-body p {
  margin: 0.25rem 0;
}

.needle-warning-body .needle-counts {
  margin: 0.75rem 0;
  padding-left: 1rem;
  border-left: 3px solid #fca5a5;
}

.needle-warning-body .go-to-size-link {
  display: inline-block;
  margin-top: 0.75rem;
  color: #991b1b;
  text-decoration: underline;
  cursor: pointer;
  font-weight: 500;
}

.needle-warning-body .go-to-size-link:hover {
  color: #7f1d1d;
}

/* Blanket Size attention state */
.blanket-size-section.needs-attention {
  border: 1px solid var(--kbm-green, #52682D);
  border-radius: var(--radius, 18px);
  background: rgba(82, 104, 45, 0.08);
  padding: 12px;
  margin: -12px;
  animation: attentionPulse 1.5s ease-out 1;
}

@keyframes attentionPulse {
  0% { background: rgba(82, 104, 45, 0.15); }
  100% { background: rgba(82, 104, 45, 0.08); }
}

/* Attention highlight for scroll-to-focus */
.kbm-attn {
  outline: 2px solid var(--kbm-green, #52682D);
  outline-offset: 2px;
  box-shadow: 0 0 12px rgba(82, 104, 45, 0.35);
  transition: outline 0.3s ease, box-shadow 0.3s ease;
}

@media print {
  .kbm-attn {
    outline: none !important;
    box-shadow: none !important;
  }
}

.size-tile.recommended {
  border: 2px solid var(--kbm-green, #52682D);
  position: relative;
}

.size-tile.recommended::after {
  content: 'Try this';
  display: block;
  font-size: 10px;
  color: var(--kbm-green, #52682D);
  margin-top: 2px;
}

.size-fix-helper {
  display: none;
  font-size: 0.9rem;
  color: #991b1b;
  margin-top: 0;
  padding: 0.75rem 1rem;
  background: #fef2f2;
  border: 1px solid #fca5a5;
  border-top: none;
  border-radius: 0 0 12px 12px;
}

.size-fix-helper-icon {
  margin-right: 0.5rem;
}

.size-fix-helper strong {
  font-weight: 700;
}

.size-fix-helper.visible {
  display: block;
}


.pulse-once {
  animation: kbmPulse 1.2s ease-out 1;
}

@keyframes kbmPulse {
  0% { box-shadow: 0 0 0 0 rgba(82, 104, 45, 0.4); }
  50% { box-shadow: 0 0 0 8px rgba(82, 104, 45, 0); }
  100% { box-shadow: 0 0 0 0 rgba(82, 104, 45, 0); }
}

/* Print button disabled state */
.wizard-action-btn:disabled,
.wizard-action-btn[aria-disabled="true"] {
  opacity: 0.5;
  cursor: not-allowed;
  pointer-events: none;
}

.print-blocked-hint {
  font-size: 0.85rem;
  color: #dc2626;
  margin-top: 0.5rem;
  text-align: center;
}

/* Responsive */
@media (max-width: 640px) {
  .stitch-counts-cards {
    grid-template-columns: 1fr;
  }
  
  .input-row {
    grid-template-columns: 1fr;
  }
  
  .custom-size-row {
    grid-template-columns: 1fr;
  }
}

/* Print-only content: hidden on screen, visible in print */
.print-only {
  display: none;
}

/* Print Styles */
@media print {
  @page { margin: 0.5in; }

  html, body {
    height: auto !important;
    min-height: 0 !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  /* CRITICAL: Hide ALL header/nav/footer elements - use every possible selector */
  header, nav, footer,
  .site-header, .hero, .topbar, .announcement, .breadcrumbs,
  .page-header, .pattern-nav, .global-header,
  .hero-constrained, [slot="hero"],
  .kbm-header-wrap, .kbm-footer,
  .kbm-logo-section, .kbm-nav-row, .kbm-nav-trigger,
  .kbm-container > *:not(main) {
    display: none !important;
    visibility: hidden !important;
    height: 0 !important;
    max-height: 0 !important;
    overflow: hidden !important;
    margin: 0 !important;
    padding: 0 !important;
    border: none !important;
    position: absolute !important;
    top: -9999px !important;
    left: -9999px !important;
  }

  /* Fixed header must be removed from flow completely */
  .kbm-header-wrap {
    position: absolute !important;
    top: -9999px !important;
  }

  /* Kill layout spacing that can push content down */
  main, .page, .container, .content, .layout, .pattern-page, .pattern-wide,
  .page-wrap, .tabs-shell, .panels, #panel-pattern {
    margin: 0 !important;
    padding: 0 !important;
    position: static !important;
  }
  
  /* Make sure main element in BaseLayout doesn't add spacing */
  body > main,
  .page-wrap > main {
    margin: 0 !important;
    padding: 0 !important;
  }

  /* No-print elements */
  .glass-overlay,
  .settings-drawer,
  .no-print,
  .customize-btn,
  .action-bar-wrapper,
  .sales-section,
  .pattern-illustration {
    display: none !important;
  }
  
  .pattern-slot-wrapper {
    padding: 0 !important;
    background: white !important;
    margin: 0 !important;
  }
  
  .pattern-slot-wrapper > :first-child {
    margin-top: 0 !important;
    padding-top: 0 !important;
  }
  
  .pattern-preview-wrapper {
    padding: 0 !important;
    margin: 0 !important;
  }
  
  .pattern-content-wrapper {
    padding: 0 !important;
    margin: 0 !important;
  }
  
  .pattern-card {
    box-shadow: none !important;
    border: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  /* Screen-hidden print container must be visible in print */
  .print-only {
    display: block !important;
    visibility: visible !important;
  }

  /* The printable region must be visible and positioned normally */
  #print-root {
    display: block !important;
    visibility: visible !important;
    position: static !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  /* Prevent margin-collapsing / phantom top space */
  #print-root > :first-child,
  .pattern-card > :first-child,
  .pattern-output-header:first-child,
  .pattern-wide > :first-child,
  #panel-pattern > :first-child {
    margin-top: 0 !important;
    padding-top: 0 !important;
  }

  /* Ensure pattern header starts at top */
  .pattern-output-header {
    margin-top: 0 !important;
    padding-top: 0 !important;
  }

  /* Remove any forced page breaks that could create a blank page */
  .page-break, .break-before, [data-page-break] {
    break-before: auto !important;
    page-break-before: auto !important;
  }

  /* Section styling for print */
  .kbm-section { 
    outline: none !important; 
    border: 1px solid #ddd !important;
  }
  .kbm-section__title {
    font-size: 14pt !important;
    color: #000 !important;
  }
}

/* =========================
   MOBILE LAYOUT FIXES
   ========================= */

/* keep the pattern area from feeling "squeezed" */
.pattern-wide {
  width: 100%;
  max-width: 100%;
}

/* card should be full-width on phones */
.pattern-card {
  width: 100%;
  max-width: 980px;
  margin: 0 auto;
}

/* make the counts behave like a grid */
.stitch-counts-cards {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
}


/* =========================
   PHONE BREAKPOINT
   ========================= */
@media (max-width: 640px) {
  /* reduce header spacing so content isn't pushed down */
  .page-header {
    padding-left: 12px;
    padding-right: 12px;
  }

  .pattern-card {
    border-radius: 12px;
  }

  .pattern-output-header h2 {
    font-size: 20px;
    line-height: 1.2;
    margin-bottom: 6px;
  }

  .pattern-output-header .subtitle {
    font-size: 14px;
    margin-bottom: 8px;
  }

  .what-youll-do {
    font-size: 14px;
    line-height: 1.35;
  }

  .inputs-summary p {
    font-size: 14px;
    line-height: 1.35;
    margin: 8px 0;
  }

  /* stitch cards should stack 1 per row on phones */
  .stitch-counts-cards {
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .stitch-count-card dt {
    font-size: 13px;
  }

  .stitch-count-card dd {
    font-size: 20px;
  }

  /* steps should be readable */
  .instructions-wrapper h3 {
    font-size: 18px;
  }

  .instructions-list {
    padding-left: 18px;
  }

  .instructions-list li {
    font-size: 15px;
    line-height: 1.4;
    margin: 10px 0;
  }

  .instructions-list .phase-heading {
    font-size: 14px;
    margin: 16px 0 8px;
  }

  /* tile grid: 2 columns on phones */
  .size-tiles {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  /* settings drawer should behave like a bottom sheet / full-screen panel */
  .settings-drawer {
    width: 100vw;
    max-width: 100vw;
    height: 100vh;
    max-height: 100vh;
    border-radius: 0;
    margin: 0;
  }

  .drawer-content {
    padding-bottom: 90px; /* room for footer button */
  }

  .drawer-footer {
    position: sticky;
    bottom: 0;
    background: white;
    padding: 12px;
    border-top: 1px solid rgba(0,0,0,0.08);
  }
}
