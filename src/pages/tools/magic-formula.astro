---
import Layout from "../../layouts/Layout.astro";
import Tooltip from "../../components/Tooltip.astro";
import PrintFooter from "../../components/common/PrintFooter.astro";
import ActionBar from "../../components/wizards/ActionBar.astro";
import WizardBackLink from "../../components/wizards/WizardBackLink.astro";
import UnitToggle from "../../components/wizards/components/UnitToggle.astro";
import GaugeInput from "../../components/wizards/components/GaugeInput.astro";
import ToolPageHeader from "../../components/tools/ToolPageHeader.astro";
import FloatingInput from "../../components/tools/FloatingInput.astro";
import toolsData from "../../../data/tools.json";
import "../../styles/wizard.css";

const pageTitle = "Magic Formula – Shaping Calculator | Knit it Now";
const pageDescription = "The \"Magic Formula\" is the industry standard for distributing increases or decreases evenly across a slope. Whether you're shaping a sleeve, a neckline, or a waist, just plug in your starting and ending counts to get perfectly spaced instructions. No math, no \"rounding errors,\" just a smooth edge.";
const pageUrl = "tools/magic-formula";
const whyUseText = "Use this tool to evenly distribute increases or decreases across a shaping section. Enter either stitch counts and rows, or measurements and gauge, and get clear pattern-style instructions for one side or both sides of your piece.";

const tools = toolsData as Array<{ href?: string; title?: string; icon?: string }>;
const tool = tools.find((t) => t.href === Astro.url.pathname) ?? null;
---

<Layout title={pageTitle} description={pageDescription}>
  <main class="wizard-page">
    <div class="wizard-shell">
      <WizardBackLink category="tool" />

      <section class="wizard-hero">
        <div class="tool-title-row">
          <ToolPageHeader tool={tool} fallbackTitle="Magic Formula" />
                 </div>
        <p class="wizard-intro">
          Use this tool to evenly distribute increases or decreases across a shaping section. Enter either stitch counts and rows, or measurements and gauge, and the tool will calculate the shaping for one side or both sides of your piece.
        </p>
      </section>

      <div class="action-bar-wrap no-print">
        <ActionBar />
      </div>

      <div class="magic-formula-panel">
        <form id="wizard-form" class="magic-formula-form">
          <p class="input-mode-label">How do you want to calculate your shaping?</p>
          <div class="input-mode-toggle" role="group" aria-label="Input mode">
            <button type="button" class="input-mode-btn active" data-mode="stitch" id="inputModeStitch">
              I know my stitches and rows
            </button>
            <button type="button" class="input-mode-btn" data-mode="measurement" id="inputModeMeasurement">
              I know my measurements
            </button>
          </div>

          <p class="shaping-side-label">Where does the shaping happen?</p>
          <p class="shaping-side-hint">One side = single slope or neckline edge. Both sides = sleeve caps, armholes, or waist shaping.</p>
          <div class="shaping-side-toggle" role="group" aria-label="Shaping side">
            <button type="button" class="shaping-side-btn active" data-side="one" id="shapeOneSide">
              Shaping on one side
            </button>
            <button type="button" class="shaping-side-btn" data-side="both" id="shapeBothSides">
              Shaping on both sides
            </button>
          </div>

          <!-- Stitch/row mode -->
          <div id="stitchModeFields" class="mode-fields">
            <h2 class="panel-h2">Stitch counts and rows</h2>
            <p class="optional-gauge-note">Optional: add gauge to see approximate measurements in the results.</p>
            <GaugeInput id="magicformula" showTitle={false} showToggle={false} />
            <div id="gaugePartialError" class="validation-msg" role="alert" hidden>If you enter one gauge value, enter both.</div>
            <div class="input-row">
              <FloatingInput id="startingStitches" name="startingStitches" label="Starting stitches" type="number" min={1} step={1} placeholder=" " />
              <FloatingInput id="endingStitches" name="endingStitches" label="Ending stitches" type="number" min={0} step={1} placeholder=" " />
            </div>
            <div class="input-row">
              <FloatingInput id="totalRows" name="totalRows" label="Total rows for shaping" type="number" min={1} step={1} placeholder=" " />
            </div>
          </div>

          <!-- Measurement mode -->
          <div id="measurementModeFields" class="mode-fields" hidden>
            <div class="section-header-with-toggle">
              <h2 class="panel-h2">Measurements</h2>
              <UnitToggle id="mf-units" />
            </div>
            <GaugeInput id="magicformula-measure" showTitle={false} showToggle={false} toggleId="mf-units" />
            <div id="measurementGaugeError" class="validation-msg" role="alert" hidden>Measurement mode requires both stitch and row gauge.</div>
            <div class="input-row">
              <FloatingInput id="startingWidth" name="startingWidth" label="Starting width" type="number" min={0.1} step={0.01} placeholder=" " />
              <FloatingInput id="endingWidth" name="endingWidth" label="Ending width" type="number" min={0} step={0.01} placeholder=" " />
            </div>
            <div class="input-row">
              <FloatingInput id="shapingLength" name="shapingLength" label="Shaping length" type="number" min={0.1} step={0.01} placeholder=" " />
            </div>
          </div>

          <div id="validationSummary" class="validation-msg validation-summary" role="alert" hidden></div>
          <div class="form-actions">
            <button type="submit" class="wizard-button" id="calculateBtn">Calculate Shaping</button>
          </div>
        </form>

        <div id="results" class="results no-print" hidden>
          <h2 class="results-title">Your Shaping Instructions</h2>
          <div id="resultsContent" class="results-content print-only-show"></div>
          <div class="results-actions">
            <button type="button" id="copyBtn" class="copy-btn">Copy instructions</button>
          </div>
        </div>
      </div>
    </div>
  </main>

  <PrintFooter url={pageUrl} />

  <style>
    .wizard-hero .wizard-intro-sub { margin-top: 0.5rem; font-size: 0.95rem; color: #6b7280; }
    .tool-title-row { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 0.5rem; }
    .action-bar-wrap { margin-bottom: 1rem; }
    .magic-formula-panel {
      background: #fff;
      padding: 1.75rem;
      border-radius: 12px;
      border: 1px solid #e5e7eb;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
      margin-bottom: 1.5rem;
    }
    @media (max-width: 640px) { .magic-formula-panel { padding: 1.25rem; } }
    .section-header-with-toggle { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; flex-wrap: wrap; }
    .panel-h2 { font-size: 1.1rem; color: #374151; margin: 0 0 1rem 0; }
    .input-mode-label, .shaping-side-label { font-weight: 600; color: #374151; margin: 1rem 0 0.5rem 0; }
    .shaping-side-hint { font-size: 0.85rem; color: #6b7280; margin: 0 0 0.5rem 0; }
    .input-mode-toggle, .shaping-side-toggle {
      display: flex; gap: 0; border-radius: 8px; overflow: hidden; border: 2px solid #d0d5cc; background: #f9fafb;
    }
    .input-mode-btn, .shaping-side-btn {
      flex: 1; padding: 0.65rem 1rem; border: none; background: transparent; font-family: var(--font);
      font-size: 0.9rem; font-weight: 500; color: #6b7280; cursor: pointer; transition: background 0.2s, color 0.2s;
    }
    .input-mode-btn:hover, .shaping-side-btn:hover { background: rgba(82, 104, 45, 0.08); color: #374151; }
    .input-mode-btn.active, .shaping-side-btn.active { background: var(--kbm-green); color: white; }
    .mode-fields { margin-top: 1rem; }
    .input-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
    @media (max-width: 640px) { .input-row { grid-template-columns: 1fr; } }
    .optional-gauge-note { font-size: 0.85rem; color: #6b7280; margin-bottom: 0.5rem; }
    .validation-msg { color: #dc3545; font-size: 0.9rem; margin-top: 0.5rem; }
    .validation-summary { margin-bottom: 0.5rem; }
    .form-actions { margin-top: 1.25rem; }
    .wizard-button {
      padding: 12px 22px; font-size: 1rem; font-weight: 600; border-radius: 8px;
      background: #52682D; color: white; border: none; cursor: pointer; transition: background 0.2s;
    }
    .wizard-button:hover { background: #445626; }
    .results { margin-top: 1.5rem; padding: 1.25rem; background: #f8faf5; border-radius: 12px; border: 2px solid var(--kbm-green); }
    .results-title { color: var(--kbm-green); font-size: 1.15rem; margin: 0 0 0.75rem 0; }
    .results-content { line-height: 1.6; }
    .results-content p { margin: 0.5rem 0; }
    .results-summary { font-weight: 600; color: #374151; margin-top: 0.75rem; }
    .results-approx { font-size: 0.95rem; color: #6b7280; margin-top: 0.5rem; }
    .results-rows-list { font-size: 0.9rem; color: #6b7280; margin-top: 0.75rem; }
    .results-instruction { margin-top: 1rem; padding: 0.75rem; background: #fff; border-radius: 8px; border-left: 4px solid var(--kbm-green); }
    .note-box { margin-top: 1rem; padding: 1rem; background: #fff3cd; border-left: 4px solid #ffc107; border-radius: 4px; font-size: 0.9rem; }
    .note-box.info { background: #e8f4fd; border-left-color: #0d6efd; }
    .note-box.error { background: #f8d7da; border-left-color: #dc3545; }
    /* Simple vs Smoother shaping (mirror Triangle Tool) */
    :global(.distributed-option-row) { display: flex; align-items: center; gap: 8px; margin-top: 16px; flex-wrap: wrap; }
    :global(.distributed-toggle-link) { padding: 0; border: 0; background: none; color: #52682D; font-size: 14px; font-weight: 600; text-decoration: underline; cursor: pointer; }
    :global(.distributed-toggle-link:hover) { color: #445925; }
    :global(.distributed-toggle-link:focus-visible) { outline: 2px solid #52682D; outline-offset: 2px; }
    :global(.help-icon-btn) { width: 24px; height: 24px; border-radius: 50%; border: 1px solid #52682D; background: #fff; color: #52682D; font-size: 14px; font-weight: 700; line-height: 1; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; }
    :global(.help-icon-btn:hover) { background: rgba(82, 104, 45, 0.1); }
    :global(.help-icon-btn:focus-visible) { outline: 2px solid #52682D; outline-offset: 2px; }
    :global(.distributed-help-panel) { margin-top: 10px; padding: 12px; border: 1px solid #d8d8d8; border-radius: 10px; background: #f9f9f9; max-width: 520px; }
    :global(.distributed-help-panel img) { display: block; width: 100%; height: auto; }
    :global(.distributed-help-panel p) { margin-top: 10px; font-size: 14px; line-height: 1.5; color: #555; }
    :global(#distributed-instructions) { margin-top: 14px; padding: 12px; border-left: 4px solid #52682D; background: #f8f8f8; }
    :global(.distributed-instructions-title) { margin: 0 0 6px 0; font-size: 1rem; font-weight: 700; }
    :global(.distributed-instructions-intro) { margin: 0 0 12px 0; font-size: 14px; color: #555; line-height: 1.5; }
    .copy-btn { margin-top: 1rem; padding: 0.65rem 1.25rem; background: white; color: var(--kbm-green); border: 2px solid var(--kbm-green); border-radius: 6px; font-weight: 500; cursor: pointer; transition: all 0.2s; }
    .copy-btn:hover { background: var(--kbm-green); color: white; }
    @media print {
      .no-print { display: none !important; }
      .results { border: none !important; background: white !important; }
      .print-only-show { display: block !important; }
    }
  </style>

  <script define:vars={{ pageUrl }}>
    (function() {
      const form = document.getElementById('wizard-form');
      const stitchModeFields = document.getElementById('stitchModeFields');
      const measurementModeFields = document.getElementById('measurementModeFields');
      const inputModeStitch = document.getElementById('inputModeStitch');
      const inputModeMeasurement = document.getElementById('inputModeMeasurement');
      const shapeOneSide = document.getElementById('shapeOneSide');
      const shapeBothSides = document.getElementById('shapeBothSides');
      const resultsEl = document.getElementById('results');
      const resultsContent = document.getElementById('resultsContent');
      const validationSummary = document.getElementById('validationSummary');
      const calculateBtn = document.getElementById('calculateBtn');
      const copyBtn = document.getElementById('copyBtn');

      let inputMode = 'stitch';
      let useCm = false;

      function getUnit() {
        const unitInput = document.getElementById('unit');
        if (unitInput) return unitInput.value === 'cm' ? 'cm' : 'in';
        const cmBtn = document.getElementById('mf-units-btn-cm');
        return cmBtn && cmBtn.classList.contains('active') ? 'cm' : 'in';
      }

      function getInputValue(id) {
        const el = document.getElementById(id);
        if (!el || el.tagName !== 'INPUT') return '';
        return el.value == null ? '' : String(el.value).trim();
      }

      function setInputMode(mode) {
        inputMode = mode;
        if (stitchModeFields) stitchModeFields.hidden = mode !== 'stitch';
        if (measurementModeFields) measurementModeFields.hidden = mode !== 'measurement';
        document.querySelectorAll('.input-mode-btn').forEach(btn => {
          btn.classList.toggle('active', btn.getAttribute('data-mode') === mode);
        });
      }

      function getShapingSide() {
        const active = document.querySelector('.shaping-side-btn.active');
        return active && active.getAttribute('data-side') === 'both' ? 'both-sides' : 'one-side';
      }

      // ---------- Validation ----------
      function validateInput(input) {
        const errors = [];
        if (input.inputMode === 'stitches') {
          if (input.startingStitches == null || input.startingStitches < 1) errors.push('Starting stitches must be greater than 0.');
          if (input.endingStitches == null || input.endingStitches < 0) errors.push('Ending stitches must be 0 or more.');
          if (input.totalRows == null || input.totalRows < 1) errors.push('Total rows must be greater than 0.');
        } else {
          if (input.startingWidth == null || input.startingWidth <= 0) errors.push('Starting width must be greater than 0.');
          if (input.endingWidth == null || input.endingWidth < 0) errors.push('Ending width must be 0 or more.');
          if (input.shapingLength == null || input.shapingLength <= 0) errors.push('Shaping length must be greater than 0.');
          if (!input.stitchGauge || input.stitchGauge <= 0) errors.push('Stitch gauge is required and must be greater than 0.');
          if (!input.rowGauge || input.rowGauge <= 0) errors.push('Row gauge is required and must be greater than 0.');
        }
        return { isValid: errors.length === 0, errors };
      }

      // ---------- Gauge conversion (per 4 in or 10 cm) ----------
      function convertMeasurementsToStitchesAndRows(input) {
        const units = input.units === 'cm' ? 'cm' : 'in';
        const div = units === 'cm' ? 10 : 4;
        const stitchesPerUnit = input.stitchGauge / div;
        const rowsPerUnit = input.rowGauge / div;
        const startingStitches = Math.round(input.startingWidth * stitchesPerUnit);
        const endingStitches = Math.round(input.endingWidth * stitchesPerUnit);
        let totalRows = Math.round(input.shapingLength * rowsPerUnit);
        if (totalRows < 1) totalRows = 1;
        return { startingStitches, endingStitches, totalRows, units };
      }

      // ---------- Shaping engine ----------
      function runShapingEngine(normalized) {
        const result = {
          isValid: true,
          errors: [],
          noShaping: false,
          steepWarning: false,
          direction: null,
          shapingSides: normalized.shapingSides,
          startingStitches: normalized.startingStitches,
          endingStitches: normalized.endingStitches,
          totalRows: normalized.totalRows,
          totalChange: 0,
          shapingEvents: 0,
          hasRemainderStitch: false,
          shortInterval: 0,
          longInterval: 0,
          shortCount: 0,
          longCount: 0,
          rowList: [],
          breakdown: [],
          measurementSummary: normalized.measurementSummary || null,
          approximateLength: normalized.approximateLength || null
        };

        const totalChange = Math.abs(normalized.startingStitches - normalized.endingStitches);
        result.totalChange = totalChange;

        if (normalized.endingStitches > normalized.startingStitches) result.direction = 'increase';
        else if (normalized.endingStitches < normalized.startingStitches) result.direction = 'decrease';
        else {
          result.noShaping = true;
          return result;
        }

        let shapingEvents;
        if (normalized.shapingSides === 'one-side') {
          shapingEvents = totalChange;
        } else {
          shapingEvents = Math.floor(totalChange / 2);
          result.hasRemainderStitch = (totalChange % 2) === 1;
        }
        result.shapingEvents = shapingEvents;

        if (shapingEvents === 0) {
          result.noShaping = true;
          return result;
        }

        let totalRows = normalized.totalRows;
        let intervalExact = totalRows / shapingEvents;
        let shortInterval = Math.floor(intervalExact);
        let longInterval = Math.ceil(intervalExact);

        if (shortInterval < 1) {
          result.steepWarning = true;
          shapingEvents = Math.min(shapingEvents, totalRows);
          result.shapingEvents = shapingEvents;
          if (shapingEvents === 0) {
            result.noShaping = true;
            return result;
          }
          intervalExact = totalRows / shapingEvents;
          shortInterval = Math.floor(intervalExact);
          longInterval = Math.ceil(intervalExact);
          if (shortInterval < 1) shortInterval = 1;
          if (longInterval < 1) longInterval = 1;
        }

        let shortCount, longCount;
        if (shortInterval === longInterval) {
          shortCount = shapingEvents;
          longCount = 0;
        } else {
          longCount = totalRows - (shortInterval * shapingEvents);
          shortCount = shapingEvents - longCount;
          if (longCount < 0) longCount = 0;
          if (shortCount < 0) shortCount = 0;
        }
        result.shortInterval = shortInterval;
        result.longInterval = longInterval;
        result.shortCount = shortCount;
        result.longCount = longCount;

        const steps = [];
        if (longCount > 0) steps.push({ sts: 1, rows: longInterval, times: longCount });
        if (shortCount > 0) steps.push({ sts: 1, rows: shortInterval, times: shortCount });
        const sideMode = normalized.shapingSides === 'both-sides' ? 'both' : 'one';
        const multiplier = sideMode === 'both' ? 2 : 1;
        const locationText = sideMode === 'both' ? 'Both sides' : 'One side';
        const actionVerb = result.direction === 'decrease' ? 'Decrease' : 'Increase';
        let currentStitches = normalized.startingStitches;
        let currentRow = 0;
        const breakdown = [];
        const rowList = [];
        for (const step of steps) {
          const { sts, rows: interval, times } = step;
          for (let i = 0; i < times; i++) {
            currentRow += interval;
            if (result.direction === 'decrease') currentStitches -= sts * multiplier;
            else currentStitches += sts * multiplier;
            breakdown.push({
              rowNumber: currentRow,
              action: `${actionVerb} ${sts} ${sts === 1 ? 'stitch' : 'stitches'}`,
              location: locationText,
              stitchesAfter: currentStitches
            });
            rowList.push(currentRow);
          }
        }
        result.breakdown = breakdown;
        result.rowList = rowList;
        return result;
      }

      // ---------- Build normalized input from form ----------
      function getNormalizedInput() {
        const units = getUnit() === 'cm' ? 'cm' : 'in';
        const div = units === 'cm' ? 10 : 4;
        const input = {
          inputMode: inputMode === 'stitch' ? 'stitches' : 'measurements',
          shapingSides: getShapingSide(),
          units
        };
        if (inputMode === 'stitch') {
          input.startingStitches = parseInt(getInputValue('startingStitches'), 10);
          input.endingStitches = parseInt(getInputValue('endingStitches'), 10);
          input.totalRows = parseInt(getInputValue('totalRows'), 10);
          const sg = getInputValue('magicformula-stitch-gauge');
          const rg = getInputValue('magicformula-row-gauge');
          const hasSg = sg !== '' && !isNaN(Number(sg)) && Number(sg) >= 1;
          const hasRg = rg !== '' && !isNaN(Number(rg)) && Number(rg) >= 1;
          if (hasSg && hasRg) {
            input.stitchGauge = Number(sg);
            input.rowGauge = Number(rg);
            input.approximateLength = input.totalRows / (input.rowGauge / div);
          }
        } else {
          input.stitchGauge = Number(getInputValue('magicformula-measure-stitch-gauge'));
          input.rowGauge = Number(getInputValue('magicformula-measure-row-gauge'));
          input.startingWidth = parseFloat(getInputValue('startingWidth'));
          input.endingWidth = parseFloat(getInputValue('endingWidth'));
          input.shapingLength = parseFloat(getInputValue('shapingLength'));
          const converted = convertMeasurementsToStitchesAndRows(input);
          input.startingStitches = converted.startingStitches;
          input.endingStitches = converted.endingStitches;
          input.totalRows = converted.totalRows;
          input.measurementSummary = {
            startingWidth: input.startingWidth,
            endingWidth: input.endingWidth,
            shapingLength: input.shapingLength,
            units
          };
        }
        return input;
      }

      // Even distribution for "smoother" option (same as Triangle Tool)
      function calculateEvenDistribution(totalRows, shapingEvents) {
        const rows = [];
        const step = totalRows / shapingEvents;
        for (let i = 1; i <= shapingEvents; i++) {
          rows.push(Math.round(i * step));
        }
        return rows;
      }

      // ---------- Row-number schedule (cumulative, long intervals spread evenly) ----------
      function buildShapingRows(result) {
        const shapingRows = [];
        const { shapingEvents, shortInterval, longInterval, shortCount, longCount, totalRows } = result;
        if (shapingEvents <= 0) return shapingRows;
        let currentRow = 0;
        if (longCount === 0) {
          for (let i = 0; i < shapingEvents; i++) {
            currentRow += shortInterval;
            currentRow = Math.min(currentRow, totalRows);
            shapingRows.push(currentRow);
          }
        } else if (shortCount === 0) {
          for (let i = 0; i < shapingEvents; i++) {
            currentRow += longInterval;
            currentRow = Math.min(currentRow, totalRows);
            shapingRows.push(currentRow);
          }
        } else {
          const spacing = shapingEvents / longCount;
          const longIndices = new Set();
          for (let k = 0; k < longCount; k++) {
            longIndices.add(Math.min(shapingEvents - 1, Math.floor(k * spacing)));
          }
          for (let i = 0; i < shapingEvents; i++) {
            const interval = longIndices.has(i) ? longInterval : shortInterval;
            currentRow += interval;
            currentRow = Math.min(currentRow, totalRows);
            shapingRows.push(currentRow);
          }
        }
        return shapingRows;
      }

      // ---------- Pattern wording from result ----------
      function formatPatternInstructions(result) {
        const action = result.direction === 'increase' ? 'Increase' : 'Decrease';
        const oneEdge = 'at one edge';
        const eachEdge = 'at each edge';
        const isOne = result.shapingSides === 'one-side';
        const edge = isOne ? oneEdge : eachEdge;
        const rowWord = (n) => n === 1 ? 'row' : `${n}th row`;
        const singleInterval = result.longCount === 0 || result.shortCount === 0;
        const interval = result.longCount > 0 ? result.longInterval : result.shortInterval;
        const times = result.longCount > 0 ? result.longCount : result.shortCount;
        if (singleInterval) {
          return `${action} 1 stitch ${edge} every ${rowWord(interval)} ${times} times.`;
        }
        const parts = [];
        if (result.longCount > 0) parts.push(`every ${rowWord(result.longInterval)} ${result.longCount} times`);
        if (result.shortCount > 0) parts.push(`every ${rowWord(result.shortInterval)} ${result.shortCount} times`);
        if (isOne) {
          return `Work shaping ${result.shapingEvents} times total:\n  • ${parts.join('\n  • ')}`;
        }
        return `Work shaping at both edges ${result.shapingEvents} times total:\n  • ${parts.join('\n  • ')}`;
      }

      function runCalculation() {
        validationSummary.hidden = true;
        validationSummary.textContent = '';
        document.getElementById('gaugePartialError').hidden = true;
        document.getElementById('measurementGaugeError').hidden = true;

        if (inputMode === 'stitch') {
          const sg = getInputValue('magicformula-stitch-gauge');
          const rg = getInputValue('magicformula-row-gauge');
          const hasSg = sg !== '' && !isNaN(Number(sg)) && Number(sg) >= 1;
          const hasRg = rg !== '' && !isNaN(Number(rg)) && Number(rg) >= 1;
          if (hasSg !== hasRg) {
            document.getElementById('gaugePartialError').hidden = false;
            validationSummary.textContent = 'If you enter one gauge value, enter both.';
            validationSummary.hidden = false;
            return;
          }
        }

        const rawInput = getNormalizedInput();
        const validation = validateInput(rawInput);
        if (!validation.isValid) {
          validationSummary.textContent = validation.errors.join(' ');
          validationSummary.hidden = false;
          return;
        }

        const result = runShapingEngine(rawInput);

        if (result.noShaping) {
          resultsContent.innerHTML = `<p><strong>No shaping is needed for this section.</strong></p><p>Starting and ending stitch counts are the same (${result.startingStitches} stitches). Knit ${result.totalRows} rows with no increases or decreases.</p>`;
          resultsEl.hidden = false;
          resultsEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          window.currentInstructions = resultsContent.innerText;
          return;
        }

        const action = result.direction === 'increase' ? 'Increase' : 'Decrease';
        const actionLower = result.direction === 'increase' ? 'increasing' : 'decreasing';
        const sideText = result.shapingSides === 'both-sides' ? 'both sides' : 'one side';
        let html = '';

        if (result.measurementSummary) {
          const u = result.measurementSummary.units === 'cm' ? 'cm' : '"';
          const m = result.measurementSummary;
          html += `<div class="note-box info"><strong>Your measurements:</strong> ${m.startingWidth}${u} → ${result.startingStitches} sts; ${m.endingWidth}${u} → ${result.endingStitches} sts; ${m.shapingLength}${u} length → ${result.totalRows} rows.</div>`;
        }

        html += `<p class="results-summary"><strong>Summary</strong></p>`;
        html += `<p>Shaping type: <strong>${result.direction}</strong>. Worked on <strong>${sideText}</strong>.</p>`;
        html += `<p>Starting stitches: <strong>${result.startingStitches}</strong> → Ending stitches: <strong>${result.endingStitches}</strong>. Total stitch change: <strong>${result.totalChange}</strong>. Total rows: <strong>${result.totalRows}</strong>. Shaping events: <strong>${result.shapingEvents}</strong>.</p>`;

        if (result.steepWarning) {
          html += `<div class="note-box error"><strong>Note:</strong> There are more shaping events than rows available. This shaping is steeper than a standard every-row distribution. The instructions below are a best-effort fit.</div>`;
        }
        if (result.hasRemainderStitch) {
          html += `<div class="note-box info">This stitch difference is not perfectly symmetrical across both sides. The instructions below distribute the symmetrical portion, with 1 stitch remaining to handle separately.</div>`;
        }
        if (result.approximateLength != null) {
          const u = getUnit() === 'cm' ? 'cm' : 'in';
          const str = u === 'cm' ? Math.round(result.approximateLength) + ' cm' : result.approximateLength.toFixed(1) + ' in';
          html += `<p class="results-approx">This shaping section is approximately <strong>${str}</strong> long.</p>`;
        }

        html += '<p class="results-instruction"><strong>Instructions</strong></p>';
        html += `<p>${formatPatternInstructions(result)}</p>`;
        if (result.shortCount > 0 && result.longCount > 0) {
          html += `<p class="note-box"><strong>Tip:</strong> Alternate between the two row intervals to spread the shaping evenly over ${result.totalRows} rows.</p>`;
        }

        const shapingRows = buildShapingRows(result);
        const rowLabel = result.direction === 'decrease' ? 'Decrease rows:' : 'Increase rows:';
        const rowListText = shapingRows.length > 0 ? shapingRows.join(', ') : '';
        if (rowListText) {
          html += `<p class="results-rows-list"><strong>${rowLabel}</strong><br>${rowListText}</p>`;
        }

        const smootherRows = calculateEvenDistribution(result.totalRows, result.shapingEvents);
        const smootherRowsText = smootherRows.join(', ');
        const smootherSummary = `Shaping events: ${result.shapingEvents}. Total rows: ${result.totalRows}.`;

        html += `
          <div class="distributed-option-row">
            <button type="button" class="distributed-toggle-link" id="distributed-toggle" aria-expanded="false" aria-controls="distributed-instructions">Show smoother shaping option</button>
            <button type="button" class="help-icon-btn" id="distributed-help-toggle" aria-expanded="false" aria-controls="distributed-help-panel" aria-label="Show help for smoother shaping option">?</button>
          </div>
          <div class="distributed-help-panel" id="distributed-help-panel" hidden>
            <img src="/images/tools/decrease-distribution-compare.svg" alt="Comparison of evenly distributed decreases and simple decreases" />
            <p>Evenly distributed shaping spreads the ${result.direction}s more smoothly across the rows. Simple shaping uses fixed intervals, which can create a more stepped look.</p>
          </div>
          <div id="distributed-instructions" hidden>
            <div class="distributed-instructions-inner">
              <h4 class="distributed-instructions-title">Smoother Shaping Option</h4>
              <p class="distributed-instructions-intro">This version spreads the shaping more evenly across the rows.</p>
              <p><strong>${rowLabel}</strong><br>${smootherRowsText}</p>
              <p><strong>Shaping Summary</strong><br>${smootherSummary}</p>
            </div>
          </div>`;

        resultsContent.innerHTML = html;

        const distributedToggle = document.getElementById('distributed-toggle');
        const distributedSection = document.getElementById('distributed-instructions');
        if (distributedToggle && distributedSection) {
          distributedToggle.addEventListener('click', () => {
            const isHidden = distributedSection.hidden;
            distributedSection.hidden = !isHidden;
            distributedToggle.setAttribute('aria-expanded', String(!isHidden));
            distributedToggle.textContent = isHidden ? 'Hide smoother shaping option' : 'Show smoother shaping option';
          });
        }
        const distributedHelpPanel = document.getElementById('distributed-help-panel');
        const distributedHelpToggle = document.getElementById('distributed-help-toggle');
        if (distributedHelpToggle && distributedHelpPanel) {
          distributedHelpToggle.addEventListener('click', () => {
            const wasHidden = distributedHelpPanel.hidden;
            distributedHelpPanel.hidden = !wasHidden;
            distributedHelpToggle.setAttribute('aria-expanded', String(!wasHidden));
          });
        }

        resultsEl.hidden = false;
        window.currentInstructions = resultsContent.innerText;
        resultsEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }

      inputModeStitch.addEventListener('click', () => setInputMode('stitch'));
      inputModeMeasurement.addEventListener('click', () => setInputMode('measurement'));

      shapeOneSide.addEventListener('click', () => {
        document.querySelectorAll('.shaping-side-btn').forEach(b => b.classList.remove('active'));
        shapeOneSide.classList.add('active');
      });
      shapeBothSides.addEventListener('click', () => {
        document.querySelectorAll('.shaping-side-btn').forEach(b => b.classList.remove('active'));
        shapeBothSides.classList.add('active');
      });

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        runCalculation();
      });

      copyBtn.addEventListener('click', () => {
        if (window.currentInstructions) {
          navigator.clipboard.writeText(window.currentInstructions).then(() => {
            const orig = copyBtn.textContent;
            copyBtn.textContent = 'Copied!';
            setTimeout(() => { copyBtn.textContent = orig; }, 2000);
          });
        }
      });

      window.addEventListener('kbm:units-change', (e) => {
        useCm = e.detail && e.detail.unit === 'cm';
      });
    })();
  </script>
</Layout>
