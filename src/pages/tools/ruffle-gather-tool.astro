---
import Layout from "../../layouts/Layout.astro";
import WizardBackLink from "../../components/wizards/WizardBackLink.astro";
import ToolPageHeader from "../../components/tools/ToolPageHeader.astro";
import toolsData from "../../../data/tools.json";
import "../../styles/wizard.css";
import FloatingInput from "../../components/tools/FloatingInput.astro";
import ToolResultCard from "../../components/tools/ToolResultCard.astro";
import ToolHelpToggle from "../../components/tools/ToolHelpToggle.astro";

const tools = toolsData as Array<{ href?: string; title?: string; icon?: string }>;
const tool = tools.find((t) => t.href === Astro.url.pathname) ?? null;
---

<Layout title="Ruffle / Gather — One-Row Distribution | Knit by Machine" description="Distribute increases or decreases evenly across a single row. Enter starting and ending stitches and edge stitches to get clear machine-knitting instructions.">
  <main class="wizard-page">
    <div class="wizard-shell">
      <WizardBackLink category="tool" />

      <section class="wizard-hero">
        <ToolPageHeader tool={tool} fallbackTitle="Ruffle / Gather — One-Row Distribution" />
        <p class="wizard-intro">
          Stop guessing.  Get precise instructions for increasing or decreasing a number of stitches across a row.       </p>
        
      </section>

      <div class="dist-calculator-panel kbm-tool-calculator-area">
        <h2>Enter Your Numbers</h2>
        <form id="distForm">
          <div class="dist-input-grid">
            <FloatingInput
              id="startingStitches"
              name="startingStitches"
              label="Starting stitches"
              type="number"
              min={1}
              step={1}
              placeholder=" "
            />
            <FloatingInput
              id="endingStitches"
              name="endingStitches"
              label="Ending stitches"
              type="number"
              min={1}
              step={1}
              placeholder=" "
            />
            <div class="dist-field-with-help">
              <FloatingInput
                id="edgeStitches"
                name="edgeStitches"
                label="Leave edge stitches untouched (each side)"
                type="number"
                min={0}
                step={1}
                value={2}
                placeholder=" "
              />
              <ToolHelpToggle title="What does “each side” mean?">
                <p>This is the number of stitches you leave unchanged on the <strong>left</strong> edge and the same number on the <strong>right</strong> edge. All shaping happens only in the middle (working area). For example, 2 means 2 stitches untouched on the left and 2 on the right (4 total edge stitches).</p>
              </ToolHelpToggle>
            </div>
          </div>
          <div class="dist-actions">
            <button type="button" id="calculateDist" class="wizard-button">
              Calculate
            </button>
          </div>
          <div id="distValidation" class="dist-validation" role="alert" hidden></div>
        </form>
      </div>

      <ToolResultCard id="distResults" hidden title="Your One-Row Distribution" resultsContentId="distResultsContent">
        <div id="distDiagramWrap" class="dist-diagram-wrap" slot="diagram" aria-hidden="true"></div>
      </ToolResultCard>
    </div>
  </main>

  <style>
    .wizard-hero .wizard-intro-sub {
      margin-top: 0.5rem;
      font-size: 0.95rem;
      color: #6b7280;
    }

    .dist-calculator-panel {
      background: #fff;
      padding: 1.75rem;
      border-radius: 12px;
      border: 1px solid #e5e7eb;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
      margin-bottom: 1.5rem;
    }

    @media (max-width: 640px) {
      .dist-calculator-panel {
        padding: 1.25rem;
      }
    }

    .dist-input-grid {
      display: flex;
      flex-direction: column;
      gap: 20px;
      margin-top: 16px;
    }

    .dist-field-with-help {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .dist-actions {
      margin-top: 20px;
    }

    .dist-actions .wizard-button {
      padding: 12px 22px;
      font-size: 1rem;
      font-weight: 600;
      border-radius: 8px;
      background: #52682D;
      color: white;
      border: none;
      cursor: pointer;
    }

    .dist-actions .wizard-button:hover {
      background: #445925;
    }

    .dist-validation {
      margin-top: 20px;
      padding: 14px 18px;
      border-left: 6px solid #d9534f;
      background: #fff4f4;
      border-radius: 6px;
      font-size: 0.95rem;
      color: #333;
    }

    .dist-validation:not([hidden]) {
      display: block;
    }

    .dist-result-summary {
      font-size: 1.2rem;
      font-weight: 700;
      color: #52682D;
      margin-bottom: 1rem;
    }

    .dist-stats {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-bottom: 1.25rem;
    }

    .dist-stat-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 1rem;
    }

    .dist-stat-label {
      font-size: 0.95rem;
      color: #374151;
    }

    .dist-stat-value {
      font-weight: 600;
      color: #2f3a2f;
    }

    .dist-instructions-block {
      border-left: 4px solid #52682D;
      padding-left: 16px;
      margin: 1rem 0;
      font-size: 1rem;
      line-height: 1.6;
    }

    .dist-instructions-block p {
      margin: 0 0 0.5em 0;
    }

    .dist-instructions-block p:last-child {
      margin-bottom: 0;
    }

    .dist-pattern-line {
      font-size: 0.95rem;
      color: #4b5563;
      font-style: italic;
      margin-top: 0.5rem;
    }

    .dist-tip-block {
      margin-top: 1.25rem;
      padding: 14px 18px;
      background: #f4f7ef;
      border-left: 4px solid #52682D;
      border-radius: 6px;
      font-size: 0.95rem;
      line-height: 1.5;
    }

    .dist-tip-block strong {
      display: block;
      margin-bottom: 4px;
    }

    .dist-diagram-wrap {
      min-width: 0;
      max-width: 520px;
    }

    .dist-diagram-wrap svg {
      width: 100%;
      height: auto;
    }

    @media (max-width: 768px) {
      .dist-diagram-wrap {
        max-width: none;
      }
    }
  </style>

  <script>
    const form = document.getElementById("distForm") as HTMLFormElement | null;
    const calculateBtn = document.getElementById("calculateDist");
    const resultsCard = document.getElementById("distResults");
    const resultsContent = document.getElementById("distResultsContent");
    const validationEl = document.getElementById("distValidation");
    const diagramWrap = document.getElementById("distDiagramWrap");

    if (!form || !calculateBtn || !resultsCard || !resultsContent || !validationEl || !diagramWrap) {
      throw new Error("Distribution tool: required elements not found");
    }

    type Mode = "decrease" | "increase" | "none";

    interface DistResult {
      mode: Mode;
      startingStitches: number;
      endingStitches: number;
      edgeEachSide: number;
      protectedTotal: number;
      workingArea: number;
      totalChange: number;
      /** For decrease: rehang counts before each transfer; for increase: hang counts before each empty */
      pattern: number[];
      /** Human pattern line e.g. "4 + transfer, repeated" or "alternate 4 + transfer / 5 + transfer" */
      patternLine: string;
      instructions: string[];
      tip: string;
    }

    function parseInputs(): { start: number; end: number; edge: number } {
      const startRaw = (form!.querySelector("#startingStitches") as HTMLInputElement)?.value ?? "";
      const endRaw = (form!.querySelector("#endingStitches") as HTMLInputElement)?.value ?? "";
      const edgeRaw = (form!.querySelector("#edgeStitches") as HTMLInputElement)?.value ?? "";
      return {
        start: parseInt(startRaw, 10) || 0,
        end: parseInt(endRaw, 10) || 0,
        edge: parseInt(edgeRaw, 10) || 0,
      };
    }

    function validate(start: number, end: number, edge: number): string[] {
      const errors: string[] = [];
      if (start < 1) errors.push("Starting stitches must be at least 1.");
      if (end < 1) errors.push("Ending stitches must be at least 1.");
      if (edge < 0) errors.push("Edge stitches (each side) must be 0 or greater.");
      const protectedTotal = edge * 2;
      if (protectedTotal >= start) {
        errors.push("Starting stitches must be greater than twice the edge stitches (so there is at least one stitch in the working area).");
      }
      const workingArea = start - protectedTotal;
      const totalChange = Math.abs(end - start);
      if (start > end) {
        if (totalChange > workingArea) {
          errors.push("You cannot decrease more stitches than you have in the working area. Total decreases must be less than or equal to the working area.");
        }
      }
      return errors;
    }

    function computeDistribution(start: number, end: number, edge: number): DistResult | null {
      const protectedTotal = edge * 2;
      const workingArea = start - protectedTotal;
      const totalChange = Math.abs(end - start);

      if (end === start) {
        return {
          mode: "none",
          startingStitches: start,
          endingStitches: end,
          edgeEachSide: edge,
          protectedTotal,
          workingArea,
          totalChange: 0,
          pattern: [],
          patternLine: "",
          instructions: [],
          tip: "",
        };
      }

      if (end < start) {
        const rehangsTotal = workingArea - totalChange;
        const base = Math.floor(rehangsTotal / totalChange);
        const remainder = rehangsTotal % totalChange;
        const pattern: number[] = [];
        for (let i = 0; i < totalChange; i++) {
          pattern.push(i < remainder ? base + 1 : base);
        }
        const patternLine = buildDecreasePatternLine(pattern);
        const instructions = buildDecreaseInstructions(edge, pattern, totalChange);
        const tip = "Pro tip: Push the empty needles back before knitting the next row.";
        return {
          mode: "decrease",
          startingStitches: start,
          endingStitches: end,
          edgeEachSide: edge,
          protectedTotal,
          workingArea,
          totalChange,
          pattern,
          patternLine,
          instructions,
          tip,
        };
      }

      const base = Math.floor(workingArea / totalChange);
      const remainder = workingArea % totalChange;
      const pattern: number[] = [];
      for (let i = 0; i < totalChange; i++) {
        pattern.push(i < remainder ? base + 1 : base);
      }
      const patternLine = buildIncreasePatternLine(pattern);
      const instructions = buildIncreaseInstructions(edge, pattern, totalChange);
      const tip = "Pro tip: Push the empty needles back before knitting the next row.";
      return {
        mode: "increase",
        startingStitches: start,
        endingStitches: end,
        edgeEachSide: edge,
        protectedTotal,
        workingArea,
        totalChange,
        pattern,
        patternLine,
        instructions,
        tip,
      };
    }

    function buildDecreasePatternLine(pattern: number[]): string {
      const uniq = [...new Set(pattern)].sort((a, b) => a - b);
      if (uniq.length === 1) {
        return `Pattern: ${uniq[0]} + transfer, repeated`;
      }
      const parts = pattern.map((n) => `${n} + transfer`);
      const simplified = [...new Set(parts)];
      if (simplified.length === 2 && pattern.length === 2) {
        return `Pattern: alternate ${pattern[0]} + transfer / ${pattern[1]} + transfer`;
      }
      return `Pattern: alternate ${parts.join(" / ")}`;
    }

    function buildIncreasePatternLine(pattern: number[]): string {
      const uniq = [...new Set(pattern)].sort((a, b) => a - b);
      if (uniq.length === 1) {
        return `Pattern: ${uniq[0]} stitches, leave 1 empty, repeated`;
      }
      const parts = pattern.map((n) => `${n} stitches, leave 1 empty`);
      return `Pattern: alternate ${parts.join(" / ")}`;
    }

    function buildDecreaseInstructions(edge: number, pattern: number[], totalChange: number): string[] {
      const lines: string[] = [];
      lines.push(`Decrease ${totalChange} stitches across this row.`);
      if (edge > 0) {
        lines.push(`Leave ${edge} stitch${edge === 1 ? "" : "es"} untouched at each edge (left and right).`);
      }
      if (pattern.length === 0) return lines;
      const allSame = pattern.every((n) => n === pattern[0]);
      if (allSame) {
        const n = pattern[0];
        lines.push(`Starting from the left, rehang ${n} stitches, then transfer the next stitch onto the last needle (doubling up). Repeat across the row.`);
      } else {
        const parts = pattern.map((n) => `rehang ${n} stitches, then transfer the next stitch`);
        lines.push(`Starting from the left, alternate between ${parts.join("; and ")}.`);
      }
      return lines;
    }

    function buildIncreaseInstructions(edge: number, pattern: number[], totalChange: number): string[] {
      const lines: string[] = [];
      lines.push(`Increase ${totalChange} stitches across this row.`);
      if (edge > 0) {
        lines.push(`Leave ${edge} stitch${edge === 1 ? "" : "es"} untouched at each edge (left and right).`);
      }
      if (pattern.length === 0) return lines;
      const allSame = pattern.every((n) => n === pattern[0]);
      if (allSame) {
        const n = pattern[0];
        lines.push(`Starting from the left, hang ${n} stitches, leave 1 empty needle, and repeat across the row.`);
      } else {
        const parts = pattern.map((n) => `hang ${n} stitches, leave 1 empty needle`);
        lines.push(`Starting from the left, alternate between ${parts.join("; and ")}.`);
      }
      return lines;
    }

    function renderResult(result: DistResult): void {
      let html = "";

      if (result.mode === "none") {
        html = `
          <p class="dist-result-summary">No shaping needed across this row.</p>
          <p>Starting and ending stitch counts are the same (${result.startingStitches} stitches). Knit the row with no changes.</p>`;
        resultsContent!.innerHTML = html;
        diagramWrap!.innerHTML = "";
        resultsCard!.hidden = false;
        return;
      }

      const summary =
        result.mode === "decrease"
          ? `Decrease ${result.totalChange} stitches across this row.`
          : `Increase ${result.totalChange} stitches across this row.`;

      html = `<p class="dist-result-summary">${summary}</p>`;

      html += `
        <div class="dist-stats">
          <div class="dist-stat-row"><span class="dist-stat-label">Starting stitches</span><span class="dist-stat-value">${result.startingStitches}</span></div>
          <div class="dist-stat-row"><span class="dist-stat-label">Ending stitches</span><span class="dist-stat-value">${result.endingStitches}</span></div>
          <div class="dist-stat-row"><span class="dist-stat-label">Edge stitches left untouched (each side)</span><span class="dist-stat-value">${result.edgeEachSide}</span></div>
          <div class="dist-stat-row"><span class="dist-stat-label">Working area</span><span class="dist-stat-value">${result.workingArea}</span></div>
          <div class="dist-stat-row"><span class="dist-stat-label">Total change</span><span class="dist-stat-value">${result.totalChange}</span></div>
        </div>`;

      html += '<div class="dist-instructions-block"><p>' + result.instructions.join("</p><p>") + "</p>";
      if (result.patternLine) {
        html += `<p class="dist-pattern-line">${result.patternLine}</p>`;
      }
      html += "</div>";

      if (result.mode === "increase") {
        html += `
          <div class="dist-tip-block" role="note">
            <strong>Important</strong>
            Pick up the purl bump from the row below on each empty needle to create the new stitches.
          </div>`;
      }

      html += `
        <div class="dist-tip-block" role="note">
          <strong>Tip</strong>
          ${result.tip}
        </div>`;

      resultsContent!.innerHTML = html;

      diagramWrap!.innerHTML = buildDiagram(result);
      resultsCard!.hidden = false;
    }

    function buildDiagram(result: DistResult): string {
      if (result.mode === "none") return "";

      const totalStitches = result.startingStitches;
      const edge = result.edgeEachSide;
      const maxCells = 48;
      const scale = totalStitches <= maxCells ? 1 : maxCells / totalStitches;
      const w = Math.max(1, Math.round(totalStitches * scale));
      const edgeL = Math.max(0, Math.round(edge * scale));
      const edgeR = Math.max(0, Math.round(edge * scale));
      const workW = Math.max(0, w - edgeL - edgeR);

      const cellSize = 12;
      const rowHeight = cellSize + 4;
      const padding = 24;
      const width = w * cellSize + padding * 2;
      const height = rowHeight + 80;

      const actionIndices: number[] = [];
      if (result.mode === "decrease") {
        let idx = edge;
        for (const rehang of result.pattern) {
          idx += rehang;
          actionIndices.push(idx - 1);
          idx += 1;
        }
      } else {
        let idx = edge;
        for (const hang of result.pattern) {
          idx += hang;
          actionIndices.push(idx);
          idx += 1;
        }
      }

      let cells = "";
      for (let i = 0; i < w; i++) {
        const x = padding + i * cellSize;
        const stitchStart = i / scale;
        const stitchEnd = (i + 1) / scale;
        let fill = "#e5e7eb";
        if (i < edgeL || i >= w - edgeR) fill = "#9ca3af";
        const isAction = actionIndices.some((a) => a >= stitchStart && a < stitchEnd);
        if (isAction && result.mode === "decrease") fill = "#52682D";
        if (isAction && result.mode === "increase") fill = "#d1d5db";
        cells += `<rect x="${x}" y="4" width="${cellSize - 1}" height="${cellSize}" fill="${fill}" stroke="#6b7280" stroke-width="0.5" rx="1"/>`;
      }

      const labelY = rowHeight + 28;
      const leftEdgeX = padding + (edgeL * cellSize) / 2 - 20;
      const workX = padding + edgeL * cellSize + (workW * cellSize) / 2 - 28;
      const rightEdgeX = padding + (w - edgeR) * cellSize + (edgeR * cellSize) / 2 - 24;

      return `
        <svg class="dist-row-diagram" viewBox="0 0 ${width} ${height}" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <title>One row: left edge, working area, right edge${result.mode === "decrease" ? "; transfer points in green" : result.mode === "increase" ? "; empty needles in gray" : ""}</title>
          ${cells}
          <text x="${Math.max(padding, leftEdgeX)}" y="${labelY}" font-size="10" fill="#6b7280" text-anchor="middle">Left edge</text>
          <text x="${workX}" y="${labelY}" font-size="10" fill="#374151" text-anchor="middle">Working area</text>
          <text x="${Math.min(width - padding, rightEdgeX)}" y="${labelY}" font-size="10" fill="#6b7280" text-anchor="middle">Right edge</text>
        </svg>`;
    }

    calculateBtn.addEventListener("click", () => {
      const { start, end, edge } = parseInputs();
      validationEl.hidden = true;
      validationEl.textContent = "";

      const errors = validate(start, end, edge);
      if (errors.length > 0) {
        validationEl.textContent = errors.join(" ");
        validationEl.hidden = false;
        resultsCard.hidden = true;
        return;
      }

      const result = computeDistribution(start, end, edge);
      if (result) renderResult(result);
    });
  </script>
</Layout>
