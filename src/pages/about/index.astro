---
import Layout from "../../layouts/Layout.astro";
import PageHead from "../../components/PageHead.astro";
const updated = "February 20, 2026";
---

<Layout>
  <style>
    .page-wrap h1 {
      font-size: var(--text-xxl);
      margin-bottom: 0.5rem;
    }

    .page-wrap h2 {
      font-size: var(--text-xl);
      margin-top: 2rem;
    }

    .page-wrap p {
      margin: 1rem 0;
      font-size: var(--text-base);
      line-height: 1.6;
    }

    .subhead {
      color: var(--kbm-green);
      font-weight: 600;
      margin-bottom: 1.5rem;
      font-size: var(--text-lg);
    }

    /* ===== Responsive Banner / Placeholder ===== */
    .banner {
      position: relative;
      width: 100%;
      border-radius: 16px;
      overflow: hidden;
      background: linear-gradient(135deg, var(--kbm-green), var(--kbm-green-2));
      color: #fff;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
      margin-bottom: 2rem;

      /* desktop height */
      min-height: 260px;

      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 2rem;
    }

    /* inner text wrapper so we can style headline/text later next to an image */
    .banner-content {
      max-width: 600px;
    }

    .banner-title {
      font-size: var(--text-lg);
      font-weight: 600;
      line-height: 1.3;
      letter-spacing: 0.4px;
      margin: 0 0 .5rem 0;
    }

    .banner-note {
      font-size: var(--text-base);
      line-height: 1.4;
      opacity: 0.9;
      margin: 0;
    }

    /* space reserved for future headshot / product image */
    .banner-photo {
      position: absolute;
      right: 1.5rem;
      bottom: 1.5rem;
      width: 96px;
      height: 96px;
      border-radius: 12px;
      background: rgba(255,255,255,0.15);
      border: 2px solid rgba(255,255,255,0.5);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: var(--text-base);
      font-weight: 600;
      text-align: center;
      line-height: 1.2;
    }

    /* On smaller screens: shorter banner, photo drops below text so it doesn't overlap */
    @media (max-width: 640px) {
      .banner {
        min-height: 180px;
        padding: 1.5rem;
      }

      .banner-photo {
        position: static;
        width: 80px;
        height: 80px;
        margin: 1rem auto 0 auto;
      }

      .banner-content {
        max-width: 100%;
      }
    }

    /* ===== Card Grid ===== */
    .card-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
      margin-top: 2rem;
    }

    @media (max-width: 1024px) {
      .card-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 640px) {
      .card-grid {
        grid-template-columns: 1fr;
      }
    }

    .card {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 16px;
      padding: 1.5rem;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      text-align: center;
    }

    .card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.12);
    }

    .card h3 {
      margin-top: 0;
      font-size: var(--text-lg);
      color: #111827;
    }

    .card p {
      font-size: var(--text-base);
      margin-top: 0.5rem;
    }

    /* ===== Let's Connect box ===== */
    .connect {
      margin-top: 3rem;
      background: #fff;
      border-radius: 12px;
      padding: 1.5rem;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
    }

    .connect h2 {
      margin-top: 0;
      color: var(--kbm-green);
    }

    .connect a {
      color: var(--kbm-green);
      text-decoration: underline;
    }

    /* ===== Back to top button ===== */
    #kbm-top {
      position: fixed;
      bottom: 30px;
      right: 30px;
      width: 46px;
      height: 46px;
      border: none;
      border-radius: 50%;
      background: var(--kbm-green);
      color: #fff;
      font-size: var(--text-xl);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.25);
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.2s ease;
      z-index: 9999;
    }

    #kbm-top.show {
      opacity: 1;
      visibility: visible;
    }

    #kbm-top:hover {
      background: var(--kbm-green-2);
      transform: translateY(-3px);
    }
    
    @media (max-width: 1024px) {
      .page-wrap p {
        line-height: 1.7;
      }
      
      .banner {
        margin-bottom: 1.5rem;
      }
      
      .card {
        padding: 1.25rem;
      }
      
      .connect {
        padding: 1.25rem;
      }
    }

    .about-content {
      max-width: 760px;
      margin: 0 auto;          /* centers the text block */
    }

    .about-photo {
      float: right;
      width: 200px;            /* slightly smaller = better wrap balance */
      margin: 6px 0 18px 28px; /* nudges it down + gives nicer breathing room */
      border-radius: 50%;
      border: 4px solid #f3f3f3;
      box-shadow: 0 4px 10px rgba(0,0,0,0.12);
    }

    /* Prevent extra top gap on the first paragraph after the floated image */
    .about-photo + p { margin-top: 0; }

    /* Make sure sections after the wrapped intro don't get odd float behavior */
    .about-content::after {
      content: "";
      display: table;
      clear: both;
    }

    /* Tighten spacing under the My Story heading a bit */
    .about-content h2,
    .about-content h3 {
      margin-bottom: 10px;
    }

    .kin-card-logo {
      width: 42px;
      height: 42px;
      display: block;
      margin: 0 auto 10px auto;
    }
  </style>

  <div class="page-wrap">
  <PageHead
    title="About Knit it Now"
    breadcrumb="Home / About"
    subhead="Master your knitting machine with confidence. 15+ years of expert guidance for every project."
  />

  <div class="about-content">
  <p>
    Stop struggling with your machine—start finishing projects you love.
  </p>

  <img
    src="/images/sue.jpg"
    alt="Sue Jalowiec at her knitting machine, founder of Knit it Now"
    class="about-photo"
  />

  <p>
    For more than 15 years, Knit it Now has helped machine knitters move past confusing manuals, frustrating setup issues, and piles of unfinished projects. With clear instruction, practical tips, and real examples, you can finally understand how your machine works—and start enjoying the knitting again.
  </p>

  <h2>My Story</h2>
  <p>
    I'm <strong>Sue Jalowiec</strong>, and I know how overwhelming machine knitting can feel—especially when you're trying to figure everything out on your own.
  </p>
  <p>
    That's why I created Knit it Now. My goal has always been simple: take the mystery out of machine knitting and give knitters the clear guidance they need to build confidence, solve problems, and finish projects they're proud of.
  </p>
  <p>
    Over the years, thousands of machine knitters have used Knit it Now to learn new skills, troubleshoot problems, and bring their knitting ideas to life.
  </p>

  <h2>Start Exploring</h2>
  <p>
    Whether you're just getting started or looking to expand your skills, you'll find resources here to help you move forward with confidence.
  </p>
  <p>
    Explore the tutorials, patterns, and guides available throughout the site and discover just how enjoyable machine knitting can be.
  </p>
  </div>

  <h2>What You'll Discover</h2>
  <p>Here's a quick look at what you'll discover inside <strong><strong>Knit It Now</strong> </strong>:</p>

  <div class="card-grid">
    <div class="card">
      <img src="/images/KINlogo.svg" alt="" class="kin-card-logo" aria-hidden="true">
      <h3>Patterns & Wizards</h3>
      <p>Solve common knitting hurdles with expert tips.</p>
    </div>
    <div class="card">
      <img src="/images/KINlogo.svg" alt="" class="kin-card-logo" aria-hidden="true">
      <h3>Tutorials & Tips</h3>
      <p>Master new techniques with clear video lessons.</p>
    </div>
    <div class="card">
      <img src="/images/KINlogo.svg" alt="" class="kin-card-logo" aria-hidden="true">
      <h3>Reference</h3>
      <p>Simplify your setup with go-to technical guides.</p>
    </div>
    <div class="card">
      <img src="/images/KINlogo.svg" alt="" class="kin-card-logo" aria-hidden="true">
      <h3>Support for All Levels</h3>
      <p>Connect with expert advice to keep your projects moving.</p>
    </div>
  </div>

  <p style="margin-top:2rem;">
    Start Knitting with clarity and confidence today.  </p>

  <div class="connect">
    <h2>Let's Connect</h2>
    <p>
      If you'd like help, have a question, or just want to say hello, I'd love to hear from you.<br />
      Reach out anytime at <a href="mailto:contact@knititnow.com">contact@knititnow.com</a>.
    </p>
  </div>

  <button id="kbm-top" aria-label="Back to top">↑</button>

  <script>
    const topBtn = document.getElementById("kbm-top");
    window.addEventListener("scroll", () => {
      if (window.scrollY > 200) topBtn.classList.add("show");
      else topBtn.classList.remove("show");
    });
    topBtn.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  </script>
  </div>
</Layout>
