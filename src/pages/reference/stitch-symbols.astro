---
import Layout from "../../layouts/Layout.astro";
import ReferencePageShell from "../../components/ReferencePageShell.astro";
import symbols from "../../data/reference/stitch-symbols.json";
---

<Layout
  title="Stitch Symbols"
  description="A quick visual reference for commonly used stitch symbols."
>
  <ReferencePageShell
    title="Stitch Symbols"
    subhead="A quick visual reference for commonly used stitch symbols."
    backHref="/learn/reference"
    backLabel="Back to Reference"
  >
    <div class="symbols-reference">
      <div class="symbols-grid">
        {symbols.map((symbol) => (
          <article class="symbol-card">
            <span class="symbol-card__title">{symbol.title}</span>
            <img
              src={`/images/stitchSymbols/${symbol.icon}`}
              alt={symbol.title}
              class="symbol-card__image"
              loading="lazy"
            />
          </article>
        ))}
      </div>
    </div>
  </ReferencePageShell>
</Layout>

<style>
  .symbols-reference {
    background: #fafaf8;
    border: 1px solid #e5e5df;
    border-radius: 18px;
    padding: 1.5rem;
  }

  .symbols-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.1rem;
    align-items: stretch;
  }

  .symbol-card {
    border: 1px solid #e3e3e3;
    background: #fff;
    border-radius: 14px;
    padding: 1rem 0.9rem 1.15rem;
    text-align: center;
  }

  .symbol-card__title {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 3.2rem;
    font-weight: 600;
    font-size: 1.3rem;
    line-height: 1.3;
    margin-bottom: 0.85rem;
    text-align: center;
  }

  .symbol-card__image {
    width: 100%;
    max-width: 90px;
    max-height: 90px;
    height: auto;
    margin: 0 auto;
    display: block;
    object-fit: contain;
  }

  @media (max-width: 640px) {
    .symbols-reference {
      padding: 1rem;
      border-radius: 14px;
    }

    .symbols-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.85rem;
    }

    .symbol-card {
      padding: 0.85rem 0.65rem 0.95rem;
    }

    .symbol-card__title {
      min-height: 2.8rem;
      font-size: 1.05rem;
      margin-bottom: 0.7rem;
    }

    .symbol-card__image {
      max-width: 72px;
      max-height: 72px;
    }
  }

  @media print {
    .symbols-reference {
      background: #fff;
      border: 1px solid #ccc;
      padding: 1rem;
    }

    .symbols-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem;
    }

    .symbol-card {
      break-inside: avoid;
      page-break-inside: avoid;
    }
  }
</style>
