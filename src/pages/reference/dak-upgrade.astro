---

import Layout from "../../layouts/Layout.astro";

const SITE_URL = "https://knitbymachine.com";
const PAGE_PATH = "/reference/designaknit-upgrades";
const CANONICAL_URL = `${SITE_URL}${PAGE_PATH}`;

const EMAIL = "designaknit@knitbymachine.com";

const mailtoHref =
  `mailto:DAKupgrade@knitbymachine.com` +
  `?subject=${encodeURIComponent("DesignaKnit upgrade inquiry (KBM reference page)")}` +
  `&body=${encodeURIComponent(
    "Hi Sue,\n\nI'd like help upgrading DesignaKnit.\n\n- My current DAK version:\n- Hand or Machine:\n- Machine brand/model (if machine):\n- What I'm hoping to do with DAK:\n\nThanks!"
  )}`;


const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": CANONICAL_URL,
      "url": CANONICAL_URL,
      "name": "DesignaKnit 9 Upgrade Pricing",
      "description":
        "DesignaKnit 9 upgrade pricing based on the version you already own. Reference page with contact option.",
      "inLanguage": "en",
      "isPartOf": {
        "@type": "WebSite",
        "@id": `${SITE_URL}/#website`,
        "name": "Knit by Machine",
        "url": SITE_URL
      },
      "about": [
        { "@type": "Thing", "name": "DesignaKnit" },
        { "@type": "Thing", "name": "Machine knitting software" },
        { "@type": "Thing", "name": "DesignaKnit upgrades" }
      ],
      "publisher": {
        "@type": "Organization",
        "name": "Knit by Machine",
        "url": SITE_URL
      }
    },
    {
      "@type": "FAQPage",
      "@id": `${CANONICAL_URL}#faq`,
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How do I purchase a DesignaKnit upgrade?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text":
              "Email Sue with your current DesignaKnit version and what you want to do with the software. Upgrades require version verification before purchase."
          }
        },
        {
          "@type": "Question",
          "name": "Why isn’t there a checkout on this page?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text":
              "DesignaKnit upgrades require version verification. This page keeps pricing easy to reference while purchase details are handled by email."
          }
        },
        {
          "@type": "Question",
          "name": "What information should I include in my email?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text":
              "Include your current DesignaKnit version, whether you use Hand or Machine, your machine brand/model (if applicable), and what you want to make."
          }
        },
        {
          "@type": "Question",
          "name": "Are the prices final?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text":
              "Prices are shown for reference and may change. Final pricing is confirmed at the time of purchase after verification."
          }
        }
      ]
    }
  ]
};

const title = "DesignaKnit 9 Upgrade Pricing | Knit by Machine";
const description = "DesignaKnit 9 upgrade pricing based on the version you already own. Reference page with email purchase option.";
---
<Layout {title} {description}>
  <Fragment slot="head">
    <link rel="canonical" href={CANONICAL_URL} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

<style>
  :root{
    --kbm-green:#738C52;
    --ink:#0f172a;
    --muted:#475569;
    --bg:#f8fafc;
    --card:#ffffff;
    --border:#e2e8f0;
    --soft:#f1f5f9;
    --radius:18px;
    --shadow:0 10px 25px rgba(15,23,42,.08);
  }
  .wrap{max-width:1100px;margin:0 auto;padding:28px 18px 60px}
  .ref-hero{
    background:var(--card);
    border:1px solid var(--border);
    border-radius:calc(var(--radius) + 6px);
    box-shadow:var(--shadow);
    padding:22px 18px;
    margin-bottom:16px;
  }
  .ref-kicker{
    display:inline-block;
    font-size:12px;
    font-weight:800;
    color:var(--kbm-green);
    background:rgba(115,140,82,.12);
    border:1px solid rgba(115,140,82,.25);
    padding:6px 10px;
    border-radius:999px;
  }
  h1{margin:12px 0 8px;font-size:32px}
  .ref-subhead{margin:0;color:var(--muted);max-width:78ch;line-height:1.55}
  .ref-actions{margin-top:14px}
  .btn-primary{
    padding:10px 14px;border-radius:999px;font-weight:800;text-decoration:none;
    background:var(--kbm-green);color:#fff;display:inline-block;
  }
  .ref-footnote{margin-top:12px;font-size:12px;color:var(--muted)}
  .grid{display:grid;grid-template-columns:repeat(12,1fr);gap:14px}
  .card{
    grid-column:span 6;background:var(--card);border:1px solid var(--border);
    border-radius:var(--radius);padding:16px;box-shadow:0 6px 18px rgba(15,23,42,.06);
  }
  .card h2{display:flex;justify-content:space-between;align-items:center;margin:0 0 10px;font-size:18px;gap:12px}
  .tag{
    font-size:12px;font-weight:800;color:var(--kbm-green);
    background:rgba(115,140,82,.12);padding:5px 10px;border-radius:999px;border:1px solid rgba(115,140,82,.25);
    white-space:nowrap;
  }
  ul{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px}
  li{display:flex;justify-content:space-between;gap:12px;padding:10px;background:var(--soft);border:1px solid var(--border);border-radius:14px}
  .item small{display:block;color:var(--muted);margin-top:2px}
  .price{font-weight:900;white-space:nowrap}
  @media (max-width:900px){.card{grid-column:span 12}h1{font-size:28px}}

  /* Modal styles */
  .kbm-modal{position:fixed;inset:0;z-index:9999;display:flex;align-items:center;justify-content:center;opacity:0;visibility:hidden;transition:opacity .2s,visibility .2s}
  .kbm-modal[aria-hidden="false"]{opacity:1;visibility:visible}
  .kbm-modal__overlay{position:absolute;inset:0;background:rgba(15,23,42,.5);backdrop-filter:blur(2px)}
  .kbm-modal__panel{position:relative;background:var(--card);border-radius:var(--radius);box-shadow:var(--shadow);max-width:900px;width:calc(100% - 32px);max-height:calc(100vh - 64px);display:flex;flex-direction:column;overflow:hidden}
  .kbm-modal__header{display:flex;justify-content:space-between;align-items:flex-start;gap:16px;padding:20px 24px;border-bottom:1px solid var(--border)}
  .kbm-modal__title{margin:0;font-size:24px;font-weight:700;color:var(--ink)}
  .kbm-modal__subtitle{margin:4px 0 0;font-size:16px;color:var(--muted)}
  .kbm-modal__close{background:none;border:none;font-size:28px;line-height:1;color:var(--muted);cursor:pointer;padding:0;width:32px;height:32px;display:flex;align-items:center;justify-content:center;border-radius:8px;transition:background .15s}
  .kbm-modal__close:hover{background:var(--soft)}
  .kbm-modal__body{padding:24px;overflow-y:auto}
  .kbm-table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch}
  .kbm-compare{width:100%;border-collapse:collapse;font-size:16px}
  .kbm-compare th,.kbm-compare td{padding:14px 18px;text-align:left;border-bottom:1px solid var(--border)}
  .kbm-compare th{background:var(--soft);font-weight:700;font-size:15px;white-space:nowrap}
  .kbm-compare td:first-child{min-width:280px}
  .kbm-compare td:not(:first-child){text-align:center;white-space:nowrap}
  .kbm-yes{color:var(--kbm-green);font-weight:700}
  .kbm-no{color:var(--muted)}
  .kbm-note{font-size:14px;color:var(--muted);margin-top:4px;font-style:italic}
  .kbm-modal__fineprint{margin:16px 0 0;font-size:15px;color:var(--muted);text-align:center}
  .btn-secondary{padding:8px 14px;border-radius:999px;font-weight:700;font-size:14px;background:var(--soft);color:var(--ink);border:1px solid var(--border);cursor:pointer;margin-top:10px}
  .btn-secondary:hover{background:var(--border)}
</style>

<main class="wrap">
  <header class="ref-hero">
    <span class="ref-kicker">Reference</span>
    <h1>DesignaKnit 9 upgrade pricing</h1>
    <p class="ref-subhead">
            To purchase an upgrade, email me and I’ll confirm the right option and pricing before anything is processed.
    </p>

    <div class="ref-actions">
      <a class="btn-primary" href={mailtoHref}>Email me to purchase an upgrade</a>
    </div>

    <p class="ref-footnote">
      Upgrades require version verification. Prices are shown for reference and may change.
    </p>
    <button class="btn-secondary" type="button" data-open-modal="dakCompare">
      Compare DAK versions
    </button>
  </header>

  <section class="grid" aria-label="DesignaKnit 9 upgrade prices">
    <section class="card">
      <h2>If you have DAK 8 Hand <span class="tag">Upgrade to DAK 9</span></h2>
      <ul><li><span class="item">DAK 9 Hand</span><span class="price">$105</span></li></ul>
    </section>

    <section class="card">
      <h2>If you have DAK 8 Standard <span class="tag">Upgrade to DAK 9</span></h2>
      <ul>
        <li><span class="item">Machine Standard <small>Includes Lace</small></span><span class="price">$170</span></li>
        <li><span class="item">Machine Professional <small>Includes Lace</small></span><span class="price">$230</span></li>
        <li><span class="item">Complete <small>Includes Lace</small></span><span class="price">$290</span></li>
      </ul>
    </section>

    <section class="card">
      <h2>If you have DAK 8 Professional <span class="tag">Upgrade to DAK 9</span></h2>
      <ul>
        <li><span class="item">Machine Standard <small>Includes Lace</small></span><span class="price">$140</span></li>
        <li><span class="item">Machine Professional <small>Includes Lace</small></span><span class="price">$170</span></li>
        <li><span class="item">Complete <small>Includes Lace</small></span><span class="price">$200</span></li>
      </ul>
    </section>

    <section class="card">
      <h2>If you have DAK 8 Complete <span class="tag">Upgrade to DAK 9</span></h2>
      <ul>
        <li><span class="item">Machine Standard <small>Includes Lace</small></span><span class="price">$140</span></li>
        <li><span class="item">Machine Professional <small>Includes Lace</small></span><span class="price">$150</span></li>
        <li><span class="item">Complete <small>Includes Lace</small></span><span class="price">$180</span></li>
      </ul>
    </section>

    <section class="card">
      <h2>If you have DAK 7 <span class="tag">Upgrade to DAK 9</span></h2>
      <ul>
        <li><span class="item">Machine Standard <small>Includes Lace</small></span><span class="price">$250</span></li>
        <li><span class="item">Machine Professional <small>Includes Lace</small></span><span class="price">$350</span></li>
        <li><span class="item">Complete <small>Includes Lace</small></span><span class="price">$418</span></li>
      </ul>
    </section>
  </section>
</main>

<!-- Compare DAK versions modal -->
<div class="kbm-modal" id="dakCompare" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Compare DesignaKnit versions">
  <div class="kbm-modal__overlay" data-close-modal="dakCompare"></div>

  <div class="kbm-modal__panel" role="document">
    <div class="kbm-modal__header">
      <div>
        <h2 class="kbm-modal__title">Compare DesignaKnit versions</h2>
        <p class="kbm-modal__subtitle">Quick scan of what's included in each level.</p>
      </div>
      <button class="kbm-modal__close" type="button" aria-label="Close" data-close-modal="dakCompare">×</button>
    </div>

    <div class="kbm-modal__body">
      <div class="kbm-table-wrap" tabindex="0">
        <table class="kbm-compare" aria-label="DesignaKnit edition comparison table">
          <thead>
            <tr>
              <th></th>
              <th>Hand Knit</th>
              <th>Machine Standard</th>
              <th>Machine Pro</th>
              <th>Complete</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Includes: Standard Garment Styling, Stitch Designer, Interactive Knitting, Graphics Studio</td>
              <td><span class="kbm-yes" aria-label="Included">✓</span></td>
              <td><span class="kbm-yes" aria-label="Included">✓</span></td>
              <td><span class="kbm-yes" aria-label="Included">✓</span></td>
              <td><span class="kbm-yes" aria-label="Included">✓</span></td>
            </tr>

            <tr>
              <td>
                Includes Original Pattern Drafting
                <div class="kbm-note">Garments designed in a higher level may be knitted (but not modified) using Machine Standard.</div>
              </td>
              <td><span class="kbm-yes" aria-label="Included">✓</span></td>
              <td><span class="kbm-no" aria-label="Not included">—</span></td>
              <td><span class="kbm-yes" aria-label="Included">✓</span></td>
              <td><span class="kbm-yes" aria-label="Included">✓</span></td>
            </tr>

            <tr>
              <td>Can use optional cable links to knitting machines</td>
              <td><span class="kbm-no" aria-label="Not included">—</span></td>
              <td><span class="kbm-yes" aria-label="Included">✓</span></td>
              <td><span class="kbm-yes" aria-label="Included">✓</span></td>
              <td><span class="kbm-yes" aria-label="Included">✓</span></td>
            </tr>

            <tr>
              <td>
                Can design and print hand knitting patterns
                <div class="kbm-note">Hand knit stitch patterns can be opened in Machine Standard/Pro, but are treated as machine knit patterns.</div>
              </td>
              <td><span class="kbm-yes" aria-label="Included">✓</span></td>
              <td><span class="kbm-no" aria-label="Not included">—</span></td>
              <td><span class="kbm-no" aria-label="Not included">—</span></td>
              <td><span class="kbm-yes" aria-label="Included">✓</span></td>
            </tr>

            <tr>
              <td>
                Can open hand knitting patterns as machine knitting patterns
                <div class="kbm-note">Machine knit stitch patterns can be opened in Hand Knit, but are treated as hand knit patterns.</div>
              </td>
              <td><span class="kbm-no" aria-label="Not included">—</span></td>
              <td><span class="kbm-yes" aria-label="Included">✓</span></td>
              <td><span class="kbm-yes" aria-label="Included">✓</span></td>
              <td><span class="kbm-yes" aria-label="Included">✓</span></td>
            </tr>

            <tr>
              <td>Can design machine knitting patterns and print KnitLeader, KnitRadar, colour changes printouts, and punch card &amp; mylar templates</td>
              <td><span class="kbm-no" aria-label="Not included">—</span></td>
              <td><span class="kbm-yes" aria-label="Included">✓</span></td>
              <td><span class="kbm-yes" aria-label="Included">✓</span></td>
              <td><span class="kbm-yes" aria-label="Included">✓</span></td>
            </tr>

            <tr>
              <td>Can design using stitch cable crossings over 6 stitches wide</td>
              <td><span class="kbm-yes" aria-label="Included">✓</span></td>
              <td><span class="kbm-no" aria-label="Not included">—</span></td>
              <td><span class="kbm-no" aria-label="Not included">—</span></td>
              <td><span class="kbm-yes" aria-label="Included">✓</span></td>
            </tr>

            <tr>
              <td>Can enter knitting instructions for custom stitch cables</td>
              <td><span class="kbm-yes" aria-label="Included">✓</span></td>
              <td><span class="kbm-no" aria-label="Not included">—</span></td>
              <td><span class="kbm-no" aria-label="Not included">—</span></td>
              <td><span class="kbm-yes" aria-label="Included">✓</span></td>
            </tr>

          </tbody>
        </table>
      </div>

      <p class="kbm-modal__fineprint">
        This comparison is here as a quick reference. If you're unsure which level you need, email me and I'll help you choose.
      </p>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const openBtns = document.querySelectorAll('[data-open-modal]');
    const closeBtns = document.querySelectorAll('[data-close-modal]');

    openBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const modalId = btn.getAttribute('data-open-modal');
        const modal = document.getElementById(modalId);
        if (modal) modal.setAttribute('aria-hidden', 'false');
      });
    });

    closeBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const modalId = btn.getAttribute('data-close-modal');
        const modal = document.getElementById(modalId);
        if (modal) modal.setAttribute('aria-hidden', 'true');
      });
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        document.querySelectorAll('.kbm-modal[aria-hidden="false"]').forEach(modal => {
          modal.setAttribute('aria-hidden', 'true');
        });
      }
    });
  });
</script>
</Layout>
