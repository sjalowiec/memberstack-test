---
import Layout from "../layouts/Layout.astro";
import tools from "../../data/tools.json";

// Group tools by category
const activeTools = tools.filter(tool => tool.active === "TRUE");
const groupedTools = Object.groupBy(activeTools, tool => tool.category);

// Unique category list for filter (All Categories first)
const categories = ["All", ...new Set(tools.map((tool: { category?: string }) => tool.category).filter(Boolean))];
---

<Layout title="Charting Tools">

<section class="tools-page">

  <h1>Charting Tools</h1>

  <p class="tools-intro">
    From complex shaping to gauge conversions, we’ve automated the "knitting math." Plug in your numbers, get your custom chart, and get knitting.
  </p>
 

  <div id="tool-access-filters" class="filter-pills">
    <button type="button" class="filter-pill active" data-filter="all">All</button>
    <button type="button" class="filter-pill" data-filter="free">Free</button>
    <button type="button" class="filter-pill" data-filter="member">Member</button>
  </div>

  <div id="tool-category-filters" class="filter-pills">
    {categories.map((category, index) => (
      <button
        type="button"
        class={`filter-pill ${index === 0 ? "active" : ""}`}
        data-category-filter={category === "All" ? "all" : category}
      >
        {category === "All" ? "All Categories" : category}
      </button>
    ))}
  </div>

  {Object.entries(groupedTools).map(([category, items]) => (
    <section class="tool-category">
      <div class="tool-category-inner">
        <h2>{category}</h2>
        <div class="tools-grid">
          {(items ?? []).map((tool) => {
            const isActive = String(tool.active ?? true).toUpperCase() !== "FALSE";
            const membersOnly = tool.membersonly ?? false;
            const badge = !isActive ? (
              <span class="tool-badge coming">Coming Soon</span>
            ) : membersOnly ? (
              <span class="tool-badge member">🔒 Member</span>
            ) : (
              <span class="tool-badge free">Free</span>
            );
            return isActive ? (
              <a href={tool.href} class="tool-card active" data-members-only={membersOnly} data-category={tool.category}>
                {badge}
                <img
                  src={`/icons/tools/${tool.icon}`}
                  alt=""
                  class="tool-icon"
                />
                <h3>{tool.title} </h3>
                
                <p>{tool.description}</p>
              </a>
            ) : (
              <div class="tool-card inactive" aria-disabled="true" data-members-only={membersOnly} data-category={tool.category}>
                {badge}
                <img
                  src={`/icons/tools/${tool.icon}`}
                  alt=""
                  class="tool-icon"
                />
                <h3>{tool.title}</h3>
                <p>{tool.description}</p>
              </div>
            );
          })}
        </div>
        <div class="tools-coming-soon">
          <span class="tools-coming-soon-icon">✦</span>
          <span>More tools coming to this section</span>
        </div>
      </div>
    </section>
  ))}

</section>

<script>
  const accessButtons = document.querySelectorAll<HTMLButtonElement>("#tool-access-filters .filter-pill");
  const categoryButtons = document.querySelectorAll<HTMLButtonElement>("#tool-category-filters .filter-pill");
  const cards = document.querySelectorAll<HTMLElement>(".tool-card");

  let activeAccessFilter = "all";
  let activeCategoryFilter = "all";

  function applyToolFilters() {
    cards.forEach(card => {
      const isMember = card.dataset.membersOnly === "true";
      const category = card.dataset.category || "";

      const matchesAccess =
        activeAccessFilter === "all" ||
        (activeAccessFilter === "free" && !isMember) ||
        (activeAccessFilter === "member" && isMember);

      const matchesCategory =
        activeCategoryFilter === "all" ||
        category === activeCategoryFilter;

      card.style.display = matchesAccess && matchesCategory ? "" : "none";
    });
  }

  accessButtons.forEach(button => {
    button.addEventListener("click", () => {
      accessButtons.forEach(b => b.classList.remove("active"));
      button.classList.add("active");
      activeAccessFilter = button.dataset.filter || "all";
      applyToolFilters();
    });
  });

  categoryButtons.forEach(button => {
    button.addEventListener("click", () => {
      categoryButtons.forEach(b => b.classList.remove("active"));
      button.classList.add("active");
      activeCategoryFilter = button.dataset.categoryFilter || "all";
      applyToolFilters();
    });
  });

  applyToolFilters();
</script>

<style>

.tools-page{
  max-width:1100px;
  margin:auto;
  padding:40px 20px;
}

.tools-intro{
  max-width:700px;
  margin-bottom:30px;
}

#tool-access-filters.filter-pills {
  margin-top: 20px;
}

#tool-category-filters.filter-pills {
  margin-bottom: 30px;
}

.tool-category{
  margin-top:60px;
}

.tool-category-inner{
  max-width:1100px;
  margin:auto;
}

.tool-category h2{
  background:var(--kbm-green);
  color:white;
  padding:12px 20px;
  border-radius:6px;
  font-size:18px;
  font-weight:600;
  margin-bottom:24px;
}

.tools-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
  gap:28px;
  margin-top:18px;
}

.tool-card{
  position:relative;
  display:block;
  text-decoration:none;
  color:inherit;
  padding:32px 26px;
  text-align:center;
  border-radius:20px;
  border:1px solid #e5e7eb;
  background:white;
}

.tool-badge{
  position:absolute;
  top:0;
  right:0;
  font-size:11px;
  font-weight:600;
  padding:5px 10px;
  border-bottom-left-radius:8px;
  line-height:1.2;
  z-index:2;
}

.tool-badge.member{
  background:#ececec;
  color:#333;
}

.tool-badge.free{
  background:#e8f5e9;
  color:#2e7d32;
}

.tool-badge.coming{
  background:#f3f3f3;
  color:#888;
}

.tool-card.active{
  transition:transform 0.15s ease, box-shadow 0.15s ease;
}

.tool-card.active:hover{
  transform:translateY(-2px);
  box-shadow:0 14px 28px rgba(0,0,0,.08);
}

.tool-card.inactive{
  opacity:0.6;
  cursor:default;
}

.tool-card.inactive h3,
.tool-card.inactive p{
  color:inherit;
}

.tool-icon{
  width:64px;
  height:64px;
  margin-bottom:16px;
}

.tool-card h3{
  margin:8px 0;
  text-decoration:none;
}

.tool-card p{
  font-size:14px;
  color:#555;
  text-decoration:none;
}

.tools-coming-soon {
  margin-top: 1rem;
  font-size: 0.875rem;
  color: #666;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.tools-coming-soon-icon {
  color: var(--kbm-green, #52682d);
}

</style>