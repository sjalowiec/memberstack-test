---
import Header from "../components/Header.astro";
import footer from "../components/footer.astro";
import "../styles/global.css";
---   

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- CRITICAL: Inline typography to prevent Astro CSS bundler reordering issues -->
    <style data-kbm-typography>
      html {
        font-size: 112.5% !important; /* 18px - comfortable mobile reading */
        -webkit-text-size-adjust: 100%;
        text-size-adjust: 100%;
      }
      @media (min-width: 1025px) {
        html {
          font-size: 100% !important; /* 16px for desktop */
        }
      }
    </style>
    
    <title>Start Here | Knit by Machine</title>
    <meta
      name="description"
      content="New to machine knitting? Start here. Find your next step, build skills, and get guidance one small win at a time."
    />
  </head>

  <body>
    <Header />

    <!-- Welcome Banner -->
    <div class="kbm-intro-wrapper" data-testid="welcome-intro-wrapper">
      <div class="kbm-intro-banner" data-testid="welcome-intro-banner">
        <div class="kbm-intro-banner-inner">
          <span class="kbm-intro-banner-text">
            Welcome! Knit by Machine is brand new -
            <button 
              type="button" 
              class="kbm-intro-banner-inline-link" 
              data-testid="button-see-intro"
              aria-haspopup="dialog"
              id="open-intro-drawer"
            >
              see what's here and what's coming.
            </button>
          </span>
        </div>
      </div>
    </div>

    <!-- Right-side Drawer Dialog -->
    <dialog 
      id="intro-drawer" 
      class="kbm-drawer" 
      aria-labelledby="drawer-title"
      aria-describedby="drawer-description"
      data-testid="dialog-intro-drawer"
    >
      <div class="kbm-drawer-content">
        <header class="kbm-drawer-header">
          <h2 id="drawer-title" class="kbm-drawer-title">Clear answers and practical tools for machine knitters</h2>
          <button 
            type="button" 
            class="kbm-drawer-close" 
            aria-label="Close drawer"
            data-testid="button-drawer-close"
          >&times;</button>
        </header>
        <div id="drawer-description" class="kbm-drawer-body">
  <p>
    Knit by Machine is a fresh, focused space for machine knitters who want clear answers and practical tools — without digging through forums or scattered resources.
  </p>

  <p>
    You’ll find planners, tools, and guided help designed to make the next step obvious, whether you’re restarting, refreshing skills, or trying something new.
  </p>
<p> Right now, you’ll find Ask ’n Answer help, practical tools, and guided paths — with more being added as Knit by Machine grows.</p>
  <p>
    New here?
  </p>

  <a
    href="#where-are-you"
    id="drawer-where-link"
    class="kbm-drawer-link"
    data-testid="link-where-drawer"
  >
    See where to start →
  </a>
</div>

    </dialog>

    <script>
      const openBtn = document.getElementById('open-intro-drawer');
      const drawer = document.getElementById('intro-drawer') as HTMLDialogElement;
      const closeBtn = drawer?.querySelector('.kbm-drawer-close');

      function openDrawer() {
        drawer?.showModal();
        drawer?.classList.add('kbm-drawer--open');
      }

      function closeDrawer() {
        drawer?.classList.remove('kbm-drawer--open');
        setTimeout(() => drawer?.close(), 200);
      }

      openBtn?.addEventListener('click', openDrawer);
      closeBtn?.addEventListener('click', closeDrawer);

      drawer?.addEventListener('click', (e) => {
        if (e.target === drawer) {
          closeDrawer();
        }
      });

      drawer?.addEventListener('cancel', (e) => {
        e.preventDefault();
        closeDrawer();
      });

      // Handle "See where to start" link: close drawer, then scroll with offset
      const whereLink = document.getElementById('drawer-where-link');
      whereLink?.addEventListener('click', (e) => {
        e.preventDefault();
        closeDrawer();
        // Wait for drawer close animation (200ms) before scrolling
        setTimeout(() => {
          const headerEl = document.querySelector('header');
          const headerHeight = headerEl ? headerEl.getBoundingClientRect().height : 160;
          const target = document.getElementById('where-are-you');
          if (target) {
            const y = target.getBoundingClientRect().top + window.scrollY - headerHeight - 16;
            window.scrollTo({ top: y, behavior: 'smooth' });
          }
        }, 220);
      });
    </script>

    <main class="kbm-start-here">
      <!-- HERO SECTION -->
      <section class="kbm-hero">
        <div class="kbm-hero__grid">
          <div class="kbm-hero__content">
            <h1>Stop guessing. Get knitting.</h1>
            <p class="kbm-hero__text">
             Get clear, step-by-step guidance so you can start strong, fix issues fast, and finish with confidence.
            </p>
          </div>
          <div class="kbm-hero__image">
            <picture>
              <source srcset="/images/seeit-loveit-knitit.webp" type="image/webp" />
              <img 
                src="/images/machine-knitting-cast-on.webp" 
                alt="Machine knitting in progress with a latch tool fixing stitches on a knitting machine, with the words See it • Love it • Knit it"hine set up and ready to knit." 
                loading="eager"
                data-testid="img-hero"
              />
            </picture>
          </div>
        </div>
      </section>

      <!-- WHERE ARE YOU RIGHT NOW? SECTION -->
      <section id="where-are-you" class="kbm-where-section">
        <div class="kbm-where-inner">
          <div class="kbm-section-header">
            <h2>Where are you right now?</h2>
            <p class="kbm-section-subtitle">Tell me where you are right now, and I’ll point you to the right next step.</p>
            <p class="kbm-section-subtitle kbm-section-subtitle--secondary">There's no wrong choice — each path starts where you are.</p>
          </div>

          <div class="kbm-hex-grid">
          <!-- Card 1: I'm just starting -->
          <a href="/start/just-opened-the-box" class="kbm-hex-card kbm-hex-card--link" data-testid="card-start-phase">
            <div class="kbm-hex-icon">
              <img src="/images/KINlogo.svg" alt="" />
            </div>
            <h3>I'm just getting started</h3>
            <p>Get comfortable with the basics so you can knit your first confident rows.</p>
            <span class="btn primary" data-testid="button-getting-started">Start with the basics</span>
          </a>

          <!-- Card 2: I've knitted a little -->
          <a href="/practice-projects" class="kbm-hex-card kbm-hex-card--link" data-testid="card-skills-phase">
            <div class="kbm-hex-icon">
              <img src="/images/KINlogo.svg" alt="" />  </div>
            <h3>I've knitted a little</h3>
            <p>Build your skills with small, low-pressure projects that actually turn out right.</p>
            <span class="btn primary" data-testid="button-skill-builders">Practice Key Skills</span>
          </a>

          <!-- Card 3: I'm ready to make something -->
          <a href="/patterns" class="kbm-hex-card kbm-hex-card--link" data-testid="card-projects-phase">
            <div class="kbm-hex-icon">
              <img src="/images/KINlogo.svg" alt="" />
            </div>
            <h3>I'm ready to make something</h3>
            <p>These patterns give you a solid place to start. You can follow them as written, or use them as a base for your own ideas.</p>
            <span class="btn primary" data-testid="button-rsk">Start a project</span>
          </a>

          <!-- Card 4: Need help? -->
          <a href="/start-here" class="kbm-hex-card kbm-hex-card--link" data-testid="card-need-help">
            <div class="kbm-hex-icon">
              <img src="/images/KINlogo.svg" alt="" />
            </div>
            <h3>Help Hub</h3>
            <p>Start here and get your next right step.</p>
            <span class="btn primary" data-testid="button-need-help">Start Here</span>
          </a>

          
          </div>
        </div>
      </section>

      <!-- WHAT YOU'LL FIND SECTION -->
      <section class="kbm-reassurance-section">
        <div class="kbm-section-header">
          <h2>What you'll find at Knit by Machine</h2>
          <p class="kbm-section-framing">Straightforward help for getting more done on your machine — without guessing, overwhelm, or endless scrolling online.</p>
          
        </div>

        <div class="kbm-reassurance-grid">
          <div class="kbm-reassurance-item" data-testid="reassurance-next-steps">
            <h4><img src="/images/hex_dark.svg" alt="" class="kbm-reassurance-icon">Clear next steps</h4>
            <p>Know what to do next, without second-guessing. You’ll see one clear, sensible step at a time so you can keep moving without overwhelm.</p>
          </div>

          <div class="kbm-reassurance-item" data-testid="reassurance-tools">
            <h4><img src="/images/hex_dark.svg" alt="" class="kbm-reassurance-icon">Tools that do the hard parts</h4>
            <p>Skip the complicated gauge math, stitch counts, and shaping plans. The tools handle the technical details so you can focus on knitting.</p>
          </div>

          <div class="kbm-reassurance-item" data-testid="reassurance-support">
            <h4><img src="/images/hex_dark.svg" alt="" class="kbm-reassurance-icon">Support when you get stuck</h4>
            <p>Find clear answers and targeted troubleshooters when something goes wrong, so you can fix the problem and keep knitting.</p>
          </div>
        </div>
      </section>

      <!-- ABOUT-LITE STRIP -->
      <section class="kbm-about-strip">
        <div class="kbm-about-strip__inner">
          <div class="kbm-about-strip__image">
            <img src="/images/sue_icon9.png" alt="Sue at a knitting machine." data-testid="img-sue-headshot" />
          </div>
          <div class="kbm-about-strip__content">
            <h3>Clear guidance, from someone who understands machines.</h3>
            <p>
              I'm Sue, your guide here at Knit by Machine. I've helped thousands of knitters feel confident using their machines. I'll walk with you one small win at a time.
            </p>
            <a href="/about" class="kbm-about-link" data-testid="link-about">Learn more about Knit by Machine</a>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  html {
    scroll-behavior: smooth;
  }

  :root {
    --kbm-green: #52682d;
    --kbm-green-hover: #445626;
    --kbm-green-2: #738c52;
    --font: "Poppins", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  body {
    margin: 0;
    background: #f7f8f7;
    font-family: var(--font);
    color: #222;
  }

  /* ========== MAIN WRAPPER ========== */
  .kbm-start-here {
    max-width: 1000px;
    margin: 0 auto;
    padding: 1rem 1.5rem 3rem;
  }

  /* ========== SHARED BUTTON STYLES ========== */
  .btn {
    display: inline-block;
    padding: 0.65rem 1.4rem;
    border-radius: 999px;
    font-size: 0.95rem;
    text-decoration: none;
    font-weight: 500;
    border: 1px solid transparent;
    transition: background-color 0.2s ease;
  }

  .btn.primary {
    background-color: var(--kbm-green);
    color: #fff;
  }

  .btn.primary:hover {
    background-color: var(--kbm-green-hover);
  }

  /* ========== SECTION HEADERS ========== */
  .kbm-section-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .kbm-section-header h2 {
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    color: #2c3a57;
    margin: 0 0 0.5rem;
  }

  .kbm-section-subtitle {
    color: #4d5a48;
    font-size: 1rem;
    margin: 0;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .kbm-section-subtitle--secondary {
    font-style: italic;
    margin-top: 0.35rem;
    font-size: 0.95rem;
    color: #6b7565;
  }

  /* ========== HERO SECTION ========== */
  .kbm-hero {
    margin-bottom: 1.5rem;
    padding-top: 0.5rem;
  }

  @media (max-width: 640px) {
    .kbm-hero {
      padding-top: 0.5rem;
    }
  }

  .kbm-hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }

  .kbm-hero__content {
    text-align: center;
  }

  .kbm-hero__eyebrow {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--kbm-green-2);
    margin-bottom: 0.75rem;
    padding: 0.35rem 1rem;
    background: rgba(115, 140, 82, 0.12);
    border-radius: 999px;
  }

  .kbm-hero h1 {
    font-size: clamp(1.4rem, 3vw, 2rem);
    margin: 0 0 1rem;
    color: #2c3a57;
    line-height: 1.3;
  }

  .kbm-hero__text {
    max-width: 42rem;
    margin: 0 auto 1.5rem;
    font-size: 1rem;
    line-height: 1.6;
    color: #4d5a48;
  }

  .kbm-hero__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .kbm-hero__helper {
    font-style: italic;
    font-size: 0.9rem;
    color: #4d5a48;
    margin: 0;
    text-align: center;
  }

  .kbm-hero__image {
    display: flex;
    justify-content: center;
  }

  .kbm-hero__image img {
    width: 100%;
    max-width: 420px;
    height: auto;
    border-radius: 1rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    background: #e0e5d8;
    min-height: 200px;
    object-fit: cover;
  }

  @media (min-width: 900px) {
    .kbm-hero__grid {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }

    .kbm-hero__content {
      text-align: left;
    }

    .kbm-hero__text {
      margin-left: 0;
    }

    .kbm-hero__actions {
      align-items: center;
    }

    .kbm-hero__image img {
      max-width: 100%;
    }
  }

  /* ========== WHERE ARE YOU SECTION ========== */
  .kbm-where-section {
    background-color: #ffffff;
    padding-top: 2rem;
    padding-bottom: 4rem;
    margin-top: 3rem;
    margin-left: -1.5rem;
    margin-right: -1.5rem;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    scroll-margin-top: calc(var(--header-height, 160px) + 1rem);
  }

  .kbm-where-inner {
    max-width: 1000px;
    margin: 0 auto;
  }

  .kbm-where-section .kbm-section-header {
    margin-bottom: 2rem;
  }

  .kbm-where-section .kbm-section-header h2 {
    margin-bottom: 0.5rem;
  }

  .kbm-hex-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 600px) {
    .kbm-hex-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .kbm-hex-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .kbm-hex-card {
    background-color: #ffffff;
    border-radius: 1.25rem;
    padding: 1.5rem 1.25rem;
    border: 2px solid #c7d8a4;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
  }

  .kbm-hex-card:hover {
    background-color: #f6f8f2;
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(82, 104, 45, 0.12);
    border-color: var(--kbm-green);
  }

  .kbm-hex-card--link {
    text-decoration: none;
    cursor: pointer;
    color: inherit;
  }

  .kbm-hex-icon {
    width: 56px;
    height: 56px;
    margin-bottom: 1rem;
    margin-left: auto;
    margin-right: auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .kbm-hex-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .kbm-hex-card h3 {
    font-size: 1rem;
    color: #2c3a57;
    margin: 0 0 0.75rem;
    line-height: 1.35;
  }

  .kbm-hex-card p {
    font-size: 0.9rem;
    color: #4f5a4b;
    line-height: 1.5;
    margin: 0 0 0.5rem;
  }

  .kbm-highlight {
    font-weight: 600;
    color: var(--kbm-green);
    font-style: italic;
  }

  .kbm-hex-card .btn {
    margin-top: auto;
    text-align: center;
    font-size: 0.85rem;
    padding: 0.55rem 1rem;
  }

  .kbm-link-list {
    padding-left: 1.1rem;
    margin: 0.5rem 0 0;
    font-size: 0.85rem;
    color: #4f5a4b;
  }

  .kbm-link-list li {
    margin-bottom: 0.4rem;
    line-height: 1.45;
  }

  .kbm-link-list a {
    color: var(--kbm-green);
    font-weight: 600;
    text-decoration: none;
  }

  .kbm-link-list a:hover {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ========== REASSURANCE SECTION ========== */
  .kbm-reassurance-section {
    margin-bottom: 1.5rem;
    padding: 2rem 0;
  }

  .kbm-reassurance-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .kbm-reassurance-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  .kbm-reassurance-item {
    text-align: center;
    padding: 1.25rem;
  }

  @media (min-width: 768px) {
    .kbm-reassurance-item {
      text-align: left;
    }
  }

  .kbm-reassurance-item h4 {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 1.05rem;
    color: #2c3a57;
    margin: 0 0 0.5rem;
    font-weight: 600;
  }

  .kbm-reassurance-icon {
    width: 1.25rem;
    height: auto;
    flex-shrink: 0;
  }

  .kbm-reassurance-item p {
    font-size: 0.9rem;
    color: #4d5a48;
    line-height: 1.55;
    margin: 0;
  }

  .kbm-power-user-shortcut {
    font-size: 0.9rem;
    color: #666;
    line-height: 1.5;
    margin-top: 0.5rem;
  }

  /* ========== ABOUT-LITE STRIP ========== */
  .kbm-about-strip {
    margin-bottom: 2rem;
  }

  .kbm-about-strip__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
    background: #ffffff;
    border-radius: 1.25rem;
    padding: 2rem 1.5rem;
    border: 1px solid #e0e5d8;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  @media (min-width: 600px) {
    .kbm-about-strip__inner {
      flex-direction: row;
      text-align: left;
      padding: 2rem;
    }
  }

  .kbm-about-strip__image {
    flex-shrink: 0;
  }

  .kbm-about-strip__image img {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #c7d8a4;
    background: #e0e5d8;
  }

  .kbm-about-strip__content h3 {
    font-size: 1.15rem;
    color: #2c3a57;
    margin: 0 0 0.5rem;
  }

  .kbm-about-strip__content p {
    font-size: 0.95rem;
    color: #4d5a48;
    line-height: 1.6;
    margin: 0 0 0.75rem;
  }

  .kbm-about-link {
    color: var(--kbm-green);
    font-weight: 600;
    text-decoration: none;
    font-size: 0.95rem;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .kbm-about-link::after {
    content: "→";
    font-size: 0.85em;
  }

  .kbm-about-link:hover {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ========== MOBILE ADJUSTMENTS ========== */
  @media (max-width: 480px) {
    .kbm-start-here {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .kbm-hex-card {
      padding: 1.25rem 1rem;
    }

    .kbm-reassurance-item {
      padding: 1rem 0.5rem;
    }

    .kbm-where-section {
      margin-left: -1rem;
      margin-right: -1rem;
      padding-left: 1rem;
      padding-right: 1rem;
      padding-top: 3rem;
      padding-bottom: 3rem;
    }
  }

  /* ========== FIRST CARD PULSE ANIMATION ========== */
  .pulse-once {
    animation: pulseOnce 1.2s ease-out 0.8s 1;
  }

  @keyframes pulseOnce {
    0%   { transform: scale(1); }
    40%  { transform: scale(1.03); }
    100% { transform: scale(1); }
  }

  /* ========== RIGHT-SIDE DRAWER ========== */
  .kbm-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    left: auto;
    margin: 0;
    width: 100%;
    max-width: 400px;
    height: 100vh;
    max-height: 100vh;
    border: none;
    padding: 0;
    background: #ffffff;
    box-shadow: -4px 0 24px rgba(0, 0, 0, 0.15);
    transform: translateX(100%);
    transition: transform 200ms ease-out;
  }

  .kbm-drawer::backdrop {
    background: rgba(0, 0, 0, 0.4);
    cursor: pointer;
  }

  .kbm-drawer[open] {
    display: flex;
    flex-direction: column;
  }

  .kbm-drawer--open {
    transform: translateX(0);
  }

  .kbm-drawer-content {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.5rem;
  }

  .kbm-drawer-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .kbm-drawer-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: #2c3a57;
    margin: 0;
    line-height: 1.3;
  }

  .kbm-drawer-close {
    border: none;
    background: transparent;
    font-size: 1.75rem;
    line-height: 1;
    cursor: pointer;
    color: #8891a6;
    padding: 0;
    flex-shrink: 0;
  }

  .kbm-drawer-close:hover {
    color: #2c3a57;
  }

  .kbm-drawer-body {
    flex: 1;
  }

  .kbm-drawer-body p {
    font-size: 1rem;
    color: #4d5a48;
    line-height: 1.6;
    margin: 0 0 1.25rem;
  }

  .kbm-drawer-link {
    color: var(--kbm-green);
