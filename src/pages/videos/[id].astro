---
import videos from "../../data/videos-public.json";
import Layout from "../../layouts/Layout.astro";
import PageHead from "../../components/PageHead.astro";

export const prerender = true;

export function getStaticPaths() {
  return videos.map((v) => ({
    params: { id: String(v.content_id) },
  }));
}

const id = String(Astro.params.id);
const video = videos.find((v) => String(v.content_id) === id);

const contentIdForJumplinks = Number((video as any)?.content_id ?? Astro.params?.id ?? NaN);
const contentIdAttr = !Number.isNaN(contentIdForJumplinks) ? String(contentIdForJumplinks) : "";

const vimeoId = (video as any)?.vimeo_id;
const title = (video as any)?.title ?? "Video";
const description = (video as any)?.description ?? "";
---

<Layout title={video ? title : "Video not found"} description={video ? description : "Video not found."}>
  <div class="page-wrap">
    {!video ? (
      <>
        <PageHead title="Video not found" breadcrumb="Home / Videos" />
        <article class="video-detail">
          <p>Video not found. <a href="/videos">Back to Videos</a>.</p>
        </article>
      </>
    ) : (
      <>
        <PageHead title={title} breadcrumb="Home / Videos" />

        <article class="video-detail">
          <section class="video-player">
            <div class="vimeo-wrap">
              <iframe
                class="vimeo-player"
                src={`https://player.vimeo.com/video/${vimeoId}`}
                frameborder="0"
                allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen
              />
            </div>
          </section>

          <nav class="video-jumplinks" aria-label="Jump links" hidden data-content-id={contentIdAttr}>
            <div class="jumplinks-head"><h2>Jump to</h2></div>
            <div class="jumplinks" id="jumplinks"></div>
          </nav>

          {description && (
            <section class="video-description">
              <h2>Description</h2>
              <div class="video-desc-text">
                <p>{description}</p>
              </div>
            </section>
          )}
        </article>
      </>
    )}
  </div>

  <style>
    .video-detail { display: grid; gap: 18px; }

    .vimeo-wrap {
      position: relative;
      width: 100%;
      padding-top: 56.25%;
      border-radius: 14px;
      overflow: hidden;
      background: rgba(0,0,0,0.06);
    }
    .vimeo-player {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }

    .video-jumplinks { display: grid; gap: 10px; }
    .jumplinks-head h2 { margin: 0; font-size: 16px; }
    .jumplinks { display: flex; flex-wrap: wrap; gap: 10px; }

    .jl-pill {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 8px 12px;
      border-radius: 999px;
      border: 1px solid rgba(0,0,0,0.14);
      background: rgba(255,255,255,0.9);
      text-decoration: none;
      color: inherit;
      line-height: 1;
    }
    .jl-pill:hover { background: rgba(0,0,0,0.03); }
    .jl-label { font-size: 14px; }
    .jl-time { font-size: 12px; opacity: 0.7; }

    .video-description h2 { margin: 0 0 8px; font-size: 16px; }
    .video-desc-text p { margin: 0; }
  </style>

  <script is:inline>
    window.addEventListener("DOMContentLoaded", async () => {
      const nav = document.querySelector(".video-jumplinks");
      const contentIdRaw = nav?.getAttribute("data-content-id") ?? "";
      const contentId = Number(contentIdRaw);
      const wrap = document.getElementById("jumplinks");
      if (!nav || !wrap || !contentIdRaw || Number.isNaN(contentId)) return;

      const url = `/api/jumplinks/${encodeURIComponent(contentIdRaw)}.json`;

      function mmss(sec) {
        const s = Math.max(0, Math.floor(Number(sec) || 0));
        const m = Math.floor(s / 60);
        const r = String(s % 60).padStart(2, "0");
        return `${m}:${r}`;
      }

      try {
        const r = await fetch(url);
        if (!r.ok) return;
        const data = await r.json();
        const rawList = data?.jumplinks;
        if (!Array.isArray(rawList)) return;
        const list = rawList.filter(function (j) {
          const jId = Number(j.content_id ?? j.contentId ?? j.video_id ?? j.videoId ?? j.id ?? NaN);
          return Number.isNaN(jId) || jId === contentId;
        });
        if (list.length === 0) return;

        wrap.innerHTML = list.map(j => `
          <a href="#" class="jl-pill" data-t="${j.t}">
            <span class="jl-label">${j.label ?? ""}</span>
            <span class="jl-time">${mmss(j.t)}</span>
          </a>
        `).join("");

        nav.hidden = false;
        nav.removeAttribute("hidden");
      } catch {}
    });
  </script>
</Layout>
