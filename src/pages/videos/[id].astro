---
import videos from "../../data/videos-public.json";
import Layout from "../../layouts/Layout.astro";
import PageHead from "../../components/PageHead.astro";

export const prerender = true;

export function getStaticPaths() {
  return videos.map((v) => ({
    params: { id: String(v.content_id) },
  }));
}

const id = String(Astro.params.id);
const video = videos.find((v) => String(v.content_id) === id);

const contentIdForJumplinks = Number((video as any)?.content_id ?? Astro.params?.id ?? NaN);
const contentIdAttr = !Number.isNaN(contentIdForJumplinks) ? String(contentIdForJumplinks) : "";

const vimeoId = (video as any)?.vimeo_id;
const title = (video as any)?.title ?? "Video";
const description = (video as any)?.description ?? "";
---

<Layout title={video ? title : "Video not found"} description={video ? description : "Video not found."}>
  <div class="page-wrap">
    {!video ? (
      <>
        <PageHead title="Video not found" breadcrumb="Home / Videos" />
        <article class="video-detail">
          <p>Video not found. <a href="/videos">Back to Videos</a>.</p>
        </article>
      </>
    ) : (
      <>
        <PageHead title={title} breadcrumb="Home / Videos" />

        <article class="video-detail">
          <section class="video-player">
            <div class="vimeo-wrap">
              <iframe
                class="vimeo-player"
                src={`https://player.vimeo.com/video/${vimeoId}`}
                frameborder="0"
                allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen
              />
            </div>
          </section>

          <nav class="video-jumplinks" aria-label="Jump links" hidden data-content-id={contentIdAttr}>
            <div class="jumplinks-head"><h2>Jump to</h2></div>
            <div class="jumplinks" id="jumplinks"></div>
          </nav>

          {description && (
            <section class="video-description">
              <h2>Description</h2>
              <div class="video-desc-text">
                <p>{description}</p>
              </div>
            </section>
          )}
        </article>
      </>
    )}
  </div>

  <style is:global>
    .video-detail {
      display: grid;
      gap: 18px;
    }
  
    /* Vimeo embed wrapper */
    .vimeo-wrap {
      position: relative;
      width: 100%;
      padding-top: 56.25%;
      border-radius: 14px;
      overflow: hidden;
      background: rgba(0,0,0,0.06);
    }
  
    .vimeo-wrap iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }
  
    /* Jump links */
    .video-jumplinks {
      display: grid;
      gap: 10px;
    }
  
    .jumplinks-head h2 {
      margin: 0;
      font-size: 16px;
    }
  
    .jumplinks {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }
  
    .jl-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
  
      padding: 6px 10px;
      border-radius: 999px;
      border: 1px solid rgba(0,0,0,0.14);
  
      background-color: rgba(255,255,255,0.92);
      text-decoration: none;
      color: inherit;
      line-height: 1;
  
      transition: background 120ms ease, transform 120ms ease, border-color 120ms ease;
    }
  
    .jl-pill:hover {
      background: rgba(0,0,0,0.03);
      border-color: rgba(0,0,0,0.20);
    }
  
    .jl-pill:active {
      transform: translateY(1px);
    }
  
    .jl-pill:focus-visible {
      outline: 2px solid rgba(0,0,0,0.25);
      outline-offset: 2px;
    }
  
    .jl-icon {
      display: inline-flex;
      align-items: center;
      opacity: 0.7;
    }
  
    .jl-icon svg {
      width: 12px;
      height: 12px;
    }
  
    .jl-label {
      font-size: 14px;
    }
  
    .jl-time {
      font-size: 11px;
      opacity: 0.55;
      font-variant-numeric: tabular-nums;
    }
  
    /* Description */
    .video-description h2 {
      margin: 0 0 8px;
      font-size: 16px;
    }
  
    .video-desc-text p {
      margin: 0;
    }
  </style>

  <script is:inline>
    window.addEventListener("DOMContentLoaded", async () => {
      const nav = document.querySelector(".video-jumplinks");
      const contentIdRaw = nav?.getAttribute("data-content-id") ?? "";
      const contentId = Number(contentIdRaw);
      const wrap = document.getElementById("jumplinks");
      if (!nav || !wrap || !contentIdRaw || Number.isNaN(contentId)) return;

      const url = `/api/jumplinks/${encodeURIComponent(contentIdRaw)}.json`;

      function formatTime(sec) {
        const s = Math.max(0, Math.floor(Number(sec) || 0));
        const m = Math.floor(s / 60) % 60;
        const h = Math.floor(s / 3600);
        const secPart = String(s % 60).padStart(2, "0");
        if (h > 0) {
          const minPart = String(m).padStart(2, "0");
          return h + ":" + minPart + ":" + secPart;
        }
        const minPart = String(m).padStart(2, "0");
        return minPart + ":" + secPart;
      }
      const ffSvg = '<svg viewBox="0 0 16 16" width="12" height="12" fill="currentColor" focusable="false" aria-hidden="true"><path d="M2 2l6 6-6 6V2zm6 0l6 6-6 6V2z"/></svg>';

      try {
        const r = await fetch(url);
        if (!r.ok) return;
        const data = await r.json();
        const rawList = data?.jumplinks;
        if (!Array.isArray(rawList)) return;
        const list = rawList.filter(function (j) {
          const jId = Number(j.content_id ?? j.contentId ?? j.video_id ?? j.videoId ?? j.id ?? NaN);
          return Number.isNaN(jId) || jId === contentId;
        });
        if (list.length === 0) return;

        wrap.innerHTML = list.map(j => `
          <a href="#" class="jl-pill" data-t="${j.t}">
            <span class="jl-icon" aria-hidden="true">${ffSvg}</span>
            <span class="jl-label">${j.label ?? ""}</span>
            <span class="jl-time">${formatTime(j.t)}</span>
          </a>
        `).join("");

        const container = document.getElementById("jumplinks");
        if (container && container.children.length > 0) {
          nav?.removeAttribute("hidden");
        } else {
          nav?.setAttribute("hidden", "");
        }
      } catch {}
    });
  </script>
</Layout>
