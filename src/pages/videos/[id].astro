---
import videos from "../../data/videos-public.json";
import Layout from "../../layouts/Layout.astro";
import PageHead from "../../components/PageHead.astro";
import LoginNudge from "../../components/auth/LoginNudge.astro";
import GatedVimeoEmbed from "../../components/videos/GatedVimeoEmbed.astro";
export const prerender = true;

export function getStaticPaths() {
  return videos.map((v) => ({
    params: { id: String(v.content_id) },
  }));
}

const id = String(Astro.params.id);
const video = videos.find((v) => String(v.content_id) === id);

const contentIdForJumplinks = Number((video as any)?.content_id ?? Astro.params?.id ?? NaN);
const contentIdAttr = !Number.isNaN(contentIdForJumplinks) ? String(contentIdForJumplinks) : "";

const vimeoId = (video as any)?.vimeo_id;
const title = (video as any)?.title ?? "Video";
const description = (video as any)?.description ?? "";

// thumbnail / poster: support full URL, /path, or filename → /images/filename
const rawPosterUrl = (video as any)?.posterUrl ?? (video as any)?.poster_url ?? "";
const posterSrc =
  rawPosterUrl && (rawPosterUrl.startsWith("http") || rawPosterUrl.startsWith("/"))
    ? rawPosterUrl
    : rawPosterUrl
      ? `/images/${rawPosterUrl}`
      : "";
---

<Layout title={video ? title : "Video not found"} description={video ? description : "Video not found."}>
  <div class="page-wrap">
    {!video ? (
      <>
        <PageHead title="Video not found" breadcrumb="Home / Videos" />
        <article class="video-detail">
          <p>Video not found. <a href="/videos">Back to Videos</a>.</p>
        </article>
      </>
    ) : (
      <>
        <PageHead title={title} breadcrumb="Home / Videos" />

        <article class="video-detail">
          {/* PLAYER AREA */}
          <section class="video-player">
            {/* Locked (default) */}
            <div class="gated-locked" data-gated="locked">
              <div class="teaser-player">
                {posterSrc ? (
                  <img class="video-poster" src={posterSrc} alt={title} loading="lazy" />
                ) : (
                  <div class="video-poster-fallback" aria-hidden="true"></div>
                )}

                <div class="locked-overlay">
                  <h2 class="locked-title">Full video available to members</h2>
                  <p class="locked-text">
                    Watch the complete tutorial, scan key sections with jump links, and reference the transcript anytime.
                  </p>

                  <div class="locked-actions">
                    <a class="btn btn-primary" href="/join">Become a member</a>
                    {/* swap /videos for your real pricing / join / Stripe page when ready */}
                  </div>
                  <LoginNudge className="locked-nudge" />
                </div>
              </div>
            </div>

            <GatedVimeoEmbed
              videoId={vimeoId}
              title={title}
              access_level={(video as any)?.access_level ?? "member"}
            />
          </section>

          {/* JUMP LINKS */}
          <nav class="video-jumplinks" aria-label="Jump links" data-content-id={contentIdAttr}>
            <div class="jumplinks-head"><h2>Jump to</h2></div>

            {/* Locked view: show disabled UI */}
            <div class="gated-locked" data-gated="locked">
              <div class="jumplinks-disabled" aria-disabled="true">
                <p class="locked-inline">
                  Jump links are available with access.
                </p>
              </div>
            </div>

            {/* Member view: your existing jumplink container */}
            <div class="gated-content" data-gated="content" hidden>
              <div class="jumplinks" id="jumplinks"></div>
            </div>
          </nav>

          {/* DESCRIPTION (always visible) */}
          <section class="video-description">
            <h2>Description</h2>
            <div class="video-desc-text" set:html={description}></div>
          </section>

          {/* TRANSCRIPT LINK (no transcript content for non-members) */}
          <section class="video-transcript-link">
            <h2>Transcript</h2>

            <div class="gated-locked" data-gated="locked">
              <a class="transcript-link is-disabled" aria-disabled="true" role="link" tabindex="-1">
                View transcript (members)
              </a>
            </div>

            <div class="gated-content" data-gated="content" hidden>
              {/* If you have a real transcript route, link it here */}
              <a class="transcript-link" href={`/videos/${id}/transcript`}>View transcript</a>
            </div>
          </section>
        </article>

        <script>
          // --- Memberstack gating (client-side unlock) ---
          const MEMBER_PLAN_IDS = new Set([
            "pln_dev-kin-member-eim6011h",
            "pln_kin-membership-monthly-a59701wy",
            "pln_kin-membership-annual-qf9g01et",
          ]);

          async function waitForMemberstackReady({ attempts = 30, delayMs = 200 } = {}) {
            for (let i = 0; i < attempts; i++) {
              try {
                const api = window.$memberstackDom?.getAppAndMember;
                if (typeof api === "function") return await api();
              } catch (e) {}
              await new Promise((r) => setTimeout(r, delayMs));
            }
            return null;
          }

          function getViewerStateFromRes(res) {
            const member = res?.data?.member ?? null;
            const planConnections = member?.planConnections ?? [];
            const activePlanIds = new Set(
              planConnections
                .filter((p) => (p?.status ?? "").toUpperCase() === "ACTIVE")
                .map((p) => p?.planId)
                .filter(Boolean)
            );

            const isLoggedIn = Boolean(member);
            const isMember = [...activePlanIds].some((id) => MEMBER_PLAN_IDS.has(id));
            return { isLoggedIn, isMember, member };
          }

          function setAccess(hasFullAccess) {
            document.querySelectorAll('[data-gated="content"]').forEach((el) => {
              if (hasFullAccess) el.removeAttribute("hidden");
              else el.setAttribute("hidden", "");
            });
            document.querySelectorAll('[data-gated="locked"]').forEach((el) => {
              if (hasFullAccess) el.setAttribute("hidden", "");
              else el.removeAttribute("hidden");
            });
          }

          (async () => {
            // default: locked
            setAccess(false);

            // Dev override (optional): ?mode=full
            const urlParams = new URLSearchParams(window.location.search);
            const devFull = urlParams.get("mode") === "full";

            if (devFull) {
              setAccess(true);
              return;
            }

            const res = await waitForMemberstackReady();
            const viewer = getViewerStateFromRes(res);
            setAccess(Boolean(viewer.isMember));
          })();
        </script>

        <style>
          /* minimal safety styles; keep or delete if you already have equivalents */
          .teaser-player { position: relative; border-radius: 16px; overflow: hidden; background: #111; }
          .video-poster { width: 100%; display: block; }
          .video-poster-fallback { width: 100%; aspect-ratio: 16/9; background: #222; }
          /* Ensure overlay text is white and overrides global heading color */
          .locked-overlay { position: absolute; inset: 0; display: grid; place-content: center; gap: 6px; /* tighter vertical spacing */ padding: 18px; text-align: center; background: rgba(0,0,0,.55); color: #fff; }
          .locked-overlay .locked-title { color: #fff; margin-bottom: 6px; }
          .locked-overlay .locked-text { margin-top: 0; }
          .locked-overlay .locked-nudge { margin-top: 10px; }
          .locked-actions { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
          .btn { padding: 10px 14px; border-radius: 10px; border: 1px solid rgba(255,255,255,.35); color: white; text-decoration: none; }
          .btn-primary { background: rgba(255,255,255,.15); }
          .transcript-link.is-disabled { opacity: .55; cursor: not-allowed; text-decoration: none; }
        </style>
      </>
    )}
  </div>
</Layout>