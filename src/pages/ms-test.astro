---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Memberstack Test">
  <main style="max-width: 820px; margin: 40px auto; padding: 0 20px;">
    <h1>Memberstack Test Page</h1>
    

    
    <p>
      <button type="button" data-ms-modal="login">Open Login Modal</button>
      &nbsp;|&nbsp;
      <a href="#" data-ms-modal="signup">Open Signup Modal</a>
      &nbsp;|&nbsp;
      <a href="#" data-ms-action="logout" data-ms-show="member">Log out</a>
    </p>

    <hr style="margin: 24px 0;" />

    <section style="padding: 16px; border: 1px solid #ddd; border-radius: 12px; margin-bottom: 16px;">
      <h2>Public (always visible)</h2>
      <p>This should always show.</p>
    </section>

    <section data-ms-hide="member" style="padding: 16px; border: 1px solid #ddd; border-radius: 12px; margin-bottom: 16px;">
      <h2>Logged OUT only</h2>
      <p>If you are NOT logged in, you should see this.</p>
    </section>
    <button id="talkyardSsoBtn">Log into Roundtable</button>
    <section data-ms-show="member" style="padding: 16px; border: 1px solid #ddd; border-radius: 12px;">
      <h2>Logged IN only</h2>
      <p>If you ARE logged in, you should see this.</p>
    </section>
  </main>
</Layout>
<script>
  document.getElementById("talkyardSsoBtn").addEventListener("click", async () => {
    const member = await $memberstackDom.getCurrentMember();
    if (!member) {
      alert("Not logged into Memberstack");
      return;
    }

    const externalUserId = member.data.id;
    const email = member.data.auth.email;
    const fullName =
      member.data.customFields?.fullName ||
      member.data.auth?.email ||
      "Member";

    // IMPORTANT: this navigates the whole window after POST returns the 302
    const res = await fetch("/api/talkyard-sso?thenGoTo=/", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ externalUserId, email, fullName }),
      redirect: "manual",
    });

    const loc = res.headers.get("Location");
    if (!loc) {
      const t = await res.text();
      alert("SSO failed: " + t);
      return;
    }

    window.location.href = loc;
  });
</script>
<script is:inline>
  (function () {
    if (!window.$memberstackDom || typeof window.$memberstackDom.on !== "function") return;

    window.$memberstackDom.on("member.login", function () {
      window.location.reload();
    });
  })();
</script>
<script is:inline>
    (function () {
      const origFetch = window.fetch;
      if (!origFetch) return;
  
      window.fetch = async function (...args) {
        const res = await origFetch.apply(this, args);
  
        try {
          const url = typeof args[0] === "string" ? args[0] : args[0]?.url || "";
          // When Memberstack login succeeds, close the modal
          if (url.includes("/auth/login") && res.ok) {
            // click the modal's close button if it exists
            const closeBtn =
              document.querySelector('[data-ms-close]') ||
              document.querySelector('button[aria-label="Close"]') ||
              document.querySelector('.ms-modal button');
  
            closeBtn?.click();
          }
        } catch (e) {}
  
        return res;
      };
    })();
  </script>