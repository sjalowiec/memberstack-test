---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Memberstack Test">
  <main style="max-width: 820px; margin: 40px auto; padding: 0 20px;">
    <h1>Memberstack Test Page</h1>

    <p>
      <button type="button" data-ms-modal="login">Open Login Modal</button>
      &nbsp;|&nbsp;
      <a href="#" data-ms-modal="signup">Open Signup Modal</a>
      &nbsp;|&nbsp;
      <a href="#" data-ms-action="logout" data-ms-show="member">Log out</a>
    </p>

    <hr style="margin: 24px 0;" />

    <section style="padding: 16px; border: 1px solid #ddd; border-radius: 12px; margin-bottom: 16px;">
      <h2>Public (always visible)</h2>
      <p>This should always show.</p>
    </section>

    <section data-ms-hide="member" style="padding: 16px; border: 1px solid #ddd; border-radius: 12px; margin-bottom: 16px;">
      <h2>Logged OUT only</h2>
      <p>If you are NOT logged in, you should see this.</p>
    </section>

    <section data-ms-show="member" style="padding: 16px; border: 1px solid #ddd; border-radius: 12px;">
      <h2>Logged IN only</h2>
      <p>If you ARE logged in, you should see this.</p>
    </section>
  </main>
</Layout>