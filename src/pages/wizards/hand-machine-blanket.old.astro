---
/**
 * Hand + Machine Blanket Planner Wizard
 * Location: src/pages/wizards/hand-machine-blanket.astro
 * 
 * A wizard that calculates stitch counts for blankets combining hand-knit garter 
 * borders with machine-knit body sections. Outputs printable step-by-step instructions.
 */

import BaseLayout from "../../layouts/BaseLayout.astro";
import ActionBar from "../../components/wizards/ActionBar.astro";
import Tooltip from "../../components/Tooltip.astro";
import PrintFooter from "../../components/common/PrintFooter.astro";
import WizardBackLink from "../../components/wizards/WizardBackLink.astro";
import GaugeInput from "../../components/wizards/components/GaugeInput.astro";
import UnitToggle from "../../components/wizards/components/UnitToggle.astro";
import PinterestEmbed from "../../components/PinterestEmbed.astro";

const pageUrl = "https://knitbymachine.com/wizards/hand-machine-blanket";
---

<BaseLayout 
  title="The Hybrid Blanket Pattern | Knit by Machine" 
  description="Hand Knit + Machine Knit Blanket Pattern. Calculate stitch counts for blankets with hand-knit garter borders and machine-knit body.">

<style>
.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

.wizard-page {
  padding-top: 20px;
  padding-bottom: 3rem;
  min-height: 100vh;
  background: var(--page-bg);
}

.page-header {
  max-width: 800px;
  margin: 0 auto 2rem;
  padding: 0 1rem;
}

.page-header-title {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  margin-bottom: 0.75rem;
  flex-wrap: wrap;
}

@media (max-width: 640px) {
  .page-header-title {
    flex-direction: column;
    gap: 0.75rem;
  }
}

.page-header h1 {
  color: var(--kbm-green);
  font-size: 2rem;
  font-weight: 700;
  margin: 0;
}

.page-header p {
  color: #6b7280;
  font-size: 1.05rem;
  line-height: 1.6;
  text-align: center;
}

.page-subtitle {
  color: var(--kbm-green);
  font-size: 1.15rem;
  font-weight: 600;
  margin-bottom: 0.5rem;
}

.inspiration-section {
  max-width: 800px;
  margin: 2rem auto;
  padding: 0 1rem;
}

.inspiration-intro {
  color: #6b7280;
  font-size: 1rem;
  margin-bottom: 1rem;
}

.wizard-container {
  max-width: 800px;
  margin: 0 auto;
  padding: 0 1rem 120px 1rem;
}

.calculator-card {
  background: white;
  padding: 2rem;
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.section-title {
  color: var(--kbm-green);
  font-size: 1.3rem;
  font-weight: 700;
  margin: 1.5rem 0 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 2px solid #eef0ea;
}

.section-title:first-child {
  margin-top: 0;
}

.gauge-row {
  background: rgba(82, 104, 45, 0.05);
  border-radius: 8px;
  padding: 1rem;
  margin-bottom: 1rem;
}

.gauge-row-title {
  color: #374151;
  font-size: 1rem;
  font-weight: 600;
  margin: 0 0 0.75rem 0;
}

.gauge-unit-hint {
  font-weight: 400;
  color: #6b7280;
}

.gauge-row .input-grid {
  margin-bottom: 0;
}

.input-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1.5rem;
  margin-bottom: 1.5rem;
}

.input-group {
  display: flex;
  flex-direction: column;
}

.input-group label {
  font-weight: 600;
  color: #374151;
  margin-bottom: 0.5rem;
  font-size: 0.9rem;
}

.input-group input, .input-group select {
  padding: 0.75rem;
  border: 1px solid #d1d5db;
  border-radius: 6px;
  font-size: 1rem;
  transition: all 0.2s;
}

.input-group input:focus, .input-group select:focus {
  outline: none;
  border-color: var(--kbm-green);
  box-shadow: 0 0 0 3px rgba(82, 104, 45, 0.1);
}

.input-group input.error {
  border-color: #dc3545;
}

.validation-message {
  margin-top: 0.25rem;
  font-size: 0.85rem;
  display: flex;
  align-items: center;
  gap: 0.25rem;
}

.validation-message.error {
  color: #dc3545;
}

.gauge-warning {
  display: flex;
  gap: 0.75rem;
  padding: 1rem;
  margin: 1rem 0;
  background-color: #fef3c7;
  border: 1px solid #f59e0b;
  border-radius: 0.5rem;
  color: #92400e;
}

.gauge-warning-icon {
  font-size: 1.25rem;
  flex-shrink: 0;
}

.gauge-warning-content {
  flex: 1;
}

.gauge-warning-content strong {
  display: block;
  margin-bottom: 0.25rem;
}

.gauge-warning-content p {
  margin: 0;
  font-size: 0.9rem;
  line-height: 1.5;
}

.pattern-illustration {
  margin-top: 1.5rem;
  text-align: center;
}

.pattern-illustration img {
  max-width: 100%;
  height: auto;
}

.unit-toggle {
  display: inline-flex;
  background: #f3f4f6;
  border-radius: 6px;
  padding: 3px;
  margin-bottom: 1rem;
}

.unit-toggle button {
  padding: 0.5rem 1rem;
  border: none;
  background: transparent;
  cursor: pointer;
  font-weight: 600;
  color: #6b7280;
  border-radius: 4px;
  transition: all 0.2s;
}

.unit-toggle button.active {
  background: var(--kbm-green);
  color: white;
}

.unit-toggle button:hover:not(.active) {
  background: #e5e7eb;
}

.info-box {
  background: rgba(82, 104, 45, 0.1);
  border-left: 4px solid var(--kbm-green);
  padding: 1rem;
  border-radius: 4px;
  margin-bottom: 1.5rem;
  font-size: 0.95rem;
  line-height: 1.6;
}

.results-section {
  margin-top: 2rem;
  padding-top: 2rem;
  border-top: 2px solid #eef0ea;
}

.pattern-card {
  background: #f9fafb;
  padding: 1.5rem;
  border-radius: 8px;
  margin-bottom: 1.5rem;
}

.pattern-card h3 {
  color: var(--kbm-green);
  font-size: 1.2rem;
  margin-bottom: 1rem;
}

.highlight-box {
  background: rgba(82, 104, 45, 0.15);
  border-left: 4px solid var(--kbm-green);
  padding: 1rem;
  border-radius: 4px;
  margin-bottom: 1rem;
}

.instructions-list {
  margin-left: 0;
  padding-left: 0;
  line-height: 1.9;
  list-style: none;
  counter-reset: step-counter;
}

:global(.instructions-list li) {
  margin-bottom: 0.75rem;
  position: relative;
  padding-left: 1.75rem;
}

:global(.instructions-list li:not(.phase-heading)) {
  counter-increment: step-counter;
}

:global(.instructions-list li:not(.phase-heading)::before) {
  content: counter(step-counter) ".";
  position: absolute;
  left: 0;
  font-weight: 400;
  color: inherit;
}

:global(.instructions-list li:last-child) {
  margin-bottom: 0;
}
/* NOTE: these spans are injected via innerHTML, so Astro-scoped selectors won’t match.
   Use :global so the styling applies to runtime-injected markup. */
:global(.instructions-list .calculated-value) {
  font-weight: 700;
  white-space: nowrap;
}

:global(.instructions-list .phase-heading) {
  font-weight: 600;
  font-size: 0.9rem;
  color: var(--kbm-green);
  text-transform: uppercase;
  letter-spacing: 0.025em;
  margin-top: 1.25rem;
  margin-bottom: 0.5rem;
  padding-left: 0;
  padding-bottom: 0.25rem;
  border-bottom: 1px solid rgba(82, 104, 45, 0.2);
}

:global(.instructions-list .phase-heading:first-child) {
  margin-top: 0;
}

:global(.instructions-list .step-aside) {
  display: block;
  margin: 0.5rem 0 0 1.25rem;
  padding-left: 0.75rem;
  border-left: 2px solid rgba(82, 104, 45, 0.35);
  color: #6b7280;
  font-size: 0.95em;
  font-style: normal;
}

:global(.instructions-list .step-aside__label) {
  font-weight: 600;
  letter-spacing: 0.02em;
}


.why-note {
  font-style: italic;
  color: #6b7280;
  margin-top: 1.5rem;
  padding: 1rem;
  background: #f9fafb;
  border-radius: 6px;
  font-size: 0.95rem;
}

:global(.unlock-hint) {
  margin: 1rem 0;
  padding: 0.75rem 1rem;
  border-left: 4px solid rgba(82, 104, 45, 0.55);
  background: rgba(82, 104, 45, 0.06);
  border-radius: 6px;
  color: #374151;
  font-size: 0.95rem;
  line-height: 1.4;
}

:global(.incomplete-field) {
  border-color: #d97706 !important;
  background-color: rgba(217, 119, 6, 0.08) !important;
}

:global(.incomplete-field:focus) {
  box-shadow: 0 0 0 3px rgba(217, 119, 6, 0.25) !important;
}

:global(.size-categories.incomplete-field) {
  border: 2px solid #d97706;
  border-radius: 10px;
  padding: 0.75rem;
}

.summary-box {
  background: linear-gradient(135deg, rgba(82, 104, 45, 0.15) 0%, rgba(82, 104, 45, 0.08) 100%);
  border: 2px solid var(--kbm-green);
  padding: 1.25rem;
  border-radius: 8px;
  margin-bottom: 1.5rem;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 1rem;
}

.summary-item {
  text-align: center;
}

.summary-item .label {
  font-size: 0.85rem;
  color: #6b7280;
  margin-bottom: 0.25rem;
}

.summary-item .value {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--kbm-green);
}

.inputs-summary {
  background: #f9fafb;
  padding: 1rem;
  border-radius: 6px;
  margin-bottom: 1rem;
  font-size: 0.95rem;
}

.inputs-summary p {
  margin: 0 0 0.25rem 0;
}

.gauge-helper {
  font-size: 0.85rem;
  color: #6b7280;
  margin-top: 0;
  margin-bottom: 1rem;
  font-style: italic;
}

.pattern-output-header {
  margin-bottom: 1.5rem;
}

.pattern-output-header h2 {
  color: var(--kbm-green);
  font-size: 1.5rem;
  font-weight: 700;
  margin: 0 0 0.25rem 0;
}

.pattern-output-header .subtitle {
  color: #6b7280;
  font-size: 1rem;
  margin: 0 0 0.75rem 0;
}

.pattern-output-header .what-youll-do {
  color: #374151;
  font-size: 1rem;
  margin: 0;
}

.custom-size-button {
  width: 100%;
  padding: 0.875rem 1.5rem;
  margin-top: 0.75rem;
  margin-bottom: 1.5rem;
  background: transparent;
  border: 2px dashed var(--kbm-green);
  border-radius: 8px;
  color: var(--kbm-green);
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s ease;
}

.custom-size-button:hover {
  background: rgba(82, 104, 45, 0.08);
  border-style: solid;
}

.custom-size-button:focus-visible {
  outline: 2px solid var(--kbm-green);
  outline-offset: 2px;
}

.custom-size-button.active {
  background: var(--kbm-green);
  color: white;
  border-style: solid;
}

.stitch-counts-section {
  background: rgba(82, 104, 45, 0.08);
  padding: 1rem;
  border-radius: 6px;
  margin-bottom: 1.5rem;
}

.stitch-counts-section h4 {
  color: var(--kbm-green);
  font-size: 1rem;
  font-weight: 600;
  margin: 0 0 1rem 0;
  text-align: center;
}

.stitch-counts-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.75rem;
  margin: 0;
  padding: 0;
}

.stitch-count-card {
  background: white;
  border-radius: 8px;
  padding: 1rem;
  text-align: center;
  border: 1px solid rgba(82, 104, 45, 0.15);
}

.stitch-count-card dt {
  font-size: 0.85rem;
  color: #6b7280;
  margin-bottom: 0.25rem;
  font-weight: 500;
}

.stitch-count-card dd {
  font-size: 1.75rem;
  font-weight: 700;
  color: var(--kbm-green);
  margin: 0;
  line-height: 1.2;
}

.stitch-counts-helper {
  font-size: 0.875rem;
  color: #4b5563;
  margin: 0.75rem 0 0 0;
  padding: 0.5rem 0.75rem;
  border-left: 3px solid var(--kbm-green);
  background: rgba(255, 255, 255, 0.6);
  border-radius: 0 4px 4px 0;
  line-height: 1.5;
}

@media (max-width: 600px) {
  .stitch-counts-cards {
    grid-template-columns: 1fr;
  }
  
  .stitch-counts-helper {
    font-size: 0.875rem;
    padding: 0.5rem 0.75rem;
  }
}

:global(.checklist-panel) {
  background: linear-gradient(135deg, #f8faf5 0%, #eef2e6 100%);
  border: 2px dashed #c5d4a8;
  border-radius: 12px;
  padding: 1.5rem;
  margin: 1.5rem 0;
  text-align: left;
}

:global(.checklist-header) {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1rem;
  flex-wrap: wrap;
  gap: 0.5rem;
}

:global(.checklist-title) {
  font-size: 1rem;
  font-weight: 600;
  color: #52682d;
  margin: 0;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

:global(.checklist-title svg) {
  width: 20px;
  height: 20px;
}

:global(.checklist-progress) {
  font-size: 0.85rem;
  color: #6b7280;
  font-weight: 500;
}

:global(.checklist-list) {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

:global(.checklist-item) {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  padding: 0.5rem 0.75rem;
  background: white;
  border-radius: 6px;
  border: 1px solid #e5e7eb;
  font-size: 0.9rem;
  color: #4b5563;
  transition: all 0.2s ease;
}

:global(.checklist-item.completed) {
  background: rgba(82, 104, 45, 0.08);
  border-color: rgba(82, 104, 45, 0.3);
  color: #52682d;
}

:global(.checklist-check) {
  width: 18px;
  height: 18px;
  min-width: 18px;
  min-height: 18px;
  border-radius: 4px;
  border: 2px solid #d1d5db;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
  transition: all 0.2s ease;
}

:global(.checklist-item.completed .checklist-check) {
  background: var(--kbm-green);
  border-color: var(--kbm-green);
}

:global(.checklist-check svg) {
  width: 12px;
  height: 12px;
  min-width: 12px;
  min-height: 12px;
  max-width: 12px;
  max-height: 12px;
  color: white;
  opacity: 0;
  transition: opacity 0.15s ease;
}

:global(.checklist-item.completed .checklist-check svg) {
  opacity: 1;
}

:global(.checklist-success) {
  display: none;
  text-align: center;
  padding: 1rem;
  color: #52682d;
  font-weight: 500;
  font-size: 1rem;
}

:global(.checklist-success.show) {
  display: block;
}

:global(.checklist-success svg) {
  width: 32px;
  height: 32px;
  color: var(--kbm-green);
  margin-bottom: 0.5rem;
}

:global(.checklist-still-needed-label) {
  font-size: 0.9rem;
  color: #6b7280;
  margin: 0 0 0.5rem 0;
  font-weight: 500;
}

:global(.checklist-panel.complete) {
  text-align: center;
  border-style: solid;
  border-color: var(--kbm-green);
  background: rgba(82, 104, 45, 0.08);
}

:global(.checklist-panel.complete .checklist-still-needed-label) {
  display: none;
}

:global(.size-options) {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  margin-bottom: 1.5rem;
}

:global(.size-option) {
  padding: 0.75rem;
  min-height: 64px;
  width: 160px;
  border: 2px solid #e5e7eb;
  border-radius: 8px;
  cursor: pointer;
  text-align: center;
  transition: all 0.25s ease;
  background: white;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 0.375rem;
}

:global(.size-option:hover) {
  border-color: var(--kbm-green);
  background: rgba(82, 104, 45, 0.05);
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(82, 104, 45, 0.15);
}

:global(.size-option.selected) {
  border-color: var(--kbm-green);
  background: rgba(82, 104, 45, 0.12);
  box-shadow: 0 0 0 3px rgba(82, 104, 45, 0.2), 0 4px 12px rgba(82, 104, 45, 0.2);
  transform: translateY(-2px);
}

:global(.size-option-name) {
  font-size: 1rem;
  color: #1f2937;
  font-weight: 700;
  line-height: 1.3;
}

:global(.size-option.selected .size-option-name) {
  color: var(--kbm-green);
}

:global(.size-option-dims) {
  font-size: 0.875rem;
  color: #6b7280;
  font-weight: 500;
}

:global(.size-option.disabled) {
  opacity: 0.5;
  cursor: not-allowed;
}

@media (max-width: 1024px) {
  :global(.size-option) {
    width: 100%;
    min-height: 56px;
  }
}

.checkbox-group {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin: 1rem 0;
}

.checkbox-group input[type="checkbox"] {
  width: 18px;
  height: 18px;
  cursor: pointer;
  accent-color: #52682D;
}

.checkbox-group label {
  cursor: pointer;
  font-weight: 600;
  color: #374151;
}

@media print {
  * {
    background: white !important;
    background-color: white !important;
  }
  
  body {
    background: white !important;
    margin: 0 !important;
    padding: 0 !important;
  }
  
  .no-print,
  .calculator-inputs {
    display: none !important;
    visibility: hidden !important;
    position: absolute !important;
    left: -9999px !important;
    top: -9999px !important;
    height: 0 !important;
    max-height: 0 !important;
    min-height: 0 !important;
    width: 0 !important;
    margin: 0 !important;
    padding: 0 !important;
    overflow: hidden !important;
    border: none !important;
    line-height: 0 !important;
    font-size: 0 !important;
  }
  
  .wizard-page {
    padding: 0 !important;
    margin: 0 !important;
    background: white !important;
  }
  
  .page-header {
    display: none !important;
    visibility: hidden !important;
    height: 0 !important;
    max-height: 0 !important;
  }
  
