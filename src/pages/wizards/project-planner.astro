---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PrintFooter from "../../components/common/PrintFooter.astro";
import ActionBar from "../../components/wizards/ActionBar.astro";
import WizardBackLink from "../../components/wizards/WizardBackLink.astro";

const pageUrl = "https://knitbymachine.com/wizards/project-planner";
---

<BaseLayout 
  title="Project Planner | Knit by Machine" 
  description="What do you want to knit? Use our interactive project planner to explore knitting project ideas and get started.">

<style>
.wizard-page {
  padding-top: 120px;
  padding-bottom: 3rem;
  min-height: 100vh;
  background: var(--page-bg);
}

.page-header {
  max-width: 900px;
  margin: 0 auto 2rem;
  padding: 0 1rem;
}

.page-header h1 {
  color: var(--kbm-green);
  font-size: 2rem;
  font-weight: 700;
  margin: 0 0 0.75rem 0;
  text-align: center;
}

.page-header p {
  color: #6b7280;
  font-size: 1.05rem;
  line-height: 1.6;
  text-align: center;
}

.chatbot-container {
  max-width: 900px;
  margin: 0 auto;
  background: white;
  padding: 2rem;
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.kbm-chat {
  width: 100%;
  min-height: 700px;
}

.kbm-chat iframe {
  border: none;
  border-radius: 12px;
  width: 100%;
  height: 700px;
}

@media (max-width: 768px) {
  .wizard-page {
    padding-top: 100px;
  }
  
  .chatbot-container {
    padding: 1rem;
  }
  
  .kbm-chat iframe {
    height: 600px;
  }
}

.back-link {
  display: inline-block;
  color: #52682D;
  text-decoration: none;
  font-weight: 500;
  margin-bottom: 1.5rem;
  padding: 0.5rem 0;
  transition: color 0.2s;
}

.back-link:hover {
  color: #3d4e21;
  text-decoration: underline;
}

/* Print styles - hide navigation */
@media print {
  .wizard-page {
    padding-top: 0 !important;
    background: white !important;
  }
  
  .page-header,
  .back-link,
  .no-print {
    display: none !important;
  }
  
  .chatbot-container {
    box-shadow: none !important;
    padding: 0 !important;
    background: white !important;
    border: none !important;
  }
}
</style>

<div class="wizard-page">
  <div style="max-width: 900px; margin: 0 auto; padding: 0 1rem;">
    <WizardBackLink category="tool" />
  </div>
  <div class="page-header">
    <h1>Project Planner</h1>
    <p>What do you want to knit?</p>
  </div>

  <div class="chatbot-container">
    <ActionBar />
    <section class="kbm-chat">
      <iframe 
        src="https://chatbot.getmindpal.com/ready-set-knit-td6"
        width="100%"
        height="700"
        style="border: none; border-radius: 12px;"
        title="Knitting Project Planner Chatbot"
      ></iframe>
    </section>
  </div>
  <PrintFooter url={pageUrl} />
</div>

<script>
  // Action Bar buttons - Show by default for chatbot-based wizard
  const actionBar = document.getElementById('action-bar');
  const startOverBtn = document.getElementById('start-over-btn');
  const printBtn = document.getElementById('print-btn');

  // Show ActionBar on load (chatbot is always visible)
  if (actionBar) actionBar.style.display = 'flex';
  if (printBtn) printBtn.style.display = 'block';

  // Start Over handler - reload the chatbot iframe
  if (startOverBtn) {
    startOverBtn.addEventListener('click', () => {
      const iframe = document.querySelector('.kbm-chat iframe');
      if (iframe) {
        iframe.src = iframe.src;
      }
    });
  }

  // Print handler
  if (printBtn) {
    printBtn.addEventListener('click', () => {
      window.print();
    });
  }
</script>

</BaseLayout>
