---
import Layout from "../../layouts/Layout.astro";
import WizardBackLink from "../../components/wizards/WizardBackLink.astro";
import "../../styles/wizard.css";
import IsoTriangleIcon from "../../components/tools/triangle-iso-icon.svg";
import RightTriangleIcon from "../../components/tools/triangle-right-icon.svg";
import UnitToggle from "../../components/wizards/components/UnitToggle.astro";
import TriangleIsoSvg from "../../components/tools/triangle-iso.svg";
import TriangleRightSvg from "../../components/tools/triangle-right.svg";
---
<Layout title="Triangle Calculator">
  <main class="wizard-page">
    <div class="wizard-shell">
      <WizardBackLink category="tool" />

      <section class="wizard-hero">
                <h1>Triangle Calculator</h1>
        <p class="wizard-intro">
          Choose your triangle style, enter your finished measurements and gauge,
          and the calculator will generate the knitting numbers.
        </p>
      </section>

      <div class="triangle-calculator-panel">
        <div class="triangle-tool-layout">
          <div class="triangle-input-column">
          <section class="triangle-style-section">
            <h2>Choose Your Triangle Style</h2>

            <button type="button" class="triangle-option is-selected" data-style="isosceles">
              <IsoTriangleIcon />
              <span>Symmetrical Triangle</span>
            </button>
            
            <button
              type="button"
              class="triangle-option"
              data-style="right"
            >
              <RightTriangleIcon />
              <span>Right-Angle Triangle</span>
            </button>
          </section>

          <div class="section-header-with-toggle">
            <h2>Enter Your Measurements</h2>
            <UnitToggle />
          </div>
          <form id="triangleForm">
            <input type="hidden" id="triangleType" value="isosceles">
            <div class="triangle-input-grid">
              <div class="triangle-input-row triangle-input-row--dimensions">
                <label class="triangle-field">
                  <span>Width</span>
                  <input type="number" name="finishedWidth" min="0" step="0.01" data-highlight="width" />
                </label>
                <label class="triangle-field">
                  <span>Height</span>
                  <input type="number" name="finishedHeight" min="0" step="0.01" data-highlight="height" />
                </label>
              </div>
              <div class="triangle-input-row triangle-input-row--gauge">
                <label class="triangle-field">
                  <span>Gauge Stitches</span>
                  <input type="number" id="stitchesInput" name="stitchesInMeasure" min="0" step="0.01">
                </label>
                <label class="triangle-field">
                  <span>Gauge Rows</span>
                  <input type="number" id="rowsInput" name="rowsInMeasure" min="0" step="0.01">
                </label>
                <label class="triangle-field triangle-field--needles">
                  <span>Available Needles</span>
                  <input type="number" name="availableNeedles" min="0" step="1" id="availableNeedlesInput" />
                  <div class="needle-validation-error" id="needle-validation-error" hidden>
                    Please enter the number of needles available on your machine (typically between 100 and 200).
                  </div>
                </label>
              </div>
            </div>
            <div class="triangle-actions">
              <button type="button" id="calculateTriangle" class="wizard-button">
                Generate Knitting Instructions
              </button>
            </div>
            
            <div id="triangleResults" class="triangle-results">
            </div>
          </form>
        </div>

        <aside class="triangle-preview-panel" id="trianglePreviewPanel" data-current-style="isosceles">
          <div class="triangle-preview-card">
            <div class="triangle-preview-svg-wrap triangle-preview-svg-wrap--iso" data-style="isosceles">
              <TriangleIsoSvg />
            </div>
            <div class="triangle-preview-svg-wrap triangle-preview-svg-wrap--right" data-style="right">
              <TriangleRightSvg />
            </div>
          </div>
        </aside>
        </div>
      </div>
    </div>
  </main>

  <style>
/* Single white panel wrapping the entire calculator working area */
.triangle-calculator-panel {
  background: #fff;
  padding: 1.75rem;
  border-radius: 12px;
  border: 1px solid #e5e7eb;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  margin-bottom: 1.5rem;
}

@media (max-width: 640px) {
  .triangle-calculator-panel {
    padding: 1.25rem;
  }
}

/* Tool layout: inputs + preview side by side on desktop, stacked on small screens */
.triangle-tool-layout {
  display: flex;
  flex-wrap: wrap;
  gap: 24px;
  align-items: flex-start;
}
.triangle-input-column {
  flex: 1 1 320px;
  min-width: 0;
}
.triangle-preview-panel {
  flex: 0 1 280px;
  min-width: 0;
}

@media (max-width: 767px) {
  .triangle-preview-panel {
    display: none;
  }
}

/* Preview sits inside the panel; no separate card look so it feels integrated */
.triangle-preview-card {
  background: transparent;
  border: none;
  border-radius: 0;
  padding: 0;
  color: #52682D;
}
.triangle-preview-svg-wrap {
  display: none;
  width: 100%;
  max-width: 240px;
  margin: 0 auto;
}
.triangle-preview-svg-wrap .triangle-preview-svg,
.triangle-preview-svg-wrap :global(svg) {
  width: 100%;
  height: auto;
  display: block;
  color: #9ca3af;
}
.triangle-preview-panel[data-current-style="isosceles"] .triangle-preview-svg-wrap--iso {
  display: block;
}
.triangle-preview-panel[data-current-style="right"] .triangle-preview-svg-wrap--right {
  display: block;
}
.triangle-preview-panel[data-current-style="right"] .triangle-preview-svg-wrap--iso {
  display: none;
}
.triangle-preview-panel[data-current-style="isosceles"] .triangle-preview-svg-wrap--right {
  display: none;
}
/* SVG part default and active highlight */
.triangle-preview-svg-wrap :global(.svg-part) {
  transition: stroke 0.15s ease, stroke-width 0.15s ease;
}
.triangle-preview-svg-wrap :global(.svg-part) {
  stroke: #9ca3af;
}
.triangle-preview-svg-wrap :global(.svg-part.is-active) {
  stroke: #52682D;
  stroke-width: 3;
}

.section-header-with-toggle {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 12px;
}

.triangle-style-selector {
  display: grid !important;
  grid-template-columns: repeat(2, max-content);
  gap: 24px;
  align-items: start;
  justify-content: start;
  margin-top: 12px;
  margin-bottom: 30px;
}

.triangle-option {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  padding: 18px;
  border: 2px solid #ddd;
  border-radius: 10px;
  background: #fff;
  cursor: pointer;
  width: auto;
  min-width: 140px;
  transition: border-color 0.2s ease, background 0.2s ease;
}

    .triangle-option svg {
      width: 70px;
      height: 70px;
    }

    .triangle-option span {
      font-size: 0.9rem;
      font-weight: 600;
    }

    .triangle-option:hover {
      border-color: #52682D;
    }

    .triangle-option.is-selected {
      border-color: #52682D;
      background: #f4f7ef;
    }

    /* INPUT AREA: Row 1 = Width + Height, Row 2 = Gauge Stitches + Gauge Rows + Available Needles */
    .triangle-input-grid {
      display: flex;
      flex-direction: column;
      gap: 20px;
      margin-top: 16px;
    }

    .triangle-input-row {
      display: grid;
      gap: 20px;
    }

    .triangle-input-row--dimensions {
      grid-template-columns: repeat(2, 1fr);
    }

    .triangle-input-row--gauge {
      grid-template-columns: 1fr 1fr minmax(120px, 0.75fr);
    }

    @media (max-width: 640px) {
      .triangle-input-row--dimensions,
      .triangle-input-row--gauge {
        grid-template-columns: 1fr;
      }
    }

    .triangle-field {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .triangle-field span {
      font-weight: 600;
      font-size: 0.9rem;
    }

    .triangle-field input {
      padding: 10px;
      border: 1px solid #ccc;
      border-radius: 6px;
      font-size: 1rem;
    }

.needle-validation-error {
  margin-top: 6px;
  color: #b94a48;
  font-size: 14px;
}
    .triangle-actions {
  margin-top: 20px;
}

.triangle-actions .wizard-button {
  padding: 12px 22px;
  font-size: 1rem;
  font-weight: 600;
  border-radius: 8px;
  background: #52682D;
  color: white;
  border: none;
  cursor: pointer;
}

.triangle-actions .wizard-button:hover {
  background: #445925;
}
.triangle-results {
  margin-top: 24px;
}

/* Not enough needles warning callout (global for JS-injected HTML) */
:global(.triangle-warning-callout) {
  margin: 20px 0;
  padding: 16px 18px;
  border-left: 6px solid #d9534f;
  background: #fff4f4;
  border-radius: 6px;
}

:global(.triangle-warning-callout > strong) {
  display: block;
  font-size: 16px;
  margin-bottom: 6px;
}

:global(.triangle-warning-callout p) {
  margin: 6px 0;
  font-size: 14px;
  line-height: 1.5;
}

/* Instructions output: white card on screen, plain text when printed */
.triangle-instructions {
  background: #ffffff;
  border: 1px solid #e2e2e2;
  border-radius: 10px;
  padding: 24px;
}

.triangle-printable-results .triangle-print-type {
  margin-bottom: 1em;
}

.triangle-cast-on-note {
  margin: 0.25em 0 0.75em 0;
  font-size: 0.9rem;
  color: #555;
  font-style: italic;
}
:global(.print-attribution) {
  display: none;
}

/* Instructions header: title and print on one line (global so it applies to JS-injected HTML) */
:global(.triangle-instructions-header) {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 0.25em;
}

:global(.triangle-instructions-title) {
  margin: 0;
  font-size: 1.25rem;
}

:global(.triangle-print-btn) {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  padding: 0;
  border: none;
  border-radius: 8px;
  background: transparent;
  color: #52682D;
  cursor: pointer;
}

:global(.triangle-print-btn:hover) {
  background: rgba(82, 104, 45, 0.1);
  color: #445925;
}

:global(.triangle-print-btn:focus-visible) {
  outline: 2px solid #52682D;
  outline-offset: 2px;
}

/* Optional smoother shaping: link row and help (global for JS-injected HTML) */
:global(.distributed-option-row) {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 16px;
  flex-wrap: wrap;
}

:global(.distributed-toggle-link) {
  padding: 0;
  border: 0;
  background: none;
  color: #52682D;
  font-size: 14px;
  font-weight: 600;
  text-decoration: underline;
  cursor: pointer;
}

:global(.distributed-toggle-link:hover) {
  color: #445925;
}

:global(.distributed-toggle-link:focus-visible) {
  outline: 2px solid #52682D;
  outline-offset: 2px;
}

:global(.help-icon-btn) {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  border: 1px solid #52682D;
  background: #fff;
  color: #52682D;
  font-size: 14px;
  font-weight: 700;
  line-height: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

:global(.help-icon-btn:hover) {
  background: rgba(82, 104, 45, 0.1);
}

:global(.help-icon-btn:focus-visible) {
  outline: 2px solid #52682D;
  outline-offset: 2px;
}

:global(.distributed-help-panel) {
  margin-top: 10px;
  padding: 12px;
  border: 1px solid #d8d8d8;
  border-radius: 10px;
  background: #f9f9f9;
  max-width: 520px;
}

:global(.distributed-help-panel img) {
  display: block;
  width: 100%;
  height: auto;
}

:global(.distributed-help-panel p) {
  margin-top: 10px;
  font-size: 14px;
  line-height: 1.5;
  color: #555;
}

/* Shared left accent for both instruction blocks (global for JS-injected HTML) */
:global(.triangle-instructions-block) {
  border-left: 4px solid #52682D;
  padding-left: 16px;
  margin: 18px 0;
}

:global(#distributed-instructions) {
  margin-top: 14px;
  padding: 12px;
  border-left: 4px solid #52682D;
  background: #f8f8f8;
}

:global(.distributed-instructions-title) {
  margin: 0 0 6px 0;
  font-size: 1rem;
  font-weight: 700;
}

:global(.distributed-instructions-intro) {
  margin: 0 0 12px 0;
  font-size: 14px;
  color: #555;
  line-height: 1.5;
}

/* Simple option: show/hide shaping rows */
.row-toggle-btn {
  margin-top: 10px;
  padding: 10px 14px;
  border: 0;
  background: none;
  color: #52682D;
  font-size: 14px;
  font-weight: 600;
  line-height: 1.4;
  text-decoration: underline;
  cursor: pointer;
}

.row-toggle-btn:hover {
  color: #445925;
}

.row-toggle-btn:focus-visible {
  outline: 2px solid #52682D;
  outline-offset: 2px;
}

.simple-row-toggle-wrap {
  margin-bottom: 0;
}

.simple-row-list {
  margin-top: 10px;
  font-size: 14px;
  line-height: 1.6;
}

.simple-row-list.hidden {
  display: none;
}

@media print {
  .triangle-calculator-panel {
    background: none !important;
    border: none !important;
    box-shadow: none !important;
    border-radius: 0 !important;
    padding: 0 !important;
  }
  .wizard-hero,
  .triangle-style-section,
  .triangle-preview-panel,
  .section-header-with-toggle,
  .triangle-input-grid,
  .triangle-actions,
  .triangle-results-warning,
  .triangle-warning-callout,
  .triangle-print-btn,
  .back-link,
  #triangleForm input,
  #triangleForm label {
    display: none !important;
  }
  .triangle-printable-results {
    display: block !important;
    width: 100%;
    margin: 0;
    padding: 0;
    background: none;
    border: none;
    border-radius: 0;
    box-shadow: none;
  }

  .triangle-instructions {
    background: none !important;
    border: none !important;
    box-shadow: none !important;
    border-radius: 0 !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  .triangle-results {
    background: none !important;
    border: none !important;
    box-shadow: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  body {
    background: #ffffff !important;
  }
  .distributed-option-row,
  .distributed-help-panel {
    display: none !important;
  }
  :global(.distributed-help-panel) {
    display: none !important;
  }
  img[src*="decrease-distribution-compare.svg"] {
    display: none !important;
  }

  #distributed-instructions,
  .distributed-instructions-inner {
    background: transparent !important;
    background-color: transparent !important;
    box-shadow: none !important;
    border: 0 !important;
    padding: 0 !important;
    margin-top: 12px !important;
  }

  .distributed-instructions-title {
    margin-top: 12px !important;
    margin-bottom: 6px !important;
    color: #000 !important;
  }

  .distributed-instructions-intro {
    color: #000 !important;
  }

  :global(.triangle-instructions-block) {
    border-left: 3px solid #000 !important;
  }
  .row-toggle-btn,
  .simple-row-toggle-wrap {
    display: none !important;
  }
  .simple-row-list.hidden {
    display: none !important;
  }
  .triangle-instructions-title {
    font-size: 14pt;
    margin: 0 0 0.25em 0;
  }
  .triangle-printable-results p {
    font-size: 11pt;
    line-height: 1.4;
    margin-bottom: 0.75em;
  }
  .print-attribution {
    display: block !important;
    margin-top: 20px;
    font-size: 12px;
    color: #000;
  }

  .print-attribution p {
    margin: 4px 0;
  }
}
  </style>

<script>
  let instructionStyle = "even";
  let showSimpleRowNumbers = false;
  let lastResultData = null;

  function ordinal(n) {
    if (n === 1) return "1st";
    if (n === 2) return "2nd";
    if (n === 3) return "3rd";
    return n + "th";
  }

  function getSimplePhases(decreaseRowList) {
    if (decreaseRowList.length <= 1) {
      if (decreaseRowList.length === 1) return [{ interval: decreaseRowList[0], count: 1 }];
      return [];
    }
    const phases = [];
    let currentGap = decreaseRowList[1] - decreaseRowList[0];
    let gapCount = 1;
    for (let i = 2; i < decreaseRowList.length; i++) {
      const gap = decreaseRowList[i] - decreaseRowList[i - 1];
      if (gap === currentGap) {
        gapCount++;
      } else {
        phases.push({ interval: currentGap, count: gapCount + 1 });
        currentGap = gap;
        gapCount = 1;
      }
    }
    phases.push({ interval: currentGap, count: gapCount + 1 });
    return phases;
  }

  function calculateEvenDistribution(totalRows, totalDecreaseRows) {
    const rows = [];
    const step = totalRows / totalDecreaseRows;
    for (let i = 1; i <= totalDecreaseRows; i++) {
      rows.push(Math.round(i * step));
    }
    return rows;
  }

  function renderInstructions() {
    const container = document.getElementById("triangle-instruction-body");
    if (!container || !lastResultData) return;
    const d = lastResultData;
    const phases = getSimplePhases(d.decreaseRowList);
    const atEachEdge = d.isSymmetrical ? " at each edge" : "";
    const phaseHtml = phases
      .map(
        (ph, i) =>
          `<p><strong>Phase ${i + 1}:</strong> Decrease 1 stitch${atEachEdge} every ${ph.interval === 1 ? "row" : ordinal(ph.interval) + " row"}, ${ph.count} times.</p>`
      )
      .join("");
    const totalsLine = d.isSymmetrical
      ? `<p><strong>Combined Totals:</strong> ${d.totalDecreaseRows} decrease rows over ${d.totalRows} rows.</p><p><strong>Total Stitches Decreased:</strong> ${d.totalStitchesDecreased}</p><p><strong>Ending Stitches:</strong> ${d.finalStitchCount}</p>`
      : `<p><strong>Combined Totals:</strong> ${d.totalDecreaseRows} decreases over ${d.totalRows} rows.</p>`;
    const rowListLabel = d.isSymmetrical ? "Decrease rows (decrease 1 at each edge on these rows):" : "Decrease rows:";
    const rowListHidden = showSimpleRowNumbers ? "" : ' hidden';
    const rowToggleLabel = showSimpleRowNumbers ? "Hide shaping rows" : "Show shaping rows";
    const castOnNote = d.castOnAdjusted ? '<p class="triangle-cast-on-note">The cast-on was adjusted to an even number so the edge decreases work correctly.</p>' : '';
    container.innerHTML = `
      <p class="triangle-print-type">Triangle Type: ${d.triangleTypeLabel}</p>
      <p><strong>Cast On</strong><br>Cast on ${d.baseStitches} stitches.</p>
      ${castOnNote}
      <p><strong>Total Rows</strong><br>Work ${d.totalRows} rows.</p>
      ${phaseHtml}
      ${totalsLine}
      <p class="simple-row-toggle-wrap">
        <button type="button" class="row-toggle-btn" id="simple-row-toggle">${rowToggleLabel}</button>
      </p>
      <div class="simple-row-list"${rowListHidden}>
        <strong>${rowListLabel}</strong> ${d.decreaseRowsDisplay}
      </div>
    `;
  }

  function attachSimpleRowToggle() {
    const rowToggle = document.getElementById("simple-row-toggle");
    if (!rowToggle) return;
    rowToggle.addEventListener("click", () => {
      showSimpleRowNumbers = !showSimpleRowNumbers;
      renderInstructions();
      attachSimpleRowToggle();
    });
  }

  // Triangle style selector: highlight selected option and store for calculator
  document.querySelectorAll(".triangle-option").forEach((button) => {
    button.addEventListener("click", () => {
      document
        .querySelectorAll(".triangle-option")
        .forEach((btn) => btn.classList.remove("is-selected"));
      button.classList.add("is-selected");
      const triangleStyle = button.dataset.style ?? "";
      window.selectedTriangleStyle = triangleStyle;
      const triangleTypeInput = document.getElementById("triangleType");
      if (triangleTypeInput) triangleTypeInput.value = triangleStyle;
      const previewPanel = document.getElementById("trianglePreviewPanel");
      if (previewPanel) previewPanel.setAttribute("data-current-style", triangleStyle || "isosceles");
      console.log("Triangle style selected:", triangleStyle);
    });
  });

  // Preview: highlight SVG part that matches the focused/active input
  (function initTrianglePreviewHighlight() {
    const panel = document.getElementById("trianglePreviewPanel");
    if (!panel) return;
    const inputs = document.querySelectorAll("#triangleForm [data-highlight]");
    function getActiveHighlight() {
      const active = document.activeElement;
      if (!active || !active.closest("#triangleForm")) return null;
      return active.getAttribute("data-highlight");
    }
    function clearAndHighlight(wrap, highlight) {
      const allParts = wrap.querySelectorAll(".svg-part--width, .svg-part--height, #width, #height");
      allParts.forEach((el) => el.classList.remove("is-active"));
      if (highlight === "width") {
        wrap.querySelectorAll(".svg-part--width, #width").forEach((el) => el.classList.add("is-active"));
      } else if (highlight === "height") {
        wrap.querySelectorAll(".svg-part--height, #height").forEach((el) => el.classList.add("is-active"));
      }
    }
    function updateHighlight() {
      const highlight = getActiveHighlight();
      const style = panel.getAttribute("data-current-style") || "isosceles";
      const wrap = panel.querySelector(
        style === "right" ? ".triangle-preview-svg-wrap--right" : ".triangle-preview-svg-wrap--iso"
      );
      if (!wrap) return;
      clearAndHighlight(wrap, highlight);
    }
    inputs.forEach((input) => {
      input.addEventListener("focus", updateHighlight);
      input.addEventListener("input", updateHighlight);
      input.addEventListener("blur", () => {
        setTimeout(updateHighlight, 0);
      });
    });
  })();

  const calculateButton = document.getElementById("calculateTriangle");
  const resultsPanel = document.getElementById("triangleResults");

  calculateButton.addEventListener("click", () => {
    const form = document.getElementById("triangleForm");
    const formData = form ? new FormData(form) : new FormData();
    const finishedHeight = parseFloat(formData.get("finishedHeight")) || 0;

    const baseWidth = Number(document.querySelector('[name="finishedWidth"]')?.value);
    const height = Number(document.querySelector('[name="finishedHeight"]')?.value);
    const stitchGauge = Number(document.querySelector('[name="stitchesInMeasure"]')?.value);
    const rowGauge = Number(document.querySelector('[name="rowsInMeasure"]')?.value);

    const needlesInput = document.querySelector('[name="availableNeedles"]');
    const needles = parseInt(needlesInput?.value ?? "", 10);
    if (isNaN(needles) || needles < 50 || needles > 400) {
      const needleErrorEl = document.getElementById("needle-validation-error");
      if (needleErrorEl) needleErrorEl.hidden = false;
      return;
    }
    const needleErrorEl = document.getElementById("needle-validation-error");
    if (needleErrorEl) needleErrorEl.hidden = true;
    const availableNeedles = needles;

    if (!baseWidth || !height || !stitchGauge || !rowGauge) {
      resultsPanel.innerHTML = "<p>Please enter width, depth, stitch gauge, and row gauge.</p>";
      return;
    }

    const triangleStyle = window.selectedTriangleStyle || "isosceles";

    const unit = localStorage.getItem("kbm-units") || "in";
    let stitchesPerUnit, rowsPerUnit;
    if (unit === "cm") {
      stitchesPerUnit = stitchGauge / 10;
      rowsPerUnit = rowGauge / 10;
    } else {
      stitchesPerUnit = stitchGauge / 4;
      rowsPerUnit = rowGauge / 4;
    }

    const baseStitches = Math.round(baseWidth * stitchesPerUnit);
    const totalRows = Math.round(finishedHeight * rowsPerUnit);

    let castOnStitches = baseStitches;
    let endingStitches = 0;
    let castOnAdjusted = false;
    let countToDistribute;

    if (triangleStyle === "isosceles") {
      if (castOnStitches % 2 !== 0) {
        castOnStitches += 1;
        castOnAdjusted = true;
      }
      endingStitches = 2;
      const totalStitchesToRemove = castOnStitches - endingStitches;
      const decreaseRowsNeeded = Math.floor(totalStitchesToRemove / 2);
      countToDistribute = decreaseRowsNeeded;
    } else {
      const shapingStitches = Math.round(baseWidth * stitchesPerUnit);
      countToDistribute = shapingStitches;
    }

    console.log("Triangle style:", triangleStyle, "Count to distribute:", countToDistribute, "Total rows:", totalRows);

    let shapingMethod;
    if (countToDistribute > totalRows) {
      shapingMethod = "slope";
    } else {
      shapingMethod = "magic";
    }
    console.log("Shaping method:", shapingMethod);

    let warningHtml = "";
    if (castOnStitches > availableNeedles && availableNeedles > 0) {
      warningHtml = `
    <div class="triangle-warning-callout" role="alert">
      <strong>⚠ Not enough needles available</strong>
      <p>
        This triangle requires <strong>${castOnStitches}</strong> needles,
        but your machine has <strong>${availableNeedles}</strong>.
      </p>
      <p>
        Reduce the width, increase your gauge, or knit the piece in sections.
      </p>
    </div>`;
    }

    let decreaseRowList = [];
    if (shapingMethod === "magic") {
      const exactRowsPerDecrease = totalRows / countToDistribute;
      const lowerInterval = Math.floor(exactRowsPerDecrease);
      const upperInterval = Math.ceil(exactRowsPerDecrease);

      if (lowerInterval === upperInterval) {
        for (let i = 1; i <= countToDistribute; i++) decreaseRowList.push(i * lowerInterval);
      } else {
        const upperCount = Math.round((totalRows - (lowerInterval * countToDistribute)) / (upperInterval - lowerInterval));
        const lowerCount = countToDistribute - upperCount;
        for (let i = 1; i <= lowerCount; i++) decreaseRowList.push(i * lowerInterval);
        const lastPhase1 = lowerCount * lowerInterval;
        for (let i = 1; i <= upperCount; i++) decreaseRowList.push(lastPhase1 + i * upperInterval);
      }
    } else if (shapingMethod === "slope") {
      for (let r = 0; r < totalRows; r++) decreaseRowList.push(r);
    }

    const totalDecreaseRows = decreaseRowList.length;
    const finalStitchCount = endingStitches;
    const isSymmetrical = triangleStyle === "isosceles";
    const totalStitchesDecreased = isSymmetrical ? totalDecreaseRows * 2 : totalDecreaseRows;
    const perLine = 20;
    const decreaseRowsParts = [];
    for (let i = 0; i < decreaseRowList.length; i += perLine) {
      decreaseRowsParts.push(decreaseRowList.slice(i, i + perLine).join(", "));
    }
    const decreaseRowsDisplay = decreaseRowsParts.join(",<br> ");

    const smootherRows = calculateEvenDistribution(totalRows, totalDecreaseRows);
    const smootherRowsParts = [];
    for (let i = 0; i < smootherRows.length; i += perLine) {
      smootherRowsParts.push(smootherRows.slice(i, i + perLine).join(", "));
    }
    const smootherRowsDisplay = smootherRowsParts.join(",<br> ");

    const triangleTypeLabel = triangleStyle === "isosceles" ? "Symmetrical Triangle" : "Right-Angle Triangle";
    const createdDate = new Date().toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

    const printIconSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>`;

    lastResultData = {
      baseStitches: castOnStitches,
      totalRows,
      decreaseRowList,
      totalDecreaseRows,
      totalStitchesDecreased,
      finalStitchCount,
      triangleTypeLabel,
      createdDate,
      decreaseRowsDisplay,
      isSymmetrical,
      castOnAdjusted,
    };
    instructionStyle = "simple";
    showSimpleRowNumbers = false;

    const distributedDecreaseLabel = isSymmetrical
      ? "Decrease rows (decrease 1 at each edge on these rows)"
      : "Decrease Rows";
    const distributedSummaryHtml = isSymmetrical
      ? `Total Decrease Rows: ${totalDecreaseRows}<br>Total Stitches Decreased: ${totalStitchesDecreased}<br>Ending Stitches: ${finalStitchCount}`
      : `Total Decreases: ${totalDecreaseRows}<br>Final Stitch Count: ${finalStitchCount} stitches`;
    const distributedInstructionsHtml = `
      <p class="triangle-print-type">Triangle Type: ${triangleTypeLabel}</p>
      <p><strong>Cast On</strong><br>Cast on ${castOnStitches} stitches.</p>
      ${castOnAdjusted ? '<p class="triangle-cast-on-note">The cast-on was adjusted to an even number so the edge decreases work correctly.</p>' : ''}
      <p><strong>Total Rows</strong><br>Work ${totalRows} rows.</p>
      <p><strong>${distributedDecreaseLabel}</strong><br>${smootherRowsDisplay}</p>
      <p><strong>Shaping Summary</strong><br>${distributedSummaryHtml}</p>
    `;

    resultsPanel.innerHTML =
      warningHtml +
      `
    <div class="triangle-printable-results triangle-instructions">
      <div class="triangle-instructions-header">
        <h3 class="triangle-instructions-title">Triangle Instructions</h3>
        <button type="button" class="triangle-print-btn" id="trianglePrintBtn" title="Print triangle instructions" aria-label="Print triangle instructions">${printIconSvg}</button>
      </div>
      <div class="triangle-instructions-block simple-instructions">
        <div class="triangle-instructions-content" id="triangle-instruction-body"></div>
      </div>
      <div class="distributed-option-row">
        <button
          type="button"
          class="distributed-toggle-link"
          id="distributed-toggle"
          aria-expanded="false"
          aria-controls="distributed-instructions"
        >
          Want a smoother shaping option?
        </button>
        <button
          type="button"
          class="help-icon-btn"
          id="distributed-help-toggle"
          aria-expanded="false"
          aria-controls="distributed-help-panel"
          aria-label="Show help for smoother shaping option"
        >
          ?
        </button>
      </div>
      <div
        class="distributed-help-panel"
        id="distributed-help-panel"
        hidden
      >
        <img
          src="/images/help/decrease-distribution-compare.svg"
          alt="Comparison of evenly distributed decreases and simple decreases"
        />
        <p>
          Evenly distributed decreases spread the shaping more smoothly across the rows.
          Simple decreases group the shaping more in blocks, which can create a sharper angle.
        </p>
      </div>
      <div id="distributed-instructions" hidden>
        <div class="distributed-instructions-inner">
          <h4 class="distributed-instructions-title">Smoother Shaping Option</h4>
          <p class="distributed-instructions-intro">This version spreads the decreases more evenly across the rows.</p>
          ${distributedInstructionsHtml}
        </div>
      </div>
      <div class="print-attribution">
        <p>Created: ${createdDate}</p>
        <p>Created using the Triangle Tool at Knit It Now</p>
        <p>www.knititnow.com</p>
      </div>
    </div>
  `;

    renderInstructions();

    const distributedToggle = document.getElementById("distributed-toggle");
    const distributedSection = document.getElementById("distributed-instructions");
    if (distributedToggle && distributedSection) {
      distributedToggle.addEventListener("click", () => {
        const isHidden = distributedSection.hidden;
        distributedSection.hidden = !isHidden;
        distributedToggle.setAttribute("aria-expanded", String(!isHidden));
        distributedToggle.textContent = isHidden ? "Hide smoother shaping option" : "Want a smoother shaping option?";
      });
    }

    const distributedHelpPanel = document.getElementById("distributed-help-panel");
    const distributedHelpToggle = document.getElementById("distributed-help-toggle");
    if (distributedHelpToggle && distributedHelpPanel) {
      distributedHelpToggle.addEventListener("click", () => {
        const wasHidden = distributedHelpPanel.hidden;
        distributedHelpPanel.hidden = !wasHidden;
        distributedHelpToggle.setAttribute("aria-expanded", String(!wasHidden));
      });
    }

    attachSimpleRowToggle();

    const printBtn = document.getElementById("trianglePrintBtn");
    if (printBtn) {
      printBtn.addEventListener("click", () => window.print());
    }
  });

  function updateGaugePlaceholders(unit) {
    const stitchesInput = document.getElementById("stitchesInput");
    const rowsInput = document.getElementById("rowsInput");

    if (!stitchesInput || !rowsInput) return;

    if (unit === "cm") {
      stitchesInput.placeholder = "in 10 cm";
      rowsInput.placeholder = "in 10 cm";
    } else {
      stitchesInput.placeholder = "in 4 inches";
      rowsInput.placeholder = "in 4 inches";
    }
  }

  window.addEventListener("kbm:units-change", (e) => {
    const unit = e.detail && e.detail.unit ? e.detail.unit : "in";
    updateGaugePlaceholders(unit);
  });

  updateGaugePlaceholders(localStorage.getItem("kbm-units") || "in");

  const availableNeedlesInput = document.querySelector('[name="availableNeedles"]');
  const needleValidationError = document.getElementById("needle-validation-error");
  if (availableNeedlesInput && needleValidationError) {
    availableNeedlesInput.addEventListener("input", () => {
      const n = parseInt(availableNeedlesInput.value, 10);
      if (!isNaN(n) && n >= 50 && n <= 400) {
        needleValidationError.hidden = true;
      }
    });
  }
</script>
</Layout>
