---
export const prerender = true;
import Layout from "../../../layouts/Layout.astro";
import PageHead from "../../../components/PageHead.astro";

const title = "Reference";
const description = "Quick look-up resources for machine knitters: glossary, abbreviations, machine reference, DesignaKnit, needle charts, and sizing guides.";

/** Reference categories and links. Use real hrefs where pages exist; placeholders otherwise. Easy to move to JSON later. */
const referenceCategories = [
  {
    id: "glossary-terms",
    title: "Glossary & Terms",
    items: [
  { title: "Glossary", href: "/glossary", description: "Definitions and terms for machine knitting." },
  { title: "Abbreviations", href: "/reference/abbreviations", description: "Common abbreviations used in patterns and instructions." },
],
  },
  {
    id: "machine-reference",
    title: "Machine Reference",
    items: [
      { title: "Machine Repairs", href: "/reference/repairs", description: "Repair resources worldwide." },
      { title: "Knitting Machine Reference", href: "/reference/machine-reference", description: "Model information, features, and helpful notes for common knitting machines." },
      { title: "Machine Brands Worldwide", href: "/reference/machine-brands", description: "Compare machine brands." }   
     ],
  },
  {
    id: "designaknit",
    title: "DesignaKnit Reference",
    items: [
      { title: "DesignaKnit Versions", href: "/reference/DAK-compare", description: "Version differences and compatibility." },
      { title: "DAK Cables for Brother Machines", href: "/reference/DAK-brother-cables", description: "Cable and connection setup." },
      { title: "DesignaKnit Basics", href: "/reference/designaknit-basics", description: "Essential DesignaKnit concepts." },
    ],
  },
  {
    id: "charts-comparisons",
    title: "Charts & Comparisons",
    items: [
    
      { title: "Stitch Symbols", href: "/reference/stitch-symbols", description: "Stitch Symbols for machine knitters." },
      { title: "Sizing Charts", href: "/reference/sizing-charts", description: "Standard sizing and measurements." },
    ],
  },
];
---

<Layout {title} {description}>
  <div class="page-container">
    <PageHead
      title="Reference"
      subhead="Quick reference resources for machine knitters. Browse definitions, machine basics, charts, and comparisons when you need to look something up quickly."
    />

    <div class="reference-quick-links">
      <p class="reference-quick-links__label">Popular References</p>

      <div class="reference-quick-links__list">
        <a href="/glossary" class="reference-quick-links__item">Glossary</a>
        <a href="/reference/abbreviations" class="reference-quick-links__item">Abbreviations</a>
        <a href="/reference/machine-brands" class="reference-quick-links__item">Machine Brands</a>
        <a href="/reference/sizing-charts" class="reference-quick-links__item">Sizing Charts</a>
        <a href="/reference/DAK-compare" class="reference-quick-links__item">DAK Versions</a>
      </div>
    </div>

    {referenceCategories.map((category) => (
      <section class="ref-category" aria-labelledby={`category-${category.id}`}>
        <h2 id={`category-${category.id}`} class="ref-category-title">{category.title}</h2>
        <div class="ref-cards">
          {category.items.map((item) => (
            <a href={item.href} class="ref-card" data-testid={`ref-card-${category.id}-${item.title.toLowerCase().replace(/\s+/g, "-")}`}>
              <h3 class="ref-card-title">{item.title}</h3>
              {item.description && <p class="ref-card-desc">{item.description}</p>}
            </a>
          ))}
        </div>
      </section>
    ))}

    <p class="reference-footer-note">
      Need help applying this in your knitting? <a href="/videos">Visit Tutorials</a>.
    </p>
  </div>
</Layout>

<style>
  .page-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .ref-category {
    margin-bottom: 2.5rem;
  }

  .ref-category:last-of-type {
    margin-bottom: 2rem;
  }

  .ref-category-title {
    font-size: clamp(1.25rem, 2.2vw, 1.5rem);
    font-weight: 700;
    color: var(--kbm-green, #52682d);
    margin: 0 0 1rem 0;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #c7d8a4;
  }

  .ref-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .ref-card {
    display: block;
    background-color: #ffffff;
    color: #52682d;
    border: 2px solid #c7d8a4;
    padding: 1.25rem 1.5rem;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.25s ease;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.06);
  }

  .ref-card:hover {
    background-color: #f6f8f2;
    border-color: #52682d;
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(82, 104, 45, 0.12);
  }

  .ref-card:focus-visible {
    outline: 2px solid var(--kbm-green, #52682d);
    outline-offset: 2px;
  }

  .ref-card-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #52682d;
    margin: 0 0 0.35rem 0;
    line-height: 1.3;
  }

  .ref-card-desc {
    font-size: 0.9rem;
    color: #6b7280;
    line-height: 1.5;
    margin: 0;
  }

  .reference-footer-note {
    border-top: 1px solid #e6e6e6;
    margin-top: 2rem;
    padding-top: 1rem;
    font-size: 0.95rem;
    color: #666;
    text-align: center;
  }

  .reference-footer-note a {
    color: var(--kbm-green, #52682d);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: #c7d8a4;
    text-underline-offset: 3px;
  }

  .reference-footer-note a:hover {
    text-decoration-color: #52682d;
  }

  @media (max-width: 768px) {
    .page-container {
      padding: 1.5rem 1rem 3rem;
    }

    .ref-cards {
      grid-template-columns: 1fr;
    }

    .ref-category {
      margin-bottom: 2rem;
    }
  }
</style>
