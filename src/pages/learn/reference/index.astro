---
export const prerender = true;
import Layout from "../../../layouts/Layout.astro";
import SectionHero from "../../../components/SectionHero.astro";

const title = "Reference";
const description = "Quick look-up resources for machine knitters: glossary, abbreviations, machine reference, DesignaKnit, needle charts, and sizing guides.";

/** Reference categories and links. Use real hrefs where pages exist; placeholders otherwise. Easy to move to JSON later. */
const referenceCategories = [
  {
    id: "glossary-terms",
    title: "Glossary & Terms",
    items: [
      { title: "Glossary", href: "/glossary", description: "Definitions and terms for machine knitting." },
      { title: "Abbreviations", href: "/reference/abbreviations", description: "Common abbreviations used in patterns and instructions." },
    ],
  },
  {
    id: "machine-reference",
    title: "Machine Reference",
    items: [
      { title: "Machine Parts", href: "/reference/machine-parts", description: "Parts of the machine and basic terminology." },
      { title: "Machine Comparison", href: "/reference/machine-comparison", description: "Compare machine types and features." },
      { title: "Standard vs Bulky Machines", href: "/reference/standard-vs-bulky", description: "Differences between standard and bulky gauge machines." },
    ],
  },
  {
    id: "designaknit",
    title: "DesignaKnit Reference",
    items: [
      { title: "DesignaKnit Versions", href: "/reference/designaknit-versions", description: "Version differences and compatibility." },
      { title: "DesignaKnit Cable Setup", href: "/reference/designaknit-cable-setup", description: "Cable and connection setup." },
      { title: "DesignaKnit Basics", href: "/reference/designaknit-basics", description: "Essential DesignaKnit concepts." },
    ],
  },
  {
    id: "charts-comparisons",
    title: "Charts & Comparisons",
    items: [
      { title: "Needle Chart", href: "/reference/needle-chart", description: "Needle positions and numbering reference." },
      { title: "Yarn / Gauge Reference", href: "/reference/yarn-gauge-reference", description: "Yarn weights and gauge guidelines." },
      { title: "Sizing Charts", href: "/reference/sizing-charts", description: "Standard sizing and measurements." },
    ],
  },
];
---

<Layout {title} {description}>
  <div class="page-container">
    <SectionHero
      title="Reference"
      subtitle="Quick look-up resources: definitions, machine basics, charts, and comparisons for machine knitters."
    />

    <div class="intro-section">
      <p class="intro-text">
        Use this page to find reference-style content—glossary terms, machine parts, DesignaKnit help, needle charts, and sizing—when you need to look something up quickly.
      </p>
    </div>

    {referenceCategories.map((category) => (
      <section class="ref-category" aria-labelledby={`category-${category.id}`}>
        <h2 id={`category-${category.id}`} class="ref-category-title">{category.title}</h2>
        <div class="ref-cards">
          {category.items.map((item) => (
            <a href={item.href} class="ref-card" data-testid={`ref-card-${category.id}-${item.title.toLowerCase().replace(/\s+/g, "-")}`}>
              <h3 class="ref-card-title">{item.title}</h3>
              {item.description && <p class="ref-card-desc">{item.description}</p>}
            </a>
          ))}
        </div>
      </section>
    ))}

    <p class="tutorials-note">
      Looking for a step-by-step lesson instead? <a href="/videos">Visit Tutorials</a>.
    </p>
  </div>
</Layout>

<style>
  .page-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .intro-section {
    max-width: 720px;
    margin: 0 auto 2.5rem;
  }

  .intro-text {
    font-size: clamp(1rem, 1.8vw, 1.125rem);
    color: #5a6b47;
    line-height: 1.6;
    margin: 0;
  }

  .ref-category {
    margin-bottom: 2.5rem;
  }

  .ref-category:last-of-type {
    margin-bottom: 2rem;
  }

  .ref-category-title {
    font-size: clamp(1.25rem, 2.2vw, 1.5rem);
    font-weight: 700;
    color: var(--kbm-green, #52682d);
    margin: 0 0 1rem 0;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #c7d8a4;
  }

  .ref-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .ref-card {
    display: block;
    background-color: #ffffff;
    color: #52682d;
    border: 2px solid #c7d8a4;
    padding: 1.25rem 1.5rem;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.25s ease;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.06);
  }

  .ref-card:hover {
    background-color: #f6f8f2;
    border-color: #52682d;
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(82, 104, 45, 0.12);
  }

  .ref-card:focus-visible {
    outline: 2px solid var(--kbm-green, #52682d);
    outline-offset: 2px;
  }

  .ref-card-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #52682d;
    margin: 0 0 0.35rem 0;
    line-height: 1.3;
  }

  .ref-card-desc {
    font-size: 0.9rem;
    color: #6b7280;
    line-height: 1.5;
    margin: 0;
  }

  .tutorials-note {
    font-size: 0.95rem;
    color: #5a6b47;
    margin: 2rem 0 0;
    padding-top: 1.5rem;
    border-top: 1px solid #e5e9dc;
  }

  .tutorials-note a {
    color: var(--kbm-green, #52682d);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: #c7d8a4;
    text-underline-offset: 3px;
  }

  .tutorials-note a:hover {
    text-decoration-color: #52682d;
  }

  @media (max-width: 768px) {
    .page-container {
      padding: 1.5rem 1rem 3rem;
    }

    .ref-cards {
      grid-template-columns: 1fr;
    }

    .ref-category {
      margin-bottom: 2rem;
    }
  }
</style>
